{%- style -%}
  .available-benefits--{{ block.id }} {
    margin-top: {{ block.settings.margin_top }}px;
    margin-bottom: {{ block.settings.margin_bottom }}px;
    width: 100%;
    border: {{ block.settings.block_border_thickness }}px solid {{ block.settings.block_border_color }};
    padding: {{ block.settings.block_padding }}px;
    border-radius: {{ block.settings.block_border_radius }}px;
  }
  .available-benefits__header--{{ block.id }} {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.2rem;
  }
  .available-benefits__title--{{ block.id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    letter-spacing: 0.5px;
    margin-bottom: 0;
    font-weight: {{ block.settings.title_weight }};
  }
  .available-benefits__nav--{{ block.id }} {
    display: flex;
    gap: 0.5rem;
  }
  .available-benefits__arrow--{{ block.id }} {
    background: transparent;
    border: none;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: {{ block.settings.title_color }};
    padding: 4px;
    transition: opacity 0.2s ease;
  }
  .available-benefits__arrow--{{ block.id }}:hover {
    opacity: 0.6;
  }
  .available-benefits__grid--{{ block.id }} {
    display: flex;
    flex-wrap: nowrap;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    gap: {{ block.settings.gap_between_cards }}px;
    scrollbar-width: none;
    -ms-overflow-style: none;
    padding-bottom: 2px;
  }
  .available-benefits__grid--{{ block.id }}::-webkit-scrollbar {
    display: none;
  }
  .benefit-card--{{ block.id }} {
    flex: 0 0 {{ block.settings.card_width }}px;
    {%- if block.settings.card_height > 0 -%}
      height: {{ block.settings.card_height }}px;
      justify-content: center;
    {%- endif -%}
    scroll-snap-align: start;
    border: 1px dashed {{ block.settings.border_color }};
    background-color: {{ block.settings.card_bg_color }};
    padding: {{ block.settings.card_padding_vertical }}px {{ block.settings.card_padding_horizontal }}px;
    border-radius: {{ block.settings.card_border_radius }}px;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .benefit-card__top--{{ block.id }} {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .benefit-card__code-wrap--{{ block.id }} {
    font-size: {{ block.settings.main_text_size }}px;
    color: {{ block.settings.main_text_color }};
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 400;
  }
  .benefit-card__code--{{ block.id }} {
    color: {{ block.settings.code_color }};
    font-weight: 500;
    text-transform: uppercase;
    cursor: pointer;
    transition: opacity 0.2s ease;
  }
  .benefit-card__code--{{ block.id }}:hover {
    opacity: 0.7;
  }
  .benefit-card__tc--{{ block.id }} {
    font-size: {{ block.settings.tc_text_size }}px;
    color: {{ block.settings.tc_text_color }};
    text-decoration: underline;
    cursor: pointer;
  }
  .benefit-card__desc--{{ block.id }} {
    font-size: {{ block.settings.desc_text_size }}px;
    color: {{ block.settings.desc_text_color }};
  }
{%- endstyle -%}

<div class="available-benefits--{{ block.id }}" {{ block.shopify_attributes }}>
  <div class="available-benefits__header--{{ block.id }}">
    {%- if block.settings.title != blank -%}
      <div class="available-benefits__title--{{ block.id }}">{{ block.settings.title }}</div>
    {%- endif -%}
    <div class="available-benefits__nav--{{ block.id }}">
      <button type="button" class="available-benefits__arrow--{{ block.id }}" aria-label="Previous" onclick="scrollBenefitsGrid(this, 'prev')">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg>
      </button>
      <button type="button" class="available-benefits__arrow--{{ block.id }}" aria-label="Next" onclick="scrollBenefitsGrid(this, 'next')">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
      </button>
    </div>
  </div>

  <div class="available-benefits__grid--{{ block.id }}">
    {%- for i in (1..3) -%}
      {%- assign prefix_key = 'prefix_' | append: i -%}
      {%- assign code_key = 'code_' | append: i -%}
      {%- assign desc_key = 'desc_' | append: i -%}
      {%- assign tc_link_key = 'tc_link_' | append: i -%}
      
      {%- assign prefix = block.settings[prefix_key] -%}
      {%- assign code = block.settings[code_key] -%}
      {%- assign desc = block.settings[desc_key] -%}
      {%- assign tc_link = block.settings[tc_link_key] -%}

      {%- if code != blank or desc != blank -%}
        <div class="benefit-card--{{ block.id }}">
          <div class="benefit-card__top--{{ block.id }}">
            <div class="benefit-card__code-wrap--{{ block.id }}">
              {% if prefix != blank %}{{ prefix }} {% endif %}<span class="benefit-card__code--{{ block.id }}" data-code="{{ code }}" onclick="copyBenefitCode(this)" title="Click to copy">{{ code }}</span>
            </div>
          </div>
          <div class="benefit-card__desc--{{ block.id }}">
            {{ desc }}
          </div>
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>
</div>

<script>
  if (typeof window.scrollBenefitsGrid !== 'function') {
    window.scrollBenefitsGrid = function(btn, dir) {
      const wrapper = btn.closest('[class*="available-benefits--"]');
      const grid = wrapper.querySelector('[class*="available-benefits__grid--"]');
      if (!grid || grid.children.length === 0) return;
      
      const gap = parseInt(window.getComputedStyle(grid).gap) || 0;
      const scrollAmt = grid.children[0].offsetWidth + gap;
      
      grid.scrollBy({ left: dir === 'prev' ? -scrollAmt : scrollAmt, behavior: 'smooth' });
    };
  }

  if (typeof window.copyBenefitCode !== 'function') {
    window.copyBenefitCode = function(element) {
      const code = element.getAttribute('data-code');
      navigator.clipboard.writeText(code).then(function() {
        element.innerText = 'COPIED!';
        setTimeout(function() {
          element.innerText = code;
        }, 2000);
      });
    };
  }
</script>

