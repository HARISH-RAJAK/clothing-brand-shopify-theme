{% doc %}
  @prompt
    create a countdown timer section with offers text and schema for editing it.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  /* Import Josefin Sans Font */
  @import url('https://fonts.googleapis.com/css2?family=Josefin+Sans:wght@400;600;700&display=swap');

  .ai-countdown-timer-{{ ai_gen_id }} {
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.padding_top }}px {{ block.settings.padding_horizontal }}px {{ block.settings.padding_bottom }}px;
    text-align: center;
  }

  .ai-countdown-timer__content-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
  }

  .ai-countdown-timer__offer-{{ ai_gen_id }} {
    /* Apply Josefin Sans here */
    font-family: 'Josefin Sans', sans-serif;
    color: {{ block.settings.offer_text_color }};
    font-size: {{ block.settings.offer_text_size }}px;
    margin-bottom: {{ block.settings.offer_spacing }}px;
    font-weight: 600;
  }

  .ai-countdown-timer__timer-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    gap: {{ block.settings.timer_gap }}px;
    flex-wrap: wrap;
  }

  .ai-countdown-timer__unit-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    min-width: {{ block.settings.unit_width }}px;
  }

  .ai-countdown-timer__number-{{ ai_gen_id }} {
    background-color: {{ block.settings.number_background }};
    color: {{ block.settings.number_color }};
    font-size: {{ block.settings.number_size }}px;
    font-weight: 700;
    padding: {{ block.settings.number_padding }}px;
    border-radius: {{ block.settings.number_border_radius }}px;
    min-width: {{ block.settings.number_min_width }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 1;
  }

  .ai-countdown-timer__label-{{ ai_gen_id }} {
    color: {{ block.settings.label_color }};
    font-size: {{ block.settings.label_size }}px;
    margin-top: {{ block.settings.label_spacing }}px;
    text-transform: {{ block.settings.label_transform }};
  }

  .ai-countdown-timer__expired-{{ ai_gen_id }} {
    color: {{ block.settings.expired_text_color }};
    font-size: {{ block.settings.expired_text_size }}px;
    font-weight: 600;
  }

  @media screen and (max-width: 749px) {
    .ai-countdown-timer__offer-{{ ai_gen_id }} {
      font-size: {{ block.settings.offer_text_size | times: 0.85 }}px;
    }

    .ai-countdown-timer__number-{{ ai_gen_id }} {
      font-size: {{ block.settings.number_size | times: 0.75 }}px;
      padding: {{ block.settings.number_padding | times: 0.75 }}px;
      min-width: {{ block.settings.number_min_width | times: 0.75 }}px;
    }

    .ai-countdown-timer__label-{{ ai_gen_id }} {
      font-size: {{ block.settings.label_size | times: 0.85 }}px;
    }

    .ai-countdown-timer__unit-{{ ai_gen_id }} {
      min-width: {{ block.settings.unit_width | times: 0.75 }}px;
    }
  }
{% endstyle %}

<countdown-timer-{{ ai_gen_id }}
  class="ai-countdown-timer-{{ ai_gen_id }}"
  data-end-date="{{ block.settings.end_date }}"
  data-end-time="{{ block.settings.end_time }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-countdown-timer__content-{{ ai_gen_id }}">
    {% if block.settings.offer_text != blank %}
      <div class="ai-countdown-timer__offer-{{ ai_gen_id }}">
      {% if collection.handle == 'tops' %}
        Buy 1 Get 10% and Buy 2 or more then get 25% off - Sale End Soon
      {% else %}
        {{ block.settings.offer_text }}
      {% endif %}
      </div>
    {% endif %}

    <div class="ai-countdown-timer__timer-{{ ai_gen_id }}" data-timer>
      {% if block.settings.show_days %}
        <div class="ai-countdown-timer__unit-{{ ai_gen_id }}">
          <div class="ai-countdown-timer__number-{{ ai_gen_id }}" data-days>00</div>
          <div class="ai-countdown-timer__label-{{ ai_gen_id }}">{{ block.settings.days_label }}</div>
        </div>
      {% endif %}

      {% if block.settings.show_hours %}
        <div class="ai-countdown-timer__unit-{{ ai_gen_id }}">
          <div class="ai-countdown-timer__number-{{ ai_gen_id }}" data-hours>00</div>
          <div class="ai-countdown-timer__label-{{ ai_gen_id }}">{{ block.settings.hours_label }}</div>
        </div>
      {% endif %}

      {% if block.settings.show_minutes %}
        <div class="ai-countdown-timer__unit-{{ ai_gen_id }}">
          <div class="ai-countdown-timer__number-{{ ai_gen_id }}" data-minutes>00</div>
          <div class="ai-countdown-timer__label-{{ ai_gen_id }}">{{ block.settings.minutes_label }}</div>
        </div>
      {% endif %}

      {% if block.settings.show_seconds %}
        <div class="ai-countdown-timer__unit-{{ ai_gen_id }}">
          <div class="ai-countdown-timer__number-{{ ai_gen_id }}" data-seconds>00</div>
          <div class="ai-countdown-timer__label-{{ ai_gen_id }}">{{ block.settings.seconds_label }}</div>
        </div>
      {% endif %}
    </div>

    <div class="ai-countdown-timer__expired-{{ ai_gen_id }}" data-expired style="display: none;">
      {{ block.settings.expired_message }}
    </div>
  </div>
</countdown-timer-{{ ai_gen_id }}>

<script>
  (function() {
    class CountdownTimer{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.endDate = this.dataset.endDate;
        this.endTime = this.dataset.endTime;
        this.timer = this.querySelector('[data-timer]');
        this.expiredMessage = this.querySelector('[data-expired]');
        this.daysEl = this.querySelector('[data-days]');
        this.hoursEl = this.querySelector('[data-hours]');
        this.minutesEl = this.querySelector('[data-minutes]');
        this.secondsEl = this.querySelector('[data-seconds]');
      }

      connectedCallback() {
        if (!this.endDate) {
          this.showExpired();
          return;
        }

        this.updateCountdown();
        this.interval = setInterval(() => this.updateCountdown(), 1000);
      }

      disconnectedCallback() {
        if (this.interval) {
          clearInterval(this.interval);
        }
      }

      updateCountdown() {
        const endDateTime = this.endTime 
          ? new Date(this.endDate + 'T' + this.endTime)
          : new Date(this.endDate + 'T23:59:59');
        
        const now = new Date().getTime();
        const distance = endDateTime.getTime() - now;

        if (distance < 0) {
          this.showExpired();
          return;
        }

        const days = Math.floor(distance / (1000 * 60 * 60 * 24));
        const hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
        const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
        const seconds = Math.floor((distance % (1000 * 60)) / 1000);

        if (this.daysEl) this.daysEl.textContent = String(days).padStart(2, '0');
        if (this.hoursEl) this.hoursEl.textContent = String(hours).padStart(2, '0');
        if (this.minutesEl) this.minutesEl.textContent = String(minutes).padStart(2, '0');
        if (this.secondsEl) this.secondsEl.textContent = String(seconds).padStart(2, '0');
      }

      showExpired() {
        if (this.interval) {
          clearInterval(this.interval);
        }
        if (this.timer) {
          this.timer.style.display = 'none';
        }
        if (this.expiredMessage) {
          this.expiredMessage.style.display = 'block';
        }
      }
    }

    customElements.define('countdown-timer-{{ ai_gen_id }}', CountdownTimer{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Countdown timer",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Timer settings"
    },
    {
      "type": "text",
      "id": "end_date",
      "label": "End date",
      "info": "Format: YYYY-MM-DD (e.g., 2025-12-31)",
      "default": "2025-12-31"
    },
    {
      "type": "text",
      "id": "end_time",
      "label": "End time",
      "info": "Format: HH:MM:SS (e.g., 23:59:59). Leave blank for end of day"
    },
    {
      "type": "header",
      "content": "Display options"
    },
    {
      "type": "checkbox",
      "id": "show_days",
      "label": "Show days",
      "default": true
    },
    {
