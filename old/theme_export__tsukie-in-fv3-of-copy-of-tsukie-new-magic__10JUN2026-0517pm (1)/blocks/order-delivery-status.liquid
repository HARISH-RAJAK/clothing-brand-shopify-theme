{%- assign current_time = 'now' | date: '%s' -%}
{%- assign one_day = 86400 -%}
{%- assign three_days = 259200 -%}

{%- assign date_1 = current_time | date: "%b %d %A" -%}
{%- assign date_2 = current_time | plus: one_day | date: "%b %d %A" -%}
{%- assign date_3 = current_time | plus: three_days | date: "Expected %b %d %A" -%}

{%- style -%}
  .order-delivery-status-{{ block.id }} {
    text-align: center;
    padding-top: {{ block.settings.padding_top }}px;
    padding-bottom: {{ block.settings.padding_bottom }}px;
    margin-top: {{ block.settings.margin_top }}px;
    margin-bottom: {{ block.settings.margin_bottom }}px;
    width: 100%;
    font-family: inherit;
  }
  .order-delivery-status-{{ block.id }} .ods-title {
    font-size: {{ block.settings.title_size }}px;
    font-weight: {{ block.settings.title_weight }};
    margin: 0 0 8px 0;
    color: {{ block.settings.title_color }};
    line-height: 1.2;
  }
  .order-delivery-status-{{ block.id }} .ods-subtitle {
    font-size: {{ block.settings.subtitle_size }}px;
    font-weight: {{ block.settings.subtitle_weight }};
    color: {{ block.settings.subtitle_color }};
    margin: 0 auto 16px auto;
    max-width: 80%;
    line-height: 1.4;
  }
  
  .order-delivery-status-{{ block.id }} .ods-timeline-wrapper {
    position: relative;
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    max-width: 500px;
    margin: 0 auto;
    padding: 0 20px;
  }
  
  .order-delivery-status-{{ block.id }} .ods-timeline-line {
    position: absolute;
    top: calc({{ block.settings.circle_size }}px / 2);
    left: 16.66%;
    right: 16.66%;
    height: 1px;
    background-color: {{ block.settings.line_color }};
    z-index: 1;
    transform: translateY(-50%);
  }
  
  .order-delivery-status-{{ block.id }} .ods-step {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 33.33%;
  }
  
  .order-delivery-status-{{ block.id }} .ods-circle {
    width: {{ block.settings.circle_size }}px;
    height: {{ block.settings.circle_size }}px;
    border-radius: 50%;
    background-color: {{ block.settings.circle_bg_color }};
    border: 2px solid {{ block.settings.circle_border_color }};
    display: flex;
    justify-content: center;
    align-items: center;
    margin-bottom: 12px;
  }
  
  .order-delivery-status-{{ block.id }} .ods-circle svg {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    color: {{ block.settings.icon_color }};
  }
  
  .order-delivery-status-{{ block.id }} .ods-step-title {
    font-size: {{ block.settings.step_title_size }}px;
    font-weight: {{ block.settings.step_title_weight }};
    color: {{ block.settings.title_color }};
    margin: 0 0 4px 0;
    line-height: 1.2;
  }
  
  .order-delivery-status-{{ block.id }} .ods-step-date {
    font-size: {{ block.settings.step_date_size }}px;
    font-weight: {{ block.settings.step_date_weight }};
    color: {{ block.settings.subtitle_color }};
    margin: 0;
    line-height: 1.2;
    max-width: 120px;
  }

  @media screen and (max-width: 749px) {
    .order-delivery-status-{{ block.id }} .ods-title {
      font-size: calc({{ block.settings.title_size }}px * 0.85);
    }
    .order-delivery-status-{{ block.id }} .ods-timeline-wrapper {
      padding: 0;
    }
    .order-delivery-status-{{ block.id }} .ods-step-title {
      font-size: calc({{ block.settings.step_title_size }}px * 0.85);
    }
    .order-delivery-status-{{ block.id }} .ods-step-date {
      font-size: calc({{ block.settings.step_date_size }}px * 0.85);
    }
    .order-delivery-status-{{ block.id }} .ods-circle {
      width: calc({{ block.settings.circle_size }}px * 0.8);
      height: calc({{ block.settings.circle_size }}px * 0.8);
    }
    .order-delivery-status-{{ block.id }} .ods-circle svg {
      width: calc({{ block.settings.icon_size }}px * 0.8);
      height: calc({{ block.settings.icon_size }}px * 0.8);
    }
    .order-delivery-status-{{ block.id }} .ods-timeline-line {
      top: calc({{ block.settings.circle_size }}px * 0.4);
    }
  }
{%- endstyle -%}

<div class="order-delivery-status-{{ block.id }}" {{ block.shopify_attributes }}>
  {%- if block.settings.title != blank -%}
    <h3 class="ods-title">{{ block.settings.title }}</h3>
  {%- endif -%}
  
  {%- if block.settings.subtitle != blank -%}
    <p class="ods-subtitle">{{ block.settings.subtitle }}</p>
  {%- endif -%}
  
  <div class="ods-timeline-wrapper">
    <div class="ods-timeline-line"></div>
    
    <div class="ods-step">
      <div class="ods-circle">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="20 6 9 17 4 12"></polyline>
        </svg>
      </div>
      <div class="ods-step-title">{{ block.settings.step_1_title }}</div>
      <div class="ods-step-date">{{ date_1 }}</div>
    </div>
    
    <div class="ods-step">
      <div class="ods-circle">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="20 6 9 17 4 12"></polyline>
        </svg>
      </div>
      <div class="ods-step-title">{{ block.settings.step_2_title }}</div>
      <div class="ods-step-date">{{ date_2 }}</div>
    </div>
    
    <div class="ods-step">
      <div class="ods-circle">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"></circle>
          <polyline points="12 6 12 12 16 14"></polyline>
        </svg>
      </div>
      <div class="ods-step-title">{{ block.settings.step_3_title }}</div>
      <div class="ods-step-date">{{ date_3 }}</div>
    </div>
  </div>
</div>

{% schema %}
