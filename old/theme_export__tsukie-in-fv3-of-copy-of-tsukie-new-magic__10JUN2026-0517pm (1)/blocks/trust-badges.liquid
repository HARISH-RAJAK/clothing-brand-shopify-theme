{%- style -%}
  .trust-badges--{{ block.id }} {
    display: flex;
    flex-wrap: wrap;
    justify-content: {{ block.settings.alignment }};
    gap: {{ block.settings.gap_between_badges }}px;
    padding-top: {{ block.settings.block_padding_top }}px;
    padding-bottom: {{ block.settings.block_padding_bottom }}px;
    margin-top: {{ block.settings.margin_top }}px;
    margin-bottom: {{ block.settings.margin_bottom }}px;
    width: 100%;
  }
  .trust-badge--{{ block.id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.badge_padding_vertical }}px {{ block.settings.badge_padding_horizontal }}px;
    border-radius: {{ block.settings.border_radius }}px;
    flex: 0 0 auto !important;
    width: fit-content;
    max-width: 100%;
  }
  .trust-badge--{{ block.id }} svg {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    flex-shrink: 0;
  }
  .trust-badge--{{ block.id }} img {
    height: {{ block.settings.icon_size }}px;
    width: auto;
    object-fit: contain;
    flex-shrink: 0;
  }
  .trust-badge--{{ block.id }} span {
    font-size: {{ block.settings.text_size }}px;
    color: {{ block.settings.text_color }};
    font-weight: 600;
    line-height: 1.2;
  }
{%- endstyle -%}

<div class="trust-badges--{{ block.id }}" {{ block.shopify_attributes }}>
  {%- for i in (1..3) -%}
    {%- assign icon_svg_key = 'icon_svg_' | append: i -%}
    {%- assign icon_image_key = 'icon_image_' | append: i -%}
    {%- assign text_key = 'text_' | append: i -%}
    {%- assign theme_icon_key = 'icon_' | append: i -%}

    {%- assign icon_svg = block.settings[icon_svg_key] -%}
    {%- assign icon_image = block.settings[icon_image_key] -%}
    {%- assign text = block.settings[text_key] -%}
    {%- assign theme_icon = block.settings[theme_icon_key] -%}

    {%- if icon_svg != blank or icon_image != blank or text != blank or theme_icon != 'none' -%}
      <div class="trust-badge--{{ block.id }}">
        {%- if icon_svg != blank -%}
          {{ icon_svg }}
        {%- elsif theme_icon != 'none' -%}
          {%- render 'icon', icon: theme_icon -%}
        {%- elsif icon_image != blank -%}
          {{ icon_image | image_url: width: 100 | image_tag: loading: 'lazy' }}
        {%- endif -%}
        
        {%- if text != blank -%}
          <span>{{ text }}</span>
        {%- endif -%}
      </div>
    {%- endif -%}
  {%- endfor -%}
</div>

