 <style>
  .onhow-whatsapp-btn {
    position: fixed;
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    border-radius: var(--onhow-radius);
    background-color: var(--onhow-color);
    width: var(--onhow-size);
    height: var(--onhow-size);
    z-index: var(--onhow-z-index);
    transition: all 0.3s ease;
    color: white;
  }

  .onhow-pos-top-left {
    top: calc(20px + var(--onhow-y-offset));
    left: calc(20px + var(--onhow-x-offset));
  }

  .onhow-pos-top-right {
    top: calc(20px + var(--onhow-y-offset));
    right: calc(20px - var(--onhow-x-offset));
  }

  .onhow-pos-center-left {
    top: calc(50% + var(--onhow-y-offset));
    left: calc(20px + var(--onhow-x-offset));
    transform: translateY(-50%);
  }

  .onhow-pos-center-right {
    top: calc(50% + var(--onhow-y-offset));
    right: calc(20px - var(--onhow-x-offset));
    transform: translateY(-50%);
  }

  .onhow-pos-bottom-left {
    bottom: calc(20px - var(--onhow-y-offset));
    left: calc(20px + var(--onhow-x-offset));
  }

  .onhow-pos-bottom-right {
    bottom: calc(20px - var(--onhow-y-offset));
    right: calc(20px - var(--onhow-x-offset));
  }

  .onhow-shadow-light {
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
  }

  .onhow-shadow-medium {
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.25);
  }

  .onhow-shadow-heavy {
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.35);
  }

  .onhow-entry-fade {
    animation: onhowFadeIn 0.5s ease-out;
  }

  .onhow-entry-slide {
    animation: onhowSlideIn 0.5s ease-out;
  }

  .onhow-hover-scale:hover {
    transform: scale(1.1);
  }

  .onhow-pos-center-left.onhow-hover-scale:hover,
  .onhow-pos-center-right.onhow-hover-scale:hover {
    transform: translateY(-50%) scale(1.1);
  }

  .onhow-hover-color:hover {
    filter: brightness(1.2);
  }

  .onhow-idle-pulse {
    animation: onhowPulse 2s ease-in-out infinite;
  }

  .onhow-idle-breathing {
    animation: onhowBreathing 3s ease-in-out infinite;
  }

  .onhow-whatsapp-icon {
    width: calc(var(--onhow-size) * 0.8);
    height: calc(var(--onhow-size) * 0.8);
  }

  .onhow-custom-icon {
    width: calc(var(--onhow-size) * 0.8);
    height: calc(var(--onhow-size) * 0.8);
    object-fit: contain;
  }

  @keyframes onhowFadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  @keyframes onhowSlideIn {
    from { 
      opacity: 0; 
      transform: translateX(100px); 
    }
    to { 
      opacity: 1; 
      transform: translateX(0); 
    }
  }

  @keyframes onhowPulse {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.05); }
  }

  @keyframes onhowBreathing {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.8; }
  }

  @media (max-width: 768px) {
    .onhow-whatsapp-btn {
      width: var(--onhow-mobile-size);
      height: var(--onhow-mobile-size);
    }
    
    .onhow-whatsapp-icon {
      width: calc(var(--onhow-mobile-size) * 0.8);
      height: calc(var(--onhow-mobile-size) * 0.8);
    }
    
    .onhow-custom-icon {
      width: calc(var(--onhow-mobile-size) * 0.8);
      height: calc(var(--onhow-mobile-size) * 0.8);
    }
  }

  .onhow-hide-desktop {
    display: none !important;
  }

  .onhow-hide-mobile {
    display: flex !important;
  }

  @media (max-width: 768px) {
    .onhow-hide-mobile {
      display: none !important;
    }
    
    .onhow-hide-desktop {
      display: flex !important;
    }
  }
</style>

{% if section.settings.enable_whatsapp %}
  {% assign position_class = 'onhow-pos-' | append: section.settings.position %}
  {% assign shadow_class = '' %}
  {% if section.settings.shadow != 'none' %}
    {% assign shadow_class = 'onhow-shadow-' | append: section.settings.shadow %}
  {% endif %}
  {% assign entry_class = '' %}
  {% if section.settings.entry_animation != 'none' %}
    {% assign entry_class = 'onhow-entry-' | append: section.settings.entry_animation %}
  {% endif %}
  {% assign hover_class = '' %}
  {% if section.settings.hover_effect != 'none' %}
    {% assign hover_class = 'onhow-hover-' | append: section.settings.hover_effect %}
  {% endif %}
  {% assign idle_class = '' %}
  {% if section.settings.idle_animation != 'none' %}
    {% assign idle_class = 'onhow-idle-' | append: section.settings.idle_animation %}
  {% endif %}
  
  {% assign visibility_class = '' %}
  {% unless section.settings.show_desktop %}
    {% assign visibility_class = visibility_class | append: ' onhow-hide-desktop' %}
  {% endunless %}
  {% unless section.settings.show_mobile %}
    {% assign visibility_class = visibility_class | append: ' onhow-hide-mobile' %}
  {% endunless %}

  {% if template contains 'product' %}
    {% assign final_message = section.settings.default_message | append: ' : ' | append: product.title %}
  {% else %}
    {% assign final_message = section.settings.default_message %}
  {% endif %}

  <a 
    href="https://wa.me/{{ section.settings.phone_number }}?text={{ final_message | url_encode }}" 
    class="onhow-whatsapp-btn {{ position_class }} {{ shadow_class }} {{ entry_class }} {{ hover_class }} {{ idle_class }}{{ visibility_class }}"
    {% if section.settings.link_target == 'new_tab' %}target="_blank"{% endif %}
    {% if section.settings.tooltip_text != blank %}title="{{ section.settings.tooltip_text }}"{% endif %}
    style="
      --onhow-size: {{ section.settings.button_size }}px;
      --onhow-mobile-size: {{ section.settings.mobile_size }}px;
      --onhow-color: {{ section.settings.button_color }};
      --onhow-radius: {{ section.settings.border_radius }}px;
      --onhow-x-offset: {{ section.settings.x_offset }}px;
      --onhow-y-offset: {{ section.settings.y_offset }}px;
      --onhow-z-index: {{ section.settings.z_index }};
    "
  >
    {% if section.settings.custom_icon != blank %}
      <img src="{{ section.settings.custom_icon | image_url }}" alt="WhatsApp" class="onhow-custom-icon">
    {% else %}
      <svg class="onhow-whatsapp-icon" xmlns="http://www.w3.org/2000/svg" viewBox="-93.2412 -156.2325 808.0904 937.395" fill="white">
        <path d="M242.63 186.78c-5.205-11.57-10.684-11.803-15.636-12.006-4.05-.173-8.687-.162-13.316-.162-4.632 0-12.161 1.74-18.527 8.693-6.37 6.953-24.322 23.761-24.322 57.947 0 34.19 24.901 67.222 28.372 71.862 3.474 4.634 48.07 77.028 118.694 104.88 58.696 23.146 70.64 18.542 83.38 17.384 12.74-1.158 41.11-16.805 46.9-33.03 5.791-16.223 5.791-30.128 4.054-33.035-1.738-2.896-6.37-4.633-13.319-8.108-6.95-3.475-41.11-20.287-47.48-22.603-6.37-2.316-11.003-3.474-15.635 3.482-4.633 6.95-17.94 22.596-21.996 27.23-4.053 4.643-8.106 5.222-15.056 1.747-6.949-3.485-29.328-10.815-55.876-34.485-20.656-18.416-34.6-41.16-38.656-48.116-4.053-6.95-.433-10.714 3.052-14.178 3.12-3.113 6.95-8.11 10.424-12.168 3.467-4.057 4.626-6.953 6.942-11.586 2.316-4.64 1.158-8.698-.579-12.172-1.737-3.475-15.241-37.838-21.42-51.576"/>
      </svg>
    {% endif %}
  </a>
{% endif %}

{% schema %}
{
  "name": "WhatsApp Button",
  "settings": [
    {
      "type": "header",
      "content": "Display Controls"
    },
    {
      "type": "checkbox",
      "id": "enable_whatsapp",
      "label": "Enable WhatsApp Button",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_desktop",
      "label": "Show on Desktop",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_mobile",
      "label": "Show on Mobile",
      "default": true
    },
    {
      "type": "number",
      "id": "z_index",
      "label": "Layer Priority (Z-index)",
      "default": 100,
      "info": "Higher numbers appear above other elements"
    },
    {
      "type": "header",
      "content": "Position & Layout"
    },
    {
      "type": "select",
      "id": "position",
      "label": "Button Position",
      "options": [
        {
          "value": "top-left",
          "label": "Top Left"
        },
        {
          "value": "top-right",
          "label": "Top Right"
        },
        {
          "value": "center-left",
          "label": "Center Left"
        },
        {
          "value": "center-right",
          "label": "Center Right"
        },
        {
          "value": "bottom-left",
          "label": "Bottom Left"
        },
        {
          "value": "bottom-right",
          "label": "Bottom Right"
        }
      ],
      "default": "bottom-right"
    },
    {
      "type": "range",
      "id": "x_offset",
      "min": -100,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Horizontal Offset",
      "default": 0
    },
    {
      "type": "range",
      "id": "y_offset",
      "min": -100,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Vertical Offset",
      "default": 0
    },
    {
      "type": "range",
      "id": "button_size",
      "min": 30,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Desktop Size",
      "default": 60
    },
    {
      "type": "range",
      "id": "mobile_size",
      "min": 30,
      "max": 80,
      "step": 2,
      "unit": "px",
      "label": "Mobile Size",
      "default": 50
    },
    {
      "type": "header",
      "content": "Visual Styling"
    },
    {
      "type": "color",
      "id": "button_color",
      "label": "Button Color",
      "default": "#25d366"
    },
    {
      "type": "select",
      "id": "shadow",
      "label": "Shadow Effect",
      "options": [
        {
          "value": "none",
          "label": "None"
        },
        {
          "value": "light",
          "label": "Light"
        },
        {
          "value": "medium",
          "label": "Medium"
        },
        {
          "value": "heavy",
          "label": "Heavy"
        }
      ],
      "default": "medium"
    },
    {
      "type": "range",
      "id": "border_radius",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "label": "Border Radius",
      "default": 50,
      "info": "0 = square, 50 = circle"
    },
    {
      "type": "image_picker",
      "id": "custom_icon",
      "label": "Custom Icon (Optional)",
      "info": "Upload your own icon to replace the WhatsApp logo"
    },
    {
      "type": "header",
      "content": "Animation Effects"
    },
    {
      "type": "select",
      "id": "entry_animation",
      "label": "Entry Animation",
      "options": [
        {
          "value": "none",
          "label": "None"
        },
        {
          "value": "fade",
          "label": "Fade In"
        },
        {
          "value": "slide",
          "label": "Slide In"
        }
      ],
      "default": "fade"
    },
    {
      "type": "select",
      "id": "hover_effect",
      "label": "Hover Effect",
      "options": [
        {
          "value": "none",
          "label": "None"
        },
        {
          "value": "scale",
          "label": "Scale Up"
        },
        {
          "value": "color",
          "label": "Brighten Color"
        }
      ],
      "default": "scale"
    },
    {
      "type": "select",
      "id": "idle_animation",
      "label": "Idle Animation",
      "options": [
        {
          "value": "none",
          "label": "None"
        },
        {
          "value": "pulse",
          "label": "Gentle Pulse"
        },
        {
          "value": "breathing",
          "label": "Breathing Effect"
        }
      ],
      "default": "none"
    },
    {
      "type": "header",
      "content": "Contact Setup"
    },
    {
      "type": "text",
      "id": "phone_number",
      "label": "Phone Number",
      "info": "Include country code (e.g., +1234567890)",
      "placeholder": "1234567890"
    },
    {
      "type": "textarea",
      "id": "default_message",
      "label": "Default Message",
      "default": "Hello! I'm interested in your products.",
      "info": "This message will be pre-filled when customers click the button"
    },
    {
      "type": "text",
      "id": "tooltip_text",
      "label": "Tooltip Text (Optional)",
      "placeholder": "Chat with us on WhatsApp",
      "info": "Text shown when hovering over the button"
    },
    {
      "type": "select",
      "id": "link_target",
      "label": "Link Target",
      "options": [
        {
          "value": "same_window",
          "label": "Same Window"
        },
        {
          "value": "new_tab",
          "label": "New Tab"
        }
      ],
      "default": "new_tab"
    }
  ],
  "presets": [
    {
      "name": "WhatsApp Button"
    }
  ]
}
{% endschema %}