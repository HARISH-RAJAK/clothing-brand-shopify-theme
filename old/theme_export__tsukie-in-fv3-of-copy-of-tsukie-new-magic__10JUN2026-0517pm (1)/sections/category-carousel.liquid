<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  class="
    section
    section--{{ section.settings.section_width }}
    color-{{ section.settings.color_scheme }}
    section-resource-list
    spacing-style
    gap-style
  "
  style="
    {% render 'spacing-style', settings: section.settings %}
    {% render 'gap-style', value: section.settings.gap %}
  "
>
  <div class="section-resource-list__header">
    {% if section.settings.heading != blank %}
      <div 
        class="category-carousel-heading" 
        style="
          padding-bottom: {{ section.settings.gap }}px;
          font-weight: {{ section.settings.heading_weight }};
          text-align: {{ section.settings.heading_alignment }};
        "
      >
        {{ section.settings.heading }}
      </div>
    {% endif %}
  </div>

  {% capture list_items %}
    {% for block in section.blocks %}
      <div
        class="resource-list__item category-carousel__item"
        {{ block.shopify_attributes }}
      >
        {% if block.settings.link != blank %}
          <a href="{{ block.settings.link }}" class="category-card category-card--linked">
        {% else %}
          <div class="category-card">
        {% endif %}
          {% if block.settings.image != blank %}
            {% liquid
              assign image_ratio = 1
              case section.settings.image_ratio
                when 'landscape'
                  assign image_ratio = 0.5625
                when 'portrait'
                  assign image_ratio = 1.25
                when 'square'
                  assign image_ratio = 1
                when 'adapt'
                  if block.settings.image.aspect_ratio != blank
                    assign image_ratio = 1 | divided_by: block.settings.image.aspect_ratio
                  endif
              endcase
            %}
            <div class="category-card__image" style="padding-bottom: {{ image_ratio | times: 100 }}%;">
              <img
                src="{{ block.settings.image | image_url: width: 600 }}"
                alt="{{ block.settings.title | strip_html | escape }}"
                loading="lazy"
                width="600"
                height="{{ 600 | divided_by: block.settings.image.aspect_ratio | round }}"
              >
            </div>
          {% else %}
            <div class="category-card__image category-card__image--placeholder" style="padding-bottom: 100%;">
              {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
            </div>
          {% endif %}
          
          {% if block.settings.title != blank or block.settings.description != blank %}
            <div class="category-card__content">
              {% if block.settings.title != blank %}
                <div class="category-card__title" style="font-size: {{ block.settings.title_size }}px; font-weight: {{ block.settings.title_weight }};">
                  {{ block.settings.title }}
                </div>
              {% endif %}
              {% if block.settings.description != blank %}
                <div class="category-card__description rte" style="font-size: {{ block.settings.description_size }}px; font-weight: {{ block.settings.description_weight }};">
                  {{ block.settings.description }}
                </div>
              {% endif %}
              {% if block.settings.button_label != blank and block.settings.link != blank %}
                <span class="button button--secondary category-card__button">
                  {{ block.settings.button_label }}
                </span>
              {% endif %}
            </div>
          {% endif %}
        {% if block.settings.link != blank %}
          </a>
        {% else %}
          </div>
        {% endif %}
      </div>

      {% unless forloop.last %}
        <!--@list/split-->
      {% endunless %}
    {% endfor %}
  {% endcapture %}

  {% liquid
    # Create an array from the list items to be used for carousel layout
    assign list_items_array = list_items | strip | split: '<!--@list/split-->'
  %}

  <div class="category-carousel-marquee" id="category-carousel-{{ section.id }}" data-autoplay="{{ section.settings.autoplay }}" data-icons-style="{{ section.settings.icons_style }}" data-icons-shape="{{ section.settings.icons_shape }}">
    <div class="category-carousel-offset" style="--manual-offset: 0px;">
      <div class="category-carousel-track">
      {% for item in list_items_array %}
        {{ item }}
      {% endfor %}
      {% comment %} Duplicate items for seamless loop {% endcomment %}
      {% for item in list_items_array %}
        {{ item }}
      {% endfor %}
      </div>
    </div>
    {% unless section.settings.icons_style == 'none' %}
      <button class="category-carousel-nav category-carousel-nav--prev nav-shape--{{ section.settings.icons_shape }} nav-style--{{ section.settings.icons_style }}" type="button" aria-label="Previous">
        {% case section.settings.icons_style %}
          {% when 'chevron' %}
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M14.7 6.3a1 1 0 0 1 0 1.4L10.4 12l4.3 4.3a1 1 0 1 1-1.4 1.4L8.3 12.7a1.99 1.99 0 0 1 0-2.8l5-5a1 1 0 0 1 1.4 0Z" fill="currentColor"/></svg>
          {% when 'arrows_large' %}
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M15 6l-6 6 6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          {% when 'chevron_large' %}
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M15 6l-6 6 6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          {% else %}
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M14 6l-6 6 6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        {% endcase %}
      </button>
      <button class="category-carousel-nav category-carousel-nav--next nav-shape--{{ section.settings.icons_shape }} nav-style--{{ section.settings.icons_style }}" type="button" aria-label="Next">
        {% case section.settings.icons_style %}
          {% when 'chevron' %}
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M9.3 17.7a1 1 0 0 1 0-1.4L13.6 12 9.3 7.7a1 1 0 1 1 1.4-1.4l5 5a1.99 1.99 0 0 1 0 2.8l-5 5a1 1 0 0 1-1.4 0Z" fill="currentColor"/></svg>
          {% when 'arrows_large' %}
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M9 18l6-6-6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          {% when 'chevron_large' %}
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M9 18l6-6-6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          {% else %}
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M9 18l6-6-6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        {% endcase %}
      </button>
    {% endunless %}
  </div>
</div>

<style>
  .category-carousel-heading {
    color: var(--color-foreground);
    line-height: 1.2;
    font-family: var(--font-heading-family);
    text-align: center;
    font-size: {{ section.settings.heading_font_size_desktop | default: 32 }}px;
  }

  .category-carousel-heading h1,
  .category-carousel-heading h2,
  .category-carousel-heading h3,
  .category-carousel-heading h4,
  .category-carousel-heading h5,
  .category-carousel-heading h6,
  .category-carousel-heading p {
    margin: 0;
    font-size: inherit;
    font-weight: inherit;
    line-height: inherit;
    text-align: inherit;
  }

  .category-carousel-heading strong {
    font-weight: 700;
  }

  .category-carousel-heading em {
    font-style: italic;
  }

  .category-carousel-marquee {
    overflow: hidden;
    width: 100%;
    position: relative;
    touch-action: pan-y;
    container-type: inline-size;
  }

  .category-carousel-offset {
    transform: translate3d(var(--manual-offset, 0px), 0, 0);
    will-change: transform;
  }

  .category-carousel-offset.with-transition {
    transition: transform 300ms ease;
  }

  .category-carousel-track {
    display: flex;
    gap: {{ section.settings.columns_gap }}px;
    width: fit-content;
  }

  {% assign step_count = section.blocks.size %}
  {% if step_count <= 0 %}
    {% assign step_count = 1 %}
  {% endif %}
  {% assign hold_seconds = section.settings.autoplay_speed | default: 3 %}
  {% assign hold_duration = hold_seconds | times: 1000 %}
  {% assign slide_duration = 400 %}
  {% assign step_total_duration = hold_duration | plus: slide_duration %}
  {% assign total_animation_duration = step_total_duration | times: step_count %}
  .category-carousel-marquee[data-autoplay="true"] .category-carousel-track {
    animation: marquee-step-scroll {{ total_animation_duration }}ms cubic-bezier(0.4, 0.0, 0.2, 1) infinite;
    will-change: transform;
  }

  .category-carousel-marquee:hover .category-carousel-track {
    animation-play-state: paused;
  }

  {% assign hold_percent_total = hold_duration | times: 100.0 | divided_by: step_total_duration %}
  {% assign hold_percent_step = hold_percent_total | divided_by: step_count %}
  {% assign last_index = step_count | minus: 1 %}
  {% if last_index < 0 %}
    {% assign last_index = 0 %}
  {% endif %}
  @keyframes marquee-step-scroll {
    {% for i in (0..last_index) %}
      {% assign start_percent = 100.0 | times: i | divided_by: step_count %}
      {% assign hold_end_percent = start_percent | plus: hold_percent_step %}
      {% assign next_index = i | plus: 1 %}
      {% assign end_percent = 100.0 | times: next_index | divided_by: step_count %}
      {{ start_percent | round: 5 }}% {
        transform: translate3d(calc(-50% / {{ step_count }} * {{ i }}), 0, 0);
      }
      {{ hold_end_percent | round: 5 }}% {
        transform: translate3d(calc(-50% / {{ step_count }} * {{ i }}), 0, 0);
      }
      {{ end_percent | round: 5 }}% {
        transform: translate3d(calc(-50% / {{ step_count }} * {{ next_index }}), 0, 0);
      }
    {% endfor %}
    100% {
      transform: translate3d(calc(-50% / {{ step_count }} * {{ step_count }}), 0, 0);
    }
  }

  .category-carousel-track .resource-list__item {
    flex-shrink: 0;
    width: calc((100cqw - ({{ section.settings.columns }} - 1) * {{ section.settings.columns_gap }}px) / {{ section.settings.columns }});
    max-width: 450px;
  }

  @media screen and (max-width: 749px) {
    .category-carousel-heading {
      font-size: {{ section.settings.heading_font_size_mobile | default: 24 }}px;
    }

    .category-carousel-track .resource-list__item {
      width: {{ section.settings.mobile_card_size }};
    }
  }

  .category-card {
    display: flex;
    flex-direction: column;
    height: 100%;
    background: var(--color-background);
    border-radius: {{ section.settings.border_radius }}px;
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    text-decoration: none;
    color: inherit;
  }

  .category-card--linked {
    cursor: pointer;
  }

  .category-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 16px rgba(0, 0, 0, 0.1);
  }

  .category-card__image {
    position: relative;
    width: 100%;
    overflow: hidden;
    background: var(--color-background-2);
  }

  .category-card__image img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .category-card__image--placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .category-card__image--placeholder svg {
    width: 50%;
    height: 50%;
    opacity: 0.3;
  }

  .category-card__content {
    padding: {{ section.settings.content_padding }}px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    flex-grow: 1;
    text-align: center;
  }

  .category-card__title {
    margin: 0;
    color: var(--color-foreground);
    line-height: 1.3;
    text-align: center;
  }

  .category-card__title h1,
  .category-card__title h2,
  .category-card__title h3,
  .category-card__title h4,
  .category-card__title h5,
  .category-card__title h6,
  .category-card__title p {
    margin: 0;
    font-size: inherit;
    font-weight: inherit;
    line-height: inherit;
    text-align: center;
  }

  .category-card__description {
    margin: 0;
    color: var(--color-foreground-secondary);
    line-height: 1.5;
    text-align: center;
  }

  .category-card__description.rte h1,
  .category-card__description.rte h2,
  .category-card__description.rte h3,
  .category-card__description.rte h4,
  .category-card__description.rte h5,
  .category-card__description.rte h6 {
    margin: 0 0 0.5em 0;
    font-size: inherit;
    line-height: inherit;
    text-align: center;
  }

  .category-card__description.rte p {
    margin: 0 0 0.5em 0;
    text-align: center;
  }

  .category-card__description.rte p:last-child {
    margin-bottom: 0;
  }

  .category-card__description.rte strong {
    font-weight: 600;
  }

  .category-card__description.rte em {
    font-style: italic;
  }

  .category-card__button {
    margin-top: auto;
    width: fit-content;
    align-self: center;
  }

  /* Navigation arrows */
  .category-carousel-nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 2;
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-foreground);
    background: transparent;
    border: none;
    padding: 0;
    cursor: pointer;
  }
/* Category carousel heading: black background label behind the title text */
.section-resource-list__header {
  text-align: center;
}
.category-carousel-heading > h1,
.category-carousel-heading > h2,
.category-carousel-heading > h3,
.category-carousel-heading > h4,
.category-carousel-heading > h5,
.category-carousel-heading > h6,
.category-carousel-heading > p {
    display: inline-block;
    background-color: {{ section.settings.heading_bg_color | default: '#000000' }};
    color: #fff;
    padding: {{ section.settings.heading_bg_vertical_desktop | default: 14 }}px {{ section.settings.heading_bg_horizontal_desktop | default: 240 }}px;
    line-height: 1;
    text-transform: {{ section.settings.heading_text_transform | default: 'uppercase' }};
    white-space: nowrap;
}

@media screen and (max-width: 749px) {
  .category-carousel-heading > h1,
  .category-carousel-heading > h2,
  .category-carousel-heading > h3,
  .category-carousel-heading > h4,
  .category-carousel-heading > h5,
  .category-carousel-heading > h6,
  .category-carousel-heading > p {
    display: block;
    width: calc(100% + {{ section.settings.heading_bg_horizontal_mobile | default: 24 | times: 2 }}px);
    margin-left: -{{ section.settings.heading_bg_horizontal_mobile | default: 24 }}px;
    margin-right: -{{ section.settings.heading_bg_horizontal_mobile | default: 24 }}px;
    padding: {{ section.settings.heading_bg_vertical_mobile | default: 14 }}px {{ section.settings.heading_bg_horizontal_mobile | default: 24 }}px;
    white-space: normal;
  }
}

{% if section.settings.heading_bg_width_desktop == 'full' %}
.category-carousel-heading > h1,
.category-carousel-heading > h2,
.category-carousel-heading > h3,
.category-carousel-heading > h4,
.category-carousel-heading > h5,
.category-carousel-heading > h6,
.category-carousel-heading > p {
  display: block;
  width: 100%;
  padding: {{ section.settings.heading_bg_vertical_desktop | default: 14 }}px 0;
  text-align: center;
}
{% endif %}

  .category-carousel-nav--prev { left: 0; }
  .category-carousel-nav--next { right: 0; }

  .category-carousel-nav.nav-shape--circle { background: color-mix(in oklab, var(--color-background) 40%, transparent); border-radius: 999px; }
  .category-carousel-nav.nav-shape--square { background: color-mix(in oklab, var(--color-background) 40%, transparent); border-radius: 4px; }
  .category-carousel-nav.nav-shape--none { background: transparent; }

  .category-carousel-nav svg { pointer-events: none; }

  @media (hover: hover) {
    .category-carousel-nav:hover { filter: brightness(0.92); }
  }
</style>

<script>
  (function() {
    const root = document.getElementById('category-carousel-{{ section.id }}');
    if (!root) return;
    const offsetWrap = root.querySelector('.category-carousel-offset');
    const track = root.querySelector('.category-carousel-track');
    const btnPrev = root.querySelector('.category-carousel-nav--prev');
    const btnNext = root.querySelector('.category-carousel-nav--next');

    let manualOffset = 0;
    let dragging = false;
    let startX = 0;
    let lastX = 0;
    let dragMoved = 0;
    let isResetting = false;

    // Calculate the width of one full set of items for infinite loop
    function getLoopWidth() {
      if (!track) return 0;
      const items = track.querySelectorAll('.resource-list__item');
      const totalItems = items.length;
      if (totalItems === 0) return 0;
      // We have duplicated items, so half the items = one full set
      const setSize = totalItems / 2;
      const firstItem = items[0];
      if (!firstItem) return 0;
      const rect = firstItem.getBoundingClientRect();
      const styles = getComputedStyle(track);
      const gap = parseFloat(styles.gap || '0');
      return (rect.width + gap) * setSize;
    }

    function setOffset(value, withTransition = false) {
      if (isResetting) return;
      
      const loopWidth = getLoopWidth();
      
      // Check if we need to wrap
      if (loopWidth > 0) {
        // If we've scrolled past the end of the first set, instantly reset to beginning
        if (value <= -loopWidth) {
          isResetting = true;
          offsetWrap.classList.remove('with-transition');
          manualOffset = 0;
          offsetWrap.style.setProperty('--manual-offset', '0px');
          requestAnimationFrame(() => {
            requestAnimationFrame(() => {
              isResetting = false;
              // Now continue with the actual offset
              setOffset(value + loopWidth, withTransition);
            });
          });
          return;
        }
        // If we've scrolled backwards past the beginning, wrap to end
        if (value > 0) {
          isResetting = true;
          offsetWrap.classList.remove('with-transition');
          manualOffset = -loopWidth;
          offsetWrap.style.setProperty('--manual-offset', manualOffset + 'px');
          requestAnimationFrame(() => {
            requestAnimationFrame(() => {
              isResetting = false;
              setOffset(value - loopWidth, withTransition);
            });
          });
          return;
        }
      }
      
      manualOffset = value;
      if (!offsetWrap) return;
      if (withTransition) {
        offsetWrap.classList.add('with-transition');
      } else {
        offsetWrap.classList.remove('with-transition');
      }
      offsetWrap.style.setProperty('--manual-offset', manualOffset + 'px');
    }

    function getStep() {
      const firstItem = track && track.querySelector('.resource-list__item');
      if (!firstItem) return 0;
      const rect = firstItem.getBoundingClientRect();
      const styles = track ? getComputedStyle(track) : null;
      const gap = styles ? parseFloat(styles.gap || '0') : 0;
      return rect.width + gap;
    }    function onPrev() { setOffset(manualOffset + getStep(), true); }
    function onNext() { setOffset(manualOffset - getStep(), true); }

    if (btnPrev) btnPrev.addEventListener('click', onPrev);
    if (btnNext) btnNext.addEventListener('click', onNext);

    // Drag / swipe
    function onPointerDown(e) {
      dragging = true;
      root.classList.add('is-dragging');
      startX = lastX = e.clientX;
      dragMoved = 0;
      // Disable transition while dragging
      offsetWrap && offsetWrap.classList.remove('with-transition');
      window.addEventListener('pointermove', onPointerMove, { passive: false });
      window.addEventListener('pointerup', onPointerUp, { once: true });
    }

    function onPointerMove(e) {
      if (!dragging) return;
      const x = e.clientX;
      const dx = x - lastX;
      dragMoved += Math.abs(dx);
      lastX = x;
      setOffset(manualOffset + dx, false);
      // If horizontal dragging, prevent scrolling the page
      if (e.cancelable && dragMoved > 4 && e.pointerType === 'touch') {
        e.preventDefault();
      }
    }

    function onPointerUp() {
      dragging = false;
      root.classList.remove('is-dragging');
      // Snap optional: nudge offset to nearest step could be added; keeping freeform
      window.removeEventListener('pointermove', onPointerMove);
    }

    // Prevent click when a drag occurred
    root.addEventListener('click', function(e) {
      if (dragMoved > 6) {
        e.preventDefault();
        e.stopPropagation();
      }
      dragMoved = 0;
    }, true);

  // Bind pointer events (works for mouse and touch)
  root.addEventListener('pointerdown', onPointerDown);

    // Resize recalculation (no action required now, but keep step stable after resize by removing transition briefly)
    window.addEventListener('resize', () => {
      offsetWrap && offsetWrap.classList.remove('with-transition');
    });
  })();
</script>

{% schema %}
{
  "name": "Category Carousel",
  "class": "section-category-carousel",
  "tag": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading",
      "default": "<p>Shop by Category</p>",
      "info": "Use rich text formatting - bold, italic, headings supported"
    },
    {
      "type": "range",
      "id": "heading_font_size_desktop",
      "label": "Heading Font Size - Desktop",
      "min": 16,
      "max": 72,
      "step": 1,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "heading_font_size_mobile",
      "label": "Heading Font Size - Mobile",
      "min": 12,
      "max": 48,
      "step": 1,
      "unit": "px",
      "default": 24
    },
    {
      "type": "select",
      "id": "heading_weight",
      "label": "Heading Font Weight",
      "options": [
        {
          "value": "400",
          "label": "Normal"
        },
        {
          "value": "500",
          "label": "Medium"
        },
        {
          "value": "600",
          "label": "Semi Bold"
        },
        {
          "value": "700",
          "label": "Bold"
        }
      ],
      "default": "700"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Heading Alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "heading_text_transform",
      "label": "Heading Text Style",
      "options": [
        { "value": "uppercase", "label": "Uppercase" },
        { "value": "none", "label": "Normal" }
      ],
      "default": "uppercase"
    },
    {
      "type": "color",
      "id": "heading_bg_color",
      "label": "Background Color",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Heading Background - Desktop"
    },
    {
      "type": "select",
      "id": "heading_bg_width_desktop",
      "label": "Background Width",
      "options": [
        { "value": "auto", "label": "Auto" },
        { "value": "full", "label": "Full width" }
      ],
      "default": "auto"
    },
    {
      "type": "range",
