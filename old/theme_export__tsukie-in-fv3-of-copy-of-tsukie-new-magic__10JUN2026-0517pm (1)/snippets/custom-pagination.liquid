<div class="custom-pagination">
  {%- for media in media_items -%}
    <button
      type="button"
      class="custom-pagination__dot{% if forloop.first %} is-active{% endif %}"
      data-index="{{ forloop.index0 }}"
      aria-label="Go to slide {{ forloop.index }}"
    ></button>
  {%- endfor -%}
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const mediaGallery = document.querySelector('media-gallery.media-gallery--custom-layout');
    if (!mediaGallery) return;

    const slideshow = mediaGallery.querySelector('slideshow-component');
    if (!slideshow) return;

    const slidesContainer = slideshow.querySelector('slideshow-slides');
    if (!slidesContainer) return;

    const dots = mediaGallery.querySelectorAll('.custom-pagination__dot');

    const updatePagination = () => {
      const scrollLeft = slidesContainer.scrollLeft;
      const containerWidth = slidesContainer.offsetWidth;
      const allSlides = Array.from(slidesContainer.querySelectorAll('slideshow-slide'));
      
      if (allSlides.length === 0) return;
      
      const totalSlides = {{ media_items.size }};
      let activeIndex = 0;
      let minDistance = Infinity;
      
      // Find the slide closest to the center of the viewport
      allSlides.forEach((slide, idx) => {
        const slideLeft = slide.offsetLeft;
        const slideWidth = slide.offsetWidth;
        const slideCenter = slideLeft + slideWidth / 2;
        const containerCenter = scrollLeft + containerWidth / 2;
        const distance = Math.abs(slideCenter - containerCenter);
        
        if (distance < minDistance) {
          minDistance = distance;
          // Get the actual index from the slide's data attribute or calculate it
          const slideIndex = slide.getAttribute('data-index');
          if (slideIndex !== null) {
            activeIndex = parseInt(slideIndex, 10);
          } else {
            // Fallback: calculate index based on position
            activeIndex = idx % totalSlides;
          }
        }
      });
      
      // Ensure activeIndex is within valid range
      activeIndex = activeIndex % totalSlides;
      if (activeIndex < 0) {
        activeIndex = totalSlides + activeIndex;
      }

      dots.forEach((dot, index) => {
        dot.classList.toggle('is-active', index === activeIndex);
      });
    };

    let scrollTimeout;
    let isScrolling = false;
    
    slidesContainer.addEventListener('scroll', () => {
      if (!isScrolling) {
        isScrolling = true;
        requestAnimationFrame(() => {
          updatePagination();
          isScrolling = false;
        });
      }
      
      clearTimeout(scrollTimeout);
      scrollTimeout = setTimeout(updatePagination, 150);
    }, { passive: true });

    dots.forEach(dot => {
      dot.addEventListener('click', () => {
        const index = parseInt(dot.dataset.index, 10);
        const slideWidth = slidesContainer.querySelector('slideshow-slide:not(.clone)').offsetWidth;
        const gap = parseInt(window.getComputedStyle(slidesContainer).gap, 10) || 16;
        const clonesCount = slidesContainer.querySelectorAll('.clone-last').length;
        
        slidesContainer.scrollTo({
          left: (index + clonesCount) * (slideWidth + gap),
          behavior: 'smooth'
        });
      });
    });

    // Initial state
    updatePagination();
  });
</script>

<style>
  .custom-pagination {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 8px;
    margin-top: 16px;
  }

  .custom-pagination__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background-color: #ccc;
    border: none;
    padding: 0;
    cursor: pointer;
    transition: background-color 0.3s ease;
  }

  .custom-pagination__dot.is-active {
    background-color: #333;
  }
</style>
