{% liquid
  assign desktop_height = section.settings.section_height
  assign mobile_height = section.settings.section_height_mobile | default: section.settings.section_height

  if desktop_height == 'custom'
    assign desktop_height_value = section.settings.section_height_custom | append: 'svh'
  elsif desktop_height == 'full-screen'
    assign desktop_height_value = '100svh'
  elsif desktop_height == 'auto'
    assign desktop_height_value = 'auto'
  elsif desktop_height == 'small'
    assign desktop_height_value = '50svh'
  elsif desktop_height == 'medium'
    assign desktop_height_value = '65svh'
  elsif desktop_height == 'large'
    assign desktop_height_value = '80svh'
  else
    assign desktop_height_value = '65svh'
  endif

  if mobile_height == 'custom'
    assign mobile_height_value = section.settings.section_height_mobile_custom | append: 'svh'
  elsif mobile_height == 'full-screen'
    assign mobile_height_value = '100svh'
  elsif mobile_height == 'auto'
    assign mobile_height_value = 'auto'
  elsif mobile_height == 'small'
    assign mobile_height_value = '15rem'
  elsif mobile_height == 'medium'
    assign mobile_height_value = '25rem'
  elsif mobile_height == 'large'
    assign mobile_height_value = '35rem'
  else
    assign mobile_height_value = '25rem'
  endif
%}

<style>
/* Section Wrapper Heights */
.tsukie-hero-slider {
  position: relative;
  width: 100%;
  height: var(--hero-min-height, 600px);
  overflow: hidden;
  background-color: #f5f1ea;
  user-select: none;
  -webkit-user-select: none;
  transition: height 0.4s cubic-bezier(0.4, 0, 0.2, 1);
}
.tsukie-hero-slider[style*="--hero-min-height: auto"] {
  height: auto;
}

@media (max-width: 749px) {
  .tsukie-hero-slider {
    height: var(--hero-min-height-mobile, 450px) !important;
    transition: height 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .tsukie-hero-slider[style*="--hero-min-height-mobile: auto"] {
    height: auto !important;
  }
}

/* Scroll Snap Container */
.tsukie-hero-slides {
  width: 100%;
  height: 100%;
  display: flex;
  overflow-x: auto;
  scroll-snap-type: x mandatory;
  scroll-behavior: smooth;
  scrollbar-width: none;
  -ms-overflow-style: none;
  -webkit-overflow-scrolling: touch;
}
.tsukie-hero-slides::-webkit-scrollbar {
  display: none;
}

/* Individual Slides */
.tsukie-hero-slide {
  flex: 0 0 100%;
  width: 100%;
  height: 100%;
  scroll-snap-align: start;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
  will-change: transform;
}

/* Clickable Slide Wrapper */
.tsukie-hero-slide-link-wrapper {
  display: block;
  width: 100%;
  height: 100%;
  position: absolute;
  top: 0;
  left: 0;
  z-index: 3;
  text-decoration: none;
}

/* Slide Images */
.tsukie-hero-slide-image-wrap {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 1;
}
.tsukie-hero-slide-image-wrap img {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  display: block;
  transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1), filter 0.4s ease, opacity 0.4s ease;
  will-change: transform, opacity;
  backface-visibility: hidden;
  -webkit-backface-visibility: hidden;
  transform: translate3d(0,0,0);
}
.tsukie-hero-slide-image-wrap::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.25);
  z-index: 2;
}

/* Placeholder */
.tsukie-hero-image-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #eae6dd;
}
.tsukie-hero-image-placeholder svg {
  width: 120px;
  height: 120px;
  opacity: 0.3;
}

/* Responsive Image Toggle */
.tsukie-hero-image-desktop {
  display: block !important;
}
.tsukie-hero-image-mobile {
  display: none !important;
}
@media (max-width: 749px) {
  .tsukie-hero-slide.tsukie-hero-slider--has-mobile-image .tsukie-hero-image-desktop {
    display: none !important;
  }
  .tsukie-hero-slide.tsukie-hero-slider--has-mobile-image .tsukie-hero-image-mobile {
    display: block !important;
  }
}

/* Overlay Content Box */
.tsukie-hero-slide-content {
  position: relative;
  z-index: 4; /* Overlay text is on top of link wrapper so buttons work */
  text-align: center;
  color: #ffffff;
  max-width: 800px;
  padding: 0 20px;
  transform: translateY(20px);
  opacity: 0;
  transition: transform 0.8s ease, opacity 0.8s ease;
  pointer-events: auto;
}
.tsukie-hero-slide.is-active .tsukie-hero-slide-content {
  transform: translateY(0);
  opacity: 1;
}

.tsukie-hero-slide-eyebrow {
  font-family: 'Montserrat', sans-serif;
  font-size: 12px;
  letter-spacing: 4px;
  text-transform: uppercase;
  margin: 0 0 16px;
  font-weight: 600;
  color: #d4c5a9;
}
.tsukie-hero-slide-title {
  font-family: 'Playfair Display', serif;
  font-size: 56px;
  font-style: italic;
  font-weight: 600;
  line-height: 1.15;
  margin: 0 0 24px;
  color: #ffffff;
}
.tsukie-hero-slide-desc {
  font-family: 'Montserrat', sans-serif;
  font-size: 15px;
  line-height: 1.7;
  max-width: 600px;
  margin: 0 auto 36px;
  color: #e5e5e5;
}
.tsukie-hero-slide-cta {
  display: inline-block;
  background: #1e2a38;
  color: #d4c5a9;
  padding: 16px 40px;
  font-family: 'Montserrat', sans-serif;
  font-size: 12px;
  letter-spacing: 2px;
  text-transform: uppercase;
  text-decoration: none;
  font-weight: 600;
  border: none;
  transition: all 0.3s ease;
}
.tsukie-hero-slide-cta:hover {
  background: #2a3a4a;
  transform: translateY(-2px);
}

/* Dots Styling */
.tsukie-slider-dots {
  position: absolute;
  bottom: 30px;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  gap: 12px;
  z-index: 10;
}
.tsukie-slider-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: rgba(255,255,255,0.4);
  cursor: pointer;
  transition: all 0.3s ease;
}
.tsukie-slider-dot.is-active {
  background: #d4c5a9;
  transform: scale(1.2);
}

/* Section-level transition effects */
/* Zoom Out Effect (Ken Burns) */
.tsukie-effect-zoom .tsukie-hero-slide.is-active .tsukie-hero-slide-image-wrap img {
  animation: tsukieZoomOut 5s ease-out forwards;
}
@keyframes tsukieZoomOut {
  from { transform: scale(1.08); }
  to { transform: scale(1); }
}

/* Pan Effect */
.tsukie-effect-pan .tsukie-hero-slide.is-active .tsukie-hero-slide-image-wrap img {
  animation: tsukiePanImage 5s ease-in-out forwards;
}
@keyframes tsukiePanImage {
  0% { transform: scale(1.1) translateX(-2%); }
  100% { transform: scale(1.1) translateX(2%); }
}

/* Section-level hover effects */
.tsukie-hover-zoom .tsukie-hero-slide:hover .tsukie-hero-slide-image-wrap img {
  transform: scale(1.06);
}
.tsukie-hover-brightness .tsukie-hero-slide:hover .tsukie-hero-slide-image-wrap img {
  filter: brightness(1.1);
}
.tsukie-hover-grayscale .tsukie-hero-slide-image-wrap img {
  filter: grayscale(0.3);
}
.tsukie-hover-grayscale .tsukie-hero-slide:hover .tsukie-hero-slide-image-wrap img {
  filter: grayscale(0);
}

@media(max-width: 749px) {
  .tsukie-hero-slide-title { font-size: 34px; margin: 0 0 16px; }
  .tsukie-hero-slide-desc { font-size: 13px; margin: 0 auto 24px; }
  .tsukie-hero-slide-eyebrow { font-size: 10px; margin: 0 0 12px; }
  .tsukie-hero-slide-cta { padding: 12px 30px; font-size: 11px; }
}
</style>

<div class="tsukie-hero-slider tsukie-effect-{{ section.settings.slide_effect }} tsukie-hover-{{ section.settings.hover_effect }}" id="tsukie-hero-{{ section.id }}" style="--hero-min-height: {{ desktop_height_value }}; --hero-min-height-mobile: {{ mobile_height_value }};">
  <div class="tsukie-hero-slides">
    {% for block in section.blocks %}
      {% assign slide_id = 'slide-' | append: section.id | append: '-' | append: block.id %}
      {% assign desktop_fit = block.settings.image_size | default: 'cover' %}
      {% assign mobile_fit = block.settings.mobile_image_size | default: 'cover' %}
      {% assign mobile_width = block.settings.mobile_image_width | default: 100 %}

      {% liquid
        if desktop_fit == 'auto-adapt'
          if block.settings.image != blank
            assign img_aspect = block.settings.image.aspect_ratio
            if img_aspect > 1.5 or img_aspect < 0.8
              assign desktop_fit_actual = 'contain'
            else
              assign desktop_fit_actual = 'cover'
            endif
          else
            assign desktop_fit_actual = 'cover'
          endif
        else
          assign desktop_fit_actual = desktop_fit
        endif

        if mobile_fit == 'auto-adapt'
          if block.settings.mobile_image != blank
            assign mobile_img_aspect = block.settings.mobile_image.aspect_ratio
          elsif block.settings.image != blank
            assign mobile_img_aspect = block.settings.image.aspect_ratio
          else
            assign mobile_img_aspect = 1
          endif

          if mobile_img_aspect > 1.2 or mobile_img_aspect < 0.6
            assign mobile_fit_actual = 'contain'
          else
            assign mobile_fit_actual = 'cover'
          endif
        else
          assign mobile_fit_actual = mobile_fit
        endif

        assign has_button = false
        if block.settings.button_text != blank and block.settings.button_url != blank
          assign has_button = true
        endif

        assign slide_link = block.settings.button_url | default: block.settings.link
      %}

      <div class="tsukie-hero-slide {% if forloop.first %}is-active{% endif %} {% if block.settings.mobile_image != blank %}tsukie-hero-slider--has-mobile-image{% endif %}"
        id="{{ slide_id }}"
        {{ block.shopify_attributes }}
      >
        <style>
          #{{ slide_id }} .tsukie-hero-image-desktop {
            object-fit: {{ desktop_fit_actual }};
          }
          @media screen and (max-width: 749px) {
            #{{ slide_id }} .tsukie-hero-image-mobile {
              object-fit: {{ mobile_fit_actual }} !important;
              width: {{ mobile_width }}% !important;
              left: 50% !important;
              transform: translateX(-50%) !important;
            }
          }
        </style>

        {%- if slide_link != blank and has_button == false -%}
          <a href="{{ slide_link }}" class="tsukie-hero-slide-link-wrapper">
        {%- endif -%}

        <div class="tsukie-hero-slide-image-wrap">
          {% if block.settings.image != blank %}
            <img class="tsukie-hero-image-desktop" src="{{ block.settings.image | image_url: width: 1920 }}" alt="{{ block.settings.image.alt | escape }}" loading="eager" {% if forloop.first %}fetchpriority="high"{% endif %} width="{{ block.settings.image.width }}" height="{{ block.settings.image.height }}">
            {% if block.settings.mobile_image != blank %}
              <img class="tsukie-hero-image-mobile" src="{{ block.settings.mobile_image | image_url: width: 750 }}" alt="{{ block.settings.mobile_image.alt | escape }}" loading="eager" {% if forloop.first %}fetchpriority="high"{% endif %} width="{{ block.settings.mobile_image.width }}" height="{{ block.settings.mobile_image.height }}">
            {% endif %}
          {% else %}
            <div class="tsukie-hero-image-placeholder">
              {{ 'hero-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
            </div>
          {% endif %}
        </div>

        {%- if block.settings.eyebrow != blank or block.settings.heading != blank or block.settings.description != blank or block.settings.button_text != blank -%}
          <div class="tsukie-hero-slide-content">
            {% if block.settings.eyebrow != blank %}
              <p class="tsukie-hero-slide-eyebrow">{{ block.settings.eyebrow }}</p>
            {% endif %}
            {% if block.settings.heading != blank %}
              <h2 class="tsukie-hero-slide-title">{{ block.settings.heading }}</h2>
            {% endif %}
            {% if block.settings.description != blank %}
              <p class="tsukie-hero-slide-desc">{{ block.settings.description }}</p>
            {% endif %}
            {% if has_button %}
              <a href="{{ slide_link }}" class="tsukie-hero-slide-cta">{{ block.settings.button_text }}</a>
            {% endif %}
          </div>
        {%- endif -%}

        {%- if slide_link != blank and has_button == false -%}
          </a>
        {%- endif -%}
      </div>
    {% endfor %}
  </div>

  {% if section.blocks.size > 1 %}
    <div class="tsukie-slider-dots">
      {% for block in section.blocks %}
        <span class="tsukie-slider-dot {% if forloop.first %}is-active{% endif %}" data-index="{{ forloop.index0 }}"></span>
      {% endfor %}
    </div>
  {% endif %}
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  var slider = document.getElementById('tsukie-hero-{{ section.id }}');
  if (!slider) return;

  var slidesContainer = slider.querySelector('.tsukie-hero-slides');
  var slides = slider.querySelectorAll('.tsukie-hero-slide');
  var dots = slider.querySelectorAll('.tsukie-slider-dot');

  var currentIndex = 0;
  var slideInterval;
  var speed = parseInt('{{ section.settings.autoplay_speed | default: 5 }}', 10) * 1000;
  var scrollTimeout;

  function adjustSliderHeight() {
    var isMobile = window.innerWidth <= 749;
    if (!isMobile) {
      slider.style.removeProperty('--hero-min-height-mobile');
      return;
    }
    
    var activeSlide = slides[currentIndex];
    if (!activeSlide) return;
    
    var img = activeSlide.querySelector('.tsukie-hero-image-mobile');
    if (!img || img.style.display === 'none' || window.getComputedStyle(img).display === 'none') {
      img = activeSlide.querySelector('.tsukie-hero-image-desktop');
    }
    if (!img) return;

    function doUpdate() {
      var naturalWidth = img.naturalWidth;
      var naturalHeight = img.naturalHeight;
      if (naturalWidth > 0 && naturalHeight > 0) {
        var sliderWidth = slidesContainer.clientWidth;
        var calculatedHeight = (sliderWidth * naturalHeight) / naturalWidth;
        slider.style.setProperty('--hero-min-height-mobile', calculatedHeight + 'px', 'important');
      }
    }

    if (img.complete) {
      doUpdate();
    } else {
      img.addEventListener('load', doUpdate, { once: true });
    }
  }

  function settleActiveSlide() {
    var scrollLeft = slidesContainer.scrollLeft;
    var slideWidth = slidesContainer.clientWidth;
    if (slideWidth <= 0) return;
    var activeIndex = Math.round(scrollLeft / slideWidth);
    
    if (activeIndex !== currentIndex || !slides[currentIndex].classList.contains('is-active')) {
      slides.forEach(function(slide) {
        slide.classList.remove('is-active');
      });
      dots.forEach(function(dot) {
        dot.classList.remove('is-active');
      });
      
      currentIndex = activeIndex;
      if (slides[currentIndex]) slides[currentIndex].classList.add('is-active');
      if (dots[currentIndex]) dots[currentIndex].classList.add('is-active');
      adjustSliderHeight();
    }
  }

  function updateActiveSlide() {
    var scrollLeft = slidesContainer.scrollLeft;
    var slideWidth = slidesContainer.clientWidth;
    if (slideWidth <= 0) return;
    var activeIndex = Math.round(scrollLeft / slideWidth);
    
    // Update dots instantly for responsiveness
    dots.forEach(function(dot, idx) {
      dot.classList.toggle('is-active', idx === activeIndex);
    });

    if (scrollTimeout) clearTimeout(scrollTimeout);
    scrollTimeout = setTimeout(settleActiveSlide, 100);
  }

  function showSlide(index) {
    currentIndex = (index + slides.length) % slides.length;
    var slideWidth = slidesContainer.clientWidth;
    slidesContainer.scrollTo({
      left: currentIndex * slideWidth,
      behavior: 'smooth'
    });
    settleActiveSlide();
  }

  function startAutoPlay() {
    {% if section.settings.autoplay %}
      stopAutoPlay();
      slideInterval = setInterval(function() { showSlide(currentIndex + 1); }, speed);
    {% endif %}
  }

  function stopAutoPlay() {
    if (slideInterval) clearInterval(slideInterval);
  }

  if (slides.length > 1) {
    slidesContainer.addEventListener('scroll', updateActiveSlide);
    window.addEventListener('resize', function() {
      updateActiveSlide();
      adjustSliderHeight();
    });

    dots.forEach(function(dot) {
      dot.addEventListener('click', function() {
        showSlide(parseInt(this.getAttribute('data-index'), 10));
        startAutoPlay();
      });
    });

    // Pause autoplay on user interaction (touch/swipe)
    slidesContainer.addEventListener('touchstart', stopAutoPlay, { passive: true });
    slidesContainer.addEventListener('touchend', startAutoPlay, { passive: true });

    slider.addEventListener('mouseenter', stopAutoPlay);
    slider.addEventListener('mouseleave', startAutoPlay);
  }

  // Set initial height and play state
  adjustSliderHeight();
  window.addEventListener('load', adjustSliderHeight);
  startAutoPlay();
});
</script>

{% schema %}
{
  "name": "Tsukie Hero Banner",
  "tag": "section",
  "class": "tsukie-hero-section",
  "max_blocks": 6,
  "settings": [
    {
      "type": "header",
      "content": "Carousel Settings"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Enable Autoplay",
      "default": true
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "label": "Autoplay Speed (seconds)",
      "min": 2,
      "max": 10,
      "step": 1,
      "default": 5
    },
    {
      "type": "header",
      "content": "Animation Effects"
    },
    {
      "type": "select",
      "id": "slide_effect",
      "label": "Slide Transition Effect",
      "options": [
        {
          "value": "default",
          "label": "Default"
        },
        {
          "value": "zoom",
          "label": "Ken Burns (Zoom Out)"
        },
        {
          "value": "pan",
          "label": "Pan (Left to Right)"
        }
      ],
      "default": "zoom"
    },
    {
      "type": "select",
      "id": "hover_effect",
      "label": "Hover Effect",
      "options": [
        {
          "value": "none",
          "label": "None"
        },
        {
          "value": "zoom",
          "label": "Zoom In"
        },
        {
          "value": "brightness",
          "label": "Brighten"
        },
        {
          "value": "grayscale",
          "label": "Grayscale on Hover"
        }
      ],
      "default": "none"
    },
    {
      "type": "header",
      "content": "Section Layout"
    },
    {
      "type": "select",
      "id": "section_height",
      "label": "Height",
      "options": [
        {
          "value": "auto",
          "label": "Auto"
        },
        {
          "value": "small",
          "label": "Small"
        },
        {
          "value": "medium",
          "label": "Medium"
        },
        {
          "value": "large",
          "label": "Large"
        },
        {
          "value": "full-screen",
          "label": "Full Screen"
        },
        {
          "value": "custom",
          "label": "Custom"
        }
      ],
      "default": "medium"
    },
    {
      "type": "range",
      "id": "section_height_custom",
      "label": "Custom Height",
      "min": 30,
      "max": 100,
      "step": 1,
      "default": 70,
      "unit": "%"
    },
    {
      "type": "select",
      "id": "section_height_mobile",
      "label": "Mobile height",
      "options": [
        { "value": "auto", "label": "Auto" },
        { "value": "small", "label": "Small" },
        { "value": "medium", "label": "Medium" },
        { "value": "large", "label": "Large" },
        { "value": "full-screen", "label": "Full Screen" },
        { "value": "custom", "label": "Custom" }
      ],
      "default": "medium"
    },
    {
      "type": "range",
      "id": "section_height_mobile_custom",
      "label": "Custom mobile height",
      "min": 30,
      "max": 100,
      "step": 1,
      "default": 60,
      "unit": "%"
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Desktop Image"
        },
        {
          "type": "image_picker",
          "id": "mobile_image",
          "label": "Mobile Image"
        },
        {
          "type": "select",
          "id": "image_size",
          "label": "Desktop image fit",
          "options": [
            { "value": "auto-adapt", "label": "Auto Adapt" },
            { "value": "cover", "label": "Cover" },
            { "value": "contain", "label": "Contain" },
            { "value": "fill", "label": "Fill" }
          ],
          "default": "cover"
        },
        {
          "type": "select",
          "id": "mobile_image_size",
          "label": "Mobile image fit",
          "options": [
            { "value": "auto-adapt", "label": "Auto Adapt" },
            { "value": "cover", "label": "Cover" },
            { "value": "contain", "label": "Contain" },
            { "value": "fill", "label": "Fill" }
          ],
          "default": "cover"
        },
        {
          "type": "range",
          "id": "mobile_image_width",
          "label": "Mobile image width",
          "min": 50,
          "max": 150,
          "step": 1,
          "default": 100,
          "unit": "%"
        },
        {
          "type": "text",
          "id": "eyebrow",
          "label": "Eyebrow Text",
          "default": "SUMMER 2026 COLLECTION"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Dressed for the woman you already are"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Premium silhouettes crafted for the modern Indian woman."
        },
        {
          "type": "text",
          "id": "button_text",
          "label": "Button Text",
          "default": "SHOP NOW"
        },
        {
          "type": "url",
          "id": "button_url",
          "label": "Button Link"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Slide Link (Used if Button is blank)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Tsukie Hero Banner",
      "blocks": [
        {
          "type": "slide",
          "settings": {
            "eyebrow": "SUMMER 2026 COLLECTION",
            "heading": "Dressed for the woman you already are",
            "description": "Premium silhouettes crafted for the modern Indian woman — luxurious fabrics, thoughtful fit, and enduring style.",
            "button_text": "SHOP NEW ARRIVALS"
          }
        },
        {
          "type": "slide",
          "settings": {
            "eyebrow": "CHIC & ELEGANT",
            "heading": "Style in Peplum & Flared Tops",
            "description": "Discover curated sets and tops designed for comfort, grace, and premium everyday wear.",
            "button_text": "EXPLORE BEST SELLERS"
          }
        },
        {
