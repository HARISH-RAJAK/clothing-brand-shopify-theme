{% liquid
  assign max_items = section.blocks.size

  assign desktop_height = section.settings.section_height
  assign mobile_height = section.settings.section_height_mobile | default: section.settings.section_height

  if desktop_height == 'custom'
    assign desktop_height_value = section.settings.section_height_custom | append: 'svh'
  elsif desktop_height == 'full-screen'
    assign desktop_height_value = '100svh'
  elsif desktop_height == 'auto'
    assign desktop_height_value = 'auto'
  elsif desktop_height == 'small'
    assign desktop_height_value = '50svh'
  elsif desktop_height == 'medium'
    assign desktop_height_value = '65svh'
  elsif desktop_height == 'large'
    assign desktop_height_value = '80svh'
  else
    assign desktop_height_value = '65svh'
  endif

  if mobile_height == 'custom'
    assign mobile_height_value = section.settings.section_height_mobile_custom | append: 'svh'
  elsif mobile_height == 'full-screen'
    assign mobile_height_value = '100svh'
  elsif mobile_height == 'auto'
    assign mobile_height_value = 'auto'
  elsif mobile_height == 'small'
    assign mobile_height_value = '15rem'
  elsif mobile_height == 'medium'
    assign mobile_height_value = '25rem'
  elsif mobile_height == 'large'
    assign mobile_height_value = '35rem'
  else
    assign mobile_height_value = '25rem'
  endif
%}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>

<div
  class="
    hero-carousel
    hero-carousel--effect-{{ section.settings.slide_effect }}
    hero-carousel--hover-{{ section.settings.hover_effect }}
    color-{{ section.settings.color_scheme }}
  "
  style="
    --hero-min-height: {{ desktop_height_value }};
    --hero-min-height-mobile: {{ mobile_height_value }};
  "
>

  {% capture list_items %}
    {% for block in section.blocks %}
      {% assign slide_id = 'slide-' | append: section.id | append: '-' | append: block.id %}
      {% assign desktop_fit = block.settings.image_size | default: 'cover' %}
      {% assign mobile_fit = block.settings.mobile_image_size | default: 'cover' %}
      {% assign mobile_width = block.settings.mobile_image_width | default: 100 %}
      {% liquid
        assign desktop_is_auto = false
        assign mobile_is_auto = false
        
        if desktop_fit == 'auto-adapt'
          assign desktop_is_auto = true
          if block.settings.image != blank
            assign img_aspect = block.settings.image.aspect_ratio
            if img_aspect > 1.5
              assign desktop_fit_actual = 'contain'
            elsif img_aspect < 0.8
              assign desktop_fit_actual = 'contain'
            else
              assign desktop_fit_actual = 'cover'
            endif
          else
            assign desktop_fit_actual = 'cover'
          endif
        else
          assign desktop_fit_actual = desktop_fit
        endif
        
        if mobile_fit == 'auto-adapt'
          assign mobile_is_auto = true
          if block.settings.mobile_image != blank
            assign mobile_img_aspect = block.settings.mobile_image.aspect_ratio
          elsif block.settings.image != blank
            assign mobile_img_aspect = block.settings.image.aspect_ratio
          else
            assign mobile_img_aspect = 1
          endif
          
          if mobile_img_aspect > 1.2
            assign mobile_fit_actual = 'contain'
          elsif mobile_img_aspect < 0.6
            assign mobile_fit_actual = 'contain'
          else
            assign mobile_fit_actual = 'cover'
          endif
        else
          assign mobile_fit_actual = mobile_fit
        endif
      %}
      <div
        class="hero-carousel__item{% if desktop_is_auto %} hero-carousel__item--auto-desktop{% endif %}{% if mobile_is_auto %} hero-carousel__item--auto-mobile{% endif %}"
        id="{{ slide_id }}"
        {{ block.shopify_attributes }}
        {% if block.settings.image != blank %}data-desktop-aspect="{{ block.settings.image.aspect_ratio }}"{% endif %}
        {% if block.settings.mobile_image != blank %}data-mobile-aspect="{{ block.settings.mobile_image.aspect_ratio }}"{% endif %}
      >
        <style>
          #{{ slide_id }} .hero-carousel__image-desktop {
            object-fit: {{ desktop_fit_actual }};
          }
          {% if desktop_is_auto and block.settings.image != blank %}
          #{{ slide_id }}.hero-carousel__item--auto-desktop .hero-carousel__image {
            aspect-ratio: {{ block.settings.image.aspect_ratio }};
          }
          {% endif %}
          @media screen and (max-width: 749px) {
            #{{ slide_id }} .hero-carousel__image-mobile {
              object-fit: {{ mobile_fit_actual }} !important;
              width: {{ mobile_width }}% !important;
              left: 50% !important;
              transform: translateX(-50%) !important;
            }
            {% if mobile_is_auto %}
            #{{ slide_id }}.hero-carousel__item--auto-mobile .hero-carousel__image {
              {% if block.settings.mobile_image != blank %}
              aspect-ratio: {{ block.settings.mobile_image.aspect_ratio }} !important;
              {% elsif block.settings.image != blank %}
              aspect-ratio: {{ block.settings.image.aspect_ratio }} !important;
              {% endif %}
            }
            #{{ slide_id }}.hero-carousel__item--auto-mobile .hero-carousel__image-mobile {
              object-fit: contain !important;
            }
            {% endif %}
          }
        </style>
        {% if block.settings.link != blank %}
          <a href="{{ block.settings.link }}" class="hero-carousel__card">
        {% else %}
          <div class="hero-carousel__card">
        {% endif %}
          {% if block.settings.image != blank %}
            <div class="hero-carousel__image">
              {% comment %} Desktop Image {% endcomment %}
              <img
                class="hero-carousel__image-desktop"
                src="{{ block.settings.image | image_url: width: 1200 }}"
                alt="{{ block.settings.image.alt | escape }}"
                loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
                {% if forloop.first %}
                  fetchpriority="high"
                  {% endif %}
                width="{{ block.settings.image.width }}"
                height="{{ block.settings.image.height }}"
                sizes="100vw"
              >
              {% comment %} Mobile Image {% endcomment %}
              {% if block.settings.mobile_image != blank %}
                <img
                  class="hero-carousel__image-mobile"
                  src="{{ block.settings.mobile_image | image_url: width: 600 }}"
                  alt="{{ block.settings.mobile_image.alt | escape }}"
                  loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
                  {% if forloop.first %}
                    fetchpriority="high"
                     {% endif %}
                  width="{{ block.settings.mobile_image.width }}"
                  height="{{ block.settings.mobile_image.height }}"
                  sizes="100vw"
                >
              {% endif %}
            </div>
          {% else %}
            <div class="hero-carousel__image hero-carousel__image--placeholder">
              {{ 'hero-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
            </div>
          {% endif %}
        {% if block.settings.link != blank %}
          </a>
        {% else %}
          </div>
        {% endif %}
      </div>

      {% unless forloop.last %}
        <!--@list/split-->
      {% endunless %}
    {% endfor %}
  {% endcapture %}

  {% liquid
    # Create an array from the list items to be used for carousel layout
    assign list_items_array = list_items | strip | split: '<!--@list/split-->'
  %}

  {% comment %} Render as carousel {% endcomment %}
  {% liquid
    assign slideshow_ref = 'heroCarousel-' | append: section.id
  %}

  {% capture slides %}
    {% for item in list_items_array limit: list_items_array.size %}
      {% render 'slideshow-slide'
        index : forloop.index0,
        children : item,
        class : 'hero-carousel__slide'
      %}
    {% endfor %}
  {% endcapture %}

  {% if section.settings.icons_style != 'none' %}
    {% capture slideshow_arrows %}
      {% render 'slideshow-arrows', icon_style: section.settings.icons_style, icon_shape: section.settings.icons_shape %}
    {% endcapture %}
  {% endif %}

  <div class="hero-carousel__wrapper">
    {% liquid
      if section.settings.autoplay
        assign autoplay_enabled = true
      else
        assign autoplay_enabled = false
      endif
    %}
    {% render 'slideshow',
      ref: slideshow_ref,
      class: 'hero-carousel__slideshow',
      slides: slides,
      slideshow_arrows: slideshow_arrows,
      auto_hide_controls: false,
      infinite: true,
      autoplay: autoplay_enabled,
      autoplay_speed: section.settings.autoplay_speed,
      initial_slide: 0,
      slide_count: max_items
    %}
  </div>
</div>

<style>
  .hero-carousel {
    position: relative;
    width: 100%;
    min-height: var(--hero-min-height, 65svh);
  }

  .hero-carousel[style*="--hero-min-height: auto"] {
    min-height: auto;
  }

  @media screen and (max-width: 749px) {
    .hero-carousel {
      min-height: var(--hero-min-height-mobile, var(--hero-min-height, 25rem)) !important;
    }

    .hero-carousel[style*="--hero-min-height-mobile: auto"] {
      min-height: auto !important;
    }
  }

  .hero-carousel__wrapper {
    width: 100%;
    height: 100%;
  }

  .hero-carousel__slideshow {
    width: 100%;
    height: 100%;
  }

  .hero-carousel__slideshow slideshow-slides {
    min-height: var(--hero-min-height, 65svh);
  }

  @media screen and (max-width: 749px) {
    .hero-carousel__slideshow slideshow-slides {
      min-height: var(--hero-min-height-mobile, var(--hero-min-height, 25rem)) !important;
    }
  }

  .hero-carousel__slide {
    width: 100%;
    height: 100%;
  }

  .hero-carousel__item {
    width: 100%;
    height: 100%;
  }

  .hero-carousel__card {
    display: block;
    width: 100%;
    height: 100%;
    position: relative;
    text-decoration: none;
  }

  .hero-carousel__image {
    width: 100%;
    height: 100%;
    min-height: var(--hero-min-height, 65svh);
    position: relative;
    overflow: hidden;
  }

  @media screen and (max-width: 749px) {
    .hero-carousel__image {
      min-height: var(--hero-min-height-mobile, var(--hero-min-height, 25rem)) !important;
    }
  }

  .hero-carousel__image[style*="--hero-min-height: auto"] {
    min-height: auto;
  }

  .hero-carousel__image img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: block;
    transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.4s ease;
  }

  /* Mobile/Desktop image display */
  .hero-carousel__image-mobile {
    display: none !important;
  }

  .hero-carousel__image-desktop {
    display: block !important;
  }

  @media screen and (max-width: 749px) {
    .hero-carousel__image-mobile {
      display: block !important;
    }

    .hero-carousel__image-desktop {
      display: none !important;
    }
  }

  /* Slide transition effects */
  .hero-carousel--effect-fade .hero-carousel__slide:not([aria-hidden="false"]) .hero-carousel__image img {
    opacity: 0;
  }

  .hero-carousel--effect-fade .hero-carousel__slide[aria-hidden="false"] .hero-carousel__image img {
    opacity: 1;
  }

  .hero-carousel__slide[aria-hidden="false"] .hero-carousel__image img {
    transform: scale(1.05);
    animation: zoomOut {{ section.settings.autoplay_speed }}s ease-out forwards;
  }

  @keyframes zoomOut {
    from {
      transform: scale(1.05);
    }
    to {
      transform: scale(1);
    }
  }

  .hero-carousel--effect-slide-zoom .hero-carousel__slide[aria-hidden="false"] .hero-carousel__image img {
    animation: slideZoom 0.8s cubic-bezier(0.4, 0, 0.2, 1) forwards;
  }

  @keyframes slideZoom {
    from {
      transform: scale(1.1);
      opacity: 0.8;
    }
    to {
      transform: scale(1);
      opacity: 1;
    }
  }

  .hero-carousel--effect-pan .hero-carousel__slide[aria-hidden="false"] .hero-carousel__image img {
    animation: panImage {{ section.settings.autoplay_speed }}s ease-in-out forwards;
  }

  @keyframes panImage {
    0% {
      transform: scale(1.1) translateX(-2%);
    }
    100% {
      transform: scale(1.1) translateX(2%);
    }
  }

  /* Hover effects */
  .hero-carousel--hover-zoom .hero-carousel__card:hover .hero-carousel__image img {
    transform: scale(1.08);
  }

  .hero-carousel--hover-brightness .hero-carousel__card:hover .hero-carousel__image img {
    filter: brightness(1.1);
  }

  .hero-carousel--hover-grayscale .hero-carousel__card:hover .hero-carousel__image img {
    filter: grayscale(0);
  }

  .hero-carousel--hover-grayscale .hero-carousel__image img {
    filter: grayscale(0.3);
  }

  /* Placeholder styling */
  .hero-carousel__image--placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-background-2);
  }

  .hero-carousel__image--placeholder svg {
    width: 50%;
    height: 50%;
    opacity: 0.3;
  }

  /* Auto-adapt image styles */
  .hero-carousel__item--auto-desktop .hero-carousel__image {
    min-height: auto;
  }

  .hero-carousel__item--auto-desktop .hero-carousel__image-desktop {
    object-fit: contain;
  }

  @media screen and (max-width: 749px) {
    .hero-carousel__item--auto-mobile .hero-carousel__image {
      min-height: auto !important;
    }

    .hero-carousel__item--auto-mobile .hero-carousel__image-mobile {
      object-fit: contain !important;
    }
  }

  /* Smooth scrolling for reduced motion preference */
  @media (prefers-reduced-motion: reduce) {
    .hero-carousel__slide,
    .hero-carousel__image img {
      transition: none;
      animation: none !important;
    }
  }
</style>

{% schema %}
{
  "name": "Hero Carousel",
  "class": "section-hero-carousel",
  "tag": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Carousel Settings"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Enable Autoplay",
      "default": true
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "label": "Autoplay Speed (seconds)",
      "min": 2,
      "max": 10,
      "step": 1,
      "default": 5,
      "info": "Time between slides in seconds"
    },
    {
      "type": "header",
      "content": "Animation Effects"
    },
    {
      "type": "select",
      "id": "slide_effect",
      "label": "Slide Transition Effect",
      "options": [
        {
          "value": "default",
          "label": "Default (Slide)"
        },
        {
          "value": "fade",
          "label": "Fade"
        },
        {
          "value": "zoom",
          "label": "Ken Burns (Zoom Out)"
        },
        {
          "value": "slide-zoom",
          "label": "Slide + Zoom"
        },
        {
          "value": "pan",
          "label": "Pan (Left to Right)"
        }
      ],
      "default": "zoom",
      "info": "Choose how slides transition"
    },
    {
      "type": "select",
      "id": "hover_effect",
      "label": "Hover Effect",
      "options": [
        {
          "value": "none",
          "label": "None"
        },
        {
          "value": "zoom",
          "label": "Zoom In"
        },
        {
          "value": "brightness",
          "label": "Brighten"
        },
        {
          "value": "grayscale",
          "label": "Color on Hover"
        }
      ],
      "default": "zoom",
      "info": "Effect when hovering over slides"
    },
    {
      "type": "header",
      "content": "Navigation"
    },
    {
      "type": "select",
      "id": "icons_style",
      "label": "Arrow Style",
      "options": [
        {
          "value": "arrow",
          "label": "Arrows"
        },
        {
          "value": "chevron",
          "label": "Chevrons"
        },
        {
          "value": "arrows_large",
          "label": "Arrows Large"
        },
        {
          "value": "chevron_large",
          "label": "Chevron Large"
        },
        {
          "value": "none",
          "label": "None"
        }
      ],
      "default": "arrow"
    },
    {
      "type": "select",
      "id": "icons_shape",
      "label": "Arrow Background",
      "options": [
        {
          "value": "none",
          "label": "None"
        },
        {
          "value": "circle",
          "label": "Circle"
        },
        {
          "value": "square",
          "label": "Square"
        }
      ],
      "default": "circle"
    },
    {
      "type": "header",
      "content": "Section Layout"
    },
    {
      "type": "select",
      "id": "section_height",
      "label": "Height",
      "options": [
        {
          "value": "auto",
          "label": "Auto"
        },
        {
          "value": "small",
          "label": "Small"
        },
        {
          "value": "medium",
          "label": "Medium"
        },
        {
          "value": "large",
          "label": "Large"
        },
        {
          "value": "full-screen",
          "label": "Full Screen"
        },
        {
          "value": "custom",
          "label": "Custom"
        }
      ],
      "default": "medium"
    },
    {
      "type": "range",
      "id": "section_height_custom",
      "label": "Custom Height",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 50,
      "unit": "%",
      "info": "Percentage of viewport height"
    },
    {
      "type": "select",
      "id": "section_height_mobile",
      "label": "Mobile height",
      "options": [
        { "value": "auto", "label": "Auto" },
        { "value": "small", "label": "Small" },
        { "value": "medium", "label": "Medium" },
        { "value": "large", "label": "Large" },
        { "value": "full-screen", "label": "Full Screen" },
        { "value": "custom", "label": "Custom" }
      ],
      "default": "medium"
    },
    {
      "type": "range",
      "id": "section_height_mobile_custom",
      "label": "Custom mobile height",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 60,
      "unit": "%",
      "info": "Percentage of viewport height on mobile"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "default": "scheme-1"
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Desktop Image"
        },
        {
          "type": "image_picker",
          "id": "mobile_image",
          "label": "Mobile Image",
          "info": "Optional: Use a different image for mobile devices (under 750px width)"
        },
        {
          "type": "select",
          "id": "image_size",
          "label": "Desktop image fit",
          "options": [
            { "value": "auto-adapt", "label": "Auto Adapt (Adjust to image)" },
            { "value": "cover", "label": "Cover (Fill area, may crop)" },
            { "value": "contain", "label": "Contain (Fit entire image)" },
            { "value": "fill", "label": "Fill (Stretch to fit)" },
            { "value": "scale-down", "label": "Scale Down" }
          ],
          "default": "cover",
          "info": "Auto Adapt automatically adjusts based on image dimensions"
        },
        {
          "type": "select",
          "id": "mobile_image_size",
          "label": "Mobile image fit",
          "options": [
            { "value": "auto-adapt", "label": "Auto Adapt (Adjust to image)" },
            { "value": "cover", "label": "Cover (Fill area, may crop)" },
            { "value": "contain", "label": "Contain (Fit entire image)" },
            { "value": "fill", "label": "Fill (Stretch to fit)" },
            { "value": "scale-down", "label": "Scale Down" }
          ],
          "default": "cover",
          "info": "Auto Adapt automatically adjusts based on image dimensions"
        },
        {
          "type": "range",
          "id": "mobile_image_width",
          "label": "Mobile image width",
          "min": 50,
          "max": 150,
          "step": 1,
          "default": 100,
          "unit": "%",
          "info": "Adjust the width of mobile image (100% = full width)"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero Carousel",
      "blocks": [
        {
          "type": "slide"
        },
        {
          "type": "slide"
        },
        {
          "type": "slide"
        }
      ]
    }
  ]
}
{% endschema %}
