{% comment %}
  Tsukie Product Page - Fixed Isolated Single Item Checkout Flow
{% endcomment %}

<style>
/* Fonts loaded globally via theme.liquid — no @import needed here */

.tsukie-product{
  background:#f5f1ea;
  padding:40px 0 80px;
}
.tsukie-product-container{
  max-width:1400px;
  margin:0 auto;
  padding:0 40px;
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:60px;
  align-items:start;
}

/* Left: Images */
.tsukie-pdp-media{
  position:sticky;
  top:100px;
  display:flex;
  gap:12px;
}
.tsukie-thumbnails-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
  width: 80px;
  flex-shrink: 0;
}
.tsukie-thumbnails{
  display:flex;
  flex-direction:column;
  gap:8px;
  max-height: 520px;
  overflow-y: auto;
  scroll-behavior: smooth;
  scrollbar-width: none;
}
.tsukie-thumbnails::-webkit-scrollbar {
  display: none;
}
.tsukie-thumb-nav {
  background: none;
  border: none;
  cursor: pointer;
  padding: 4px;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #1e2a38;
}
.tsukie-thumb-nav svg {
  width: 16px;
  height: 16px;
}
.tsukie-thumb{
  background:#e8e4dd;
  aspect-ratio:1;
  cursor:pointer;
  border:2px solid transparent;
  transition:border 0.2s;
  width: 80px;
  height: 80px;
}
.tsukie-thumb.active{
  border-color:#1e2a38;
}
.tsukie-thumb img{
  width:100%;
  height:100%;
  object-fit:cover;
  display:block;
}
.tsukie-main-image-wrap{
  flex:1;
}
.tsukie-main-image{
  position:relative;
  background:#e8e4dd;
}
.tsukie-main-image img{
  width:100%;
  height:auto;
  display:block;
}
.tsukie-badge{
  position:absolute;
  top:16px;
  left:16px;
  background:#1e2a38;
  color:#d4c5a9;
  font-family:'Montserrat',sans-serif;
  font-size:10px;
  letter-spacing:1px;
  text-transform:uppercase;
  padding:6px 12px;
  font-weight:600;
  z-index: 2;
}
.tsukie-carousel-nav{
  position:absolute;
  top:50%;
  transform:translateY(-50%);
  background:rgba(255,255,255,0.9);
  border:none;
  width:40px;
  height:40px;
  cursor:pointer;
  display:flex;
  align-items:center;
  justify-content:center;
  z-index: 2;
}
.tsukie-carousel-nav.prev{left:12px}
.tsukie-carousel-nav.next{right:12px}
.tsukie-carousel-nav svg{width:18px;height:18px;color:#1e2a38}

/* Right: Info */
.tsukie-pdp-info{
  padding-top:8px;
}
.tsukie-pdp-title{
  font-family:'Playfair Display',serif;
  font-size:36px;
  font-weight:400;
  color:#1e2a38;
  margin:0 0 12px;
  line-height:1.2;
}
.tsukie-product-subtitle{
  font-family:'Montserrat',sans-serif;
  font-size:13px;
  color:#666;
  margin:0 0 16px;
  font-weight:300;
}
.tsukie-rating-row{
  display:flex;
  align-items:center;
  gap:12px;
  margin-bottom:20px;
  padding-bottom:20px;
  border-bottom:1px solid rgba(30,42,56,0.08);
  flex-wrap:wrap;
}
.tsukie-stars{
  display:flex;
  gap:2px;
}
.tsukie-stars svg{
  width:14px;
  height:14px;
  color:#1e2a38;
  fill:#1e2a38;
}
.tsukie-rating-text{
  font-family:'Montserrat',sans-serif;
  font-size:13px;
  color:#1e2a38;
  font-weight:500;
}
.tsukie-rating-text span{
  color:#666;
  font-weight:400;
}
.tsukie-verified{
  border:1px solid rgba(30,42,56,0.15);
  padding:4px 10px;
  font-family:'Montserrat',sans-serif;
  font-size:10px;
  letter-spacing:1px;
  text-transform:uppercase;
  color:#666;
}

/* Price */
.tsukie-price-row{
  margin-bottom:8px;
  display:flex;
  align-items:baseline;
  gap:12px;
  flex-wrap:wrap;
}
.tsukie-price{
  font-family:'Montserrat',sans-serif;
  font-size:28px;
  font-weight:500;
  color:#1e2a38;
}
.tsukie-price-compare{
  font-family:'Montserrat',sans-serif;
  font-size:16px;
  color:#999;
  text-decoration:line-through;
  font-weight:400;
}
.tsukie-price-save{
  background:#1e2a38;
  color:#d4c5a9;
  font-family:'Montserrat',sans-serif;
  font-size:10px;
  letter-spacing:1px;
  padding:4px 8px;
  font-weight:600;
  text-transform:uppercase;
}


/* Variants */
.tsukie-variant-section{
  margin-bottom:20px;
}
.tsukie-variant-header{
  display:flex;
  justify-content:space-between;
  align-items:center;
  margin-bottom:12px;
}
.tsukie-variant-label{
  font-family:'Montserrat',sans-serif;
  font-size:11px;
  letter-spacing:1.5px;
  text-transform:uppercase;
  color:#1e2a38;
  font-weight:500;
}
.tsukie-variant-value{
  font-family:'Montserrat',sans-serif;
  font-size:11px;
  color:#666;
  font-weight:400;
}
.tsukie-color-swatches{
  display:flex;
  gap:10px;
  flex-wrap:wrap;
}
.tsukie-color-swatch{
  width:36px;
  height:36px;
  border-radius:50%;
  border:2px solid transparent;
  cursor:pointer;
  transition:all 0.2s;
}
.tsukie-color-swatch.active{
  border-color:#1e2a38;
  box-shadow:0 0 0 2px #f5f1ea, 0 0 0 4px #1e2a38;
}
.tsukie-size-options{
  display:flex;
  gap:6px;
  flex-wrap:wrap;
}
.tsukie-size-btn{
  background:#fff;
  border:1px solid rgba(30,42,56,0.15);
  padding:8px 16px;
  font-family:'Montserrat',sans-serif;
  font-size:11px;
  font-weight:500;
  color:#1e2a38;
  cursor:pointer;
  transition:all 0.2s;
  min-width:44px;
}
.tsukie-size-btn:hover{
  border-color:#1e2a38;
}
.tsukie-size-btn.active{
  background:#1e2a38;
  color:#d4c5a9;
  border-color:#1e2a38;
}
.tsukie-size-btn.disabled{
  opacity:0.3;
  cursor:not-allowed;
  text-decoration:line-through;
}
.tsukie-size-guide{
  margin-top:12px;
  display:flex;
  align-items:center;
  gap:6px;
  font-family:'Montserrat',sans-serif;
  font-size:11px;
  color:#666;
}
.tsukie-size-guide a{
  color:#1e2a38;
  text-decoration:underline;
}
.tsukie-inventory{
  margin-top:12px;
  font-family:'Montserrat',sans-serif;
  font-size:11px;
  color:#a08766;
  display:flex;
  align-items:center;
  gap:6px;
}
.tsukie-inventory::before{
  content:'';
  width:6px;
  height:6px;
  background:#a08766;
  border-radius:50%;
}

/* Buttons */
.tsukie-product-form{
  margin:32px 0;
}
.tsukie-btn-group{
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:12px;
  margin-bottom:24px;
}
.tsukie-btn{
  padding:16px;
  font-family:'Montserrat',sans-serif;
  font-size:11px;
  letter-spacing:2px;
  text-transform:uppercase;
  font-weight:600;
  cursor:pointer;
  border:none;
  transition:all 0.2s;
  display:flex;
  align-items:center;
  justify-content:center;
  gap:8px;
}
.tsukie-btn:disabled{
  opacity:0.5;
  cursor:not-allowed;
}
.tsukie-btn-add{
  background:#1e2a38;
  color:#d4c5a9;
}
.tsukie-btn-add:hover:not(:disabled){
  background:#2a3a4e;
}
.tsukie-btn-buy{
  background:#5a4a3a;
  color:#d4c5a9;
  position: relative;
}
.tsukie-btn-buy:hover:not(:disabled){
  background:#6a5a4a;
}
.tsukie-btn svg{width:16px;height:16px}

/* Features Horizontal Row */
.tsukie-features{
  display:grid;
  grid-template-columns:repeat(3,1fr);
  gap:0;
  border:1px solid rgba(30,42,56,0.08);
  margin-bottom:24px;
  background: transparent;
}
.tsukie-feature{
  padding:20px 12px;
  text-align:center;
  border-right:1px solid rgba(30,42,56,0.08);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
}
.tsukie-feature:last-child{border-right:none}
.tsukie-feature svg{
  width:20px;
  height:20px;
  color:#1e2a38;
  margin-bottom:8px;
  flex-shrink: 0;
}
.tsukie-feature-title{
  font-family:'Montserrat',sans-serif;
  font-size:10px;
  letter-spacing:1px;
  text-transform:uppercase;
  color:#1e2a38;
  font-weight:600;
  margin-bottom:4px;
}
.tsukie-feature-text{
  font-family:'Montserrat',sans-serif;
  font-size:11px;
  color:#666;
}

/* Accordions */
.tsukie-accordion{
  border-top:1px solid rgba(30,42,56,0.08);
}
.tsukie-accordion-item{
  border-bottom:1px solid rgba(30,42,56,0.08);
}
.tsukie-accordion-header{
  padding:20px 0;
  display:flex;
  justify-content:space-between;
  align-items:center;
  cursor:pointer;
  font-family:'Montserrat',sans-serif;
  font-size:11px;
  letter-spacing:2px;
  text-transform:uppercase;
  color:#1e2a38;
  font-weight:500;
}
.tsukie-accordion-icon{
  font-size:18px;
  transition:transform 0.3s;
  display: inline-block;
  line-height: 1;
}
.tsukie-accordion-item.active .tsukie-accordion-icon{
  transform:rotate(45deg);
}
.tsukie-accordion-content{
  max-height:0;
  overflow:hidden;
  transition:all 0.3s ease-out;
  font-family:'Montserrat',sans-serif;
  font-size:13px;
  line-height:1.8;
  color:#666;
}
.tsukie-accordion-item.active .tsukie-accordion-content{
  max-height:600px;
  padding-bottom:20px;
}

/* Mobile Adjustments */
@media(max-width:989px){
  .tsukie-product-container{
    grid-template-columns:1fr;
    gap:24px;
    padding:0 20px;
  }
  .tsukie-pdp-media{
    position:relative;
    top:0;
    flex-direction:column;
  }
  .tsukie-thumbnails-wrapper{
    display:none;
  }
  .tsukie-pdp-title{
    font-size:28px;
  }
  .tsukie-price{
    font-size:24px;
  }
  .tsukie-btn-group{
    grid-template-columns:1fr;
  }
  /* STRICT Horizontal Lock on Mobile */
  .tsukie-features{
    grid-template-columns:repeat(3,1fr) !important;
  }
  .tsukie-feature{
    padding:16px 4px;
    border-right:1px solid rgba(30,42,56,0.08);
    border-bottom:none;
  }
  .tsukie-feature-title{
    font-size:8px;
    letter-spacing:0.5px;
  }
  .tsukie-feature-text{
    font-size:9px;
  }
}

/* Custom Product Form Buttons Layout */
.tsukie-btn-row-1 {
  display: flex !important;
  align-items: center !important;
  gap: 8px !important;
  margin-bottom: 8px !important;
  width: 100% !important;
}
.tsukie-quantity-selector {
  display: flex !important;
  align-items: center !important;
  width: 35% !important;
  height: 48px !important;
  border: 1px solid rgba(30,42,56,0.15) !important;
  background: #fff !important;
  box-sizing: border-box !important;
}
.tsukie-qty-btn {
  background: none !important;
  border: none !important;
  width: 30% !important;
  height: 100% !important;
  cursor: pointer !important;
  font-family: 'Montserrat', sans-serif !important;
  font-size: 16px !important;
  font-weight: 500 !important;
  color: #1e2a38 !important;
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  padding: 0 !important;
}
.tsukie-qty-btn:hover {
  background: rgba(30,42,56,0.05) !important;
}
.tsukie-qty-input {
  width: 40% !important;
  height: 100% !important;
  border: none !important;
  text-align: center !important;
  font-family: 'Montserrat', sans-serif !important;
  font-size: 14px !important;
  font-weight: 600 !important;
  color: #1e2a38 !important;
  background: transparent !important;
  outline: none !important;
  -moz-appearance: textfield !important;
}
.tsukie-qty-input::-webkit-outer-spin-button,
.tsukie-qty-input::-webkit-inner-spin-button {
  -webkit-appearance: none !important;
  margin: 0 !important;
}
.tsukie-btn-add {
  width: 65% !important;
  margin: 0 !important;
  height: 48px !important;
  box-sizing: border-box !important;
}
.tsukie-btn-row-2 {
  width: 100% !important;
}
.tsukie-btn-buy {
  width: 100% !important;
  background: #1e2a38 !important;
  color: #ffffff !important;
  border: none !important;
  margin: 0 !important;
  height: 48px !important;
  box-sizing: border-box !important;
}
.tsukie-btn-buy:hover:not(:disabled) {
  background: #2a3a4e !important;
}
/* Hide vertical thumbnail navigation arrows */
.tsukie-thumb-nav, .product__media-thumbnails .slider-button {
  display: none !important;
}
/* Fix empty space below main image */
.product__media, .tsukie-main-image, .tsukie-main-image-slider, .tsukie-main-image-slide {
  height: auto !important;
  min-height: 0 !important;
}
.product__media img, .tsukie-main-image img, .tsukie-main-image-slide img {
  object-fit: contain !important;
  height: auto !important;
  padding-bottom: 0 !important;
}

/* Image Slider Base Styles */
.tsukie-main-image-slider {
  display: flex !important;
  overflow: hidden !important;
  scroll-behavior: smooth !important;
  scrollbar-width: none !important;
  width: 100% !important;
}
.tsukie-main-image-slider::-webkit-scrollbar {
  display: none !important;
}
.tsukie-main-image-slide {
  flex: 0 0 100% !important;
  width: 100% !important;
}
.tsukie-main-image-slide img {
  width: 100% !important;
  height: auto !important;
  display: block !important;
}
.tsukie-carousel-dots {
  display: none !important;
}

/* Mobile-only overrides (max-width: 749px) */
@media (max-width: 749px) {
  .tsukie-product-container {
    padding: 0 !important;
  }
  .tsukie-pdp-media {
    padding: 0 !important;
    margin: 0 !important;
    width: 100% !important;
  }
  .tsukie-pdp-info {
    padding: 0 20px !important;
  }
  .tsukie-main-image-wrap {
    width: 100vw !important;
    max-width: 100vw !important;
    overflow: hidden !important;
    margin: 0 !important;
    padding: 0 !important;
  }
  .tsukie-main-image-slider {
    display: flex !important;
    overflow-x: auto !important;
    scroll-snap-type: x mandatory !important;
    -webkit-overflow-scrolling: touch !important;
    width: 100vw !important;
    margin: 0 !important;
    padding: 0 !important;
  }
  .tsukie-main-image-slide {
    flex: 0 0 100vw !important;
    width: 100vw !important;
    scroll-snap-align: start !important;
  }
  .tsukie-carousel-nav {
    display: none !important;
  }
  .tsukie-thumbnails-wrapper {
    display: none !important;
  }
  .tsukie-carousel-dots {
    display: flex !important;
    justify-content: center !important;
    gap: 8px !important;
    margin-top: 16px !important;
    margin-bottom: 8px !important;
    width: 100% !important;
  }
  .tsukie-dot {
    width: 8px !important;
    height: 8px !important;
    border-radius: 50% !important;
    background-color: #D9D9D9 !important;
    cursor: pointer !important;
    transition: background-color 0.2s !important;
  }
  .tsukie-dot.active {
    background-color: #1E2A38 !important;
  }
}

/* Size Guide Modal Styles */
.tsukie-size-guide-modal {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  z-index: 10000;
  display: none;
  align-items: center;
  justify-content: center;
}
.tsukie-size-guide-modal-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(30, 42, 56, 0.6);
  backdrop-filter: blur(4px);
}
.tsukie-size-guide-modal-content {
  position: relative;
  background: #fdfbf7;
  border: 2px solid #d4c5a9;
  border-radius: 8px;
  width: 90%;
  max-width: 500px;
  padding: 30px;
  box-shadow: 0 10px 30px rgba(0,0,0,0.15);
  z-index: 10001;
}
.tsukie-size-guide-modal-close {
  position: absolute;
  top: 15px;
  right: 15px;
  background: none;
  border: none;
  font-size: 24px;
  cursor: pointer;
  color: #1e2a38;
  line-height: 1;
  padding: 0;
  transition: color 0.2s;
}
.tsukie-size-guide-modal-close:hover {
  color: #a08766;
}
.tsukie-size-guide-modal-title {
  font-family: 'Playfair Display', serif;
  font-size: 24px;
  font-style: italic;
  font-weight: 600;
  color: #1e2a38;
  margin: 0 0 20px;
  text-align: center;
}
.tsukie-size-guide-table-wrap {
  overflow-x: auto;
}
.tsukie-size-guide-table-wrap table {
  width: 100%;
  border-collapse: collapse;
  font-family: 'Montserrat', sans-serif;
  font-size: 13px;
}
.tsukie-size-guide-table-wrap th, 
.tsukie-size-guide-table-wrap td {
  padding: 12px;
  border: 1px solid #e0d9cd;
  text-align: center;
}
.tsukie-size-guide-table-wrap th {
  background: #1e2a38;
  color: #d4c5a9;
  font-weight: 600;
  text-transform: uppercase;
  font-size: 11px;
  letter-spacing: 1px;
}
.tsukie-size-guide-table-wrap tr:nth-child(even) {
  background: rgba(212, 197, 169, 0.1);
}

/* Special Offers Section Styling (Vertical Stack) */
.tsukie-special-offers-vertical {
  background: #fdfbf7;
  border: 1px solid #e0d9cd;
  border-radius: 4px;
  padding: 16px;
  margin-bottom: 20px;
  font-family: 'Montserrat', sans-serif;
}
.tsukie-offers-title-vertical {
  font-size: 11px;
  font-weight: 700;
  color: #1e2a38;
  text-transform: uppercase;
  letter-spacing: 1px;
  display: flex;
  align-items: center;
  gap: 6px;
  margin-bottom: 12px;
  border-bottom: 1px solid rgba(30,42,56,0.08);
  padding-bottom: 8px;
}
.tsukie-offers-title-vertical svg {
  width: 14px;
  height: 14px;
  color: #a08766;
}
.tsukie-offers-list-vertical {
  display: flex;
  flex-direction: column;
}
.tsukie-offer-row-vertical {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 10px 0;
  border-bottom: 1px solid rgba(30,42,56,0.08);
  gap: 12px;
}
.tsukie-offer-row-vertical:last-child {
  border-bottom: none;
  padding-bottom: 0;
}
.tsukie-offer-text {
  font-size: 12px;
  color: #4a4a4a;
  font-weight: 500;
  text-align: left;
}
.tsukie-offer-coupon-btn {
  background: #f5f1ea;
  border: 1px dashed #d4c5a9;
  border-radius: 3px;
  padding: 6px 10px;
  display: inline-flex;
  align-items: center;
  gap: 8px;
  cursor: pointer;
  transition: all 0.2s ease;
  font-family: 'Montserrat', sans-serif;
  flex-shrink: 0;
}
.tsukie-offer-coupon-btn:hover {
  border-color: #1e2a38;
  background: #e0d9cd;
}
.tsukie-offer-coupon-btn .coupon-code {
  font-size: 11px;
  font-weight: 700;
  color: #1e2a38;
}
.tsukie-offer-coupon-btn .copy-lbl {
  font-size: 9px;
  text-transform: uppercase;
  font-weight: 600;
  color: #a08766;
  border-left: 1px solid rgba(30,42,56,0.15);
  padding-left: 8px;
}
</style>

<section class="tsukie-product" data-section-id="{{ section.id }}" data-section-type="product">
  <div class="tsukie-product-container">
    <!-- Left Layout -->
    <div class="tsukie-pdp-media">
      {%- assign color_option_index = nil -%}
      {%- for option in product.options_with_values -%}
        {%- assign option_name_downcase = option.name | downcase -%}
        {%- if option_name_downcase == 'color' or option_name_downcase == 'colour' -%}
          {%- assign color_option_index = forloop.index -%}
        {%- endif -%}
      {%- endfor -%}
      
      {%- assign first_variant = product.variants.first -%}
      {%- assign first_variant_color = "" -%}
      {%- if color_option_index != nil and first_variant != nil -%}
        {%- if color_option_index == 1 -%}
          {%- assign first_variant_color = first_variant.option1 -%}
        {%- elsif color_option_index == 2 -%}
          {%- assign first_variant_color = first_variant.option2 -%}
        {%- elsif color_option_index == 3 -%}
          {%- assign first_variant_color = first_variant.option3 -%}
        {%- endif -%}
      {%- endif -%}

      {%- comment -%} Precompute image colors mapping to prevent scoping/nested loop issues {%- endcomment -%}
      {%- assign image_colors_string = "" -%}
      {%- assign current_color = first_variant_color -%}
      {%- for img in product.images -%}
        {%- assign img_colors = "" -%}
        {%- comment -%} 1. Check if image alt text contains any of the color values {%- endcomment -%}
        {%- for option in product.options_with_values -%}
          {%- assign option_name_downcase = option.name | downcase -%}
          {%- if option_name_downcase == 'color' or option_name_downcase == 'colour' -%}
            {%- for color_val in option.values -%}
              {%- assign color_val_down = color_val | downcase | strip -%}
              {%- assign image_alt_down = img.alt | downcase | strip -%}
              {%- if image_alt_down == color_val_down or image_alt_down contains color_val_down -%}
                {%- assign img_colors = img_colors | append: ";" | append: color_val -%}
              {%- endif -%}
            {%- endfor -%}
          {%- endif -%}
        {%- endfor -%}
        
        {%- comment -%} 2. Check if this image is the featured image of any variant {%- endcomment -%}
        {%- assign featured_var_color = "" -%}
        {%- for variant in product.variants -%}
          {%- assign var_img_id = nil -%}
          {%- if variant.featured_image -%}
            {%- assign var_img_id = variant.featured_image.id -%}
          {%- elsif variant.featured_media -%}
            {%- assign var_img_id = variant.featured_media.id -%}
          {%- elsif variant.image -%}
            {%- assign var_img_id = variant.image.id -%}
          {%- endif -%}
          {%- if var_img_id == img.id -%}
            {%- if color_option_index == 1 -%}
              {%- assign featured_var_color = variant.option1 -%}
            {%- elsif color_option_index == 2 -%}
              {%- assign featured_var_color = variant.option2 -%}
            {%- elsif color_option_index == 3 -%}
              {%- assign featured_var_color = variant.option3 -%}
            {%- endif -%}
            {%- if featured_var_color != blank -%}
              {%- break -%}
            {%- endif -%}
          {%- endif -%}
        {%- endfor -%}
        
        {%- if featured_var_color != blank -%}
          {%- assign current_color = featured_var_color -%}
          {%- assign img_colors = img_colors | append: ";" | append: featured_var_color -%}
        {%- endif -%}
        
        {%- comment -%} 3. Fallback to active sequence color if no specific matches found {%- endcomment -%}
        {%- if img_colors == blank and current_color != blank -%}
          {%- assign img_colors = img_colors | append: ";" | append: current_color -%}
        {%- endif -%}
        
        {%- comment -%} Convert option values to clean format like |black|gold| {%- endcomment -%}
        {%- assign raw_colors = img_colors | split: ";" | uniq -%}
        {%- assign clean_colors_formatted = "" -%}
        {%- for rc in raw_colors -%}
          {%- if rc != blank -%}
            {%- assign clean_colors_formatted = clean_colors_formatted | append: "|" | append: rc | append: "|" -%}
          {%- endif -%}
        {%- endfor -%}
        {%- if clean_colors_formatted == blank -%}
          {%- assign clean_colors_formatted = "unknown" -%}
        {%- endif -%}
        
        {%- assign image_colors_string = image_colors_string | append: clean_colors_formatted | append: "::" -%}
      {%- endfor -%}
      {%- assign image_colors_array = image_colors_string | split: "::" -%}

      <div class="tsukie-thumbnails-wrapper">
        {% if product.images.size > 6 %}
          <button class="tsukie-thumb-nav" type="button" onclick="tsukieScrollThumbs('up', this)">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7"></path></svg>
          </button>
        {% endif %}
        
        <div class="tsukie-thumbnails" id="tsukie-thumbs-list">
          {% for image in product.images %}
            {%- assign image_colors_clean = image_colors_array[forloop.index0] -%}
            <div class="tsukie-thumb {% if forloop.first %}active{% endif %}" onclick="tsukieChangeImage('{{ image | img_url: '1000x' }}', {{ forloop.index0 }}, this)" data-colors="{{ image_colors_clean | downcase | escape }}">
              <img src="{{ image | img_url: '200x' }}" alt="{{ product.title | escape }}" loading="lazy">
            </div>
          {% endfor %}
        </div>

        {% if product.images.size > 6 %}
          <button class="tsukie-thumb-nav" type="button" onclick="tsukieScrollThumbs('down', this)">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
          </button>
        {% endif %}
      </div>

      <div class="tsukie-main-image-wrap">
        <div class="tsukie-main-image">
          {%- assign pdp_badge_text = product.metafields.custom.badge.value | default: product.metafields.custom.badge -%}
          {%- if pdp_badge_text != blank -%}
            <div class="tsukie-badge">{{ pdp_badge_text }}</div>
          {%- endif -%}
          
          <div class="tsukie-main-image-slider" onscroll="tsukieOnSliderScroll(this)">
            {% for image in product.images %}
              {%- assign image_colors_clean = image_colors_array[forloop.index0] -%}
              <div class="tsukie-main-image-slide" data-index="{{ forloop.index0 }}" data-colors="{{ image_colors_clean | downcase | escape }}">
                <img src="{{ image | img_url: '1000x' }}" alt="{{ product.title | escape }}" loading="lazy">
              </div>
            {% endfor %}
          </div>
          
          <button class="tsukie-carousel-nav prev" type="button" onclick="tsukiePrevImage(this)">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 19l-7-7 7-7"></path></svg>
          </button>
          <button class="tsukie-carousel-nav next" type="button" onclick="tsukieNextImage(this)">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5l7 7-7 7"></path></svg>
          </button>
        </div>
        
        <div class="tsukie-carousel-dots">
          {% for image in product.images %}
            {%- assign image_colors_clean = image_colors_array[forloop.index0] -%}
            <span class="tsukie-dot {% if forloop.first %}active{% endif %}" onclick="tsukieScrollToImage(this, {{ forloop.index0 }})" data-colors="{{ image_colors_clean | downcase | escape }}"></span>
          {% endfor %}
        </div>
      </div>
    </div>

    <!-- Right Layout -->
    <div class="tsukie-pdp-info">
      <h1 class="tsukie-pdp-title">{{ product.title }}</h1>

      {% if product.metafields.custom.subtitle %}
        <p class="tsukie-product-subtitle">{{ product.metafields.custom.subtitle }}</p>
      {% endif %}

      {% if product.metafields.reviews.rating.value != blank and product.metafields.reviews.rating_count != blank and product.metafields.reviews.rating_count > 0 %}
        {% assign pdp_rating = product.metafields.reviews.rating.value %}
        {% assign pdp_reviews_count = product.metafields.reviews.rating_count %}
      {% else %}
        {% assign pdp_rating = section.settings.default_rating | default: '4.5' %}
        {% assign pdp_reviews_count = section.settings.default_review_count | default: 12 %}
      {% endif %}
      <div class="tsukie-rating-row">
        <div class="tsukie-stars">
          {% for i in (1..5) %}
            <svg viewBox="0 0 20 20"><path d="M10 15l-5.878 3.09 1.123-6.545L.489 6.91l6.572-.955L10 0l2.939 5.955 6.572.955-4.756 4.635 1.123 6.545z"/></svg>
          {% endfor %}
        </div>
        <div class="tsukie-rating-text">{{ pdp_rating }} <span>{{ pdp_reviews_count }} reviews</span></div>
        <div class="tsukie-verified">VERIFIED PURCHASE</div>
      </div>

      <div class="tsukie-price-row" id="tsukie-price-wrapper">
        <div class="tsukie-price" id="tsukie-price">{{ product.selected_or_first_available_variant.price | money }}</div>
        <div class="tsukie-price-compare" id="tsukie-compare-price" style="{% unless product.selected_or_first_available_variant.compare_at_price > product.selected_or_first_available_variant.price %}display:none;{% endunless %}">
          {{ product.selected_or_first_available_variant.compare_at_price | money }}
        </div>
        <div class="tsukie-price-save" id="tsukie-save-badge" style="{% unless product.selected_or_first_available_variant.compare_at_price > product.selected_or_first_available_variant.price %}display:none;{% endunless %}">
          {% if product.selected_or_first_available_variant.compare_at_price > product.selected_or_first_available_variant.price %}
            SAVE {{ product.selected_or_first_available_variant.compare_at_price | minus: product.selected_or_first_available_variant.price | times: 100 | divided_by: product.selected_or_first_available_variant.compare_at_price }}%
          {% endif %}
        </div>
      </div>
      
      <!-- 1. PNG Trust Badges Section -->
      <style>
        .tsukie-pdp-badges {
          display: flex;
          flex-wrap: wrap;
          justify-content: flex-start;
          gap: 12px;
          margin-top: 14px;
          margin-bottom: 24px;
          width: 100%;
        }
        .tsukie-pdp-badge {
          display: inline-flex;
          align-items: center;
          justify-content: center;
          background-color: transparent;
          padding: 0px;
          border-radius: 6px;
          flex: 0 0 auto !important;
          width: fit-content;
          max-width: 100%;
        }
        .tsukie-pdp-badge img {
          height: 18px !important;
          width: auto !important;
          object-fit: contain;
          flex-shrink: 0;
          image-rendering: -webkit-optimize-contrast;
        }
      </style>
      <div class="tsukie-pdp-badges">
        <div class="tsukie-pdp-badge">
          <img src="//tsukie.in/cdn/shop/files/1-01.png?v=1776420000&width=200" alt="Free Shipping" width="100" height="23" loading="lazy">
        </div>
        <div class="tsukie-pdp-badge">
          <img src="//tsukie.in/cdn/shop/files/1-03.png?v=1776420000&width=200" alt="7 Days Return" width="100" height="23" loading="lazy">
        </div>
        <div class="tsukie-pdp-badge">
          <img src="//tsukie.in/cdn/shop/files/1-02.png?v=1776419999&width=200" alt="Secure Payment" width="100" height="23" loading="lazy">
        </div>
      </div>

      {% form 'product', product, class: 'tsukie-product-form', id: 'tsukie-product-form' %}
        <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}" id="tsukie-variant-id">
        
        {% unless product.has_only_default_variant %}
          {% for option in product.options_with_values %}
            {% assign option_index = forloop.index %}
            <div class="tsukie-variant-section">
              <div class="tsukie-variant-header">
                <div style="display:flex; align-items:center; gap:8px;">
                  <div class="tsukie-variant-label">{{ option.name }}</div>
                  {% assign opt_name_down = option.name | downcase %}
                  {% if opt_name_down == 'size' or opt_name_down == 'size/fits' or opt_name_down == 'fit' %}
                    {% if section.settings.show_size_guide %}
                      <span style="color:#d4c5a9;">|</span>
                      <a href="#" onclick="tsukieOpenSizeGuide(event, this)" class="tsukie-size-guide-link" style="color:#a08766; text-decoration:underline; font-size:11px; font-family:'Montserrat',sans-serif; text-transform:uppercase; font-weight:600; letter-spacing:1px;">Size Guide</a>
                    {% endif %}
                  {% endif %}
                </div>
                <div class="tsukie-variant-value" id="tsukie-selected-{{ option.name | handleize }}">{{ option.selected_value }}</div>
              </div>
              
              {% assign opt_name_down = option.name | downcase %}
              {% if opt_name_down == 'color' or opt_name_down == 'colour' %}
                <div class="tsukie-color-swatches">
                  {% for value in option.values %}
                    <div 
                      class="tsukie-color-swatch {% if option.selected_value == value %}active{% endif %}" 
                      style="background-color: {{ value | handleize }};"
                      data-option-position="{{ option_index }}"
                      onclick='tsukieSelectOption(this, {{ option_index }}, {{ value | json }})'
                    ></div>
                  {% endfor %}
                </div>
              {% else %}
                <div class="tsukie-size-options">
                  {% for value in option.values %}
                    <button 
                      type="button"
                      class="tsukie-size-btn {% if option.selected_value == value %}active{% endif %}"
                      data-option-position="{{ option_index }}"
                      onclick='tsukieSelectOption(this, {{ option_index }}, {{ value | json }})'
                    >{{ value }}</button>
                  {% endfor %}
                </div>
              {% endif %}
            </div>
          {% endfor %}
        {% endunless %}

        <div class="tsukie-inventory" id="tsukie-inventory" {% if product.selected_or_first_available_variant.inventory_management and product.selected_or_first_available_variant.inventory_quantity < 10 and product.selected_or_first_available_variant.inventory_quantity > 0 %}{% else %}style="display:none"{% endif %}>
          Only <span id="tsukie-nav-qty">{{ product.selected_or_first_available_variant.inventory_quantity }}</span> left in stock
        </div>

        {% if section.settings.show_trust_badge_1 %}
          <div class="tsukie-cod-badge" style="font-size: 13px; margin-top: 12px; margin-bottom: 16px; display: flex; align-items: center; gap: 6px; font-family: 'Montserrat', sans-serif; color: #1e2a38; font-weight: 500;">
            <svg class="tsukie-tick-icon" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" style="width: 16px; height: 16px; color: #1e2a38; flex-shrink: 0;"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>
            <span>{{ section.settings.trust_badge_text_1 | default: 'COD Available' }}</span>
          </div>
        {% endif %}

        {% assign offer1_code = section.settings.offer_1_code | default: 'TSUKIE10' %}
        {% assign offer1_text = section.settings.offer_1_text | default: 'Buy 1 get 10% off' %}
        {% assign offer2_code = section.settings.offer_2_code | default: 'TSUKIE25' %}
        {% assign offer2_text = section.settings.offer_2_text | default: 'Buy 2 get 25% off' %}
        {% if section.settings.show_special_offers %}
        <div class="tsukie-special-offers-vertical">
          <div class="tsukie-offers-title-vertical">
            <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9.568 3H5.25A2.25 2.25 0 003 5.25v4.318c0 .597.237 1.17.659 1.591l9.581 9.581a1.125 1.125 0 001.59 0l4.318-4.318a1.125 1.125 0 000-1.59l-9.58-9.581a1.125 1.125 0 00-1.591-.659zm5.432 4.5a1.125 1.125 0 11-2.25 0 1.125 1.125 0 012.25 0z" /></svg>
            <span>SPECIAL OFFERS</span>
          </div>
          <div class="tsukie-offers-list-vertical">
            {% if section.settings.show_offer_1 %}
              <div class="tsukie-offer-row-vertical">
                <span class="tsukie-offer-text">{{ offer1_text }}</span>
                <button type="button" class="tsukie-offer-coupon-btn" onclick="tsukieCopyCode(this, '{{ offer1_code }}')" title="Click to copy {{ offer1_code }}">
                  <span class="coupon-code">{{ offer1_code }}</span>
                  <span class="copy-lbl">COPY</span>
                </button>
              </div>
            {% endif %}
            {% if section.settings.show_offer_2 %}
              <div class="tsukie-offer-row-vertical">
                <span class="tsukie-offer-text">{{ offer2_text }}</span>
                <button type="button" class="tsukie-offer-coupon-btn" onclick="tsukieCopyCode(this, '{{ offer2_code }}')" title="Click to copy {{ offer2_code }}">
                  <span class="coupon-code">{{ offer2_code }}</span>
                  <span class="copy-lbl">COPY</span>
                </button>
              </div>
            {% endif %}
          </div>
        </div>
        {% endif %}

        <div class="tsukie-btn-row-1">
          <div class="tsukie-quantity-selector">
            <button type="button" class="tsukie-qty-btn minus" onclick="tsukieUpdateQty(this, -1)">-</button>
            <input type="number" name="quantity" value="1" min="1" class="tsukie-qty-input" readonly>
            <button type="button" class="tsukie-qty-btn plus" onclick="tsukieUpdateQty(this, 1)">+</button>
          </div>
          
          <button type="submit" name="add" id="tsukie-add-to-cart-btn" class="tsukie-btn ss-add-to-cart tsukie-btn-add" {% unless product.selected_or_first_available_variant.available %}disabled{% endunless %}>
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path></svg>
            <span id="tsukie-add-btn-text">{% if product.selected_or_first_available_variant.available %}ADD TO BAG{% else %}SOLD OUT{% endif %}</span>
          </button>
        </div>
        
        <div class="tsukie-btn-row-2">
          <!-- Pure Clean Isolated Dynamic Buy Button -->
          <button type="button" id="tsukie-buy-now-btn" class="tsukie-btn tsukie-btn-buy" onclick="tsukieBuyNowClean(this)" {% unless product.selected_or_first_available_variant.available %}disabled{% endunless %}>
            <span id="tsukie-buy-text">BUY NOW</span>
          </button>
        </div>
      {% endform %}
