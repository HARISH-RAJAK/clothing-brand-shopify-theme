<script>
// Save product to Recently Viewed in localStorage
(function() {
  var currentId = '{{ product.id }}';
  var currentHandle = '{{ product.handle }}';
  if (currentId && currentHandle) {
    try {
      // 1. Update recentlyViewedProducts (array of handles)
      var recentlyViewed = [];
      try {
        var raw = localStorage.getItem('recentlyViewedProducts');
        if (raw) {
          recentlyViewed = JSON.parse(raw);
        }
      } catch(e) {
        recentlyViewed = [];
      }
      if (!Array.isArray(recentlyViewed)) {
        recentlyViewed = [];
      }

      recentlyViewed = recentlyViewed.filter(function(x) {
        var h = (typeof x === 'object' && x !== null) ? x.handle : x;
        return h && h !== currentHandle;
      });
      recentlyViewed.unshift(currentHandle);
      if (recentlyViewed.length > 10) recentlyViewed = recentlyViewed.slice(0, 10);
      localStorage.setItem('recentlyViewedProducts', JSON.stringify(recentlyViewed));

      // 2. Update viewedProducts (backward compatibility)
      var viewed = [];
      try {
        var rawViewed = localStorage.getItem('viewedProducts');
        if (rawViewed) {
          viewed = JSON.parse(rawViewed);
        }
      } catch(e) {
        viewed = [];
      }
      if (!Array.isArray(viewed)) {
        viewed = [];
      }

      viewed = viewed.filter(function(x) {
        var h = (typeof x === 'object' && x !== null) ? x.handle : x;
        if (h === currentHandle) return false;
        if (typeof x === 'string' && x === currentId) return false;
        return true;
      });
      viewed.unshift({ id: currentId, handle: currentHandle });
      if (viewed.length > 10) viewed = viewed.slice(0, 10);
      localStorage.setItem('viewedProducts', JSON.stringify(viewed));
    } catch(e) { /* silent */ }
  }
})();

function tsukieGetContext(el) {
  let container = null;
  if (el && typeof el.closest === 'function') {
    container = el.closest('.tsukie-product');
  }
  if (!container) {
    container = document.querySelector('#tsukie-quick-add-modal.is-open .tsukie-product');
  }
  if (!container) {
    container = document.querySelector('.tsukie-product') || document.body;
  }
  
  if (container && !container.tsukieProduct) {
    container.tsukieCurrentImage = 0;
    container.tsukieImages = [{% for image in product.images %}'{{ image | img_url: '1000x' }}'{% unless forloop.last %},{% endunless %}{% endfor %}];
    container.tsukieImageIds = [{% for image in product.images %}{{ image.id }}{% unless forloop.last %},{% endunless %}{% endfor %}];
    container.tsukieProduct = {{ product | json }};
    container.tsukieSelectedOptions = { 1: null, 2: null, 3: null };
    
    const defaultVariantId = {{ product.selected_or_first_available_variant.id | default: 'null' }};
    if (defaultVariantId && container.tsukieProduct) {
      const defaultVar = container.tsukieProduct.variants.find(v => v.id === defaultVariantId);
      if (defaultVar) {
        container.tsukieSelectedOptions[1] = defaultVar.option1;
        container.tsukieSelectedOptions[2] = defaultVar.option2;
        container.tsukieSelectedOptions[3] = defaultVar.option3;
      }
    }
  }
  return container;
}

// Initial kickoff block to pre-populate main page container
(function() {
  const container = document.querySelector('.tsukie-product') || document.body;
  if (container) {
    const ctx = tsukieGetContext(container);
    if (ctx && ctx.tsukieProduct) {
      const colorOptIdx = ctx.tsukieProduct.options.findIndex(opt => opt.toLowerCase() === 'color' || opt.toLowerCase() === 'colour');
      if (colorOptIdx > -1) {
        const selectedColor = ctx.tsukieSelectedOptions[colorOptIdx + 1];
        if (selectedColor) {
          setTimeout(() => {
            if (typeof window.tsukieFilterImagesByColor === 'function') {
              window.tsukieFilterImagesByColor(selectedColor);
            }
          }, 100);
        }
      }
    }
  }
})();

// Touch Swipe Support for Mobile Gallery
(function() {
  function initTouchSwipe() {
    document.querySelectorAll('.tsukie-main-image').forEach(function(mainImg) {
      if (mainImg.dataset.swipeInitialized) return;
      mainImg.dataset.swipeInitialized = 'true';

      var touchStartX = 0;
      var touchStartY = 0;
      var isDragging = false;

      mainImg.addEventListener('touchstart', function(e) {
        touchStartX = e.touches[0].clientX;
        touchStartY = e.touches[0].clientY;
        isDragging = false;
      }, { passive: true });

      mainImg.addEventListener('touchmove', function(e) {
        if (!isDragging) {
          var dx = Math.abs(e.touches[0].clientX - touchStartX);
          var dy = Math.abs(e.touches[0].clientY - touchStartY);
          if (dx > dy && dx > 8) {
            isDragging = true;
          }
        }
      }, { passive: true });

      mainImg.addEventListener('touchend', function(e) {
        if (!isDragging) return;
        var deltaX = e.changedTouches[0].clientX - touchStartX;
        if (Math.abs(deltaX) < 40) return;
        if (deltaX < 0) {
          window.tsukieNextImage(mainImg);
        } else {
          window.tsukiePrevImage(mainImg);
        }
        isDragging = false;
      }, { passive: true });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initTouchSwipe);
  } else {
    initTouchSwipe();
  }
})();

// Size Guide Modal JS
window.tsukieOpenSizeGuide = function(e, element) {
  if (e) e.preventDefault();
  const container = tsukieGetContext(element || (e && e.target));
  const modal = container.querySelector('#tsukie-size-guide-modal, .tsukie-size-guide-modal');
  if (modal) modal.style.display = 'flex';
};

window.tsukieCloseSizeGuide = function(element) {
  const container = tsukieGetContext(element);
  const modal = container.querySelector('#tsukie-size-guide-modal, .tsukie-size-guide-modal');
  if (modal) modal.style.display = 'none';
};

window.tsukieCopyCode = function(el, code) {
  navigator.clipboard.writeText(code).then(() => {
    const copyLbl = el.querySelector('.copy-lbl');
    if (copyLbl) {
      const origText = copyLbl.textContent;
      copyLbl.textContent = 'COPIED!';
      copyLbl.style.color = '#1e2a38';
      setTimeout(() => {
        copyLbl.textContent = origText;
        copyLbl.style.color = '#a08766';
      }, 1500);
    }
  });
};
window.tsukieFilterImagesByColor = function(colorValue) {
  const container = document.querySelector('.tsukie-product') || document.body;
  if (!container) return;
  
  const enableFilter = {% if section.settings.enable_color_filter %}true{% else %}false{% endif %};
  if (!enableFilter) return;

  const cleanColor = colorValue ? colorValue.toLowerCase().trim() : '';
  if (!cleanColor) return;

  const thumbs = container.querySelectorAll('.tsukie-thumb');
  const slides = container.querySelectorAll('.tsukie-main-image-slide');
  const dots = container.querySelectorAll('.tsukie-dot');

  let firstVisibleIndex = -1;
  let visibleCount = 0;

  function matchesColor(el) {
    const colorsAttr = el.getAttribute('data-colors');
    if (!colorsAttr) return false;
    return colorsAttr.includes('|' + cleanColor + '|');
  }

  thumbs.forEach((thumb, index) => {
    if (matchesColor(thumb)) {
      thumb.style.display = 'block';
      thumb.setAttribute('data-visible-index', visibleCount);
      if (firstVisibleIndex === -1) firstVisibleIndex = index;
      visibleCount++;
    } else {
      thumb.style.display = 'none';
      thumb.removeAttribute('data-visible-index');
    }
  });

  let slideVisibleCount = 0;
  slides.forEach((slide, index) => {
    if (matchesColor(slide)) {
      slide.style.display = 'block';
      slide.setAttribute('data-visible-index', slideVisibleCount);
      slideVisibleCount++;
    } else {
      slide.style.display = 'none';
      slide.removeAttribute('data-visible-index');
    }
  });

  let dotVisibleCount = 0;
  dots.forEach((dot, index) => {
    if (matchesColor(dot)) {
      dot.style.display = 'block';
      dot.setAttribute('data-visible-index', dotVisibleCount);
      dotVisibleCount++;
    } else {
      dot.style.display = 'none';
      dot.removeAttribute('data-visible-index');
    }
  });

  const activeThumb = container.querySelector('.tsukie-thumb.active');
  if (!activeThumb || activeThumb.style.display === 'none') {
    if (firstVisibleIndex > -1) {
      const targetThumb = thumbs[firstVisibleIndex];
      const targetSlide = slides[firstVisibleIndex];
      const targetImg = targetSlide ? targetSlide.querySelector('img') : null;
      const src = targetImg ? targetImg.src : '';
      window.tsukieChangeImage(src, firstVisibleIndex, container);
    }
  } else {
    const activeIndex = Array.from(thumbs).indexOf(activeThumb);
    window.tsukieChangeImage('', activeIndex, container);
  }
};

window.tsukieChangeImage = function(src, index, element) {
  const container = tsukieGetContext(element);
  if (!container) return;
  const slider = container.querySelector('.tsukie-main-image-slider');
  const slides = container.querySelectorAll('.tsukie-main-image-slide');
  if (slider && slides[index]) {
    const slideEl = slides[index];
    slider.scrollTo({
      left: slideEl.offsetLeft,
      behavior: 'smooth'
    });
  } else {
    const mainImg = container.querySelector('#tsukie-main-img');
    if(mainImg) mainImg.src = src;
  }
  container.tsukieCurrentImage = index;
  container.querySelectorAll('.tsukie-thumb').forEach((thumb, i) => {
    thumb.classList.toggle('active', i === index);
  });
  container.querySelectorAll('.tsukie-dot').forEach((dot, i) => {
    dot.classList.toggle('active', i === index);
  });
};

window.tsukieScrollToImage = function(dotEl, index) {
  const container = tsukieGetContext(dotEl);
  if (!container) return;
  const slider = container.querySelector('.tsukie-main-image-slider');
  const slides = container.querySelectorAll('.tsukie-main-image-slide');
  if (slider && slides[index]) {
    const slideEl = slides[index];
    slider.scrollTo({
      left: slideEl.offsetLeft,
      behavior: 'smooth'
    });
  }
  container.tsukieCurrentImage = index;
  container.querySelectorAll('.tsukie-dot').forEach((dot, i) => {
    dot.classList.toggle('active', i === index);
  });
  container.querySelectorAll('.tsukie-thumb').forEach((thumb, i) => {
    thumb.classList.toggle('active', i === index);
  });
};

window.tsukieOnSliderScroll = function(slider) {
  const container = tsukieGetContext(slider);
  if (!container) return;
  const scrollLeft = slider.scrollLeft;
  const slides = container.querySelectorAll('.tsukie-main-image-slide');
  
  let minDiff = Infinity;
  let index = 0;
  slides.forEach((slide, i) => {
    if (slide.style.display !== 'none') {
      const diff = Math.abs(slide.offsetLeft - scrollLeft);
      if (diff < minDiff) {
        minDiff = diff;
        index = i;
      }
    }
  });
  
  if (container.tsukieCurrentImage !== index) {
    container.tsukieCurrentImage = index;
    
    container.querySelectorAll('.tsukie-dot').forEach((dot, i) => {
      dot.classList.toggle('active', i === index);
    });
    
    container.querySelectorAll('.tsukie-thumb').forEach((thumb, i) => {
      thumb.classList.toggle('active', i === index);
    });
  }
};

window.tsukieScrollThumbs = function(direction, element) {
  const container = tsukieGetContext(element);
  if (!container) return;
  const thumbsList = container.querySelector('#tsukie-thumbs-list');
  if(!thumbsList) return;
  thumbsList.scrollTop += (direction === 'up') ? -88 : 88;
};

window.tsukiePrevImage = function(element) {
  const container = tsukieGetContext(element);
  if (!container || !container.tsukieImages) return;
  const thumbs = container.querySelectorAll('.tsukie-thumb');
  if(!thumbs.length) return;
  
  let curr = container.tsukieCurrentImage;
  let prev = curr;
  do {
    prev = (prev - 1 + thumbs.length) % thumbs.length;
  } while (thumbs[prev] && thumbs[prev].style.display === 'none' && prev !== curr);
  
  if (thumbs[prev] && thumbs[prev].style.display !== 'none') {
    const img = thumbs[prev].querySelector('img');
    window.tsukieChangeImage(img ? img.src : '', prev, container);
  }
};

window.tsukieNextImage = function(element) {
  const container = tsukieGetContext(element);
  if (!container || !container.tsukieImages) return;
  const thumbs = container.querySelectorAll('.tsukie-thumb');
  if(!thumbs.length) return;
  
  let curr = container.tsukieCurrentImage;
  let next = curr;
  do {
    next = (next + 1) % thumbs.length;
  } while (thumbs[next] && thumbs[next].style.display === 'none' && next !== curr);
  
  if (thumbs[next] && thumbs[next].style.display !== 'none') {
    const img = thumbs[next].querySelector('img');
    window.tsukieChangeImage(img ? img.src : '', next, container);
  }
};

window.tsukieSelectOption = function(element, position, value) {
  const container = tsukieGetContext(element);
  if (!container || !container.tsukieProduct) return;
  
  container.tsukieSelectedOptions[position] = value;
  
  container.querySelectorAll(`[data-option-position="${position}"]`).forEach(el => {
    el.classList.remove('active');
  });
  element.classList.add('active');
  
  const optionIndex = position - 1;
  if(container.tsukieProduct.options[optionIndex]) {
    const name = container.tsukieProduct.options[optionIndex].toLowerCase().replace(/\s+/g, '-');
    const selectedLabel = container.querySelector(`#tsukie-selected-${name}`);
    if(selectedLabel) selectedLabel.textContent = value;
  }
  
  // Trigger Color Filtering if applicable
  const optionName = container.tsukieProduct.options[optionIndex];
  if (optionName && (optionName.toLowerCase() === 'color' || optionName.toLowerCase() === 'colour')) {
    window.tsukieFilterImagesByColor(value);
  }
  
  const matchedVariant = container.tsukieProduct.variants.find(variant => {
    return (!variant.option1 || variant.option1 === container.tsukieSelectedOptions[1]) &&
           (!variant.option2 || variant.option2 === container.tsukieSelectedOptions[2]) &&
           (!variant.option3 || variant.option3 === container.tsukieSelectedOptions[3]);
  });
  
  if (matchedVariant) {
    const varInput = container.querySelector('#tsukie-variant-id');
    if (varInput) varInput.value = matchedVariant.id;
    
    const formatter = new Intl.NumberFormat('en-IN', { style: 'currency', currency: 'INR', maximumFractionDigits: 0 });
    const priceEl = container.querySelector('#tsukie-price');
    const emiEl = container.querySelector('#tsukie-emi-price');
    
    if(priceEl) priceEl.textContent = formatter.format(matchedVariant.price / 100);
    if(emiEl) emiEl.textContent = formatter.format((matchedVariant.price / 3) / 100) + '/month';
    
    const compPriceEl = container.querySelector('#tsukie-compare-price');
    const saveBadgeEl = container.querySelector('#tsukie-save-badge');
    const inventoryEl = container.querySelector('#tsukie-inventory');
    const qtyEl = container.querySelector('#tsukie-nav-qty');
    
    if(compPriceEl && saveBadgeEl) {
      if(matchedVariant.compare_at_price && matchedVariant.compare_at_price > matchedVariant.price) {
        compPriceEl.textContent = formatter.format(matchedVariant.compare_at_price / 100);
        compPriceEl.style.display = 'block';
        let pct = Math.round(((matchedVariant.compare_at_price - matchedVariant.price) * 100) / matchedVariant.compare_at_price);
        saveBadgeEl.textContent = `SAVE ${pct}%`;
        saveBadgeEl.style.display = 'block';
      } else {
        compPriceEl.style.display = 'none';
        saveBadgeEl.style.display = 'none';
      }
    }
    
    if (matchedVariant.featured_image && matchedVariant.featured_image.id && container.tsukieImageIds) {
      const imgIndex = container.tsukieImageIds.indexOf(matchedVariant.featured_image.id);
      if(imgIndex > -1 && container.tsukieImages) {
        window.tsukieChangeImage(container.tsukieImages[imgIndex], imgIndex, container);
      }
    }
    
    // Update inventory stock urgency
    if (inventoryEl && qtyEl) {
      if (matchedVariant.inventory_management && matchedVariant.inventory_quantity < 10 && matchedVariant.inventory_quantity > 0) {
        qtyEl.textContent = matchedVariant.inventory_quantity;
        inventoryEl.style.display = 'block';
      } else {
        inventoryEl.style.display = 'none';
      }
    }
    
    const addBtn = container.querySelector('#tsukie-add-to-cart-btn');
    const buyBtn = container.querySelector('#tsukie-buy-now-btn');
    const addText = container.querySelector('#tsukie-add-btn-text');
    if(matchedVariant.available) {
      if(addBtn) addBtn.removeAttribute('disabled');
      if(buyBtn) buyBtn.removeAttribute('disabled');
      if(addText) addText.textContent = "ADD TO BAG";
    } else {
      if(addBtn) addBtn.setAttribute('disabled', 'disabled');
      if(buyBtn) buyBtn.setAttribute('disabled', 'disabled');
      if(addText) addText.textContent = "SOLD OUT";
    }
  }
};
window.tsukieUpdateQty = function(btn, change) {
  const container = tsukieGetContext(btn);
  const input = container.querySelector('.tsukie-qty-input');
  if (input) {
    let val = parseInt(input.value) || 1;
    val += change;
    if (val < 1) val = 1;
    input.value = val;
  }
};

window.tsukieBuyNowClean = function(element) {
  const container = tsukieGetContext(element);
  const varInput = container.querySelector('#tsukie-variant-id');
  const variantId = varInput ? varInput.value : null;
  if (!variantId) return;
  
  const buyBtn = container.querySelector('#tsukie-buy-now-btn');
  const buyTxt = container.querySelector('#tsukie-buy-text');
  
  if(buyBtn) buyBtn.setAttribute('disabled', 'disabled');
  if(buyTxt) buyTxt.textContent = "PROCESSING...";

  const qtyInput = container.querySelector('.tsukie-qty-input');
  const qty = qtyInput ? parseInt(qtyInput.value) || 1 : 1;

  const rootPath = (window.Shopify && window.Shopify.routes && window.Shopify.routes.root) || '/';

  fetch(rootPath + 'cart/clear.js', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' }
  })
  .then(() => {
    return fetch(rootPath + 'cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        'items': [{ 'id': parseInt(variantId), 'quantity': qty }]
      })
    });
  })
  .then(res => res.json())
  .then(() => {
    window.location.href = '/checkout';
  })
  .catch(err => {
    console.error('Checkout error:', err);
    window.location.href = '/checkout?updates[' + variantId + ']=' + qty;
  });
};

window.tsukieToggleAccordion = function(header) {
  const currentItem = header.parentElement;
  const container = tsukieGetContext(header);
  container.querySelectorAll('.tsukie-accordion-item').forEach(item => {
    if (item !== currentItem) item.classList.remove('active');
  });
  currentItem.classList.toggle('active');
};

// Custom reviews pagination to 1+3 logic
(function() {
  function initCustomReviewsWidget() {
    const widget = document.querySelector('.jdgm-review-widget, #judgeme_product_reviews');
    if (!widget) return false;

    const origList = widget.querySelector('.jdgm-rev-list');
    if (!origList) return false;

    // Avoid double initialization
    if (widget.querySelector('.tsukie-custom-reviews-wrapper')) return true;

    const customWrap = document.createElement('div');
    customWrap.className = 'tsukie-custom-reviews-wrapper';
    customWrap.innerHTML = `
      <div class="tsukie-custom-rev-list"></div>
      <div class="tsukie-jdgm-load-more-wrapper" style="display: none; justify-content: center; margin-top: 24px; margin-bottom: 24px;">
        <button type="button" class="tsukie-jdgm-load-more-btn">
          Load More Reviews
        </button>
      </div>
    `;

    widget.appendChild(customWrap);

    const customList = customWrap.querySelector('.tsukie-custom-rev-list');
    const loadMoreWrapper = customWrap.querySelector('.tsukie-jdgm-load-more-wrapper');
    const loadMoreBtn = customWrap.querySelector('.tsukie-jdgm-load-more-btn');

    let allReviews = [];
    let visibleCount = 1;

    function renderCustomReviews() {
      customList.innerHTML = '';
      const reviewsToRender = allReviews.slice(0, visibleCount);
      reviewsToRender.forEach(function(rev) {
        const clone = rev.cloneNode(true);
        clone.style.setProperty('display', 'block', 'important');
        customList.appendChild(clone);
      });

      const nativeNextBtn = widget.querySelector('.jdgm-paginate__next-page, .jdgm-next-page, [data-page="next"], .jdgm-paginate__page[data-page="next"]');

      const hasMoreToRevealLocal = visibleCount < allReviews.length;
      const hasNativeNextPage = !!nativeNextBtn && !nativeNextBtn.classList.contains('jdgm-paginate__last-page') && !nativeNextBtn.disabled;

      if (hasMoreToRevealLocal || hasNativeNextPage) {
        loadMoreWrapper.style.setProperty('display', 'flex', 'important');
      } else {
        loadMoreWrapper.style.setProperty('display', 'none', 'important');
      }
    }

    function scanNativeReviews() {
      const origRevs = origList.querySelectorAll('.jdgm-rev');
      let addedAny = false;

      origRevs.forEach(function(rev) {
        const revId = rev.getAttribute('data-review-id') || rev.innerHTML.substring(0, 150);
        const alreadyExists = allReviews.some(function(existingRev) {
          const existingId = existingRev.getAttribute('data-review-id') || existingRev.innerHTML.substring(0, 150);
          return existingId === revId;
        });

        if (!alreadyExists) {
          allReviews.push(rev);
          addedAny = true;
        }
      });

      if (addedAny) {
        renderCustomReviews();
      }
    }

    scanNativeReviews();

    const listObserver = new MutationObserver(function() {
      scanNativeReviews();
    });
    listObserver.observe(origList, { childList: true, subtree: true });

    loadMoreBtn.addEventListener('click', function() {
      if (visibleCount < allReviews.length) {
        visibleCount += 3;
        renderCustomReviews();
      } else {
        const nativeNextBtn = widget.querySelector('.jdgm-paginate__next-page, .jdgm-next-page, [data-page="next"], .jdgm-paginate__page[data-page="next"]');
        if (nativeNextBtn) {
          loadMoreBtn.disabled = true;
          const origText = loadMoreBtn.textContent;
          loadMoreBtn.textContent = 'Loading...';

          visibleCount += 3;

          nativeNextBtn.click();

          setTimeout(function() {
            loadMoreBtn.disabled = false;
            loadMoreBtn.textContent = origText;
            renderCustomReviews();
          }, 1500);
        } else {
          loadMoreWrapper.style.setProperty('display', 'none', 'important');
        }
      }
    });

    return true;
  }

  const bodyObserver = new MutationObserver(function() {
    initCustomReviewsWidget();
  });
  bodyObserver.observe(document.body, { childList: true, subtree: true });

  initCustomReviewsWidget();
})();
</script>

<style>
