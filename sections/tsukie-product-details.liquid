          <tr><td>XXL</td><td>42</td><td>36</td><td>46</td></tr>
          <tr><td>3XL</td><td>44</td><td>38</td><td>48</td></tr>
          <tr><td>4XL</td><td>46</td><td>40</td><td>50</td></tr>
        </tbody>
