}

/* Hide native Judge.me pagination and header elements completely to show ONLY reviews + custom button */
.jdgm-widget-header,
.jdgm-histogram,
.jdgm-summary,
.jdgm-rev-widg__summary,
.jdgm-rev-widg__header,
.jdgm-widget-actions-wrapper,
