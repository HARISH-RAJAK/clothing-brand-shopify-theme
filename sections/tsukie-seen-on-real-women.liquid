<style>
.tsukie-real-women {
  {%- if section.settings.custom_bg_color != blank and section.settings.custom_bg_color != 'rgba(0,0,0,0)' -%}
    background: {{ section.settings.custom_bg_color }};
  {%- endif -%}
  padding: 80px 0;
  text-align: center;
}
.tsukie-real-women-inner {
  max-width: 1400px;
  margin: 0 auto;
  padding: 0 40px;
}
.tsukie-real-women-head {
  margin-bottom: 45px;
}
.tsukie-real-women-eyebrow {
  color: #a08766;
  font-size: 10px;
  letter-spacing: 2.5px;
  text-transform: uppercase;
  margin: 0 0 8px;
  font-weight: 500;
  font-family: 'Montserrat', sans-serif;
}
.tsukie-real-women-heading {
  font-family: 'Playfair Display', serif;
  font-size: 52px;
  font-style: italic;
  font-weight: 600;
  line-height: 1.15;
  margin: 0 0 16px;
  padding-bottom: 4px;
  color: rgb(var(--color-foreground));
  display: inline-block;
}
.tsukie-real-women-desc {
  font-size: 14px;
  line-height: 1.4;
  margin: 0 auto;
  font-family: 'Montserrat', sans-serif;
  color: rgb(var(--color-foreground) / 0.75);
  max-width: 600px;
}
.tsukie-real-women-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 24px;
  margin-bottom: 30px;
}
.tsukie-real-women-item {
  position: relative;
  overflow: hidden;
  aspect-ratio: 3/4;
  background: #eaeaea;
}
.tsukie-real-women-img,
.tsukie-real-women-video {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 0.5s ease;
}
.tsukie-real-women-item:hover .tsukie-real-women-img,
.tsukie-real-women-item:hover .tsukie-real-women-video {
  transform: scale(1.04);
}
.tsukie-real-women-tag {
  position: absolute;
  bottom: 15px;
  left: 15px;
  background: rgba(30, 42, 56, 0.75);
  color: #d4c5a9;
  padding: 6px 12px;
  font-family: 'Montserrat', sans-serif;
  font-size: 10px;
  font-weight: 500;
  letter-spacing: 1px;
  z-index: 2;
  backdrop-filter: blur(2px);
}
.tsukie-real-women-play {
  position: absolute;
  top: 15px;
  right: 15px;
  background: rgba(255, 255, 255, 0.2);
  border: 1px solid rgba(255, 255, 255, 0.4);
  width: 28px;
  height: 28px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 10px;
  backdrop-filter: blur(2px);
  z-index: 2;
  pointer-events: none;
  transition: opacity 0.3s, visibility 0.3s;
}
.tsukie-real-women-item.is-playing .tsukie-real-women-play {
  opacity: 0;
  visibility: hidden;
}
.tsukie-real-women-item:not(.is-playing) .tsukie-real-women-play {
  opacity: 1;
  visibility: visible;
}

@media(max-width: 989px) {
  .tsukie-real-women-grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
  }
  .tsukie-real-women-heading { font-size: 40px; }
}
@media(max-width: 749px) {
  .tsukie-real-women { padding: 50px 0; }
  .tsukie-real-women-inner { padding: 0; }
  .tsukie-real-women-head { padding: 0 16px; }
  .tsukie-real-women-eyebrow { font-size: 9px; margin: 0 0 6px; }
  .tsukie-real-women-heading { font-size: 36px; margin: 0 0 12px; line-height: 1.2; padding-bottom: 3px; }
  .tsukie-real-women-desc { font-size: 13px; }
  .tsukie-real-women-grid {
    display: flex;
    gap: 12px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    margin: 0;
    padding: 0 16px 8px;
  }
  .tsukie-real-women-grid::-webkit-scrollbar { display: none; }
  .tsukie-real-women-item {
    flex: 0 0 70%;
    scroll-snap-align: start;
    aspect-ratio: 9/16;
  }
}
</style>

<div class="tsukie-real-women color-{{ section.settings.color_scheme }} gradient">
  <div class="tsukie-real-women-inner">
    <div class="tsukie-real-women-head">
      <p class="tsukie-real-women-eyebrow">{{ section.settings.eyebrow }}</p>
      <h2 class="tsukie-real-women-heading">{{ section.settings.heading }}</h2>
      <p class="tsukie-real-women-desc">{{ section.settings.description }}</p>
    </div>

    {% if section.blocks.size > 0 %}
    <div class="tsukie-real-women-grid">
      {% for block in section.blocks %}
        <div class="tsukie-real-women-item" {{ block.shopify_attributes }}>
          {% if block.type == 'image_item' %}
            {% if block.settings.image %}
              <img class="tsukie-real-women-img"
                src="{{ block.settings.image | image_url: width: 800 }}"
                alt="{{ block.settings.tag | default: 'Seen on Real Women' }}"
                width="{{ block.settings.image.width }}"
                height="{{ block.settings.image.height }}"
                loading="lazy"
              >
            {% else %}
              {{ 'lifestyle-1' | placeholder_svg_tag: 'tsukie-real-women-img' }}
            {% endif %}

          {% elsif block.type == 'video_item' %}
            {%- comment -%} AG Fix - Task #3 - 2026-06-12 {%- endcomment -%}
            {%- assign poster_url = '' -%}
            {%- if block.settings.video_poster != blank -%}
              {%- assign poster_url = block.settings.video_poster | image_url: width: 800 -%}
            {%- endif -%}

            {% if block.settings.video_url != blank %}
              <video class="tsukie-real-women-video" loop muted playsinline{% if poster_url != blank %} poster="{{ poster_url }}"{% endif %}>
                <source src="{{ block.settings.video_url }}" type="video/mp4">
              </video>
              <span class="tsukie-real-women-play">&#9654;</span>
            {% elsif block.settings.shopify_video != blank %}
              {% if poster_url != blank %}
                {{ block.settings.shopify_video | video_tag: autoplay: false, loop: true, muted: true, class: 'tsukie-real-women-video', poster: poster_url }}
              {% else %}
                {{ block.settings.shopify_video | video_tag: image_size: '800x', autoplay: false, loop: true, muted: true, class: 'tsukie-real-women-video' }}
              {% endif %}
              <span class="tsukie-real-women-play">&#9654;</span>
            {% else %}
              {{ 'lifestyle-2' | placeholder_svg_tag: 'tsukie-real-women-img' }}
            {% endif %}
          {% endif %}

          {% if block.settings.tag != blank %}
            <span class="tsukie-real-women-tag">{{ block.settings.tag }}</span>
          {% endif %}
        </div>
      {% endfor %}
    </div>
    {% endif %}
  </div>
</div>

<script>
/* AG Fix - Task #3 - 2026-06-12 */
document.addEventListener('DOMContentLoaded', function() {
  const initRealWomenVideos = () => {
    const items = document.querySelectorAll('.tsukie-real-women-item');
    items.forEach(item => {
      const video = item.querySelector('video');
      if (video) {
        item.style.cursor = 'pointer';
        item.addEventListener('click', function(e) {
          if (video.paused) {
            // Pause all other videos first
            document.querySelectorAll('.tsukie-real-women-video').forEach(otherVideo => {
              if (otherVideo !== video) {
                otherVideo.pause();
                const otherItem = otherVideo.closest('.tsukie-real-women-item');
                if (otherItem) otherItem.classList.remove('is-playing');
              }
            });
            video.play();
            item.classList.add('is-playing');
          } else {
            video.pause();
            item.classList.remove('is-playing');
          }
        });

        // Sync state if controlled externally or by browser controls
        video.addEventListener('play', () => {
          item.classList.add('is-playing');
        });
        video.addEventListener('pause', () => {
          item.classList.remove('is-playing');
        });
      }
    });
  };
  
  initRealWomenVideos();
  // Support theme editor reload
  document.addEventListener('shopify:section:load', function(e) {
    if (e.target.classList.contains('tsukie-real-women-section') || e.target.querySelector('.tsukie-real-women')) {
      initRealWomenVideos();
    }
  });
});
</script>

{% schema %}
{
  "name": "Seen on Real Women",
  "tag": "section",
  "class": "tsukie-real-women-section",
  "max_blocks": 8,
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Text",
      "default": "AS SEEN ON YOU"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Seen on Real Women"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Candid moments of real women styling our timeless silhouettes. Tag us at #TsukieWomen to get featured."
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "color",
      "id": "custom_bg_color",
      "label": "Custom Background Color (Overrides Scheme)"
    }
  ],
  "blocks": [
    {
      "type": "image_item",
      "name": "Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "tag",
          "label": "Instagram Handle / Tag",
          "default": "@USERNAME"
        }
      ]
    },
    {
      "type": "video_item",
      "name": "Video",
      "settings": [
        {
          "type": "url",
          "id": "video_url",
          "label": "Video URL (MP4 link)"
        },
        {
          "type": "video",
          "id": "shopify_video",
          "label": "Or Upload Video (Shopify hosted)"
        },
        {
          "type": "image_picker",
          "id": "video_poster",
          "label": "Poster / Thumbnail Image"
        },
        {
          "type": "text",
          "id": "tag",
          "label": "Instagram Handle / Tag",
          "default": "@USERNAME"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Seen on Real Women",
      "settings": {
        "eyebrow": "AS SEEN ON YOU",
        "heading": "Seen on Real Women",
        "description": "Candid moments of real women styling our timeless silhouettes. Tag us at #TsukieWomen to get featured."
      },
      "blocks": [
        { "type": "image_item", "settings": { "tag": "@PRIYA_ANAND" } },
        { "type": "video_item", "settings": { "tag": "@ANJALI.S" } },
        { "type": "image_item", "settings": { "tag": "@MEERA_M" } },
        { "type": "video_item", "settings": { "tag": "@RIYA.SEN" } }
      ]
    }
  ]
}
{% endschema %}
