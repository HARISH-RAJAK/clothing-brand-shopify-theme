{%- style -%}
  {%- if section.settings.custom_bg_color != blank and section.settings.custom_bg_color != 'rgba(0,0,0,0)' -%}
    #tsukie-real-women-{{ section.id }} {
      background: {{ section.settings.custom_bg_color }} !important;
    }
  {%- endif -%}

  {% liquid
    case section.settings.post_spacing
      when 'none'
        assign desktop_gap = '0px'
        assign mobile_gap = '0px'
      when 'small'
        assign desktop_gap = '8px'
        assign mobile_gap = '4px'
      when 'medium'
        assign desktop_gap = '16px'
        assign mobile_gap = '8px'
      when 'large'
        assign desktop_gap = '24px'
        assign mobile_gap = '12px'
    endcase

    case section.settings.post_format
      when '1-1'
        assign aspect_ratio = '1/1'
      when '9-16'
        assign aspect_ratio = '9/16'
      when '4-5'
        assign aspect_ratio = '4/5'
    endcase

    case section.settings.rounded_corners
      when 'none'
        assign border_radius = '0px'
      when 'small'
        assign border_radius = '4px'
      when 'medium'
        assign border_radius = '8px'
      when 'large'
        assign border_radius = '16px'
    endcase

    assign visible_posts_desktop_num = section.settings.visible_posts_desktop | default: 4 | plus: 0
    assign slider_pages_desktop_num = section.settings.slider_pages_desktop | default: 4 | plus: 0
    assign limit_posts_desktop = visible_posts_desktop_num | times: slider_pages_desktop_num

    assign visible_posts_mobile_num = section.settings.visible_posts_mobile | default: '1.5' | plus: 0.0
    assign slider_pages_mobile_num = section.settings.slider_pages_mobile | default: 4 | plus: 0
    assign limit_posts_mobile = visible_posts_mobile_num | times: slider_pages_mobile_num | ceil
  %}

  #tsukie-real-women-{{ section.id }} {
    padding: 80px 0;
    text-align: center;
  }
  #tsukie-real-women-{{ section.id }} .tsukie-real-women-inner {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 40px;
  }
  #tsukie-real-women-{{ section.id }} .tsukie-real-women-head {
    margin-bottom: 45px;
  }
  #tsukie-real-women-{{ section.id }} .tsukie-real-women-eyebrow {
    color: #a08766;
    font-size: 10px;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    margin: 0 0 8px;
    font-weight: 500;
    font-family: 'Montserrat', sans-serif;
  }
  #tsukie-real-women-{{ section.id }} .tsukie-real-women-heading {
    font-family: 'Playfair Display', serif;
    font-size: 52px;
    font-style: italic;
    font-weight: 600;
    line-height: 1.15;
    margin: 0 0 16px;
    padding-bottom: 4px;
    color: #1e2a38;
    display: inline-block;
  }
  #tsukie-real-women-{{ section.id }} .tsukie-real-women-desc {
    font-size: 14px;
    line-height: 1.4;
    margin: 0 auto;
    font-family: 'Montserrat', sans-serif;
    color: #6b6b6b;
    max-width: 600px;
  }

  /* Grid Layout style */
  #tsukie-real-women-{{ section.id }} .tsukie-real-women-grid-wrapper.layout-grid .tsukie-real-women-grid {
    display: grid;
    gap: {{ desktop_gap }};
    grid-template-columns: repeat({{ section.settings.visible_posts_desktop }}, 1fr);
  }

  /* Slider Layout style */
  #tsukie-real-women-{{ section.id }} .tsukie-real-women-grid-wrapper.layout-slider .tsukie-real-women-grid {
    display: flex !important;
    flex-wrap: nowrap !important;
    overflow-x: auto !important;
    scroll-snap-type: x mandatory !important;
    -webkit-overflow-scrolling: touch !important;
    scrollbar-width: none !important;
    gap: {{ desktop_gap }};
  }
  #tsukie-real-women-{{ section.id }} .tsukie-real-women-grid-wrapper.layout-slider .tsukie-real-women-grid::-webkit-scrollbar {
    display: none !important;
  }
  #tsukie-real-women-{{ section.id }} .tsukie-real-women-grid-wrapper.layout-slider .tsukie-real-women-item {
    flex: 0 0 calc(100% / {{ section.settings.visible_posts_desktop }} - (({{ desktop_gap }} * ({{ section.settings.visible_posts_desktop }} - 1)) / {{ section.settings.visible_posts_desktop }})) !important;
    scroll-snap-align: start !important;
  }

  /* Static Layout style (Rotate one post) */
  #tsukie-real-women-{{ section.id }} .tsukie-real-women-grid-wrapper.layout-static .tsukie-real-women-grid {
    display: block !important;
    position: relative;
    max-width: 450px;
    margin: 0 auto;
  }
  #tsukie-real-women-{{ section.id }} .tsukie-real-women-grid-wrapper.layout-static .tsukie-real-women-item {
    display: none;
    width: 100%;
    opacity: 0;
    transition: opacity 0.6s ease;
  }
  #tsukie-real-women-{{ section.id }} .tsukie-real-women-grid-wrapper.layout-static .tsukie-real-women-item.active {
    display: block;
    opacity: 1;
  }

  /* Item Styling */
  #tsukie-real-women-{{ section.id }} .tsukie-real-women-item {
    position: relative;
    overflow: hidden;
    aspect-ratio: {{ aspect_ratio }} !important;
    border-radius: {{ border_radius }} !important;
    background: #eaeaea;
  }
  #tsukie-real-women-{{ section.id }} .tsukie-real-women-img,
  #tsukie-real-women-{{ section.id }} .tsukie-real-women-video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    border-radius: {{ border_radius }} !important;
    transition: transform 0.5s ease;
  }
  #tsukie-real-women-{{ section.id }} .tsukie-real-women-item:hover .tsukie-real-women-img,
  #tsukie-real-women-{{ section.id }} .tsukie-real-women-item:hover .tsukie-real-women-video {
    transform: scale(1.04);
  }
  #tsukie-real-women-{{ section.id }} .tsukie-real-women-tag {
    position: absolute;
    bottom: 15px;
    left: 15px;
    background: rgba(30, 42, 56, 0.75);
    color: #d4c5a9;
    padding: 6px 12px;
    font-family: 'Montserrat', sans-serif;
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 1px;
    z-index: 2;
    backdrop-filter: blur(2px);
  }
  #tsukie-real-women-{{ section.id }} .tsukie-real-women-play {
    position: absolute;
    top: 15px;
    right: 15px;
    background: rgba(255, 255, 255, 0.2);
    border: 1px solid rgba(255, 255, 255, 0.4);
    width: 28px;
    height: 28px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    font-size: 10px;
    backdrop-filter: blur(2px);
    z-index: 2;
    pointer-events: none;
    transition: opacity 0.3s, visibility 0.3s;
  }
  #tsukie-real-women-{{ section.id }} .tsukie-real-women-item.is-playing .tsukie-real-women-play {
    opacity: 0;
    visibility: hidden;
  }

  /* Slider controls styling */
  .tsukie-rw-slider-controls {
    display: flex;
    justify-content: center;
    gap: 16px;
    margin-top: 24px;
  }
  .tsukie-rw-slider-btn {
    background: #1e2a38;
    color: #d4c5a9;
    border: none;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 14px;
    transition: opacity 0.2s;
  }
  .tsukie-rw-slider-btn:hover {
    opacity: 0.9;
  }

  /* Modal Popup styles */
  .tsukie-real-women-popup {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    z-index: 25000;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .tsukie-rw-popup-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(30, 42, 56, 0.85);
    backdrop-filter: blur(4px);
  }
  .tsukie-rw-popup-content {
    position: relative;
    background: #fdfbf7;
    border: 2px solid #d4c5a9;
    border-radius: 8px;
    width: 90%;
    max-width: 480px;
    padding: 24px;
    box-shadow: 0 10px 40px rgba(0,0,0,0.3);
    z-index: 25001;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .tsukie-rw-popup-close {
    position: absolute;
    top: 12px;
    right: 12px;
    background: none;
    border: none;
    font-size: 28px;
    cursor: pointer;
    color: #1e2a38;
    line-height: 1;
    padding: 0;
    transition: color 0.2s;
    z-index: 25002;
  }
  .tsukie-rw-popup-close:hover {
    color: #a08766;
  }
  .tsukie-rw-popup-media-container {
    width: 100%;
    max-height: 65vh;
    background: #000;
    border-radius: 4px;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .tsukie-rw-popup-media-container img,
  .tsukie-rw-popup-media-container video {
    max-width: 100%;
    max-height: 65vh;
    object-fit: contain;
  }
  .tsukie-rw-popup-tag {
    margin-top: 16px;
    font-family: 'Montserrat', sans-serif;
    font-size: 13px;
    color: #1e2a38;
    font-weight: 600;
    letter-spacing: 1px;
  }

  @media(max-width: 989px) {
    #tsukie-real-women-{{ section.id }} .tsukie-real-women-grid-wrapper.layout-grid .tsukie-real-women-grid {
      grid-template-columns: repeat(2, 1fr) !important;
    }
    #tsukie-real-women-{{ section.id }} .tsukie-real-women-heading { font-size: 40px; }
  }
  @media(max-width: 749px) {
    #tsukie-real-women-{{ section.id }} { padding: 50px 0; }
    #tsukie-real-women-{{ section.id }} .tsukie-real-women-inner { padding: 0; }
    #tsukie-real-women-{{ section.id }} .tsukie-real-women-head { padding: 0 16px; }
    #tsukie-real-women-{{ section.id }} .tsukie-real-women-eyebrow { font-size: 9px; margin: 0 0 6px; }
    #tsukie-real-women-{{ section.id }} .tsukie-real-women-heading { font-size: 36px; margin: 0 0 12px; line-height: 1.2; padding-bottom: 3px; }
    #tsukie-real-women-{{ section.id }} .tsukie-real-women-desc { font-size: 13px; }

    #tsukie-real-women-{{ section.id }} .tsukie-real-women-grid-wrapper.layout-slider .tsukie-real-women-grid {
      display: flex !important;
      gap: {{ mobile_gap }} !important;
      overflow-x: auto !important;
      scroll-snap-type: x mandatory !important;
      -webkit-overflow-scrolling: touch !important;
      scrollbar-width: none !important;
      margin: 0 !important;
      padding: 0 16px 8px !important;
      width: 100% !important;
    }
    #tsukie-real-women-{{ section.id }} .tsukie-real-women-grid-wrapper.layout-slider .tsukie-real-women-item {
      flex: 0 0 calc(100% / {{ section.settings.visible_posts_mobile }} - (({{ mobile_gap }} * ({{ section.settings.visible_posts_mobile }} - 1)) / {{ section.settings.visible_posts_mobile }})) !important;
      scroll-snap-align: start !important;
      aspect-ratio: {{ aspect_ratio }} !important;
    }
    .tsukie-rw-slider-controls {
      display: none !important;
    }
  }

  #tsukie-real-women-{{ section.id }} .tsukie-real-women-grid-wrapper:not(.layout-static) .tsukie-real-women-item:nth-child(n+{{ limit_posts_desktop | plus: 1 }}) {
    display: none !important;
  }
  @media(max-width: 749px) {
    #tsukie-real-women-{{ section.id }} .tsukie-real-women-grid-wrapper:not(.layout-static) .tsukie-real-women-item {
      display: block !important;
    }
    #tsukie-real-women-{{ section.id }} .tsukie-real-women-grid-wrapper:not(.layout-static) .tsukie-real-women-item:nth-child(n+{{ limit_posts_mobile | plus: 1 }}) {
      display: none !important;
    }
  }
{%- endstyle -%}

<div class="tsukie-real-women color-{{ section.settings.color_scheme }} gradient" id="tsukie-real-women-{{ section.id }}">
  <div class="tsukie-real-women-inner">
    {% if section.settings.eyebrow != blank or section.settings.heading != blank or section.settings.description != blank %}
    <div class="tsukie-real-women-head">
      {% if section.settings.eyebrow != blank %}
        <p class="tsukie-real-women-eyebrow">{{ section.settings.eyebrow | escape }}</p>
      {% endif %}
      {% if section.settings.heading != blank %}
        <h2 class="tsukie-real-women-heading">{{ section.settings.heading | escape }}</h2>
      {% endif %}
      {% if section.settings.description != blank %}
        <p class="tsukie-real-women-desc">{{ section.settings.description | escape }}</p>
      {% endif %}
    </div>
    {% endif %}

    {% if section.blocks.size > 0 %}
    <div class="tsukie-real-women-grid-wrapper layout-{{ section.settings.feed_design }} spacing-{{ section.settings.post_spacing }} format-{{ section.settings.post_format }} corners-{{ section.settings.rounded_corners }}" id="tsukie-rw-grid-{{ section.id }}">
      <div class="tsukie-real-women-grid">
        {% for block in section.blocks %}
          <div class="tsukie-real-women-item" {{ block.shopify_attributes }}>
            {% if block.type == 'image_item' %}
              {% if block.settings.image %}
                <img class="tsukie-real-women-img"
                  src="{{ block.settings.image | image_url: width: 800 }}"
                  alt="{{ block.settings.tag | default: 'Seen on Real Women' }}"
                  width="{{ block.settings.image.width }}"
                  height="{{ block.settings.image.height }}"
                  loading="lazy"
                >
              {% else %}
                {{ 'lifestyle-1' | placeholder_svg_tag: 'tsukie-real-women-img' }}
              {% endif %}

            {% elsif block.type == 'video_item' %}
              {%- assign poster_url = '' -%}
              {%- if block.settings.video_poster != blank -%}
                {%- assign poster_url = block.settings.video_poster | image_url: width: 800 -%}
              {%- endif -%}

              {% if block.settings.video_url != blank %}
                <video class="tsukie-real-women-video" loop muted playsinline{% if poster_url != blank %} poster="{{ poster_url }}"{% endif %}>
                  <source src="{{ block.settings.video_url }}" type="video/mp4">
                </video>
                <span class="tsukie-real-women-play">&#9654;</span>
              {% elsif block.settings.shopify_video != blank %}
                {% if poster_url != blank %}
                  {{ block.settings.shopify_video | video_tag: autoplay: false, loop: true, muted: true, class: 'tsukie-real-women-video', poster: poster_url }}
                {% else %}
                  {{ block.settings.shopify_video | video_tag: image_size: '800x', autoplay: false, loop: true, muted: true, class: 'tsukie-real-women-video' }}
                {% endif %}
                <span class="tsukie-real-women-play">&#9654;</span>
              {% else %}
                {{ 'lifestyle-2' | placeholder_svg_tag: 'tsukie-real-women-img' }}
              {% endif %}
            {% endif %}

            {% if block.settings.tag != blank %}
              <span class="tsukie-real-women-tag">{{ block.settings.tag }}</span>
            {% endif %}
          </div>
        {% endfor %}
      </div>

      {% if section.settings.feed_design == 'slider' %}
        <div class="tsukie-rw-slider-controls">
          <button class="tsukie-rw-slider-btn prev" type="button" onclick="scrollTsukieRwSlider('{{ section.id }}', 'prev')">&#10094;</button>
          <button class="tsukie-rw-slider-btn next" type="button" onclick="scrollTsukieRwSlider('{{ section.id }}', 'next')">&#10095;</button>
        </div>
      {% endif %}
    </div>
    {% endif %}
  </div>
</div>

<!-- Dynamic Modal Popup Container -->
<div class="tsukie-real-women-popup" id="tsukie-rw-popup-{{ section.id }}" style="display: none;">
  <div class="tsukie-rw-popup-overlay" onclick="closeTsukieRwPopup('{{ section.id }}')"></div>
  <div class="tsukie-rw-popup-content">
    <button class="tsukie-rw-popup-close" type="button" onclick="closeTsukieRwPopup('{{ section.id }}')">&times;</button>
    <div class="tsukie-rw-popup-media-container"></div>
    <div class="tsukie-rw-popup-tag"></div>
  </div>
</div>

<script>
(function() {
  const sectionId = '{{ section.id }}';
  const clickAction = '{{ section.settings.on_post_click }}';
  const feedDesign = '{{ section.settings.feed_design }}';

  const visiblePostsDesktop = parseInt('{{ section.settings.visible_posts_desktop | default: 4 }}') || 4;
  const sliderPagesDesktop = parseInt('{{ section.settings.slider_pages_desktop | default: 4 }}') || 4;
  const limitDesktop = visiblePostsDesktop * sliderPagesDesktop;

  const visiblePostsMobile = parseFloat('{{ section.settings.visible_posts_mobile | default: 1.5 }}') || 1.5;
  const sliderPagesMobile = parseInt('{{ section.settings.slider_pages_mobile | default: 4 }}') || 4;
  const limitMobile = Math.ceil(visiblePostsMobile * sliderPagesMobile);

  function getLimit() {
    if (window.innerWidth <= 749) {
      return limitMobile;
    }
    return limitDesktop;
  }

  // Modal Open Handler
  window.openTsukieRwPopup = function(sectId, itemElement) {
    const popup = document.getElementById('tsukie-rw-popup-' + sectId);
    if (!popup) return;

    const mediaContainer = popup.querySelector('.tsukie-rw-popup-media-container');
    const tagContainer = popup.querySelector('.tsukie-rw-popup-tag');
    if (!mediaContainer) return;

    mediaContainer.innerHTML = '';
    if (tagContainer) tagContainer.innerHTML = '';

    const originalVideo = itemElement.querySelector('video');
    const originalImg = itemElement.querySelector('img');
    const tag = itemElement.querySelector('.tsukie-real-women-tag');

    if (originalVideo) {
      const videoClone = originalVideo.cloneNode(true);
      videoClone.setAttribute('controls', 'true');
      videoClone.removeAttribute('autoplay');
      videoClone.muted = false; // Play sound in popup modal!
      mediaContainer.appendChild(videoClone);
      popup.style.display = 'flex';
      videoClone.play().catch(e => console.log('Autoplay blocked', e));
    } else if (originalImg) {
      const imgClone = originalImg.cloneNode(true);
      mediaContainer.appendChild(imgClone);
      popup.style.display = 'flex';
    }

    if (tag && tagContainer) {
      tagContainer.textContent = tag.textContent;
      tagContainer.style.display = 'block';
    } else if (tagContainer) {
      tagContainer.style.display = 'none';
    }
  };

  // Modal Close Handler
  window.closeTsukieRwPopup = function(sectId) {
    const popup = document.getElementById('tsukie-rw-popup-' + sectId);
    if (!popup) return;

    const mediaContainer = popup.querySelector('.tsukie-rw-popup-media-container');
    if (mediaContainer) {
      const video = mediaContainer.querySelector('video');
      if (video) video.pause();
      mediaContainer.innerHTML = '';
    }
    popup.style.display = 'none';
  };

  // Slider controls helper
  window.scrollTsukieRwSlider = function(sectId, direction) {
    const gridWrapper = document.getElementById('tsukie-rw-grid-' + sectId);
    if (!gridWrapper) return;
    const container = gridWrapper.querySelector('.tsukie-real-women-grid');
    if (!container) return;
    const scrollAmount = container.clientWidth * 0.8;
    if (direction === 'prev') {
      container.scrollBy({ left: -scrollAmount, behavior: 'smooth' });
    } else {
      container.scrollBy({ left: scrollAmount, behavior: 'smooth' });
    }
  };

  // Static Cycle Handler
  let staticInterval = null;
  function initStaticCycle() {
    if (staticInterval) clearInterval(staticInterval);

    const gridWrapper = document.getElementById('tsukie-rw-grid-' + sectionId);
    if (!gridWrapper || feedDesign !== 'static') return;

    const allItems = gridWrapper.querySelectorAll('.tsukie-real-women-item');
    const limit = getLimit();
    const items = Array.from(allItems).slice(0, limit);

    if (items.length <= 1) {
      if (items.length === 1) items[0].classList.add('active');
      return;
    }

    allItems.forEach(item => item.classList.remove('active'));
    items.forEach((item, idx) => {
      item.classList.toggle('active', idx === 0);
    });

    let currentIdx = 0;
    staticInterval = setInterval(() => {
      items[currentIdx].classList.remove('active');
      currentIdx = (currentIdx + 1) % items.length;
      items[currentIdx].classList.add('active');
    }, 4000);
  }

  // Videos play/pause handling
  function initVideos() {
    const gridWrapper = document.getElementById('tsukie-rw-grid-' + sectionId);
    if (!gridWrapper) return;

    const items = gridWrapper.querySelectorAll('.tsukie-real-women-item');
    items.forEach(item => {
      const video = item.querySelector('video');
      
      item.style.cursor = 'pointer';
      item.onclick = function(e) {
        if (clickAction === 'popup') {
          openTsukieRwPopup(sectionId, item);
        } else if (video) {
          if (video.paused) {
            // Pause others
            document.querySelectorAll('.tsukie-real-women-video').forEach(otherVideo => {
              if (otherVideo !== video) {
                otherVideo.pause();
                const otherItem = otherVideo.closest('.tsukie-real-women-item');
                if (otherItem) otherItem.classList.remove('is-playing');
              }
            });
            video.play();
            item.classList.add('is-playing');
          } else {
            video.pause();
            item.classList.remove('is-playing');
          }
        }
      };

      if (video) {
        video.addEventListener('play', () => item.classList.add('is-playing'));
        video.addEventListener('pause', () => item.classList.remove('is-playing'));
      }
    });
  }

  function initAll() {
    initVideos();
    if (feedDesign === 'static') {
      initStaticCycle();
    }
  }

  let resizeTimeout;
  window.addEventListener('resize', () => {
    clearTimeout(resizeTimeout);
    resizeTimeout = setTimeout(() => {
      if (feedDesign === 'static') {
        initStaticCycle();
      }
    }, 250);
  });

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initAll);
  } else {
    initAll();
  }

  // Support theme customizer reload
  document.addEventListener('shopify:section:load', function(e) {
    if (e.detail.sectionId === sectionId || e.target.querySelector('#tsukie-real-women-' + sectionId)) {
      initAll();
    }
  });

  document.addEventListener('shopify:section:unload', function(e) {
    if (e.detail.sectionId === sectionId && staticInterval) {
      clearInterval(staticInterval);
    }
  });
})();
</script>

{% schema %}
{
  "name": "Seen on Real Women",
  "tag": "section",
  "class": "tsukie-real-women-section",
  "max_blocks": 12,
  "settings": [
    {
      "type": "header",
      "content": "Feed Layout & Design"
    },
    {
      "type": "select",
      "id": "feed_design",
      "label": "Feed Design Layout",
      "options": [
        {
          "value": "grid",
          "label": "Grid - Responsive grid of posts"
        },
        {
          "value": "slider",
          "label": "Slider - Scrollable row of posts"
        },
        {
          "value": "static",
          "label": "Static - Rotate one post"
        }
      ],
      "default": "grid"
    },
    {
      "type": "select",
      "id": "on_post_click",
      "label": "On Post Click Behavior",
      "options": [
        {
          "value": "popup",
          "label": "Open minimal popup"
        },
        {
          "value": "none",
          "label": "No action"
        }
      ],
      "default": "popup"
