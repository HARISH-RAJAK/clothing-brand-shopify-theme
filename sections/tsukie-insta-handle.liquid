{%- style -%}
#tsukie-insta-{{ section.id }} {
  position: relative;
  background: transparent;
  padding-top: {{ section.settings.padding_top }}px;
  padding-bottom: {{ section.settings.padding_bottom }}px;
  text-align: center;
  width: 100%;
}

#tsukie-insta-{{ section.id }} .tsukie-insta-inner {
  width: 100%;
  padding: 0 15px;
}

#tsukie-insta-{{ section.id }} .tsukie-insta-handle {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  background: {{ section.settings.button_bg_color | default: '#1e2a38' }};
  color: {{ section.settings.button_text_color | default: '#a08766' }};
  padding: {{ section.settings.btn_padding_vertical }}px {{ section.settings.btn_padding_horizontal }}px;
  border-radius: 50px;
  text-decoration: none;
  font-family: 'Montserrat', sans-serif;
  font-size: {{ section.settings.btn_font_size }}px;
  letter-spacing: 1.5px;
  font-weight: 600;
  text-transform: lowercase;
  transition: transform 0.3s ease;
  {%- if section.settings.button_width > 0 -%}
    width: {{ section.settings.button_width }}px;
    max-width: 100%;
    box-sizing: border-box;
  {%- else -%}
    width: auto;
  {%- endif -%}
}

#tsukie-insta-{{ section.id }} .tsukie-insta-handle:hover {
  transform: translateY(-2px);
}

@media (max-width: 749px) {
  #tsukie-insta-{{ section.id }} {
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
  }
}
{%- endstyle -%}

<div id="tsukie-insta-{{ section.id }}" class="tsukie-insta-section color-{{ section.settings.color_scheme }}">
  <div class="section-background color-{{ section.settings.color_scheme }}"></div>
  <div class="tsukie-insta-inner section section--full-width" style="position: relative; z-index: 2;">
    <a href="{{ section.settings.button_link | default: 'https://www.instagram.com/tsukieofficial/' }}" target="_blank" class="tsukie-insta-handle">
      {{ section.settings.button_text | default: '@tsukieofficial' }}
    </a>
  </div>
</div>

{% schema %}
{
  "name": "Tsukie Insta Handle",
  "tag": "section",
  "class": "tsukie-insta-handle-section",
  "settings": [
    {
      "type": "header",
      "content": "Button Settings"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "@tsukieofficial"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "color",
      "id": "button_bg_color",
      "label": "Button Background Color",
      "default": "#1e2a38"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button Text Color",
      "default": "#a08766"
    },
    {
      "type": "range",
      "id": "btn_font_size",
      "label": "Button Font Size",
      "min": 8,
      "max": 30,
      "step": 1,
      "unit": "px",
      "default": 13
    },
    {
      "type": "range",
      "id": "btn_padding_vertical",
      "label": "Button Vertical Padding",
      "min": 0,
      "max": 30,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "btn_padding_horizontal",
      "label": "Button Horizontal Padding",
      "min": 0,
      "max": 80,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "button_width",
      "label": "Button Width (0 for Auto)",
      "min": 0,
      "max": 500,
      "step": 5,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "Section Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top (Desktop)",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "default": 10
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom (Desktop)",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "default": 10
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding Top (Mobile)",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "default": 50
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding Bottom (Mobile)",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "default": 50
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1"
    }
  ],
  "presets": [
    {
      "name": "Tsukie Insta Handle"
    }
  ]
}
{% endschema %}
