<div class="tsukie-recently-viewed" id="tsukie-recently-viewed-{{ section.id }}" style="display: none;">
  <div class="recently-viewed-inner" style="max-width: 1400px; margin: 0 auto; padding: 40px 40px 80px; background: #f5f1ea;">
    
    {% if section.settings.header_style != 'none' %}
      {%- style -%}
        #tsukie-header-{{ section.id }} {
          padding-top: 20px;
          padding-bottom: 30px;
          text-align: center;
          position: relative;
          overflow: hidden;
          width: 100%;
        }

        #tsukie-header-{{ section.id }} .tsukie-header-inner {
          max-width: 1400px;
          margin: 0 auto;
        }

        /* Style 1: Collection Head Style */
        #tsukie-header-{{ section.id }} .tsukie-style-simple .tsukie-header-eyebrow {
          color: #a08766;
          font-size: 10px;
          letter-spacing: 2.5px;
          text-transform: uppercase;
          margin: 0 0 8px;
          font-weight: 500;
          font-family: 'Montserrat', sans-serif;
        }
        #tsukie-header-{{ section.id }} .tsukie-style-simple .tsukie-header-title {
          font-family: 'Playfair Display', serif;
          font-size: 52px;
          font-style: italic;
          font-weight: 600;
          line-height: 1.15;
          margin: 0 0 16px;
          padding-bottom: 4px;
          color: #1e2a38;
          display: inline-block;
        }
        #tsukie-header-{{ section.id }} .tsukie-style-simple .tsukie-header-subtext {
          font-size: 14px;
          line-height: 1.4;
          margin: 0 auto;
          font-family: 'Montserrat', sans-serif;
          color: #6b6b6b;
        }

        /* Style 2: Premium Heading with Divider Style */
        #tsukie-header-{{ section.id }} .tsukie-style-premium .tsukie-header-eyebrow {
          font-size: 11px;
          letter-spacing: 4px;
          text-transform: uppercase;
          color: #a08766;
          margin: 0 0 16px;
          font-weight: 600;
          position: relative;
          font-family: 'Montserrat', sans-serif;
        }
        #tsukie-header-{{ section.id }} .tsukie-style-premium .tsukie-header-title {
          font-family: 'Playfair Display', serif;
          font-size: 58px;
          font-weight: 600;
          font-style: italic;
          margin: 0 0 20px;
          color: #1e2a38;
          line-height: 1.1;
          position: relative;
        }
        #tsukie-header-{{ section.id }} .tsukie-style-premium .tsukie-header-divider {
          display: flex;
          align-items: center;
          justify-content: center;
          gap: 12px;
          margin: 0 auto;
        }
        #tsukie-header-{{ section.id }} .tsukie-style-premium .tsukie-header-line {
          width: 80px;
          height: 1px;
          background: linear-gradient(90deg, transparent, #a08766, transparent);
        }
        #tsukie-header-{{ section.id }} .tsukie-style-premium .tsukie-header-icon {
          font-size: 14px;
          color: #a08766;
        }
        #tsukie-header-{{ section.id }} .tsukie-style-premium .tsukie-header-subtext {
          font-family: 'Cormorant Garamond', serif;
          font-size: 18px;
          font-style: italic;
          color: #6b6b6b;
          margin: 16px 0 0;
          letter-spacing: 0.5px;
        }

        @media (max-width: 749px) {
          #tsukie-header-{{ section.id }} {
            padding-top: 30px;
            padding-bottom: 20px;
          }
          #tsukie-header-{{ section.id }} .tsukie-header-inner {
            padding: 0 20px;
          }
          #tsukie-header-{{ section.id }} .tsukie-style-simple .tsukie-header-eyebrow {
            font-size: 9px;
            margin: 0 0 6px;
          }
          #tsukie-header-{{ section.id }} .tsukie-style-simple .tsukie-header-title {
            font-size: 36px;
            margin: 0 0 12px;
            line-height: 1.2;
            padding-bottom: 3px;
          }
          #tsukie-header-{{ section.id }} .tsukie-style-simple .tsukie-header-subtext {
            font-size: 13px;
          }
          #tsukie-header-{{ section.id }} .tsukie-style-premium .tsukie-header-title {
            font-size: 40px;
          }
          #tsukie-header-{{ section.id }} .tsukie-style-premium .tsukie-header-subtext {
            font-size: 16px;
          }
        }
      {%- endstyle -%}

      <div id="tsukie-header-{{ section.id }}" class="tsukie-header-wrapper">
        <div class="tsukie-header-inner tsukie-style-{{ section.settings.header_style }}">
          {% if section.settings.eyebrow != blank %}
            <p class="tsukie-header-eyebrow">{{ section.settings.eyebrow | escape }}</p>
          {% endif %}
          
          {% if section.settings.heading != blank %}
            <h2 class="tsukie-header-title">{{ section.settings.heading | escape }}</h2>
          {% endif %}
          
          {% if section.settings.header_style == 'premium' %}
            <div class="tsukie-header-divider">
              <span class="tsukie-header-line"></span>
              <span class="tsukie-header-icon">✦</span>
              <span class="tsukie-header-line"></span>
            </div>
          {% endif %}
          
          {% if section.settings.subtext != blank %}
            <p class="tsukie-header-subtext">{{ section.settings.subtext | escape }}</p>
          {% endif %}
        </div>
      </div>
    {% endif %}

    <ul class="product-grid" id="tsukie-rv-grid-{{ section.id }}">
    </ul>
    <div class="tsukie-rv-view-more-wrap" id="tsukie-rv-more-wrap-{{ section.id }}" style="display:none; text-align:center; margin-top:40px;">
      <button class="tsukie-rv-view-more-btn" id="tsukie-rv-more-btn-{{ section.id }}" type="button">
        LOAD MORE
      </button>
    </div>
  </div>
</div>

<style>
#tsukie-recently-viewed-{{ section.id }} ul.product-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr) !important;
  gap: 32px !important;
  list-style: none;
  padding: 0;
  margin: 0;
}
#tsukie-recently-viewed-{{ section.id }} .tsukie-product-title {
  font-family: 'Playfair Display', serif !important;
  font-weight: 600 !important;
  color: #1e2a38 !important;
  font-size: 18px !important;
  margin: 0;
  letter-spacing: normal;
  line-height: 1.3;
  text-decoration: none;
  font-style: normal !important;
}
#tsukie-recently-viewed-{{ section.id }} .tsukie-product-badge {
  position: absolute;
  top: 12px;
  left: 12px;
  background: #1e2a38 !important;
  color: #d4c5a9 !important;
  font-family: 'Montserrat', sans-serif !important;
  font-size: 10px !important;
  font-weight: 500 !important;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  padding: 6px 12px;
  z-index: 2;
  border-radius: 2px;
}
#tsukie-recently-viewed-{{ section.id }} .tsukie-quick-add-btn {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: #1e2a38;
  color: #d4c5a9;
  text-align: center;
  padding: 14px;
  font-size: 11px;
  letter-spacing: 2px;
  text-transform: uppercase;
  border: none;
  cursor: pointer;
  transform: translateY(100%);
  transition: transform 0.3s ease;
  width: 100%;
  z-index: 3;
  font-family: 'Montserrat', sans-serif;
  font-weight: 500;
}
#tsukie-recently-viewed-{{ section.id }} .tsukie-quick-add-btn:hover {
  background: #1e2a38;
}
#tsukie-recently-viewed-{{ section.id }} .tsukie-product-card:hover .tsukie-quick-add-btn {
  transform: translateY(0);
}
#tsukie-recently-viewed-{{ section.id }} .tsukie-product-card:hover img {
  transform: scale(1.05);
}

/* Load More Button styling (navy background, gold text) */
.tsukie-rv-view-more-btn {
  background: #1e2a38 !important;
  color: #A08766 !important;
  border: none !important;
  font-family: 'Montserrat', sans-serif;
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 2px;
  text-transform: uppercase;
  padding: 14px 40px;
  cursor: pointer;
  transition: all 0.3s ease;
}
.tsukie-rv-view-more-btn:hover {
  opacity: 0.9;
}

/* Hidden items (shown on Load More click) */
@media (min-width: 750px) {
  #tsukie-recently-viewed-{{ section.id }} .product-grid__item.tsukie-rv-hidden {
    display: none;
  }
  #tsukie-recently-viewed-{{ section.id }} .product-grid__item.tsukie-rv-hidden.tsukie-rv-show {
    display: block;
    animation: tsukieRvFadeIn 0.4s ease forwards;
  }
}

@keyframes tsukieRvFadeIn {
  from { opacity: 0; transform: translateY(16px); }
  to { opacity: 1; transform: translateY(0); }
}

@media(max-width: 989px) and (min-width: 750px) {
  #tsukie-recently-viewed-{{ section.id }} ul.product-grid {
    grid-template-columns: repeat(3, 1fr) !important;
    gap: 24px !important;
  }
}
@media(max-width: 749px) {
  #tsukie-recently-viewed-{{ section.id }} .recently-viewed-inner {
    padding: 50px 16px !important;
  }
  #tsukie-recently-viewed-{{ section.id }} ul.product-grid {
    display: flex !important;
    flex-wrap: nowrap !important;
    overflow-x: auto !important;
    scroll-snap-type: x mandatory !important;
    -webkit-overflow-scrolling: touch !important;
    gap: 16px !important;
    padding: 0 16px !important;
    margin: 0 -16px !important;
    scrollbar-width: none !important;
  }
  #tsukie-recently-viewed-{{ section.id }} ul.product-grid::-webkit-scrollbar {
    display: none !important;
  }
  #tsukie-recently-viewed-{{ section.id }} .product-grid__item {
    flex: 0 0 calc(46% - 8px) !important;
    scroll-snap-align: start !important;
  }
  #tsukie-recently-viewed-{{ section.id }} .product-grid__item.tsukie-rv-hidden {
    display: block !important;
  }
  #tsukie-recently-viewed-{{ section.id }} .tsukie-product-badge {
    font-size: 8px !important;
    padding: 4px 8px !important;
    top: 6px !important;
    left: 6px !important;
  }
  #tsukie-recently-viewed-{{ section.id }} .tsukie-quick-add-btn {
    transform: translateY(0);
    padding: 11px;
    font-size: 10px;
  }
  #tsukie-recently-viewed-{{ section.id }} .tsukie-product-title {
    font-size: 15px !important;
  }
  #tsukie-rv-more-wrap-{{ section.id }} {
    display: none !important;
  }
}
</style>

<script>
(function() {
  var sectionId = '{{ section.id }}';

  function hideHeading() {
    var heading = document.querySelector('[id$="__custom_liquid_khNBCT"]');
    if (heading) {
      heading.style.setProperty('display', 'none', 'important');
    }
    var divider = document.querySelector('[id$="__divider_iK6mhf"]');
    if (divider) {
      divider.style.setProperty('display', 'none', 'important');
    }
  }

  function initRecentlyViewed() {
    var container = document.getElementById('tsukie-recently-viewed-' + sectionId);
    if (!container) return;

    var viewedProducts = [];

    // 1. Try reading recentlyViewedProducts
    try {
      var raw = localStorage.getItem('recentlyViewedProducts');
      if (raw) {
        viewedProducts = JSON.parse(raw);
      }
    } catch(e) {
      viewedProducts = [];
    }

    // 2. Fallback to viewedProducts if empty or invalid
    if (!Array.isArray(viewedProducts) || viewedProducts.length === 0) {
      try {
        var rawViewed = localStorage.getItem('viewedProducts');
        if (rawViewed) {
          viewedProducts = JSON.parse(rawViewed);
        }
      } catch(e) {
        viewedProducts = [];
      }
    }

    if (!Array.isArray(viewedProducts) || viewedProducts.length === 0) {
      hideHeading();
      return;
    }

    // If on a product page, filter out the current product
    var currentHandle = '{{ product.handle }}';
    var uniqueHandles = [];

    viewedProducts.forEach(function(item) {
      var handle = '';
      if (item && typeof item === 'object' && item.handle) {
        handle = item.handle;
      } else if (typeof item === 'string' && !/^\d+$/.test(item)) {
        handle = item;
      }
      if (handle && handle !== currentHandle) {
        if (uniqueHandles.indexOf(handle) === -1) {
          uniqueHandles.push(handle);
        }
      }
    });

    if (uniqueHandles.length === 0) {
      hideHeading();
      return;
    }

    // Keep up to 8 unique products
    uniqueHandles = uniqueHandles.slice(0, 8);

    var grid = document.getElementById('tsukie-rv-grid-' + sectionId);
    var moreWrap = document.getElementById('tsukie-rv-more-wrap-' + sectionId);
    var moreBtn = document.getElementById('tsukie-rv-more-btn-' + sectionId);
    if (!grid) return;

    var loadedCount = 0;
    var totalToLoad = uniqueHandles.length;
    var cardElements = new Array(totalToLoad);

    uniqueHandles.forEach(function(handle, index) {
      var productUrl = '/products/' + handle + '?section_id=tsukie-recently-viewed-card';

      fetch(productUrl)
        .then(function(res) { return res.text(); })
        .then(function(html) {
          var parser = new DOMParser();
          var doc = parser.parseFromString(html, 'text/html');
          var card = doc.querySelector('.tsukie-rv-card-wrapper');
          if (card) {
            cardElements[index] = card.innerHTML;
          }
        })
        .catch(function(err) {
          console.warn('Recently viewed fetch error for ' + handle, err);
        })
        .finally(function() {
          loadedCount++;
          if (loadedCount === totalToLoad) {
            renderCards(cardElements, grid, moreWrap, moreBtn);
          }
        });
    });
  }

  function renderCards(cardElements, grid, moreWrap, moreBtn) {
    var hasCards = false;
    var totalRendered = 0;
    var hasHidden = false;

    cardElements.forEach(function(cardHtml, idx) {
      if (cardHtml) {
        var li = document.createElement('li');
        li.className = 'product-grid__item';
        li.style.listStyle = 'none';
        li.innerHTML = cardHtml;

        // First 4 visible, rest hidden
        if (totalRendered >= 4) {
          li.classList.add('tsukie-rv-hidden');
          hasHidden = true;
        }

        grid.appendChild(li);
        hasCards = true;
        totalRendered++;
      }
    });

    if (hasCards) {
      var container = document.getElementById('tsukie-recently-viewed-' + sectionId);
      if (container) container.style.display = 'block';
    } else {
      hideHeading();
    }

    // Show "Load More" button only if there are hidden items
    if (hasHidden && moreWrap && moreBtn) {
      moreWrap.style.display = 'block';

      moreBtn.addEventListener('click', function() {
        var hiddenItems = grid.querySelectorAll('.tsukie-rv-hidden:not(.tsukie-rv-show)');
        hiddenItems.forEach(function(item, i) {
          // Stagger the animation slightly
          setTimeout(function() {
            item.classList.add('tsukie-rv-show');
          }, i * 80);
        });

        // Hide the button after click
        moreWrap.style.display = 'none';
      });
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initRecentlyViewed);
  } else {
    initRecentlyViewed();
  }
})();
</script>

{% schema %}
{
  "name": "Recently Viewed Products",
  "tag": "section",
  "class": "tsukie-recently-viewed-section-wrapper",
  "settings": [
    {
      "type": "header",
      "content": "Custom Section Header"
    },
    {
      "type": "select",
      "id": "header_style",
      "label": "Header Style",
      "options": [
        {
          "value": "none",
          "label": "None (No Header)"
        },
        {
          "value": "simple",
          "label": "Simple Title"
        },
        {
          "value": "premium",
          "label": "Premium Title with Divider"
        }
      ],
      "default": "simple"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Text",
      "default": "JUST EXPLORED"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading Text",
      "default": "Recently Viewed"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext",
      "default": "Seen Before, Loved Again"
    }
  ],
  "presets": [
    {
      "name": "Recently Viewed Products"
    }
  ]
}
{% endschema %}
