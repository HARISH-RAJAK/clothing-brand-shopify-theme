<div class="tsukie-recently-viewed" id="tsukie-recently-viewed-{{ section.id }}" style="display: none;">
  {% if search.performed and search.results.size > 0 %}
    <div class="recently-viewed-inner" style="max-width: 1400px; margin: 0 auto; padding: 80px 40px; background: #f5f1ea;">
      <h2>{{ section.settings.heading }}</h2>
      <ul class="product-grid" style="display:grid; grid-template-columns: repeat(4, 1fr); gap: 32px; list-style:none; padding:0; margin:0;">
        {% for product in search.results limit: 10 %}
          <li class="product-grid__item" data-product-id="{{ product.id }}" style="list-style:none;">
            {% render 'tsukie-product-card', product: product %}
          </li>
        {% endfor %}
      </ul>
    </div>
  {% endif %}
</div>

<style>
#tsukie-recently-viewed-{{ section.id }} h2 {
  font-family: 'Cormorant Garamond', serif !important;
  font-weight: 300 !important;
  color: #1e2a38 !important;
  font-size: 42px !important;
  text-align: center;
  margin: 0 0 40px;
  letter-spacing: normal;
}
#tsukie-recently-viewed-{{ section.id }} .tsukie-product-title {
  font-family: 'Cormorant Garamond', serif !important;
  font-weight: 300 !important;
  color: #1e2a38 !important;
  font-size: 18px !important;
  margin: 0;
  letter-spacing: normal;
  line-height: 1.3;
  text-decoration: none;
  font-style: normal !important;
}
#tsukie-recently-viewed-{{ section.id }} .tsukie-product-badge {
  position: absolute;
  top: 12px;
  left: 12px;
  background: #1e2a38 !important;
  color: #d4c5a9 !important;
  font-family: 'Cormorant Garamond', serif !important;
  font-size: 10px !important;
  font-weight: 500 !important;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  padding: 6px 12px;
  z-index: 2;
  border-radius: 2px;
}
#tsukie-recently-viewed-{{ section.id }} .tsukie-quick-add-btn {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: #1e2a38;
  color: #d4c5a9;
  text-align: center;
  padding: 14px;
  font-size: 11px;
  letter-spacing: 2px;
  text-transform: uppercase;
  border: none;
  cursor: pointer;
  transform: translateY(100%);
  transition: transform 0.3s ease;
  width: 100%;
  z-index: 3;
  font-family: 'Montserrat', sans-serif;
  font-weight: 500;
}
#tsukie-recently-viewed-{{ section.id }} .tsukie-quick-add-btn:hover {
  background: #2a3a4a;
}
#tsukie-recently-viewed-{{ section.id }} .tsukie-product-card:hover .tsukie-quick-add-btn {
  transform: translateY(0);
}
#tsukie-recently-viewed-{{ section.id }} .tsukie-product-card:hover img {
  transform: scale(1.05);
}
@media(max-width: 989px) {
  #tsukie-recently-viewed-{{ section.id }} ul.product-grid {
    grid-template-columns: repeat(3, 1fr) !important;
    gap: 24px !important;
  }
}
@media(max-width: 749px) {
  #tsukie-recently-viewed-{{ section.id }} .recently-viewed-inner {
    padding: 50px 16px !important;
  }
  #tsukie-recently-viewed-{{ section.id }} h2 {
    font-size: 30px !important;
    margin-bottom: 24px !important;
  }
  #tsukie-recently-viewed-{{ section.id }} ul.product-grid {
    grid-template-columns: repeat(2, 1fr) !important;
    gap: 16px !important;
  }
  #tsukie-recently-viewed-{{ section.id }} .tsukie-product-badge {
    font-size: 8px !important;
    padding: 4px 8px !important;
    top: 6px !important;
    left: 6px !important;
  }
  #tsukie-recently-viewed-{{ section.id }} .tsukie-quick-add-btn {
    transform: translateY(0);
    padding: 11px;
    font-size: 10px;
  }
  #tsukie-recently-viewed-{{ section.id }} .tsukie-product-title {
    font-size: 15px !important;
  }
}
</style>

<script>
(function() {
  function initRecentlyViewed() {
    var container = document.getElementById('tsukie-recently-viewed-{{ section.id }}');
    if (!container) return;

    var viewedProducts = JSON.parse(localStorage.getItem('viewedProducts') || '[]');
    
    // If we are on a product page, filter out the current product
    var currentProductId = '{{ product.id }}';
    if (currentProductId) {
      viewedProducts = viewedProducts.filter(function(id) {
        return id !== currentProductId;
      });
    }

    if (viewedProducts.length === 0) return;

    // Build search query for those IDs
    var queryParts = viewedProducts.map(function(id) {
      return 'id:' + id;
    });
    var query = queryParts.join('+OR+');

    var url = '/search?q=' + query + '&type=product&section_id=tsukie-recently-viewed';
    
    fetch(url)
      .then(function(res) { return res.text(); })
      .then(function(html) {
        if (html.trim().length > 0) {
          var parser = new DOMParser();
          var doc = parser.parseFromString(html, 'text/html');
          var newContent = doc.querySelector('.tsukie-recently-viewed');
          if (newContent) {
            var grid = newContent.querySelector('.product-grid');
            if (grid) {
              var items = Array.prototype.slice.call(grid.querySelectorAll('.product-grid__item'));
              
              // Sort items based on the order in viewedProducts
              items.sort(function(a, b) {
                var idA = a.getAttribute('data-product-id');
                var idB = b.getAttribute('data-product-id');
                var indexA = viewedProducts.indexOf(idA);
                var indexB = viewedProducts.indexOf(idB);
                
                // If not found (should not happen), put at the end
                if (indexA === -1) indexA = 999;
                if (indexB === -1) indexB = 999;
                
                return indexA - indexB;
              });
              
              // Clear grid and append only the first 4 items
              grid.innerHTML = '';
              var count = 0;
              items.forEach(function(item) {
                if (count < 4) {
                  grid.appendChild(item);
                  count++;
                }
              });

              if (count > 0) {
                container.innerHTML = newContent.innerHTML;
                container.style.display = 'block';
              }
            }
          }
        }
      })
      .catch(function(err) {
        console.error('Error fetching recently viewed products:', err);
      });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initRecentlyViewed);
  } else {
    initRecentlyViewed();
  }
})();
</script>

{% schema %}
{
  "name": "Recently Viewed Products",
  "tag": "section",
  "class": "tsukie-recently-viewed-section-wrapper",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Recently Viewed"
    }
  ],
  "presets": [
    {
      "name": "Recently Viewed Products"
    }
  ]
}
{% endschema %}
