<div class="tsukie-recently-viewed" id="tsukie-recently-viewed-{{ section.id }}" style="display: none;">
  <div class="recently-viewed-inner" style="max-width: 1400px; margin: 0 auto; padding: 80px 40px; background: #f5f1ea;">
    <h2>{{ section.settings.heading }}</h2>
    <ul class="product-grid" style="display:grid; grid-template-columns: repeat(4, 1fr); gap: 32px; list-style:none; padding:0; margin:0;">
    </ul>
  </div>
</div>

<style>
#tsukie-recently-viewed-{{ section.id }} h2 {
  font-family: 'Cormorant Garamond', serif !important;
  font-weight: 300 !important;
  color: #1e2a38 !important;
  font-size: 42px !important;
  text-align: center;
  margin: 0 0 40px;
  letter-spacing: normal;
}
#tsukie-recently-viewed-{{ section.id }} .tsukie-product-title {
  font-family: 'Cormorant Garamond', serif !important;
  font-weight: 300 !important;
  color: #1e2a38 !important;
  font-size: 18px !important;
  margin: 0;
  letter-spacing: normal;
  line-height: 1.3;
  text-decoration: none;
  font-style: normal !important;
}
#tsukie-recently-viewed-{{ section.id }} .tsukie-product-badge {
  position: absolute;
  top: 12px;
  left: 12px;
  background: #1e2a38 !important;
  color: #d4c5a9 !important;
  font-family: 'Cormorant Garamond', serif !important;
  font-size: 10px !important;
  font-weight: 500 !important;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  padding: 6px 12px;
  z-index: 2;
  border-radius: 2px;
}
#tsukie-recently-viewed-{{ section.id }} .tsukie-quick-add-btn {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: #1e2a38;
  color: #d4c5a9;
  text-align: center;
  padding: 14px;
  font-size: 11px;
  letter-spacing: 2px;
  text-transform: uppercase;
  border: none;
  cursor: pointer;
  transform: translateY(100%);
  transition: transform 0.3s ease;
  width: 100%;
  z-index: 3;
  font-family: 'Montserrat', sans-serif;
  font-weight: 500;
}
#tsukie-recently-viewed-{{ section.id }} .tsukie-quick-add-btn:hover {
  background: #2a3a4a;
}
#tsukie-recently-viewed-{{ section.id }} .tsukie-product-card:hover .tsukie-quick-add-btn {
  transform: translateY(0);
}
#tsukie-recently-viewed-{{ section.id }} .tsukie-product-card:hover img {
  transform: scale(1.05);
}
@media(max-width: 989px) {
  #tsukie-recently-viewed-{{ section.id }} ul.product-grid {
    grid-template-columns: repeat(3, 1fr) !important;
    gap: 24px !important;
  }
}
@media(max-width: 749px) {
  #tsukie-recently-viewed-{{ section.id }} .recently-viewed-inner {
    padding: 50px 16px !important;
  }
  #tsukie-recently-viewed-{{ section.id }} h2 {
    font-size: 30px !important;
    margin-bottom: 24px !important;
  }
  #tsukie-recently-viewed-{{ section.id }} ul.product-grid {
    grid-template-columns: repeat(2, 1fr) !important;
    gap: 16px !important;
  }
  #tsukie-recently-viewed-{{ section.id }} .tsukie-product-badge {
    font-size: 8px !important;
    padding: 4px 8px !important;
    top: 6px !important;
    left: 6px !important;
  }
  #tsukie-recently-viewed-{{ section.id }} .tsukie-quick-add-btn {
    transform: translateY(0);
    padding: 11px;
    font-size: 10px;
  }
  #tsukie-recently-viewed-{{ section.id }} .tsukie-product-title {
    font-size: 15px !important;
  }
}
</style>

<script>
(function() {
  function initRecentlyViewed() {
    var container = document.getElementById('tsukie-recently-viewed-{{ section.id }}');
    if (!container) return;

    var viewedRaw = localStorage.getItem('viewedProducts');
    if (!viewedRaw) return;

    var viewedProducts;
    try {
      viewedProducts = JSON.parse(viewedRaw);
    } catch(e) { return; }

    if (!Array.isArray(viewedProducts) || viewedProducts.length === 0) return;

    // If on a product page, filter out the current product
    var currentHandle = '{{ product.handle }}';
    if (currentHandle) {
      viewedProducts = viewedProducts.filter(function(item) {
        if (typeof item === 'object' && item.handle) return item.handle !== currentHandle;
        if (typeof item === 'string') return true; // old format, keep but won't be used
        return true;
      });
    }

    // Only take items that have handle info (new format: {id, handle})
    var validItems = viewedProducts.filter(function(item) {
      return typeof item === 'object' && item.handle;
    });

    if (validItems.length === 0) return;

    // Limit to 4 products
    validItems = validItems.slice(0, 4);

    var grid = container.querySelector('.product-grid');
    if (!grid) return;

    var loadedCount = 0;
    var totalToLoad = validItems.length;
    var cardElements = new Array(totalToLoad);

    validItems.forEach(function(item, index) {
      // Use Section Rendering API: fetch product page with our card section
      var productUrl = '/products/' + item.handle + '?section_id=tsukie-recently-viewed-card';

      fetch(productUrl)
        .then(function(res) { return res.text(); })
        .then(function(html) {
          var parser = new DOMParser();
          var doc = parser.parseFromString(html, 'text/html');
          var card = doc.querySelector('.tsukie-rv-card-wrapper');
          if (card) {
            cardElements[index] = card.innerHTML;
          }
        })
        .catch(function(err) {
          console.warn('Recently viewed fetch error for ' + item.handle, err);
        })
        .finally(function() {
          loadedCount++;
          if (loadedCount === totalToLoad) {
            // All fetches done, render in order
            var hasCards = false;
            cardElements.forEach(function(cardHtml) {
              if (cardHtml) {
                var li = document.createElement('li');
                li.className = 'product-grid__item';
                li.style.listStyle = 'none';
                li.innerHTML = cardHtml;
                grid.appendChild(li);
                hasCards = true;
              }
            });
            if (hasCards) {
              container.style.display = 'block';
            }
          }
        });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initRecentlyViewed);
  } else {
    initRecentlyViewed();
  }
})();
</script>

{% schema %}
{
  "name": "Recently Viewed Products",
  "tag": "section",
  "class": "tsukie-recently-viewed-section-wrapper",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Recently Viewed"
    }
  ],
  "presets": [
    {
      "name": "Recently Viewed Products"
    }
  ]
}
{% endschema %}
