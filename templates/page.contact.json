      "settings": {
        "custom_liquid": "{% comment %}\n  Contact Page Address Section - Reduced Padding\n{% endcomment %}\n\n<style>\n.tsukie-contact-address{\n  background:#f5f1ea;\n  padding:40px 20px;\n  text-align:center;\n}\n.tsukie-address-block{\n  max-width:600px;\n  margin:0 auto;\n}\n.tsukie-address-label{\n  font-family:'Montserrat',sans-serif;\n  font-size:11px;\n  letter-spacing:2px;\n  text-transform:uppercase;\n  color:#a08766;\n  font-weight:500;\n  margin-bottom:16px;\n}\n.tsukie-address-text{\n  font-family:'Montserrat',sans-serif;\n  font-size:14px;\n  line-height:1.8;\n  color:#1e2a38;\n  font-weight:400;\n  letter-spacing:0.5px;\n}\n.tsukie-address-text p{\n  margin:0 0 6px;\n}\n\n@media(max-width:749px){\n  .tsukie-contact-address{\n    padding:30px 20px;\n  }\n  .tsukie-address-text{\n    font-size:13px;\n  }\n}\n</style>\n\n<div class=\"tsukie-contact-address\">\n  <div class=\"tsukie-address-block\">\n    <div class=\"tsukie-address-label\">Our Location</div>\n    <div class=\"tsukie-address-text\">\n      <p>301/C, Abhishek Complex, Asarwa Road</p>\n      <p>Ahmedabad, Gujarat – 380016</p>\n      <p>India</p>\n    </div>\n  </div>\n</div>",
        "color_scheme": "scheme-e5234ede-d196-4b3b-a9e2-6e7d24b8ca5c",
