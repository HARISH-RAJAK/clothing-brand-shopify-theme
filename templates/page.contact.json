    "custom_liquid_UEQKH4": {
      "type": "custom-liquid",
      "name": "t:names.custom_liquid",
      "settings": {
        "custom_liquid": "<style>\n.tsukie-contact-hero{\n  background:#f5f1ea;\n  padding:70px 40px 60px;\n  text-align:center;\n}\n.tsukie-contact-eyebrow{\n  font-family:'Montserrat',sans-serif;\n  font-size:11px;\n  letter-spacing:4px;\n  text-transform:uppercase;\n  color:#a08766;\n  margin:0 0 18px;\n  font-weight:600;\n}\n.tsukie-contact-title{\n  font-family:'Playfair Display',serif;\n  font-size:64px;\n  font-weight:600;\n  font-style:italic;\n  margin:0 0 24px;\n  background:linear-gradient(135deg, #1e2a38 0%, #a08766 30%, #c9a77c 50%, #a08766 70%, #1e2a38 100%);\n  -webkit-background-clip:text;\n  -webkit-text-fill-color:transparent;\n  background-clip:text;\n  line-height:1.1;\n}\n.tsukie-contact-subtitle{\n  font-family:'Cormorant Garamond',serif;\n  font-size:20px;\n  font-style:italic;\n  color:#5a5a5a;\n  margin:0 0 30px;\n  line-height:1.6;\n}\n.tsukie-contact-divider{\n  display:flex;\n  align-items:center;\n  justify-content:center;\n  gap:14px;\n  max-width:340px;\n  margin:0 auto;\n}\n.tsukie-contact-line{\n  flex:1;\n  height:1px;\n  background:linear-gradient(90deg, transparent, #a08766, transparent);\n}\n.tsukie-contact-icon{\n  font-size:18px;\n  color:#a08766;\n}\n@media(max-width:749px){\n.tsukie-contact-hero{padding:50px 20px 45px}\n.tsukie-contact-title{font-size:42px}\n.tsukie-contact-subtitle{font-size:18px}\n}\n</style>\n\n<div class=\"tsukie-contact-hero\">\n  <p class=\"tsukie-contact-eyebrow\">Get In Touch</p>\n  <h1 class=\"tsukie-contact-title\">Contact Us</h1>\n  <p class=\"tsukie-contact-subtitle\">We'd love to hear from you</p>\n  <div class=\"tsukie-contact-divider\">\n    <span class=\"tsukie-contact-line\"></span>\n    <span class=\"tsukie-contact-icon\">✦</span>\n    <span class=\"tsukie-contact-line\"></span>\n  </div>\n</div>",
        "color_scheme": "scheme-e5234ede-d196-4b3b-a9e2-6e7d24b8ca5c",
