      "settings": {
        "custom_liquid": "<style>\n@import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600&display=swap');\n\n.tsukie-collection-toolbar{\n  background:#f5f1ea;\n  border-bottom:1px solid #e0d9cd;\n  position:relative;\n  z-index:9;\n  margin-bottom:0;\n}\n.tsukie-toolbar-inner{\n  max-width:1400px;\n  margin:0 auto;\n  padding:0 40px;\n  display:flex;\n  justify-content:space-between;\n  align-items:center;\n  min-height:58px;\n  gap:24px;\n}\n.tsukie-filters-left{\n  display:flex;\n  align-items:center;\n  gap:24px;\n}\n.tsukie-filter-wrapper{\n  display:flex;\n  align-items:center;\n  gap:8px;\n}\n.tsukie-filter-label{\n  font-size:12px;\n  color:#1e2a38;\n  letter-spacing:1.5px;\n  text-transform:uppercase;\n  font-weight:600;\n  font-family:'Montserrat',sans-serif;\n}\n.tsukie-filter-select{\n  border:none;\n  background:transparent;\n  font-size:12px;\n  color:#1e2a38;\n  letter-spacing:1.5px;\n  text-transform:uppercase;\n  font-weight:600;\n  cursor:pointer;\n  padding:0;\n  font-family:'Montserrat',sans-serif;\n}\n.tsukie-filter-select:focus{\n  outline:none;\n}\n.tsukie-toolbar-right{\n  display:flex;\n  align-items:center;\n  gap:24px;\n}\n.tsukie-items-text{\n  font-size:12px;\n  color:#5a5a5a;\n  letter-spacing:0.5px;\n  font-family:'Montserrat',sans-serif;\n}\n.tsukie-items-text strong{\n  color:#1e2a38;\n  font-weight:600;\n}\n.tsukie-sort-wrapper{\n  display:flex;\n  align-items:center;\n  gap:8px;\n}\n.tsukie-sort-label{\n  font-size:12px;\n  color:#1e2a38;\n  letter-spacing:1.5px;\n  text-transform:uppercase;\n  font-weight:600;\n  font-family:'Montserrat',sans-serif;\n}\n.tsukie-sort-select{\n  border:none;\n  background:transparent;\n  font-size:12px;\n  color:#1e2a38;\n  letter-spacing:1.5px;\n  text-transform:uppercase;\n  font-weight:600;\n  cursor:pointer;\n  padding:0;\n  font-family:'Montserrat',sans-serif;\n}\n.tsukie-sort-select:focus{\n  outline:none;\n}\n\n/* Mobile Responsive Fix */\n@media(max-width:749px){\n.tsukie-collection-toolbar{\n  z-index:5;\n}\n.tsukie-toolbar-inner{\n  padding:12px 16px;\n  flex-direction:column;\n  gap:0;\n  min-height:auto;\n}\n.tsukie-filters-left{\n  width:100%;\n  justify-content:space-between;\n  padding-bottom:12px;\n  border-bottom:1px solid #e0d9cd;\n  gap:12px;\n}\n.tsukie-filter-wrapper{\n  flex:1;\n  flex-direction:column;\n  align-items:flex-start;\n  gap:4px;\n}\n.tsukie-filter-label{\n  font-size:10px;\n  letter-spacing:1px;\n}\n.tsukie-filter-select{\n  font-size:11px;\n  width:100%;\n  letter-spacing:0.5px;\n}\n.tsukie-toolbar-right{\n  width:100%;\n  justify-content:space-between;\n  padding-top:12px;\n  gap:12px;\n}\n.tsukie-items-text{\n  font-size:11px;\n}\n.tsukie-sort-wrapper{\n  flex-direction:column;\n  align-items:flex-end;\n  gap:4px;\n}\n.tsukie-sort-label{\n  font-size:10px;\n  letter-spacing:1px;\n}\n.tsukie-sort-select{\n  font-size:11px;\n  text-align:right;\n  letter-spacing:0.5px;\n}\n}\n\n@media(max-width:380px){\n.tsukie-filters-left{\n  flex-direction:column;\n  gap:10px;\n  padding-bottom:10px;\n}\n.tsukie-filter-wrapper{\n  width:100%;\n  flex-direction:row;\n  justify-content:space-between;\n}\n.tsukie-filter-select{\n  width:auto;\n}\n}\n</style>\n\n<div class=\"tsukie-collection-toolbar\">\n  <div class=\"tsukie-toolbar-inner\">\n    <div class=\"tsukie-filters-left\">\n      <div class=\"tsukie-filter-wrapper\">\n        <span class=\"tsukie-filter-label\">AVAILABILITY:</span>\n        <select class=\"tsukie-filter-select\" id=\"tsukieAvailSelect\">\n          <option value=\"\">ALL</option>\n          <option value=\"1\">IN STOCK</option>\n          <option value=\"0\">OUT OF STOCK</option>\n        </select>\n      </div>\n\n      <div class=\"tsukie-filter-wrapper\">\n        <span class=\"tsukie-filter-label\">PRICE:</span>\n        <select class=\"tsukie-filter-select\" id=\"tsukiePriceSelect\">\n          <option value=\"\">ALL PRICES</option>\n          <option value=\"0-999\">UNDER ₹999</option>\n          <option value=\"999-1999\">₹999 - ₹1,999</option>\n          <option value=\"1999-4999\">₹1,999 - ₹4,999</option>\n          <option value=\"4999-\">ABOVE ₹4,999</option>\n        </select>\n      </div>\n    </div>\n\n    <div class=\"tsukie-toolbar-right\">\n      <span class=\"tsukie-items-text\"><strong>{{ collection.products_count }}</strong> ITEMS</span>\n      <div class=\"tsukie-sort-wrapper\">\n        <span class=\"tsukie-sort-label\">SORT:</span>\n        <select class=\"tsukie-sort-select\" id=\"tsukieSortSelect\">\n          <option value=\"\">FEATURED</option>\n          <option value=\"best-selling\">BEST SELLING</option>\n          <option value=\"price-ascending\">PRICE: LOW TO HIGH</option>\n          <option value=\"price-descending\">PRICE: HIGH TO LOW</option>\n          <option value=\"created-descending\">NEWEST</option>\n        </select>\n      </div>\n    </div>\n  </div>\n</div>\n\n<script>\n// Availability Filter\ndocument.getElementById('tsukieAvailSelect').addEventListener('change', function(){\n  const url = new URL(window.location);\n  if(this.value) {\n    url.searchParams.set('filter.v.availability', this.value);\n  } else {\n    url.searchParams.delete('filter.v.availability');\n  }\n  window.location = url.toString();\n});\n\n// Price Filter\ndocument.getElementById('tsukiePriceSelect').addEventListener('change', function(){\n  const url = new URL(window.location);\n  if(this.value){\n    const [min, max] = this.value.split('-');\n    url.searchParams.set('filter.v.price.gte', min);\n    if(max) url.searchParams.set('filter.v.price.lte', max);\n    else url.searchParams.delete('filter.v.price.lte');\n  } else {\n    url.searchParams.delete('filter.v.price.gte');\n    url.searchParams.delete('filter.v.price.lte');\n  }\n  window.location = url.toString();\n});\n\n// Sort\ndocument.getElementById('tsukieSortSelect').addEventListener('change', function(){\n  const url = new URL(window.location);\n  if(this.value) url.searchParams.set('sort_by', this.value);\n  else url.searchParams.delete('sort_by');\n  window.location = url.toString();\n});\n\n// Set active values on load\n(function(){\n  const params = new URLSearchParams(window.location.search);\n  \n  const avail = params.get('filter.v.availability');\n  if(avail) document.getElementById('tsukieAvailSelect').value = avail;\n  \n  const priceMin = params.get('filter.v.price.gte');\n  const priceMax = params.get('filter.v.price.lte');\n  if(priceMin){\n    let priceVal = priceMin + '-';\n    if(priceMax) priceVal = priceMin + '-' + priceMax;\n    document.getElementById('tsukiePriceSelect').value = priceVal;\n  }\n  \n  const sort = params.get('sort_by');\n  if(sort) document.getElementById('tsukieSortSelect').value = sort;\n})();\n</script>",
