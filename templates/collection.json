        "custom_liquid": "<style>\n@import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@1,400;1,600&family=Montserrat:wght@300;400;500;600&display=swap');\n\n.tsukie-collection-hero{\n  background:#f5f1ea;\n  padding:80px 0 70px;\n  position:relative;\n  overflow:hidden;\n}\n.tsukie-collection-inner{\n  max-width:1400px;\n  margin:0 auto;\n  padding:0 40px;\n  position:relative;\n  z-index:2;\n}\n.tsukie-collection-breadcrumb{\n  font-size:11px;\n  letter-spacing:2px;\n  text-transform:uppercase;\n  color:#a08766;\n  margin:0 0 20px;\n  font-weight:500;\n  font-family:'Montserrat',sans-serif;\n}\n.tsukie-collection-breadcrumb a{\n  color:#a08766;\n  text-decoration:none;\n}\n.tsukie-collection-breadcrumb span{\n  margin:0 8px;\n  color:#c4b59d;\n}\n.tsukie-collection-content{\n  display:flex;\n  align-items:flex-end;\n  justify-content:space-between;\n  gap:40px;\n}\n.tsukie-collection-text{\n  flex:1;\n}\n.tsukie-collection-title{\n  font-family:'Playfair Display',serif;\n  font-size:68px;\n  line-height:1;\n  font-weight:600;\n  font-style:italic;\n  margin:0 0 16px;\n  \ncolor:#1e2a38;\n  \n}\n.tsukie-collection-desc{\n  font-size:15px;\n  line-height:1.7;\n  color:#6b6b6b;\n  margin:0;\n  max-width:520px;\n  font-family:'Montserrat',sans-serif;\n}\n.tsukie-collection-count{\n  font-size:12px;\n  letter-spacing:2px;\n  text-transform:uppercase;\n  color:#1a1a1a;\n  font-weight:500;\n  white-space:nowrap;\n  padding-bottom:8px;\n  border-bottom:1px solid #1a1a1a;\n  font-family:'Montserrat',sans-serif;\n}\n.tsukie-collection-image{\n  position:absolute;\n  right:0;\n  top:0;\n  bottom:0;\n  width:35%;\n  opacity:0.15;\n}\n.tsukie-collection-image img{\n  width:100%;\n  height:100%;\n  object-fit:cover;\n}\n@media(max-width:989px){\n.tsukie-collection-content{flex-direction:column;align-items:flex-start;gap:20px}\n.tsukie-collection-image{display:none}\n}\n@media(max-width:749px){\n.tsukie-collection-hero{padding:60px 0 50px}\n.tsukie-collection-inner{padding:0 20px}\n.tsukie-collection-title{font-size:48px}\n.tsukie-collection-desc{font-size:14px}\n}\n</style>\n\n<div class=\"tsukie-collection-hero\">\n  {% if collection.image %}\n  <div class=\"tsukie-collection-image\">\n    <img \n      src=\"{{ collection.image | image_url: width: 800 }}\" \n      alt=\"{{ collection.title | escape }}\"\n      loading=\"lazy\"\n    >\n  </div>\n  {% endif %}\n  \n  <div class=\"tsukie-collection-inner\">\n    <div class=\"tsukie-collection-breadcrumb\">\n      <a href=\"/\">Home</a>\n      <span>/</span>\n      <a href=\"/collections\">Shop All</a>\n      <span>/</span>\n      {{ collection.title }}\n    </div>\n    \n    <div class=\"tsukie-collection-content\">\n      <div class=\"tsukie-collection-text\">\n        <h1 class=\"tsukie-collection-title\">{{ collection.title }}</h1>\n        {% if collection.description != blank %}\n        <p class=\"tsukie-collection-desc\">{{ collection.description | strip_html | truncate: 180 }}</p>\n        {% endif %}\n      </div>\n      \n      <div class=\"tsukie-collection-count\">\n        {{ collection.products_count }} {% if collection.products_count == 1 %}Item{% else %}Items{% endif %}\n      </div>\n    </div>\n  </div>\n</div>",
