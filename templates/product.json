    "custom_liquid_style_it_with_header": {
      "type": "custom-liquid",
      "disabled": true,
      "name": "Style It With Header",
      "settings": {
        "custom_liquid": "<style>\n.tsukie-section-header{\n  text-align:center;\n  padding:60px 40px 48px;\n  background:linear-gradient(180deg, #fff 0%, #f5f1ea 100%);\n  position:relative;\n  overflow:hidden;\n}\n.tsukie-section-header::before{\n  content:'';\n  position:absolute;\n  top:0;\n  left:50%;\n  transform:translateX(-50%);\n  width:200px;\n  height:200px;\n  background:radial-gradient(circle, rgba(160,135,102,0.08) 0%, transparent 70%);\n  pointer-events:none;\n}\n.tsukie-header-eyebrow{\n  font-size:11px;\n  letter-spacing:4px;\n  text-transform:uppercase;\n  color:#a08766;\n  margin:0 0 16px;\n  font-weight:600;\n  position:relative;\n}\n.tsukie-header-title{\n  font-family:'Playfair Display',serif;\n  font-size:58px;\n  font-weight:600;\n  font-style:italic;\n  margin:0 0 20px;\n  color:#1e2a38;\n  line-height:1.1;\n  position:relative;\n}\n.tsukie-header-divider{\n  display:flex;\n  align-items:center;\n  justify-content:center;\n  gap:12px;\n  margin:0 auto;\n}\n.tsukie-header-line{\n  width:80px;\n  height:1px;\n  background:linear-gradient(90deg, transparent, #a08766, transparent);\n}\n.tsukie-header-icon{\n  font-size:14px;\n  color:#a08766;\n}\n.tsukie-header-subtitle{\n  font-family:'Cormorant Garamond',serif;\n  font-size:18px;\n  font-style:italic;\n  color:#6b6b6b;\n  margin:16px 0 0;\n  letter-spacing:0.5px;\n}\n@media(max-width:749px){\n.tsukie-section-header{padding:50px 20px 40px}\n.tsukie-header-title{font-size:40px}\n.tsukie-header-subtitle{font-size:16px}\n}\n</style>\n\n<div class=\"tsukie-section-header\" id=\"tsukie-style-it-with-header\">\n  <p class=\"tsukie-header-eyebrow\">Pair It Perfectly</p>\n  <h2 class=\"tsukie-header-title\">Style It With</h2>\n  <div class=\"tsukie-header-divider\">\n    <span class=\"tsukie-header-line\"></span>\n    <span class=\"tsukie-header-icon\">✦</span>\n    <span class=\"tsukie-header-line\"></span>\n  </div>\n  <p class=\"tsukie-header-subtitle\">Curated selections to complete your ensemble</p>\n</div>\n\n<script>\n(function() {\n  function checkRecommendations() {\n    const recsSection = document.querySelector('[id*=\"style_it_with_recommendations\"]');\n    const header = document.getElementById('tsukie-style-it-with-header');\n    const headerSection = header ? header.closest('.shopify-section') : null;\n    \n    if (recsSection && header) {\n      const isLoaded = recsSection.querySelector('.resource-list') || recsSection.querySelector('.resource-list__item');\n      if (isLoaded) {\n        const products = recsSection.querySelectorAll('.resource-list__item, product-card, .product-card, a[href*=\"/products/\"]');\n        const hasRecsAttr = recsSection.querySelector('[data-has-recommendations=\"false\"]');\n        \n        if (products.length === 0 || hasRecsAttr) {\n          if (headerSection) headerSection.style.setProperty('display', 'none', 'important');\n          recsSection.style.setProperty('display', 'none', 'important');\n        } else {\n          if (headerSection) headerSection.style.display = '';\n          recsSection.style.display = '';\n        }\n      }\n    }\n  }\n\n  const observer = new MutationObserver(function(mutations) {\n    checkRecommendations();\n  });\n\n  document.addEventListener('DOMContentLoaded', function() {\n    checkRecommendations();\n    const target = document.querySelector('[id*=\"style_it_with_recommendations\"]');\n    if (target) {\n      observer.observe(target, { childList: true, subtree: true, attributes: true });\n    }\n  });\n\n  setTimeout(function() {\n    checkRecommendations();\n  }, 3000);\n})();\n</script>",
        "color_scheme": "",
        "section_width": "full-width",
        "padding-block-start": 0,
        "padding-block-end": 0
      }
