      "name": "t:names.custom_liquid",
      "settings": {
        "custom_liquid": "<style>\n.tsukie-thumbs-only{\n  display:flex;\n  gap:12px;\n  overflow-x:auto;\n  padding:16px 0 8px;\n  margin-top:16px;\n}\n.tsukie-thumbs-only::-webkit-scrollbar{\n  height:4px;\n}\n.tsukie-thumbs-only::-webkit-scrollbar-thumb{\n  background:#a08766;\n  border-radius:4px;\n}\n.tsukie-thumb-btn{\n  flex:0 0 80px;\n  aspect-ratio:3/4;\n  border:2px solid transparent;\n  cursor:pointer;\n  transition:all 0.3s ease;\n  background:#f5f1ea;\n  padding:0;\n}\n.tsukie-thumb-btn img{\n  width:100%;\n  height:100%;\n  object-fit:cover;\n  display:block;\n}\n.tsukie-thumb-btn:hover{\n  border-color:#a08766;\n}\n.tsukie-thumb-btn.active{\n  border-color:#1a1a1a;\n}\n@media(max-width:749px){\n.tsukie-thumb-btn{flex:0 0 64px}\n}\n</style>\n\n{% if product.images.size > 1 %}\n<div class=\"tsukie-thumbs-only\">\n  {% for image in product.images %}\n  <button \n    class=\"tsukie-thumb-btn {% if forloop.first %}active{% endif %}\" \n    data-image=\"{{ image | image_url: width: 1200 }}\"\n    onclick=\"tsukieThumbClick(this)\"\n    type=\"button\"\n  >\n    <img \n      src=\"{{ image | image_url: width: 200 }}\" \n      alt=\"{{ product.title | escape }} - {{ forloop.index }}\"\n      loading=\"lazy\"\n    >\n  </button>\n  {% endfor %}\n</div>\n\n<script>\nfunction tsukieThumbClick(btn){\n  let mainImg = document.querySelector('.product__media img, .product-media img, .product-single__photo img, [data-main-product-image]');\n  if(mainImg){\n    mainImg.src = btn.dataset.image;\n    mainImg.srcset = btn.dataset.image;\n  }\n  document.querySelectorAll('.tsukie-thumb-btn').forEach(t => t.classList.remove('active'));\n  btn.classList.add('active');\n}\n</script>\n{% endif %}",
