            "custom_liquid_kTrGwz": {
              "type": "custom-liquid",
              "name": "t:names.custom_liquid",
              "settings": {
                "custom_liquid": "{% liquid\n  assign product_resource = closest.product\n  if request.visual_preview_mode and product_resource == blank\n    assign product_resource = collections.all.products.first\n  endif\n-%}\n\n{% unless product_resource == blank %}\n  {%- assign color_option = product_resource.options_with_values | where: 'name', 'Color' | first -%}\n  {%- if color_option == blank -%}\n    {%- assign color_option = product_resource.options_with_values | where: 'name', 'Colour' | first -%}\n  {%- endif -%}\n\n  {% if color_option and color_option.values.size > 1 %}\n    <style>\n    .tsukie-block-colorpicker{\n      margin-top:16px;\n      margin-bottom:16px;\n    }\n    .tsukie-block-color-label{\n      display: none;\n\n      display: none;\n\n      font-size:11px;\n      letter-spacing:2px;\n      text-transform:uppercase;\n      color:#1a1a1a;\n      margin:0 0 10px;\n      font-weight:500;\n    }\n    .tsukie-block-color-label span{\n      color:#6b6b6b;\n      font-weight:400;\n      margin-left:4px;\n    }\n    .tsukie-block-swatches{\n      display:flex;\n      flex-wrap:wrap;\n      gap:8px;\n    }\n    .tsukie-block-swatch{\n      width:32px;\n      height:32px;\n      border-radius:50%;\n      border:2px solid #e5e5e5;\n      cursor:pointer;\n      position:relative;\n      background-color:var(--swatch-color);\n      padding:0;\n      overflow:hidden;\n      transition:all 0.2s ease;\n    }\n    .tsukie-block-swatch:hover{\n      border-color:#a08766;\n      transform:scale(1.08);\n    }\n    .tsukie-block-swatch.active{\n      border-color:#1a1a1a;\n      box-shadow:0 0 0 1px #1a1a1a;\n    }\n    .tsukie-block-swatch img{\n      width:100%;\n      height:100%;\n      object-fit:cover;\n    }\n    </style>\n\n    <div class=\"tsukie-block-colorpicker\">\n      <p class=\"tsukie-block-color-label\">\n        COLOR:<span id=\"tsukie-block-selected-{{ section.id }}\">{{ product_resource.selected_or_first_available_variant.option1 }}</span>\n      </p>\n      \n      <div class=\"tsukie-block-swatches\">\n        {% for value in color_option.values %}\n          {%- liquid\n            assign variant_for_color = blank\n            assign color_downcase = value | downcase\n            \n            for variant in product_resource.variants\n              if variant.option1 == value or variant.option2 == value or variant.option3 == value\n                assign variant_for_color = variant\n                break\n              endif\n            endfor\n            \n            assign bg_color = color_downcase | replace: ' ', ''\n            case color_downcase\n              when 'navy blue' \n                assign bg_color = '#001f3f'\n              when 'off white' \n                assign bg_color = '#f8f8f8'\n              when 'beige' \n                assign bg_color = '#f5f1ea'\n              when 'black' \n                assign bg_color = '#000000'\n              when 'white' \n                assign bg_color = '#ffffff'\n            endcase\n          -%}\n          \n          <button \n            class=\"tsukie-block-swatch {% if product_resource.selected_or_first_available_variant.id == variant_for_color.id %}active{% endif %}\"\n            data-variant-id=\"{{ variant_for_color.id }}\"\n            data-color-name=\"{{ value }}\"\n            type=\"button\"\n            style=\"--swatch-color: {{ bg_color }}\"\n            onclick=\"tsukieBlockColorSelect{{ section.id }}(this)\"\n            title=\"{{ value }}\"\n          >\n            {% if variant_for_color.featured_image %}\n              <img \n                src=\"{{ variant_for_color.featured_image | image_url: width: 80 }}\" \n                alt=\"{{ value }}\"\n                loading=\"lazy\"\n              >\n            {% endif %}\n          </button>\n        {% endfor %}\n      </div>\n    </div>\n\n    <script>\n    function tsukieBlockColorSelect{{ section.id }}(btn){\n      document.querySelectorAll('#shopify-section-{{ section.id }} .tsukie-block-swatch').forEach(s => s.classList.remove('active'));\n      btn.classList.add('active');\n      \n      document.getElementById('tsukie-block-selected-{{ section.id }}').textContent = btn.dataset.colorName;\n      \n      let variantInput = document.querySelector('form[action*=\"/cart/add\"] input[name=\"id\"]');\n      if(variantInput && btn.dataset.variantId){\n        variantInput.value = btn.dataset.variantId;\n        variantInput.dispatchEvent(new Event('change', {bubbles: true}));\n      }\n    }\n    </script>\n  {% endif %}\n{% endunless %}"
