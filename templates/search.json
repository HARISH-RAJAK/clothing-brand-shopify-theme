{
  "sections": {
    "custom_liquid_DY6aLL": {
      "type": "custom-liquid",
      "name": "t:names.custom_liquid",
      "settings": {
        "custom_liquid": "<style>\n.tsukie-search-wrap{\n  background:#f5f1ea;\n  padding:60px 40px 40px;\n  border-bottom:1px solid #d4c5a9;\n}\n.tsukie-search-container{\n  max-width:1400px;\n  margin:0 auto;\n}\n.tsukie-search-head{\n  text-align:center;\n  margin-bottom:40px;\n}\n.tsukie-search-label{\n  font-size:11px;\n  letter-spacing:3px;\n  text-transform:uppercase;\n  color:#a08766;\n  margin:0 0 10px;\n  font-weight:600;\n}\n.tsukie-search-title{\n  font-family:'Playfair Display',serif;\n  font-size:46px;\n  font-weight:600;\n  font-style:italic;\n  margin:0 0 12px;\n  color:#1e2a38;\n  line-height:1.2;\n}\n.tsukie-search-count-text{\n  font-size:14px;\n  color:#5a5a5a;\n  margin:0 0 32px;\n}\n.tsukie-search-count-text strong{\n  color:#1e2a38;\n  font-weight:600;\n}\n.tsukie-search-form-box{\n  max-width:600px;\n  margin:0 auto;\n  position:relative;\n}\n.tsukie-search-input-main{\n  width:100%;\n  padding:18px 55px;\n  border:2px solid #d4c5a9;\n  background:#fdfbf7;\n  font-size:15px;\n  color:#1e2a38;\n  border-radius:50px;\n  font-family:'Times New Roman',serif;\n  transition:all 0.3s ease;\n}\n.tsukie-search-input-main:focus{\n  outline:none;\n  border-color:#a08766;\n  background:#fff;\n  box-shadow:0 4px 20px rgba(160,135,102,0.15);\n}\n.tsukie-search-icon{\n  position:absolute;\n  left:22px;\n  top:50%;\n  transform:translateY(-50%);\n  color:#a08766;\n  font-size:18px;\n  pointer-events:none;\n}\n.tsukie-search-clear{\n  position:absolute;\n  right:22px;\n  top:50%;\n  transform:translateY(-50%);\n  background:#d4c5a9;\n  border:none;\n  color:#1e2a38;\n  cursor:pointer;\n  font-size:16px;\n  width:26px;\n  height:26px;\n  border-radius:50%;\n  line-height:1;\n  font-weight:700;\n}\n.tsukie-search-clear:hover{\n  background:#a08766;\n  color:#fff;\n}\n.tsukie-filters-simple{\n  max-width:1400px;\n  margin:32px auto 0;\n  padding:0 40px;\n  display:flex;\n  justify-content:center;\n  gap:12px;\n  flex-wrap:wrap;\n}\n.tsukie-filter-select{\n  padding:12px 20px;\n  border:1.5px solid #d4c5a9;\n  background:#fdfbf7;\n  font-size:12px;\n  letter-spacing:1px;\n  text-transform:uppercase;\n  color:#1e2a38;\n  cursor:pointer;\n  border-radius:25px;\n  font-weight:600;\n  font-family:'Times New Roman',serif;\n  transition:all 0.3s ease;\n  min-width:140px;\n}\n.tsukie-filter-select:hover{\n  background:#1e2a38;\n  color:#d4c5a9;\n  border-color:#1e2a38;\n}\n.tsukie-filter-select:focus{\n  outline:none;\n  border-color:#a08766;\n}\n@media(max-width:749px){\n.tsukie-search-wrap{padding:40px 20px 30px}\n.tsukie-search-title{font-size:32px}\n.tsukie-filters-simple{padding:0 20px;flex-direction:column}\n.tsukie-filter-select{width:100%}\n}\n</style>\n\n<div class=\"tsukie-search-wrap\">\n  <div class=\"tsukie-search-container\">\n    <div class=\"tsukie-search-head\">\n      <p class=\"tsukie-search-label\">Search Our Collection</p>\n      <h1 class=\"tsukie-search-title\">\n        {% if search.performed and search.terms!= blank %}\n          Search Results\n        {% else %}\n          Discover Your Style\n        {% endif %}\n      </h1>\n      \n      {% if search.performed %}\n        <p class=\"tsukie-search-count-text\">\n          {% if search.results_count > 0 %}\n            Found <strong>{{ search.results_count }}</strong> {% if search.results_count == 1 %}item{% else %}items{% endif %} for \"<strong>{{ search.terms | escape }}</strong>\"\n          {% else %}\n            No results for \"<strong>{{ search.terms | escape }}</strong>\"\n          {% endif %}\n        </p>\n      {% endif %}\n    </div>\n\n    <div class=\"tsukie-search-form-box\">\n      <form action=\"{{ routes.search_url }}\" method=\"get\" id=\"tsukieSearchForm\">\n        <span class=\"tsukie-search-icon\">⌕</span>\n        <input \n          type=\"search\" \n          name=\"q\" \n          value=\"{{ search.terms | escape }}\"\n          placeholder=\"Search dresses, co-ords, tops...\"\n          class=\"tsukie-search-input-main\"\n          autocomplete=\"off\"\n        >\n        {% if search.terms!= blank %}\n          <button type=\"button\" class=\"tsukie-search-clear\" onclick=\"window.location='{{ routes.search_url }}'\">×</button>\n        {% endif %}\n        <input type=\"hidden\" name=\"type\" value=\"product\">\n      </form>\n    </div>\n\n    {% if search.performed and search.results_count > 0 %}\n    <div class=\"tsukie-filters-simple\">\n      <select class=\"tsukie-filter-select\" onchange=\"updateFilter('availability', this.value)\">\n        <option value=\"\">Availability</option>\n        <option value=\"in_stock\">In Stock</option>\n        <option value=\"out_of_stock\">Out of Stock</option>\n      </select>\n\n      <select class=\"tsukie-filter-select\" onchange=\"updateFilter('price_range', this.value)\">\n        <option value=\"\">Price Range</option>\n        <option value=\"0-999\">Under ₹999</option>\n        <option value=\"999-1999\">₹999 - ₹1,999</option>\n        <option value=\"1999-4999\">₹1,999 - ₹4,999</option>\n        <option value=\"4999-999999\">Above ₹4,999</option>\n      </select>\n\n      <select class=\"tsukie-filter-select\" onchange=\"updateFilter('sort_by', this.value)\">\n        <option value=\"\">Sort By: Featured</option>\n        <option value=\"best-selling\">Best Selling</option>\n        <option value=\"price-ascending\">Price: Low to High</option>\n        <option value=\"price-descending\">Price: High to Low</option>\n        <option value=\"created-descending\">Newest First</option>\n        <option value=\"title-ascending\">Name: A-Z</option>\n      </select>\n    </div>\n    {% endif %}\n  </div>\n</div>\n\n<script>\nfunction updateFilter(type, value){\n  const url = new URL(window.location);\n  \n  if(type === 'availability'){\n    if(value) url.searchParams.set('availability', value);\n    else url.searchParams.delete('availability');\n  }\n  \n  if(type === 'price_range'){\n    if(value){\n      const [min, max] = value.split('-');\n      url.searchParams.set('filter.v.price.gte', min);\n      if(max!== '999999') url.searchParams.set('filter.v.price.lte', max);\n      else url.searchParams.delete('filter.v.price.lte');\n    } else {\n      url.searchParams.delete('filter.v.price.gte');\n      url.searchParams.delete('filter.v.price.lte');\n    }\n  }\n  \n  if(type === 'sort_by'){\n    if(value) url.searchParams.set('sort_by', value);\n    else url.searchParams.delete('sort_by');\n  }\n  \n  window.location = url.toString();\n}\n\n// Set selected values on load\n(function(){\n  const params = new URLSearchParams(window.location.search);\n  const selects = document.querySelectorAll('.tsukie-filter-select');\n  \n  selects.forEach(select => {\n    const availability = params.get('availability');\n    const sort = params.get('sort_by');\n    const priceMin = params.get('filter.v.price.gte');\n    const priceMax = params.get('filter.v.price.lte');\n    \n    if(select.options[0].text.includes('Availability') && availability){\n      select.value = availability;\n    }\n    if(select.options[0].text.includes('Sort') && sort){\n      select.value = sort;\n    }\n    if(select.options[0].text.includes('Price') && (priceMin || priceMax)){\n      const range = `${priceMin || 0}-${priceMax || 999999}`;\n      select.value = range;\n    }\n  });\n})();\n</script>",
