    "custom_liquid_39iRXh": {
      "type": "custom-liquid",
      "name": "hero",
      "settings": {
        "custom_liquid": "<style>\n.tsukie-hero{\n  background:#f5f1ea;\n  padding:120px 0 100px;\n  text-align:center;\n  color:#1a1a1a;\n  width:100vw;\n  position:relative;\n  left:50%;\n  right:50%;\n  margin-left:-50vw;\n  margin-right:-50vw;\n}\n.tsukie-hero-inner{\n  max-width:800px;\n  margin:0 auto;\n  padding:0 20px;\n}\n.tsukie-hero-eyebrow{\n  color:#a08766;\n  font-size:12px;\n  letter-spacing:3px;\n  text-transform:uppercase;\n  margin:0 0 32px;\n  font-weight:500;\n}\n.tsukie-hero-heading{\n  font-family:'Times New Roman',serif;\n  font-size:64px;\n  line-height:1.1;\n  font-weight:400;\n  margin:0 0 24px;\n  color:#1a1a1a;\n}\n.tsukie-hero-heading em{\n  font-style:italic;\n  color:#a08766;\n  font-weight:400;\n}\n.tsukie-hero-desc{\n  color:#6b6b6b;\n  font-size:16px;\n  line-height:1.7;\n  margin:0 auto 48px;\n  max-width:600px;\n}\n.tsukie-hero-cta{\n  display:inline-flex;\n  align-items:center;\n  gap:32px;\n  flex-wrap:wrap;\n  justify-content:center;\n}\n.tsukie-btn-primary{\n  background:#1e2a38;\n  color:#fff;\n  padding:16px 40px;\n  font-size:12px;\n  letter-spacing:2px;\n  text-transform:uppercase;\n  text-decoration:none;\n  font-weight:500;\n  border:0;\n  display:inline-block;\n}\n.tsukie-btn-primary:hover{\n  background:#2a3a4a;\n}\n.tsukie-btn-text{\n  color:#1a1a1a;\n  font-size:12px;\n  letter-spacing:2px;\n  text-transform:uppercase;\n  text-decoration:none;\n  border-bottom:1px solid #1a1a1a;\n  padding-bottom:4px;\n  font-weight:500;\n}\n@media(max-width:749px){\n.tsukie-hero{padding:80px 0 60px}\n.tsukie-hero-heading{font-size:42px}\n.tsukie-hero-cta{flex-direction:column;gap:20px}\n}\n</style>\n\n<div class=\"tsukie-hero\">\n  <div class=\"tsukie-hero-inner\">\n    <p class=\"tsukie-hero-eyebrow\">SUMMER 2026 COLLECTION</p>\n    \n    <h1 class=\"tsukie-hero-heading\">\n      Dressed for<br>\n      the woman<br>\n      you <em>already are</em>\n    </h1>\n    \n    <p class=\"tsukie-hero-desc\">\n      Premium silhouettes crafted for the modern Indian woman — luxurious fabrics, thoughtful fit, and enduring style. Starting at ₹1,499.\n    </p>\n    \n    <div class=\"tsukie-hero-cta\">\n      <a href=\"/collections/new-arrivals\" class=\"tsukie-btn-primary\">SHOP NEW ARRIVALS</a>\n      <a href=\"/pages/about-us\" class=\"tsukie-btn-text\">OUR STORY →</a>\n    </div>\n  </div>\n</div>",
