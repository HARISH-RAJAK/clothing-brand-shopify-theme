        "custom_liquid": "<style>\n.tsukie-404-wrap{\n  background:#fdfbf7;\n  min-height:70vh;\n  display:flex;\n  align-items:center;\n  justify-content:center;\n  padding:80px 40px;\n}\n.tsukie-404-inner{\n  text-align:center;\n  max-width:600px;\n}\n.tsukie-404-number{\n  font-family:'Playfair Display',serif;\n  font-size:140px;\n  font-weight:600;\n  font-style:italic;\n  margin:0 0 20px;\n  line-height:1;\n  background:linear-gradient(135deg, #1e2a38 0%, #a08766 30%, #c9a77c 50%, #a08766 70%, #1e2a38 100%);\n  -webkit-background-clip:text;\n  -webkit-text-fill-color:transparent;\n  background-clip:text;\n}\n.tsukie-404-title{\n  font-family:'Playfair Display',serif;\n  font-size:42px;\n  font-style:italic;\n  color:#1e2a38;\n  margin:0 0 18px;\n  font-weight:600;\n}\n.tsukie-404-text{\n  font-family:'Montserrat',sans-serif;\n  font-size:15px;\n  line-height:1.8;\n  color:#5a5a5a;\n  margin:0 0 40px;\n}\n.tsukie-404-divider{\n  display:flex;\n  align-items:center;\n  justify-content:center;\n  gap:14px;\n  max-width:300px;\n  margin:0 auto 40px;\n}\n.tsukie-404-line{\n  flex:1;\n  height:1px;\n  background:linear-gradient(90deg, transparent, #a08766, transparent);\n}\n.tsukie-404-icon{\n  font-size:18px;\n  color:#a08766;\n}\n.tsukie-404-buttons{\n  display:flex;\n  gap:16px;\n  justify-content:center;\n  flex-wrap:wrap;\n}\n.tsukie-404-btn{\n  padding:16px 38px;\n  font-family:'Montserrat',sans-serif;\n  font-size:12px;\n  letter-spacing:2px;\n  text-transform:uppercase;\n  font-weight:600;\n  text-decoration:none;\n  border-radius:2px;\n  transition:all 0.3s ease;\n  display:inline-block;\n}\n.tsukie-404-btn-primary{\n  background:#0f1a24;\n  color:#d4c5a9;\n  border:1.5px solid #0f1a24;\n}\n.tsukie-404-btn-primary:hover{\n  background:#1e2a38;\n  border-color:#1e2a38;\n  transform:translateY(-2px);\n  box-shadow:0 8px 20px rgba(15,26,36,0.25);\n}\n.tsukie-404-btn-secondary{\n  background:transparent;\n  color:#1e2a38;\n  border:1.5px solid #a08766;\n}\n.tsukie-404-btn-secondary:hover{\n  background:#f5f1ea;\n  border-color:#1e2a38;\n  transform:translateY(-2px);\n}\n.tsukie-404-suggestions{\n  margin-top:60px;\n  padding-top:50px;\n  border-top:1px solid #e0d9cd;\n}\n.tsukie-404-suggestions h3{\n  font-family:'Cormorant Garamond',serif;\n  font-size:22px;\n  font-style:italic;\n  color:#1e2a38;\n  margin:0 0 24px;\n  font-weight:600;\n}\n.tsukie-404-links{\n  display:flex;\n  gap:24px;\n  justify-content:center;\n  flex-wrap:wrap;\n}\n.tsukie-404-link{\n  font-family:'Montserrat',sans-serif;\n  font-size:13px;\n  letter-spacing:1.5px;\n  text-transform:uppercase;\n  color:#a08766;\n  text-decoration:none;\n  font-weight:600;\n  transition:color 0.3s ease;\n}\n.tsukie-404-link:hover{\n  color:#1e2a38;\n}\n@media(max-width:749px){\n.tsukie-404-wrap{padding:60px 20px;min-height:60vh}\n.tsukie-404-number{font-size:100px}\n.tsukie-404-title{font-size:32px}\n.tsukie-404-text{font-size:14px}\n.tsukie-404-buttons{flex-direction:column}\n.tsukie-404-btn{width:100%}\n}\n</style>\n\n<div class=\"tsukie-404-wrap\">\n  <div class=\"tsukie-404-inner\">\n    <h1 class=\"tsukie-404-number\">404</h1>\n    <h2 class=\"tsukie-404-title\">Page Not Found</h2>\n    \n    <div class=\"tsukie-404-divider\">\n      <span class=\"tsukie-404-line\"></span>\n      <span class=\"tsukie-404-icon\">✦</span>\n      <span class=\"tsukie-404-line\"></span>\n    </div>\n    \n    <p class=\"tsukie-404-text\">The link may be incorrect, or the page has been removed. Let's get you back to discovering something beautiful.</p>\n    \n    <div class=\"tsukie-404-buttons\">\n      <a href=\"/collections/all\" class=\"tsukie-404-btn tsukie-404-btn-primary\">Continue Shopping</a>\n      <a href=\"/\" class=\"tsukie-404-btn tsukie-404-btn-secondary\">Back To Home</a>\n    </div>\n\n    <div class=\"tsukie-404-suggestions\">\n      <h3>Discover Something New</h3>\n      <div class=\"tsukie-404-links\">\n        <a href=\"/collections/new-arrivals\" class=\"tsukie-404-link\">New Arrivals</a>\n        <a href=\"/collections/best-sellers\" class=\"tsukie-404-link\">Best Sellers</a>\n        <a href=\"/collections/sale\" class=\"tsukie-404-link\">Sale</a>\n        <a href=\"/pages/contact\" class=\"tsukie-404-link\">Contact Us</a>\n      </div>\n    </div>\n  </div>\n</div>",
