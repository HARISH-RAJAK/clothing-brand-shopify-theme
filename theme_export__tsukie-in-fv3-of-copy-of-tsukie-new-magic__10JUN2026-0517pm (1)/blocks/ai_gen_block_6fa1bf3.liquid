{% doc %}
  @prompt
    make a title text block with all the functionalities to adjust font style, font size, alignment options etc.
    also top and bottom padding.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-title-block-{{ ai_gen_id }} {
    padding-top: {{ block.settings.padding_top }}px;
    padding-bottom: {{ block.settings.padding_bottom }}px;
    width: 100%;
  }

  .ai-title-block__heading-{{ ai_gen_id }} {
    margin: 0;
    font-family: {{ block.settings.font_family.family }}, {{ block.settings.font_family.fallback_families }};
    font-weight: {{ block.settings.font_family.weight }};
    font-style: {{ block.settings.font_family.style }};
    font-size: {{ block.settings.font_size }}px;
    line-height: {{ block.settings.line_height }};
    letter-spacing: {{ block.settings.letter_spacing }}em;
    text-align: {{ block.settings.text_alignment }};
    color: {{ block.settings.text_color }};
    {% if block.settings.text_transform == 'uppercase' %}
      text-transform: uppercase;
    {% elsif block.settings.text_transform == 'lowercase' %}
      text-transform: lowercase;
    {% elsif block.settings.text_transform == 'capitalize' %}
      text-transform: capitalize;
    {% else %}
      text-transform: none;
    {% endif %}
  }

  @media screen and (max-width: 749px) {
    .ai-title-block__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.font_size_mobile }}px;
    }
  }
{% endstyle %}

<div class="ai-title-block-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.heading_tag == 'h1' %}
    <h1 class="ai-title-block__heading-{{ ai_gen_id }}">{{ block.settings.title }}</h1>
  {% elsif block.settings.heading_tag == 'h2' %}
    <h2 class="ai-title-block__heading-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
  {% elsif block.settings.heading_tag == 'h3' %}
    <h3 class="ai-title-block__heading-{{ ai_gen_id }}">{{ block.settings.title }}</h3>
  {% elsif block.settings.heading_tag == 'h4' %}
    <h4 class="ai-title-block__heading-{{ ai_gen_id }}">{{ block.settings.title }}</h4>
  {% elsif block.settings.heading_tag == 'h5' %}
    <h5 class="ai-title-block__heading-{{ ai_gen_id }}">{{ block.settings.title }}</h5>
  {% elsif block.settings.heading_tag == 'h6' %}
    <h6 class="ai-title-block__heading-{{ ai_gen_id }}">{{ block.settings.title }}</h6>
  {% else %}
    <p class="ai-title-block__heading-{{ ai_gen_id }}">{{ block.settings.title }}</p>
  {% endif %}
</div>

{% schema %}
{
  "name": "Title text",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Your Title Here"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "HTML tag",
      "options": [
        {
          "value": "h1",
          "label": "H1"
        },
        {
          "value": "h2",
          "label": "H2"
        },
        {
          "value": "h3",
          "label": "H3"
        },
        {
          "value": "h4",
          "label": "H4"
        },
        {
          "value": "h5",
          "label": "H5"
        },
        {
          "value": "h6",
          "label": "H6"
        },
        {
          "value": "p",
          "label": "Paragraph"
        }
      ],
      "default": "h2"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "font_picker",
      "id": "font_family",
      "label": "Font",
      "default": "josefin_sans_n4"
    },
    {
      "type": "range",
      "id": "font_size",
      "min": 12,
      "max": 120,
      "step": 2,
      "unit": "px",
      "label": "Font size (desktop)",
      "default": 48
    },
    {
      "type": "range",
      "id": "font_size_mobile",
      "min": 12,
      "max": 80,
      "step": 2,
      "unit": "px",
      "label": "Font size (mobile)",
      "default": 32
    },
    {
      "type": "select",
      "id": "line_height",
      "label": "Line height",
      "options": [
        {
          "value": "1",
          "label": "Tight (1.0)"
        },
        {
          "value": "1.2",
          "label": "Normal (1.2)"
        },
        {
          "value": "1.5",
          "label": "Loose (1.5)"
        },
        {
          "value": "1.8",
          "label": "Extra loose (1.8)"
        }
      ],
      "default": "1.2"
    },
    {
      "type": "select",
      "id": "letter_spacing",
      "label": "Letter spacing",
      "options": [
        {
          "value": "-0.05",
          "label": "Tight"
        },
        {
          "value": "0",
          "label": "Normal"
        },
        {
          "value": "0.05",
          "label": "Loose"
        },
        {
          "value": "0.1",
          "label": "Extra loose"
        }
      ],
      "default": "0"
    },
    {
      "type": "select",
      "id": "text_transform",
      "label": "Text transform",
      "options": [
        {
          "value": "none",
          "label": "None"
        },
        {
          "value": "uppercase",
          "label": "Uppercase"
        },
        {
          "value": "lowercase",
          "label": "Lowercase"
        },
        {
          "value": "capitalize",
          "label": "Capitalize"
        }
      ],
      "default": "none"
    },
    {
      "type": "header",
      "content": "Alignment"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "Color"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 40
    }
  ],
  "presets": [
    {
      "name": "Title text"
    }
  ]
}
{% endschema %}
