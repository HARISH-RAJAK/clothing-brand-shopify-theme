{%- assign block_settings = block.settings -%}
{%- assign condition = block_settings.product_list -%}

{%- if block_settings.metafield != blank -%}
  {%- assign ns = block_settings.metafield | split: '.' | first -%}
  {%- assign key = block_settings.metafield | split: '.' | last -%}
  {%- assign active_product = product | default: closest.product -%}
  {%- if active_product.metafields[ns][key].value != blank -%}
    {%- assign condition = active_product.metafields[ns][key].value -%}
  {%- endif -%}
{%- endif -%}

{%- if condition != blank and condition.count > 0 -%}
  <div class="style-it-with-container color-{{ block_settings.color_scheme }}" 
       style="
         padding-top: {{ block_settings.padding_top }}px;
         padding-bottom: {{ block_settings.padding_bottom }}px;
         margin-top: {{ block_settings.margin_top }}px;
       "
       {{ block.shopify_attributes }}>
    
    {%- if block_settings.heading != blank -%}
      <h3 class="style-it-with-heading">{{ block_settings.heading }}</h3>
    {%- endif -%}

    <div class="style-it-with-carousel-wrap" style="position: relative; --card-width: {{ block_settings.card_width }}px;">
      <div class="style-it-with-grid" style="
           --col-gap: {{ block_settings.columns_gap }}px; 
           --card-width: {{ block_settings.card_width }}px;
           --image-ratio: {{ block_settings.image_ratio }};
           --title-size: {{ block_settings.title_size }}px;
           --title-size-mobile: {{ block_settings.title_size_mobile }}px;
           --title-weight: {{ block_settings.title_weight }};
           --price-size: {{ block_settings.price_size }}px;
           --price-size-mobile: {{ block_settings.price_size_mobile }}px;
         ">
        {%- for product in condition limit: block_settings.max_products -%}
          <a href="{{ product.url }}" class="style-it-with-card">
            <div class="style-it-with-card__image-wrapper">
              {%- if product.featured_image != blank -%}
                {{ product.featured_image | image_url: width: 400 | image_tag: class: 'style-it-with-card__img', loading: 'lazy' }}
              {%- else -%}
                {{ 'product-1' | placeholder_svg_tag: 'style-it-with-card__img placeholder-svg' }}
              {%- endif -%}
            </div>
            
            <div class="style-it-with-card__info">
            {%- if block_settings.split_title -%}
              <div class="style-it-with-card__title-wrapper">
                {%- assign title_words = product.title | split: ' ' -%}
                <span class="style-it-with-card__name">{{ title_words.first }}</span>
                {%- assign rest_title = product.title | remove_first: title_words.first | strip -%}
                <span class="style-it-with-card__desc">{{ rest_title }}</span>
              </div>
            {%- else -%}
              <div class="style-it-with-card__name" style="margin-bottom: 8px; display: block;">{{ product.vendor }}</div>
              <div class="style-it-with-card__desc" style="display: block;">{{ product.title | truncate: 32, '...' }}</div>
            {%- endif -%}
            
            <div class="style-it-with-card__price">
              {% if product.compare_at_price > product.price %}
                <s style="color: #666; font-weight: 400; margin-right: 6px;">{{ product.compare_at_price | money | replace: 'Rs. ', '₹' | replace: 'Rs.', '₹' | replace: 'Rs', '₹' | replace: 'RS', '₹' }}</s>
              {% endif %}
              <span>{{ product.price | money | replace: 'Rs. ', '₹' | replace: 'Rs.', '₹' | replace: 'Rs', '₹' | replace: 'RS', '₹' }}</span>
            </div>
          </div>
        </a>
      {%- endfor -%}
    </div>
    
    {%- if condition.count > 2 and block_settings.show_arrow -%}
      <button type="button" class="style-it-with-arrow style-it-with-arrow--left" aria-label="Previous slide" style="display: none;">
        <svg viewBox="0 0 24 24" width="20" height="20" stroke="#000" stroke-width="1.5" fill="none" stroke-linecap="square" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
      </button>
      <button type="button" class="style-it-with-arrow style-it-with-arrow--right" aria-label="Next slide">
        <svg viewBox="0 0 24 24" width="20" height="20" stroke="#000" stroke-width="1.5" fill="none" stroke-linecap="square" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
      </button>

      <script>
        document.addEventListener('DOMContentLoaded', () => {
          const wraps = document.querySelectorAll('.style-it-with-carousel-wrap');
          wraps.forEach(wrap => {
            const grid = wrap.querySelector('.style-it-with-grid');
            const leftBtn = wrap.querySelector('.style-it-with-arrow--left');
            const rightBtn = wrap.querySelector('.style-it-with-arrow--right');
            if(!grid || !leftBtn || !rightBtn) return;
            
            const cardWidth = parseInt(getComputedStyle(wrap).getPropertyValue('--card-width')) || 110;

            const updateButtons = () => {
              if (grid.scrollLeft > 5) {
                leftBtn.style.display = 'flex';
              } else {
                leftBtn.style.display = 'none';
              }
              
              if (Math.ceil(grid.scrollLeft + grid.clientWidth) >= grid.scrollWidth - 5) {
                rightBtn.style.opacity = '0.3';
                rightBtn.style.pointerEvents = 'none';
              } else {
                rightBtn.style.opacity = '1';
                rightBtn.style.pointerEvents = 'auto';
              }
            };

            leftBtn.addEventListener('click', () => {
              grid.scrollBy({ left: -cardWidth, behavior: 'smooth' });
            });
            rightBtn.addEventListener('click', () => {
              grid.scrollBy({ left: cardWidth, behavior: 'smooth' });
            });

            grid.addEventListener('scroll', updateButtons);
            window.addEventListener('resize', updateButtons);
            
            setTimeout(updateButtons, 100);
          });
        });
      </script>
    {%- endif -%}
  </div>
</div>
{%- endif -%}

{% stylesheet %}
  .style-it-with-container {
    width: 100%;
    clear: both;
  }
  .style-it-with-heading {
    font-family: var(--font-heading--family, sans-serif);
    font-size: 13px !important;
    font-weight: 700 !important;
    letter-spacing: 1.5px !important;
    text-transform: uppercase !important;
    margin-bottom: 16px !important;
    margin-top: 0 !important;
    color: #000;
  }
  .style-it-with-grid {
    display: flex;
    gap: var(--col-gap, 4px);
    overflow-x: auto;
    scroll-behavior: smooth;
    scroll-snap-type: x mandatory;
    scrollbar-width: none; /* Firefox */
    -ms-overflow-style: none; /* IE */
  }
  .style-it-with-grid::-webkit-scrollbar {
    display: none; /* Chrome/Safari */
  }
  .style-it-with-card {
    flex: 0 0 var(--card-width, 110px);
    scroll-snap-align: start;
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
  }
  @media screen and (max-width: 749px) {
    .style-it-with-container {
      margin-top: 0 !important; /* Reset margin on stacked mobile layout */
    }
    .style-it-with-grid {
      gap: 8px !important; /* Standard mobile gap */
      flex-wrap: wrap !important;
      overflow-x: visible !important;
      scroll-snap-type: none !important;
    }
    .style-it-with-card {
      /* Match standard mobile product cards (2 columns) */
      flex: 0 0 calc(50% - 4px) !important;
      min-width: unset;
    }
    .style-it-with-card__name {
      font-size: var(--title-size-mobile, 14px) !important;
      font-weight: 400 !important;
      margin-bottom: 8px !important;
    }
    .style-it-with-card__desc {
      font-size: calc(var(--title-size-mobile, 14px) - 1px) !important;
      margin-bottom: 10px !important;
    }
    .style-it-with-card__price {
      font-size: var(--price-size-mobile, 14px) !important;
      font-weight: 400 !important;
    }
  }
  .style-it-with-card__image-wrapper {
    position: relative;
    background-color: #ededed;
    aspect-ratio: var(--image-ratio, 4/5);
    overflow: hidden;
    margin-bottom: 12px;
  }
  .style-it-with-card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    mix-blend-mode: multiply; /* Helps white background images blend with grey */
    transition: transform 0.3s ease;
    background-color: #ededed; /* Backup */
  }
  .style-it-with-card:hover .style-it-with-card__img {
    transform: scale(1.02);
  }
  .style-it-with-arrow {
    position: absolute;
    top: calc(var(--card-width) * 0.6); /* Centered relative to the image assuming 4/5 ratio */
    transform: translateY(-50%);
    width: 32px;
    height: 32px;
    background-color: transparent;
    border: none;
    box-shadow: none;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #000;
    cursor: pointer;
    z-index: 2;
    transition: opacity 0.2s ease;
  }
  .style-it-with-arrow--right {
    right: -12px;
  }
  .style-it-with-arrow--left {
    left: -12px;
  }
  @media screen and (max-width: 749px) {
    .style-it-with-arrow {
      display: none !important;
    }
  }
  .style-it-with-card__info {
    font-family: var(--font-body--family, sans-serif);
    line-height: 1.5;
    color: #000;
  }
  .style-it-with-card__title-wrapper {
    margin-bottom: 10px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: normal;
  }
  .style-it-with-card__name {
    font-size: var(--title-size, 11px);
    font-weight: var(--title-weight, 400);
    color: #000;
  }
  .style-it-with-card__desc {
    font-size: calc(var(--title-size, 11px) - 0.5px);
    color: #333;
    margin-left: 2px;
  }
  .style-it-with-card__price {
    font-size: var(--price-size, 11px);
    font-weight: 400;
    color: #000;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Style it with",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "STYLE IT WITH"
    },
    {
      "type": "checkbox",
      "id": "split_title",
      "label": "Reiss-style Titles (First word bold, rest description)",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_arrow",
      "label": "Show arrow on last image",
      "default": true
    },
    {
      "type": "product_list",
      "id": "product_list",
      "label": "Products"
    },
    {
      "type": "text",
      "id": "metafield",
      "label": "Product Metafield",
      "info": "Enter the namespace and key of your product list metafield (e.g. custom.style_it_with) to dynamically show different products per page. This overrides the 'Products' selection above."
    },
    {
      "type": "range",
      "id": "max_products",
      "min": 2,
      "max": 10,
      "step": 1,
      "default": 4,
      "label": "Maximum products to show"
    },
    {
      "type": "range",
      "id": "card_width",
      "min": 60,
      "max": 250,
      "step": 2,
      "unit": "px",
      "default": 110,
      "label": "Card width"
    },
    {
      "type": "range",
      "id": "columns_gap",
      "min": 0,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 0,
      "label": "Column gap (Matches design)"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Image ratio",
      "options": [
        { "value": "2/3", "label": "Tall (2:3)" },
        { "value": "3/4", "label": "Portrait (3:4)" },
        { "value": "4/5", "label": "Standard (4:5)" },
        { "value": "1/1", "label": "Square (1:1)" }
      ],
      "default": "4/5"
    },
    {
      "type": "range",
      "id": "title_size",
      "label": "Title font size (Desktop)",
      "min": 8,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 11
    },
    {
      "type": "range",
      "id": "title_size_mobile",
      "label": "Title font size (Mobile)",
      "min": 8,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "select",
      "id": "title_weight",
      "label": "Title font weight",
      "options": [
        { "value": "300", "label": "Light" },
        { "value": "400", "label": "Normal" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semi-bold" },
        { "value": "700", "label": "Bold" }
      ],
      "default": "400"
    },
    {
      "type": "range",
      "id": "price_size",
      "label": "Price font size (Desktop)",
      "min": 8,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 11
    },
    {
      "type": "range",
      "id": "price_size_mobile",
      "label": "Price font size (Mobile)",
      "min": 8,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "margin_top",
      "label": "Top margin",
      "info": "Use a negative value to pull the block up, aligning it next to the accordions.",
      "min": -200,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 24
    }
  ],
  "presets": [
    {
      "name": "Style it with"
    }
  ]
}
{% endschema %}