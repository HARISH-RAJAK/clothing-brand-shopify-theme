      <button
        class="footer-accordion-toggle"
        type="button"
        aria-expanded="false"
        aria-controls="FooterAccordionColumn3-{{ section.id }}"
      >
        <span class="footer-accordion-title">{{ section.settings.column3_heading }}</span>
        <span class="footer-accordion-icon" aria-hidden="true">+</span>
      </button>
      <ul id="FooterAccordionColumn3-{{ section.id }}" class="footer-accordion-panel">
        {%- if section.settings.column3_link1_label != blank -%}
          <li><a href="{{ section.settings.column3_link1_url | default: '#' }}">{{ section.settings.column3_link1_label }}</a></li>
        {%- endif -%}
        {%- if section.settings.column3_link2_label != blank -%}
          <li><a href="{{ section.settings.column3_link2_url | default: '#' }}">{{ section.settings.column3_link2_label }}</a></li>
        {%- endif -%}
        {%- if section.settings.column3_link3_label != blank -%}
          <li><a href="{{ section.settings.column3_link3_url | default: '#' }}">{{ section.settings.column3_link3_label }}</a></li>
        {%- endif -%}
        {%- if section.settings.column3_link4_label != blank -%}
          <li><a href="{{ section.settings.column3_link4_url | default: '#' }}">{{ section.settings.column3_link4_label }}</a></li>
        {%- endif -%}
      </ul>
    </div>
    
    <div class="footer-column footer-newsletter">
      <h3>{{ section.settings.newsletter_heading | default: "Newsletter" }}</h3>
      <p>{{ section.settings.newsletter_text | default: "Be the first to know about sales, new product launches and exclusive offers!" }}</p>
      
      {%- form 'customer', class: 'email-signup__form' -%}
        <input type="hidden" name="contact[tags]" value="newsletter">
        <div class="email-signup__input-group">
          <label for="FooterEmailInput-{{ section.id }}" class="visually-hidden">
            Email address
          </label>
          <input
            id="FooterEmailInput-{{ section.id }}"
            class="email-signup__input"
            type="email"
            name="contact[email]"
            autocorrect="off"
            autocapitalize="off"
            autocomplete="email"
            placeholder="Your email"
            required
            {% if form.errors %}
              autofocus
              aria-invalid="true"
              aria-describedby="FooterEmail-error-{{ section.id }}"
            {% elsif form.posted_successfully? %}
              aria-describedby="FooterEmail-success-{{ section.id }}"
            {% endif %}
          >
        </div>
        <button class="email-signup__button" type="submit">
          {{ section.settings.newsletter_button_text | default: "SUBSCRIBE" }}
        </button>

        {%- if form.errors -%}
          <div
            id="FooterEmail-error-{{ section.id }}"
            class="email-signup__message email-signup__message--error"
            tabindex="-1"
          >
            <svg viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg" focusable="false" aria-hidden="true">
              <path d="M10 0C4.48 0 0 4.48 0 10s4.48 10 10 10 10-4.48 10-10S15.52 0 10 0zm1 15H9v-2h2v2zm0-4H9V5h2v6z"/>
            </svg>
            {{- form.errors.translated_fields.email | capitalize }}
            {{ form.errors.messages.email -}}
          </div>
        {%- endif -%}

        {%- if form.posted_successfully? -%}
          <div
            id="FooterEmail-success-{{ section.id }}"
            class="email-signup__message email-signup__message--success"
            tabindex="-1"
          >
            <span class="svg-wrapper">
              {{ 'icon-checkmark.svg' | inline_asset_content }}
            </span>
            <p class="email-signup__message-text">Thanks for subscribing!</p>
          </div>
        {%- endif -%}
      {% endform %}
    </div>
    
  </div>
  
  <hr class="footer-divider">

  <div class="footer-bottom">
    {%- if section.settings.show_country_selector and localization.available_countries.size > 1 -%}
    <div class="footer-bottom-left">
      {%- form 'localization', class: 'localization-form' -%}
        <div>
          <input type="hidden" name="country_code" value="{{ localization.country.iso_code }}">
          <button class="localization-button" type="submit">
            {{ localization.country.name }}
          </button>
        </div>
      {%- endform -%}
    </div>
    {%- endif -%}
    
    <div class="footer-bottom-right">
      {%- if section.settings.show_payment_icons -%}
        <div class="payment-icons">
          <ul>
            <li>{{ 'visa' | payment_type_svg_tag: class: 'payment-icon' }}</li>
            <li>{{ 'master' | payment_type_svg_tag: class: 'payment-icon' }}</li>
            <li>{{ 'american_express' | payment_type_svg_tag: class: 'payment-icon' }}</li>
            <li>{{ 'paypal' | payment_type_svg_tag: class: 'payment-icon' }}</li>
            <li>{{ 'diners_club' | payment_type_svg_tag: class: 'payment-icon' }}</li>
            <li>{{ 'discover' | payment_type_svg_tag: class: 'payment-icon' }}</li>
          </ul>
        </div>
      {%- endif -%}
      
      <div class="footer-policy-links">
        <ul>
          {%- if section.settings.bottom_link1_label != blank -%}
            <li><a href="{{ section.settings.bottom_link1_url | default: '#' }}">{{ section.settings.bottom_link1_label }}</a></li>
          {%- endif -%}
          {%- if section.settings.bottom_link2_label != blank -%}
            <li><a href="{{ section.settings.bottom_link2_url | default: '#' }}">{{ section.settings.bottom_link2_label }}</a></li>
          {%- endif -%}
          {%- if section.settings.bottom_link3_label != blank -%}
            <li><a href="{{ section.settings.bottom_link3_url | default: '#' }}">{{ section.settings.bottom_link3_label }}</a></li>
          {%- endif -%}
          {%- if section.settings.bottom_link4_label != blank -%}
            <li><a href="{{ section.settings.bottom_link4_url | default: '#' }}">{{ section.settings.bottom_link4_label }}</a></li>
          {%- endif -%}
        </ul>
      </div>

      <div class="footer-copyright">
        © 2025 Tsukie powered by <a href="https://www.autozentic.com/" target="_blank">Autozentic</a>
      </div>

    </div>
    
  </div>
  </div>
</footer>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    var accordions = Array.prototype.slice.call(document.querySelectorAll('[data-footer-accordion]'));
    if (!accordions.length) {
      return;
    }

    var mobileQuery = window.matchMedia('(max-width: 768px)');

    function applyState() {
      accordions.forEach(function (accordion) {
        var toggle = accordion.querySelector('.footer-accordion-toggle');
        var panel = accordion.querySelector('.footer-accordion-panel');
        var icon = accordion.querySelector('.footer-accordion-icon');
        if (!toggle || !panel) {
          return;
        }

        if (mobileQuery.matches) {
          var isOpen = accordion.classList.contains('is-open');
          panel.style.display = isOpen ? 'block' : 'none';
          toggle.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
          if (icon) {
            icon.textContent = isOpen ? '-' : '+';
          }
        } else {
          panel.style.display = 'block';
          toggle.setAttribute('aria-expanded', 'true');
          if (icon) {
            icon.textContent = '+';
          }
        }
      });
    }

    accordions.forEach(function (accordion) {
      var toggle = accordion.querySelector('.footer-accordion-toggle');
      var panel = accordion.querySelector('.footer-accordion-panel');
      var icon = accordion.querySelector('.footer-accordion-icon');
      if (!toggle || !panel) {
        return;
      }

      toggle.addEventListener('click', function () {
        if (!mobileQuery.matches) {
          return;
        }

        var isOpen = accordion.classList.toggle('is-open');
        panel.style.display = isOpen ? 'block' : 'none';
        toggle.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
        if (icon) {
          icon.textContent = isOpen ? '-' : '+';
        }
      });
    });

    applyState();

    function handleChange() {
      if (!mobileQuery.matches) {
        accordions.forEach(function (accordion) {
          var toggle = accordion.querySelector('.footer-accordion-toggle');
          var panel = accordion.querySelector('.footer-accordion-panel');
          var icon = accordion.querySelector('.footer-accordion-icon');
          accordion.classList.remove('is-open');
          if (panel) {
            panel.style.display = 'block';
          }
          if (toggle) {
            toggle.setAttribute('aria-expanded', 'true');
          }
          if (icon) {
            icon.textContent = '+';
          }
        });
      }

      applyState();
    }

    if (typeof mobileQuery.addEventListener === 'function') {
      mobileQuery.addEventListener('change', handleChange);
    } else if (typeof mobileQuery.addListener === 'function') {
      mobileQuery.addListener(handleChange);
    }
  });
</script>

