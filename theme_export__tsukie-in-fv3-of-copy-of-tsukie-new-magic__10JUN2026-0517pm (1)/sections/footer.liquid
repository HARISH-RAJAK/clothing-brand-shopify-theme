{% comment %}
  Shopify Footer Section
  - Replicates the design from the provided image.
  - Column content is fully configurable through the section settings.
  - Updated: Autozentic copyright moved to bottom right, smaller font, reduced footer padding.
{% endcomment %}

<style>
  .visually-hidden {
    position: absolute !important;
    overflow: hidden;
    width: 1px;
    height: 1px;
    margin: -1px;
    padding: 0;
    border: 0;
    clip: rect(0 0 0 0);
    word-wrap: normal !important;
  }

  .custom-footer {
    background-color: #1e1e1e;
    color: #ffffff;
    /* REDUCED BOTTOM PADDING HERE (from 24px to 12px) */
    padding: 60px 5% 12px;
    display: flex;
    justify-content: center;
    width: 100%;
    box-sizing: border-box;
    font-family: 'Roboto', sans-serif;
  }

  .custom-footer__inner {
    width: min(100%, 1400px);
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .custom-footer h1,
  .custom-footer h2,
  .custom-footer h3,
  .custom-footer .footer-accordion-title,
  .custom-footer .footer-column-heading {
    font-family: 'Josefin Sans', sans-serif;
  }

  .custom-footer-grid {
    display: grid;
    grid-template-columns: 2fr repeat(3, 1fr);
    gap: 24px;
    padding-bottom: 40px;
    margin: 0 auto;
    width: min(100%, 1200px);
    justify-content: center;
  }

  .footer-column .description {
    font-size: 14px;
    line-height: 1.6;
    max-width: none;
    margin-bottom: {{ section.settings.logo_top_spacing | default: 30 }}px;
    color: #e0e0e0;
    text-align: left;
  }

  .footer-contact {
    margin-top: {{ section.settings.contact_top_spacing | default: 8 }}px;
    margin-bottom: {{ section.settings.contact_bottom_spacing | default: 8 }}px;
    font-size: 14px;
    line-height: 1.6;
    color: #ffffff;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .footer-brand > .footer-contact:first-child {
    margin-top: 0;
  }

  {% comment %} .footer-contact-item {
    display: inline-flex;
    align-items: flex-start; 
    gap: 8px;
    color: inherit;
    text-decoration: none;
    cursor:pointer;
  } {% endcomment %}


  .footer-contact-item {
  display: flex;
  align-items: center;
  gap: 10px;
  text-decoration: none;
  cursor: pointer;
  color: inherit;
  position: relative;
  z-index: 2;
}

.footer-contact-icon svg {
  pointer-events: none;
}


  .footer-contact-text {
    text-decoration: underline;
  }
  
  .footer-contact-text.address-text {
    text-decoration: none;
  }

  .footer-contact-icon {
     margin-top: 3px; 
  }

  .footer-contact-icon svg {
    width: 16px;
    height: 16px;
    display: block;
    fill: currentColor;
  }

  .footer-brand {
    padding-right: 28px;
  }

  .footer-column .logo {
    margin-top: {{ section.settings.logo_top_margin_adjust | default: 0 }}px;
    margin-bottom: {{ section.settings.logo_bottom_margin_adjust | default: section.settings.logo_bottom_spacing | default: 20 }}px;
    margin-left: {{ section.settings.logo_left_margin | default: 0 }}px;
    padding-left: {{ section.settings.logo_left_padding | default: 0 }}px;
    padding-top: {{ section.settings.logo_top_padding | default: 0 }}px;
    padding-bottom: {{ section.settings.logo_bottom_padding | default: 0 }}px;
    max-width: 200px;
  }

  .footer-column .logo img {
    width: 100%;
    height: auto;
    display: block;
  }

  .footer-social-icons {
    display: flex;
    gap: 15px;
    align-items: center;
  }

  .footer-social-icons a {
    color: #ffffff;
    transition: color 0.3s ease;
  }

  .footer-social-icons a:hover {
    color: #bbbbbb;
  }

  .footer-social-icons svg {
    width: 20px;
    height: 20px;
    fill: currentColor;
  }

  .footer-column h3 {
    font-size: 16px;
    font-weight: 600;
    margin-bottom: 20px;
    text-transform: none;
    color: #ffffff;
  }

  .footer-column ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .footer-column ul li {
    margin-bottom: 12px;
  }

  .footer-column ul li a {
    color: #e0e0e0;
    text-decoration: none;
    font-size: 14px;
    transition: color 0.3s ease;
  }

  .footer-column ul li a:hover {
    color: #ffffff;
    text-decoration: underline;
  }

  .footer-accordion {
    position: relative;
  }

  .footer-accordion-toggle {
    display: none;
    background: none;
    border: none;
    color: inherit;
    font: inherit;
    width: 100%;
    text-align: left;
    padding: 0;
    cursor: pointer;
  }

  .footer-accordion-title {
    font-size: 16px;
    font-weight: 600;
  }

  .footer-accordion-icon {
    font-size: 18px;
    line-height: 1;
    transition: transform 0.2s ease;
    margin-left: 12px;
  }

  .footer-accordion-panel {
    display: block;
  }

  .footer-divider {
    border: none;
    border-top: 1px solid #444444;
    margin: 0;
    padding: 0;
  }
  
  .footer-bottom {
    display: flex;
    justify-content: space-between;
    /* Changed items to flex-end to push country selector down if needed */
    align-items: flex-end; 
    padding-top: 20px;
    font-size: 13px;
    color: #aaaaaa;
    width: min(100%, 1200px);
    margin: 0 auto;
    flex-wrap: wrap;
    gap: 20px;
  }
  
  .footer-bottom-left {
    display: flex;
    align-items: center;
    gap: 20px;
    flex-wrap: wrap;
    /* Ensure it doesn't grow too wide */
    flex: 0 1 auto;
  }
  
  .footer-bottom-right {
    display: flex;
    flex-direction: column;
    /* CHANGED ALIGNMENT TO RIGHT (flex-end) */
    align-items: flex-end;
    /* REDUCED GAP to keep things tighter vertically */
    gap: 10px;
    /* CHANGED TEXT ALIGN TO RIGHT */
    text-align: right;
    margin-left: auto; /* Pushes block to the right */
    flex: 1 1 auto;
  }

  .localization-form {
    margin: 0;
  }

  .localization-button {
    background-color: #e0e0e0;
    color: #1e1e1e;
    border: none;
    padding: 8px 12px;
    border-radius: 4px;
    font-size: 13px;
    cursor: pointer;
  }
  
  .payment-icons ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    gap: 4px;
    /* Changed justify-content to flex-end for right alignment */
    justify-content: flex-end;
    flex-wrap: wrap;
    margin-left: auto;
    margin-right: 0;
  }

  .payment-icons {
    display: flex;
    /* Changed justify-content to flex-end for right alignment */
    justify-content: flex-end;
    width: 100%;
  }

  .payment-icons li {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .payment-icons .payment-icon {
    height: 22px;
  }

  .footer-policy-links ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    gap: 20px;
    flex-wrap: wrap;
    /* Changed justify-content to flex-end for right alignment */
    justify-content: flex-end;
  }

  .footer-policy-links a {
    color: #ffffff;
    text-decoration: none;
  }
  
  .footer-policy-links a:hover {
    color: #ffffff;
    text-decoration: underline;
  }

  /* Copyright Section Styles - UPDATED FONT SIZE */
  .footer-copyright {
    /* DECREASED FONT SIZE (from 13px to 11px) */
    font-size: 11px;
    color: #aaaaaa;
    width: 100%;
  }
  
  .footer-copyright a {
    color: #ffffff;
    text-decoration: none;
    font-weight: 600;
    transition: color 0.3s ease;
  }

  .footer-copyright a:hover {
    color: #e0e0e0;
    text-decoration: underline;
  }

  /* Newsletter Column Styles */
  .footer-newsletter {
    display: flex;
    flex-direction: column;
  }

  .footer-newsletter h3 {
    font-size: 16px;
    font-weight: 600;
    margin-bottom: 15px;
    color: #ffffff;
  }

  .footer-newsletter p {
    font-size: 14px;
    line-height: 1.6;
    color: #e0e0e0;
    margin-bottom: 20px;
  }

  .footer-newsletter .email-signup__form {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .footer-newsletter .email-signup__input-group {
    position: relative;
    display: flex;
    background-color: transparent;
  }

  .footer-newsletter .email-signup__input {
    flex: 1;
    width: 100%;
    padding: 10px 14px;
    background-color: #ffffff;
    color: #1e1e1e;
    border: 1px solid #ffffff;
    border-radius: 0;
    font-size: 13px;
    outline: none;
    transition: all 0.3s ease;
    font-family: inherit;
  }

  .footer-newsletter .email-signup__input::placeholder {
    color: #999999;
    font-size: 13px;
  }

  .footer-newsletter .email-signup__input:focus {
    outline: none;
    border-color: #ffffff;
    box-shadow: 0 0 0 2px rgba(255, 255, 255, 0.3);
  }

  .footer-newsletter .email-signup__button {
    width: auto !important;
    padding: 10px 20px;
    background-color: #ffffff;
    color: #1e1e1e;
    border: 1px solid #ffffff;
    border-radius: 0;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.5px;
    cursor: pointer;
    transition: all 0.3s ease;
    white-space: nowrap;
    margin-top: 8px;
    text-transform: uppercase;
    font-family: inherit;
    display: inline-block;
    align-self: flex-start;
  }

  .footer-newsletter .email-signup__button:hover {
    background-color: rgba(255, 255, 255, 0.9);
    transform: translateY(-1px);
    box-shadow: 0 2px 8px rgba(255, 255, 255, 0.2);
  }

  .footer-newsletter .email-signup__button:active {
    transform: translateY(0);
  }

  .footer-newsletter .email-signup__message {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    padding: 8px 0;
  }

  .footer-newsletter .email-signup__message--error {
    color: #ff6b6b;
  }

  .footer-newsletter .email-signup__message--success {
    color: #51cf66;
  }

  .footer-newsletter .email-signup__message svg,
  .footer-newsletter .email-signup__message .svg-wrapper {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
  }

  .footer-newsletter .email-signup__message svg {
    fill: currentColor;
  }

  /* Responsive adjustments */
  @media (max-width: 768px) {
    .custom-footer-grid {
      grid-template-columns: 1fr;
      gap: 0;
      padding-bottom: 0;
    }

    .footer-column.footer-accordion {
      margin: 0;
    }

    .footer-column-heading {
      display: none;
    }

    .footer-accordion-toggle {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 12px 0;
      border-top: 1px solid #444444;
      color: #ffffff;
    }

    .footer-social-icons {
      margin-bottom: 12px;
    }

    .footer-accordion-panel {
      display: none;
      padding: 10px 0 16px;
    }

    .footer-accordion.is-open .footer-accordion-panel {
      display: block;
    }

    /* Newsletter stays visible on mobile */
    .footer-newsletter {
      margin-top: 12px;
      padding-top: 12px;
      border-top: 1px solid #444444;
    }

    /* Button full width on mobile */
    .footer-newsletter .email-signup__button {
      width: 100%;
      align-self: stretch;
    }

    .footer-brand {
      padding-right: 0;
    }
  }

  @media (max-width: 1024px) and (min-width: 769px) {
    .custom-footer-grid {
      grid-template-columns: 1.5fr 1fr;
      gap: 20px;
    }

    .footer-brand {
      padding-right: 20px;
    }
  }

  @media (max-width: 480px) {
    .custom-footer-grid {
      grid-template-columns: 1fr;
    }
    .footer-bottom {
      flex-direction: column;
      align-items: center; /* Center items on mobile */
    }
    
    /* Reset right alignment on mobile so it centers properly */
    .footer-bottom-right {
      align-items: center;
      text-align: center;
      margin-left: 0;
      width: 100%;
    }
    
    .payment-icons ul,
    .footer-policy-links ul {
       justify-content: center;
       margin-right: auto;
    }
  }
</style>

