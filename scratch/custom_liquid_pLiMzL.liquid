  font-family:'Montserrat',sans-serif;
}
.tsukie-collection-heading{
  font-family:'Playfair Display',serif;
  font-size:52px;
  font-style:italic;
  font-weight:600;
  line-height:1.15;
  margin:0 0 16px;
  padding-bottom:4px;
  background:linear-gradient(135deg, #a08766 0%, #c9a77c 50%, #a08766 100%);
