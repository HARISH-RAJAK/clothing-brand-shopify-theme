<style>
@import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@1,400;1,600&family=Montserrat:wght@300;400;500;600&display=swap');

.tsukie-reviews-wrap{
  background:#fdfbf7;
  padding:60px 0;
  border-top:1px solid #e0d9cd;
}
.tsukie-reviews-inner{
  max-width:1200px;
  margin:0 auto;
  padding:0 40px;
}
.tsukie-reviews-header{
  display:grid;
  grid-template-columns:280px 1fr;
  gap:60px;
  margin-bottom:50px;
  padding-bottom:50px;
  border-bottom:1px solid #e0d9cd;
}
.tsukie-rating-summary{
  text-align:left;
}
.tsukie-rating-number{
  font-family:'Playfair Display',serif;
  font-size:56px;
  font-weight:600;
  color:#1e2a38;
  margin:0 0 8px;
  line-height:1;
}
.tsukie-stars{
  color:#a08766;
  font-size:20px;
  margin:0 0 10px;
  letter-spacing:3px;
}
.tsukie-review-count{
  font-family:'Montserrat',sans-serif;
  font-size:13px;
  color:#5a5a5a;
  margin:0 0 24px;
}
.tsukie-rating-bars{
  margin-top:24px;
}
.tsukie-rating-row{
  display:flex;
  align-items:center;
  gap:12px;
  margin-bottom:8px;
  font-family:'Montserrat',sans-serif;
  font-size:13px;
}
.tsukie-rating-label{
  color:#1e2a38;
  min-width:20px;
}
.tsukie-rating-bar{
  flex:1;
  height:6px;
  background:#f0ebe0;
  border-radius:3px;
  overflow:hidden;
}
.tsukie-rating-fill{
  height:100%;
  background:#a08766;
  border-radius:3px;
}
.tsukie-rating-num{
  color:#5a5a5a;
  min-width:25px;
  text-align:right;
}
.tsukie-review-highlights{
  display:grid;
  grid-template-columns:repeat(3,1fr);
  gap:0;
  border:1px solid #e0d9cd;
  border-radius:8px;
  overflow:hidden;
  background:#fdfbf7;
}
.tsukie-highlight-box{
  padding:30px 20px;
  text-align:center;
  border-right:1px solid #e0d9cd;
}
.tsukie-highlight-box:last-child{
  border-right:none;
}
.tsukie-highlight-value{
  font-family:'Playfair Display',serif;
  font-size:32px;
  font-weight:600;
  color:#1e2a38;
  margin:0 0 6px;
}
.tsukie-highlight-label{
  font-family:'Montserrat',sans-serif;
  font-size:11px;
  letter-spacing:1.5px;
  text-transform:uppercase;
  color:#a08766;
  font-weight:600;
}
.tsukie-featured-quote{
  margin-top:30px;
  padding:30px;
  background:#f5f1ea;
  border-left:3px solid #a08766;
  border-radius:4px;
}
.tsukie-quote-text{
  font-family:'Playfair Display',serif;
  font-size:18px;
  font-style:italic;
  color:#1e2a38;
  margin:0 0 12px;
  line-height:1.6;
}
.tsukie-quote-author{
  font-family:'Montserrat',sans-serif;
  font-size:13px;
  color:#5a5a5a;
}
.tsukie-customer-reviews-title{
  font-family:'Playfair Display',serif;
  font-size:36px;
  font-style:italic;
  color:#1e2a38;
  margin:0 0 30px;
  font-weight:600;
}
.tsukie-reviews-grid{
  display:grid;
  grid-template-columns:repeat(2,1fr);
  gap:24px;
}
.tsukie-review-card{
  background:#f5f1ea;
  padding:28px;
  border-radius:8px;
  border:1px solid #e0d9cd;
}
.tsukie-review-header{
  display:flex;
  align-items:center;
  gap:14px;
  margin-bottom:16px;
}
.tsukie-reviewer-avatar{
  width:48px;
  height:48px;
  border-radius:50%;
  background:#d4c5a9;
  display:flex;
  align-items:center;
  justify-content:center;
  font-family:'Montserrat',sans-serif;
  font-size:16px;
  font-weight:600;
  color:#1e2a38;
  flex-shrink:0;
}
.tsukie-reviewer-info h4{
  font-family:'Montserrat',sans-serif;
  font-size:15px;
  font-weight:600;
  color:#1e2a38;
  margin:0 0 4px;
}
.tsukie-reviewer-meta{
  font-family:'Montserrat',sans-serif;
  font-size:12px;
  color:#5a5a5a;
}
.tsukie-review-stars{
  color:#a08766;
  font-size:14px;
  letter-spacing:2px;
  margin-bottom:14px;
}
.tsukie-review-text{
  font-family:'Montserrat',sans-serif;
  font-size:14px;
  line-height:1.7;
  color:#4a4a4a;
  margin:0 0 16px;
}
.tsukie-review-tag{
  display:inline-block;
  padding:6px 12px;
  background:#fdfbf7;
  border:1px solid #d4c5a9;
  border-radius:4px;
  font-family:'Montserrat',sans-serif;
  font-size:11px;
  letter-spacing:1px;
  text-transform:uppercase;
  color:#1e2a38;
  font-weight:600;
}

/* MOBILE OPTIMIZED - Kam space */
@media(max-width:990px){
  .tsukie-reviews-wrap{ padding:40px 0; }
  .tsukie-reviews-inner{ padding:0 16px; }
  .tsukie-reviews-header{
    grid-template-columns:1fr;
    gap:28px;
    margin-bottom:32px;
    padding-bottom:32px;
  }
  .tsukie-rating-number{ font-size:42px; margin:0 0 6px; }
  .tsukie-stars{ font-size:18px; margin:0 0 8px; }
  .tsukie-review-count{ margin:0 0 16px; }
  .tsukie-rating-bars{ margin-top:16px; }
  .tsukie-rating-row{ gap:8px; margin-bottom:6px; font-size:12px; }
  .tsukie-review-highlights{
    grid-template-columns:repeat(3,1fr);
    gap:0;
  }
  .tsukie-highlight-box{
    padding:16px 8px;
    border-right:1px solid #e0d9cd;
    border-bottom:none;
  }
  .tsukie-highlight-box:last-child{ border-right:none; }
  .tsukie-highlight-value{ font-size:22px; margin:0 0 4px; }
  .tsukie-highlight-label{ font-size:9px; letter-spacing:1px; }
  .tsukie-featured-quote{ margin-top:20px; padding:20px; }
  .tsukie-quote-text{ font-size:15px; margin:0 0 8px; }
  .tsukie-quote-author{ font-size:12px; }
  .tsukie-customer-reviews-title{ font-size:26px; margin:0 0 20px; }
  .tsukie-reviews-grid{ grid-template-columns:1fr; gap:16px; }
  .tsukie-review-card{ padding:20px; }
  .tsukie-review-header{ gap:12px; margin-bottom:12px; }
  .tsukie-reviewer-avatar{ width:40px; height:40px; font-size:14px; }
  .tsukie-reviewer-info h4{ font-size:14px; }
  .tsukie-reviewer-meta{ font-size:11px; }
  .tsukie-review-stars{ font-size:13px; margin-bottom:10px; }
  .tsukie-review-text{ font-size:13px; line-height:1.6; margin:0 0 12px; }
  .tsukie-review-tag{ padding:5px 10px; font-size:10px; }
}

@media(max-width:749px){
  .tsukie-reviews-wrap{ padding:32px 0; }
  .tsukie-reviews-inner{ padding:0 12px; }
  .tsukie-reviews-header{ gap:24px; margin-bottom:24px; padding-bottom:24px; }
  .tsukie-rating-number{ font-size:38px; }
  .tsukie-stars{ font-size:16px; letter-spacing:2px; }
  .tsukie-highlight-box{ padding:14px 6px; }
  .tsukie-highlight-value{ font-size:20px; }
  .tsukie-highlight-label{ font-size:8px; letter-spacing:0.5px; }
  .tsukie-featured-quote{ padding:16px; }
  .tsukie-quote-text{ font-size:14px; line-height:1.5; }
  .tsukie-customer-reviews-title{ font-size:24px; margin:0 0 16px; }
  .tsukie-reviews-grid{ gap:12px; }
  .tsukie-review-card{ padding:16px; }
}
</style>

<div class="tsukie-reviews-wrap">
  <div class="tsukie-reviews-inner">
    {% assign review_count = product.metafields.reviews.rating_count | default: 0 %}
    {% assign avg_rating = product.metafields.reviews.rating.value.rating | default: 4.8 %}
    
    {% if review_count > 0 %}
      <!-- REAL REVIEWS -->
      <div class="tsukie-reviews-header">
        <div class="tsukie-rating-summary">
          <p class="tsukie-rating-number">{{ avg_rating | round: 1 }}</p>
          <div class="tsukie-stars">★★★★★</div>
          <p class="tsukie-review-count">Based on {{ review_count }} reviews</p>
          
          <div class="tsukie-rating-bars">
            <div class="tsukie-rating-row">
              <span class="tsukie-rating-label">5 ★</span>
              <div class="tsukie-rating-bar"><div class="tsukie-rating-fill" style="width:78%"></div></div>
              <span class="tsukie-rating-num">66</span>
            </div>
            <div class="tsukie-rating-row">
              <span class="tsukie-rating-label">4 ★</span>
              <div class="tsukie-rating-bar"><div class="tsukie-rating-fill" style="width:14%"></div></div>
              <span class="tsukie-rating-num">12</span>
            </div>
            <div class="tsukie-rating-row">
              <span class="tsukie-rating-label">3 ★</span>
              <div class="tsukie-rating-bar"><div class="tsukie-rating-fill" style="width:5%"></div></div>
              <span class="tsukie-rating-num">4</span>
            </div>
            <div class="tsukie-rating-row">
              <span class="tsukie-rating-label">2 ★</span>
              <div class="tsukie-rating-bar"><div class="tsukie-rating-fill" style="width:2%"></div></div>
              <span class="tsukie-rating-num">2</span>
            </div>
            <div class="tsukie-rating-row">
              <span class="tsukie-rating-label">1 ★</span>
              <div class="tsukie-rating-bar"><div class="tsukie-rating-fill" style="width:0%"></div></div>
              <span class="tsukie-rating-num">0</span>
            </div>
          </div>
        </div>

        <div>
          <div class="tsukie-review-highlights">
            <div class="tsukie-highlight-box">
              <p class="tsukie-highlight-value">92%</p>
              <p class="tsukie-highlight-label">Recommend</p>
            </div>
            <div class="tsukie-highlight-box">
              <p class="tsukie-highlight-value">True</p>
              <p class="tsukie-highlight-label">To Size</p>
            </div>
            <div class="tsukie-highlight-box">
              <p class="tsukie-highlight-value">Soft</p>
              <p class="tsukie-highlight-label">Fabric Feel</p>
            </div>
          </div>
          
          <div id="shopify-product-reviews" data-id="{{ product.id }}">{{ product.metafields.spr.reviews }}</div>
        </div>
      </div>
      
    {% else %}
      <!-- DUMMY REVIEWS - Jab real 0 ho -->
      <div class="tsukie-reviews-header">
        <div class="tsukie-rating-summary">
          <p class="tsukie-rating-number">4.8</p>
          <div class="tsukie-stars">★★★★★</div>
          <p class="tsukie-review-count">Based on 84 reviews</p>
          
          <div class="tsukie-rating-bars">
            <div class="tsukie-rating-row">
              <span class="tsukie-rating-label">5 ★</span>
              <div class="tsukie-rating-bar"><div class="tsukie-rating-fill" style="width:78%"></div></div>
              <span class="tsukie-rating-num">66</span>
            </div>
            <div class="tsukie-rating-row">
              <span class="tsukie-rating-label">4 ★</span>
              <div class="tsukie-rating-bar"><div class="tsukie-rating-fill" style="width:14%"></div></div>
              <span class="tsukie-rating-num">12</span>
            </div>
            <div class="tsukie-rating-row">
              <span class="tsukie-rating-label">3 ★</span>
              <div class="tsukie-rating-bar"><div class="tsukie-rating-fill" style="width:5%"></div></div>
              <span class="tsukie-rating-num">4</span>
            </div>
            <div class="tsukie-rating-row">
              <span class="tsukie-rating-label">2 ★</span>
              <div class="tsukie-rating-bar"><div class="tsukie-rating-fill" style="width:2%"></div></div>
              <span class="tsukie-rating-num">2</span>
            </div>
            <div class="tsukie-rating-row">
              <span class="tsukie-rating-label">1 ★</span>
              <div class="tsukie-rating-bar"><div class="tsukie-rating-fill" style="width:0%"></div></div>
              <span class="tsukie-rating-num">0</span>
            </div>
          </div>
        </div>

        <div>
          <div class="tsukie-review-highlights">
            <div class="tsukie-highlight-box">
              <p class="tsukie-highlight-value">92%</p>
              <p class="tsukie-highlight-label">Recommend</p>
            </div>
            <div class="tsukie-highlight-box">
              <p class="tsukie-highlight-value">True</p>
              <p class="tsukie-highlight-label">To Size</p>
            </div>
            <div class="tsukie-highlight-box">
              <p class="tsukie-highlight-value">Soft</p>
              <p class="tsukie-highlight-label">Fabric Feel</p>
            </div>
          </div>
          
          <div class="tsukie-featured-quote">
            <p class="tsukie-quote-text">"The most flattering dress I've owned. Comfortable enough for a full workday, stunning enough for dinner."</p>
            <p class="tsukie-quote-author">Priya A., Mumbai · Size M</p>
          </div>
        </div>
      </div>

      <h2 class="tsukie-customer-reviews-title">Customer Reviews</h2>
      <div class="tsukie-reviews-grid">
        <div class="tsukie-review-card">
          <div class="tsukie-review-header">
            <div class="tsukie-reviewer-avatar">PA</div>
            <div class="tsukie-reviewer-info">
              <h4>Priya Anand</h4>
              <p class="tsukie-reviewer-meta">Mumbai · Size M · Verified Buyer</p>
            </div>
          </div>
          <div class="tsukie-review-stars">★★★★★</div>
          <p class="tsukie-review-text">Absolutely love this dress! The fabric is so soft and the fit is perfect. I've worn it to office and dinner - works for both. Got so many compliments. Will definitely order more colors.</p>
          <span class="tsukie-review-tag">DUSTY ROSE · M</span>
        </div>

        <div class="tsukie-review-card">
          <div class="tsukie-review-header">
            <div class="tsukie-reviewer-avatar">RK</div>
            <div class="tsukie-reviewer-info">
              <h4>Riya Kapoor</h4>
              <p class="tsukie-reviewer-meta">Delhi · Size L · Verified Buyer</p>
            </div>
          </div>
          <div class="tsukie-review-stars">★★★★★</div>
          <p class="tsukie-review-text">Finally found a brand that understands Indian body types. The length is perfect, sleeves don't feel tight, and the quality is amazing for the price. True to size!</p>
          <span class="tsukie-review-tag">IVORY · L</span>
        </div>

        <div class="tsukie-review-card">
          <div class="tsukie-review-header">
            <div class="tsukie-reviewer-avatar">SM</div>
            <div class="tsukie-reviewer-info">
              <h4>Sneha Mehta</h4>
              <p class="tsukie-reviewer-meta">Bangalore · Size S · Verified Buyer</p>
            </div>
          </div>
          <div class="tsukie-review-stars">★★★★★</div>
          <p class="tsukie-review-text">The fabric doesn't wrinkle easily which is a huge plus for workwear. Wore it for 10 hours and still looked fresh. Packaging was also beautiful. Very happy with this purchase.</p>
          <span class="tsukie-review-tag">SAGE · S</span>
        </div>

        <div class="tsukie-review-card">
          <div class="tsukie-review-header">
            <div class="tsukie-reviewer-avatar">AD</div>
            <div class="tsukie-reviewer-info">
              <h4>Ananya Desai</h4>
              <p class="tsukie-reviewer-meta">Pune · Size XL · Verified Buyer</p>
            </div>
          </div>
          <div class="tsukie-review-stars">★★★★★</div>
          <p class="tsukie-review-text">As someone who struggles to find good fits in XL, this was a pleasant surprise. The cut is flattering and the material feels premium. Size chart is accurate. Thank you Tsukie!</p>
          <span class="tsukie-review-tag">NAVY · XL</span>
        </div>
      </div>
    {% endif %}
  </div>
</div>