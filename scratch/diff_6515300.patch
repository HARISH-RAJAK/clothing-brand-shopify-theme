rif;\n  font-size:16px;\n  color:#999;\n  text-decoration:line-through;\n  font-weight:400;\n}\n.tsukie-price-save{\n  background:#1e2a38;\n  color:#d4c5a9;\n  font-family:'Montserrat',sans-serif;\n  font-size:10px;\n  letter-spacing:1px;\n  padding:4px 8px;\n  font-weight:600;\n  text-transform:uppercase;\n}\n.tsukie-emi{\n  font-family:'Montserrat',sans-serif;\n  font-size:12px;\n  color:#666;\n  margin-bottom:24px;\n}\n.tsukie-emi strong{color:#1e2a38;font-weight:500}\n\n/* Variants */\n.tsukie-variant-section{\n  margin-bottom:20px;\n}\n.tsukie-variant-header{\n  display:flex;\n  justify-content:space-between;\n  align-items:center;\n  margin-bottom:12px;\n}\n.tsukie-variant-label{\n  font-family:'Montserrat',sans-serif;\n  font-size:11px;\n  letter-spacing:1.5px;\n  text-transform:uppercase;\n  color:#1e2a38;\n  font-weight:500;\n}\n.tsukie-variant-value{\n  font-family:'Montserrat',sans-serif;\n  font-size:11px;\n  color:#666;\n  font-weight:400;\n}\n.tsukie-color-swatches{\n  display:flex;\n  gap:10px;\n  flex-wrap:wrap;\n}\n.tsukie-color-swatch{\n  width:36px;\n  height:36px;\n  border-radius:50%;\n  border:2px solid transparent;\n  cursor:pointer;\n  transition:all 0.2s;\n}\n.tsukie-color-swatch.active{\n  border-color:#1e2a38;\n  box-shadow:0 0 0 2px #f5f1ea, 0 0 0 4px #1e2a38;\n}\n.tsukie-size-options{\n  display:flex;\n  gap:6px;\n  flex-wrap:wrap;\n}\n.tsukie-size-btn{\n  background:#fff;\n  border:1px solid #e0d9cd;\n  padding:8px 16px;\n  font-family:'Montserrat',sans-serif;\n  font-size:11px;\n  font-weight:500;\n  color:#1e2a38;\n  cursor:pointer;\n  transition:all 0.2s;\n  min-width:44px;\n}\n.tsukie-size-btn:hover{\n  border-color:#1e2a38;\n}\n.tsukie-size-btn.active{\n  background:#1e2a38;\n  color:#d4c5a9;\n  border-color:#1e2a38;\n}\n.tsukie-size-btn.disabled{\n  opacity:0.3;\n  cursor:not-allowed;\n  text-decoration:line-through;\n}\n.tsukie-size-guide{\n  margin-top:12px;\n  display:flex;\n  align-items:center;\n  gap:6px;\n  font-family:'Montserrat',sans-serif;\n  font-size:11px;\n  color:#666;\n}\n.tsukie-size-guide a{\n  color:#1e2a38;\n  text-decoration:underline;\n}\n.tsukie-inventory{\n  margin-top:12px;\n  font-family:'Montserrat',sans-serif;\n  font-size:11px;\n  color:#a08766;\n  display:flex;\n  align-items:center;\n  gap:6px;\n}\n.tsukie-inventory::before{\n  content:'';\n  width:6px;\n  height:6px;\n  background:#a08766;\n  border-radius:50%;\n}\n\n/* Buttons */\n.tsukie-product-form{\n  margin:32px 0;\n}\n.tsukie-btn-group{\n  display:grid;\n  grid-template-columns:1fr 1fr;\n  gap:12px;\n  margin-bottom:24px;\n}\n.tsukie-btn{\n  padding:16px;\n  font-family:'Montserrat',sans-serif;\n  font-size:11px;\n  letter-spacing:2px;\n  text-transform:uppercase;\n  font-weight:600;\n  cursor:pointer;\n  transition:all 0.2s;\n  display:flex;\n  align-items:center;\n  justify-content:center;\n  gap:8px;\n  box-sizing: border-box;\n  border: 2px solid transparent;\n  height: 52px;\n}\n.tsukie-btn:disabled{\n  opacity:0.5;\n  cursor:not-allowed;\n}\n.tsukie-btn-add{\n  background:#1e2a38;\n  color:#d4c5a9;\n  border-color:#1e2a38;\n}\n.tsukie-btn-add:hover:not(:disabled){\n  background:transparent;\n  color:#1e2a38;\n  border-color:#1e2a38;\n}\n.tsukie-btn-buy{\n  background:transparent;\n  color:#1e2a38;\n  border-color:#1e2a38;\n  position: relative;\n}\n.tsukie-btn-buy:hover:not(:disabled){\n  background:#1e2a38;\n  color:#d4c5a9;\n}\n.tsukie-btn svg{width:16px;height:16px}\n\n/* Features Horizontal Row */\n.tsukie-features{\n  display:grid;\n  grid-template-columns:repeat(3,1fr);\n  gap:0;\n  border:1px solid #e0d9cd;\n  margin-bottom:24px;\n  background: transparent;\n}\n.tsukie-feature{\n  padding:20px 12px;\n  text-align:center;\n  border-right:1px solid #e0d9cd;\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  justify-content: flex-start;\n}\n.tsukie-feature:last-child{border-right:none}\n.tsukie-feature svg{\n  width:20px;\n  height:20px;\n  color:#1e2a38;\n  margin-bottom:8px;\n  flex-shrink: 0;\n}\n.tsukie-feature-title{\n  font-family:'Montserrat',sans-serif;\n  font-size:10px;\n  letter-spacing:1px;\n  text-transform:uppercase;\n  color:#1e2a38;\n  font-weight:600;\n  margin-bottom:4px;\n}\n.tsukie-feature-text{\n  font-family:'Montserrat',sans-serif;\n  font-size:11px;\n  color:#666;\n}\n\n/* Accordions */\n.tsukie-accordion{\n  border-top:1px solid #e0d9cd;\n}\n.tsukie-accordion-item{\n  border-bottom:1px solid #e0d9cd;\n}\n.tsukie-accordion-header{\n  padding:20px 0;\n  display:flex;\n  justify-content:space-between;\n  align-items:center;\n  cursor:pointer;\n  font-family:'Montserrat',sans-serif;\n  font-size:11px;\n  letter-spacing:2px;\n  text-transform:uppercase;\n  color:#1e2a38;\n  font-weight:500;\n}\n.tsukie-accordion-icon{\n  font-size:18px;\n  transition:transform 0.3s;\n  display: inline-block;\n  line-height: 1;\n}\n.tsukie-accordion-item.active .tsukie-accordion-icon{\n  transform:rotate(45deg);\n}\n.tsukie-accordion-content{\n  max-height:0;\n  overflow:hidden;\n  transition:all 0.3s ease-out;\n  font-family:'Montserrat',sans-serif;\n  font-size:13px;\n  line-height:1.8;\n  color:#666;\n}\n.tsukie-accordion-item.active .tsukie-accordion-content{\n  max-height:600px;\n  padding-bottom:20px;\n}\n\n/* Mobile Adjustments */\n@media(max-width:989px){\n  .tsukie-product-container{\n    grid-template-columns:1fr;\n    gap:24px;\n    padding:0 20px;\n  }\n  .tsukie-product-media{\n    position:relative;\n    top:0;\n    flex-direction:column;\n  }\n  .tsukie-thumbnails-wrapper{\n    display:none;\n  }\n  .tsukie-product-title{\n    font-size:28px;\n  }\n  .tsukie-price{\n    font-size:24px;\n  }\n  .tsukie-btn-group{\n    grid-template-columns:1fr;\n  }\n  /* STRICT Horizontal Lock on Mobile */\n  .tsukie-features{\n    grid-template-columns:repeat(3,1fr) !important;\n  }\n  .tsukie-feature{\n    padding:16px 4px;\n    border-right:1px solid #e0d9cd;\n    border-bottom:none;\n  }\n  .tsukie-feature-title{\n    font-size:8px;\n    letter-spacing:0.5px;\n  }\n  .tsukie-feature-text{\n    font-size:9px;\n  }\n}\n\n  /* Size Guide Modal Styles */\n  .tsukie-size-guide-modal {\n    position: fixed;\n    top: 0;\n    left: 0;\n    width: 100vw;\n    height: 100vh;\n    z-index: 10000;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n  }\n  .tsukie-size-guide-modal-overlay {\n    position: absolute;\n    top: 0;\n    left: 0;\n    width: 100%;\n    height: 100%;\n    background: rgba(30, 42, 56, 0.6);\n    backdrop-filter: blur(4px);\n  }\n  .tsukie-size-guide-modal-content {\n    position: relative;\n    background: #fdfbf7;\n    border: 2px solid #d4c5a9;\n    border-radius: 8px;\n    width: 90%;\n    max-width: 500px;\n    padding: 30px;\n    box-shadow: 0 10px 30px rgba(0,0,0,0.15);\n    z-index: 10001;\n  }\n  .tsukie-size-guide-modal-close {\n    position: absolute;\n    top: 15px;\n    right: 15px;\n    background: none;\n    border: none;\n    font-size: 24px;\n    cursor: pointer;\n    color: #1e2a38;\n    line-height: 1;\n    padding: 0;\n    transition: color 0.2s;\n  }\n  .tsukie-size-guide-modal-close:hover {\n    color: #a08766;\n  }\n  .tsukie-size-guide-modal-title {\n    font-family: 'Playfair Display', serif;\n    font-size: 24px;\n    font-style: italic;\n    font-weight: 600;\n    color: #1e2a38;\n    margin: 0 0 20px;\n    text-align: center;\n  }\n  .tsukie-size-guide-table-wrap {\n    overflow-x: auto;\n  }\n  .tsukie-size-guide-table-wrap table {\n    width: 100%;\n    border-collapse: collapse;\n    font-family: 'Montserrat', sans-serif;\n    font-size: 13px;\n  }\n  .tsukie-size-guide-table-wrap th, \n  .tsukie-size-guide-table-wrap td {\n    padding: 12px;\n    border: 1px solid #e0d9cd;\n    text-align: center;\n  }\n  .tsukie-size-guide-table-wrap th {\n    background: #1e2a38;\n    color: #d4c5a9;\n    font-weight: 600;\n    text-transform: uppercase;\n    font-size: 11px;\n    letter-spacing: 1px;\n  }\n  .tsukie-size-guide-table-wrap tr:nth-child(even) {\n    background: rgba(212, 197, 169, 0.1);\n  }\n  \n  /* Special Offers Section Styling (Horizontal Strip above CTA) */\n  .tsukie-special-offers-strip {\n    background: #fdfbf7;\n    border: 1px solid #e0d9cd;\n    border-radius: 4px;\n    padding: 10px 14px;\n    margin-bottom: 20px;\n    font-family: 'Montserrat', sans-serif;\n    display: flex;\n    align-items: center;\n    justify-content: space-between;\n    gap: 12px;\n  }\n  .tsukie-offers-title {\n    font-size: 11px;\n    font-weight: 700;\n    color: #1e2a38;\n    text-transform: uppercase;\n    letter-spacing: 1px;\n    display: flex;\n    align-items: center;\n    gap: 6px;\n    flex-shrink: 0;\n  }\n  .tsukie-offers-title svg {\n    width: 14px;\n    height: 14px;\n    color: #a08766;\n  }\n  .tsukie-offers-strip-items {\n    display: flex;\n    gap: 12px;\n    flex-wrap: wrap;\n    flex: 1;\n    justify-content: flex-end;\n  }\n  .tsukie-offer-strip-item {\n    background: #f5f1ea;\n    border: 1px dashed #d4c5a9;\n    border-radius: 3px;\n    padding: 6px 10px;\n    display: flex;\n    align-items: center;\n    gap: 6px;\n    cursor: pointer;\n    font-size: 11px;\n    color: #1e2a38;\n    transition: all 0.2s ease;\n  }\n  .tsukie-offer-strip-item:hover {\n    border-color: #1e2a38;\n    background: #e0d9cd;\n  }\n  .tsukie-offer-strip-item strong {\n    font-weight: 700;\n  }\n  .tsukie-offer-strip-item .copy-lbl {\n    font-size: 9px;\n    text-transform: uppercase;\n    font-weight: 600;\n    color: #a08766;\n    border-left: 1px solid rgba(30,42,56,0.15);\n    padding-left: 6px;\n  }\n  \n  /* Redesigned Order Status Tracker */\n  .tsukie-order-status-v2 {\n    text-align: center;\n    margin: 28px 0;\n    background: transparent;\n  }\n  .tsukie-status-title-v2 {\n    font-family: 'Montserrat', sans-serif;\n    font-size: 13px;\n    font-weight: 700;\n    color: #1e2a38;\n    letter-spacing: 1.5px;\n    margin: 0 0 6px 0;\n    text-transform: uppercase;\n  }\n  .tsukie-status-subtitle-v2 {\n    font-family: 'Montserrat', sans-serif;\n    font-size: 11px;\n    color: #666;\n    margin: 0 0 24px 0;\n    font-weight: 400;\n  }\n  .tsukie-timeline-v2 {\n    display: flex;\n    justify-content: space-between;\n    align-items: center;\n    position: relative;\n    max-width: 380px;\n    margin: 0 auto 12px;\n    padding: 0 25px;\n  }\n  .tsukie-timeline-v2::before {\n    content: '';\n    position: absolute;\n    top: 50%;\n    left: 35px;\n    right: 35px;\n    height: 1px;\n    background: #e0d9cd;\n    transform: translateY(-50%);\n    z-index: 1;\n  }\n  .tsukie-node-v2 {\n    position: relative;\n    z-index: 2;\n  }\n  .tsukie-circle-v2 {\n    width: 24px;\n    height: 24px;\n    border-radius: 50%;\n    border: 1px solid #1e2a38;\n    background: #fdfbf7;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    transition: all 0.3s ease;\n  }\n  .tsukie-circle-v2.active {\n    background: #1e2a38;\n    border-color: #1e2a38;\n  }\n  .tsukie-circle-v2 svg {\n    width: 12px;\n    height: 12px;\n    color: #1e2a38;\n    stroke-width: 2.5;\n  }\n  .tsukie-circle-v2.active svg {\n    color: #d4c5a9;\n  }\n  .tsukie-labels-grid-v2 {\n    display: grid;\n    grid-template-columns: repeat(3, 1fr);\n    max-width: 440px;\n    margin: 0 auto;\n    gap: 4px;\n  }\n  .tsukie-label-item-v2 {\n    text-align: center;\n  }\n  .tsukie-lbl-title-v2 {\n    font-family: 'Montserrat', sans-serif;\n    font-size: 11px;\n    font-weight: 600;\n    color: #1e2a38;\n    margin-bottom: 2px;\n    line-height: 1.2;\n  }\n  .tsukie-lbl-date-v2 {\n    font-family: 'Montserrat', sans-serif;\n    font-size: 10px;\n    color: #888;\n    font-weight: 500;\n    line-height: 1.2;\n  }\n  \n  /* Premium SVG Trust Badges Row */\n  .tsukie-premium-badges {\n    display: grid;\n    grid-template-columns: repeat(3, 1fr);\n    gap: 16px;\n    margin: 24px 0;\n    border-top: 1px solid #e0d9cd;\n    border-bottom: 1px solid #e0d9cd;\n    padding: 16px 0;\n    background: transparent;\n  }\n  .tsukie-premium-badge-item {\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    text-align: center;\n    gap: 8px;\n  }\n  .tsukie-premium-badge-item svg {\n    width: 24px;\n    height: 24px;\n    color: #1e2a38;\n  }\n  .tsukie-premium-badge-text {\n    font-family: 'Montserrat', sans-serif;\n    font-size: 11px;\n    font-weight: 600;\n    color: #1e2a38;\n    letter-spacing: 0.5px;\n    text-transform: uppercase;\n  }\n  \n  @media(max-width:768px){\n    .tsukie-special-offers-strip {\n      flex-direction: column;\n      align-items: flex-start;\n      gap: 10px;\n    }\n    .tsukie-offers-strip-items {\n      justify-content: flex-start;\n      width: 100%;\n      gap: 8px;\n    }\n  }\n  @media (max-width: 480px) {\n    .tsukie-lbl-title-v2 { font-size: 9px; }\n    .tsukie-lbl-date-v2 { font-size: 8px; }\n    .tsukie-timeline-v2 { padding: 0 15px; }\n    .tsukie-timeline-v2::before { left: 25px; right: 25px; }\n    .tsukie-circle-v2 { width: 20px; height: 20px; }\n    .tsukie-circle-v2 svg { width: 10px; height: 10px; }\n    .tsukie-premium-badge-text { font-size: 9px; letter-spacing: 0px; }\n    .tsukie-premium-badge-item svg { width: 20px; height: 20px; }\n  }\n</style>\n\n<section class=\"tsukie-product\" data-section-id=\"{{ section.id }}\" data-section-type=\"product\">\n  <div class=\"tsukie-product-container\">\n    <!-- Left Layout -->\n    <div class=\"tsukie-product-media\">\n      <div class=\"tsukie-thumbnails-wrapper\">\n        {% if product.images.size > 6 %}\n          <button class=\"tsukie-thumb-nav\" type=\"button\" onclick=\"tsukieScrollThumbs('up')\">\n            <svg fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M5 15l7-7 7 7\"></path></svg>\n          </button>\n        {% endif %}\n        \n        <div class=\"tsukie-thumbnails\" id=\"tsukie-thumbs-list\">\n          {% for image in product.images %}\n            <div class=\"tsukie-thumb {% if forloop.first %}active{% endif %}\" data-alt=\"{{ image.alt | escape }}\" data-img-id=\"{{ image.id }}\" onclick=\"tsukieChangeImage('{{ image | img_url: '1000x' }}', {{ forloop.index0 }})\">\n              <img src=\"{{ image | img_url: '200x' }}\" alt=\"{{ product.title | escape }}\" loading=\"lazy\">\n            </div>\n          {% endfor %}\n        </div>\n\n        {% if product.images.size > 6 %}\n          <button class=\"tsukie-thumb-nav\" type=\"button\" onclick=\"tsukieScrollThumbs('down')\">\n            <svg fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M19 9l-7 7-7-7\"></path></svg>\n          </button>\n        {% endif %}\n      </div>\n\n      <div class=\"tsukie-main-image-wrap\">\n        <div class=\"tsukie-main-image\">\n          <div class=\"tsukie-badge-container\">\n            {% for tag in product.tags %}\n              {% unless tag contains 'filter' or tag contains 'meta-' or tag contains 'custom-' or tag == 'all' %}\n                <div class=\"tsukie-badge\">{{ tag | upcase }}</div>\n              {% endunless %}\n            {% endfor %}\n          </div>\n          <img id=\"tsukie-main-img\" src=\"{{ product.featured_image | img_url: '1000x' }}\" alt=\"{{ product.title | escape }}\">\n          <button class=\"tsukie-carousel-nav prev\" type=\"button\" onclick=\"tsukiePrevImage()\">\n            <svg fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"1.5\" d=\"M15 19l-7-7 7-7\"></path></svg>\n          </button>\n          <button class=\"tsukie-carousel-nav next\" type=\"button\" onclick=\"tsukieNextImage()\">\n            <svg fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"1.5\" d=\"M9 5l7 7-7 7\"></path></svg>\n          </button>\n        </div>\n      </div>\n    </div>\n\n    <!-- Right Layout -->\n    <div class=\"tsukie-product-info\">\n      <h1 class=\"tsukie-product-title\">{{ product.title }}</h1>\n\n      {% if product.metafields.custom.subtitle %}\n        <p class=\"tsukie-product-subtitle\">{{ product.metafields.custom.subtitle }}</p>\n      {% endif %}\n\n      <div class=\"tsukie-rating-row\">\n        <div class=\"tsukie-stars\">\n          {% for i in (1..5) %}\n            <svg viewBox=\"0 0 20 20\"><path d=\"M10 15l-5.878 3.09 1.123-6.545L.489 6.91l6.572-.955L10 0l2.939 5.955 6.572.955-4.756 4.635 1.123 6.545z\"/></svg>\n          {% endfor %}\n        </div>\n        <div class=\"tsukie-rating-text\">4.8 <span>84 reviews</span></div>\n        <div class=\"tsukie-verified\">VERIFIED PURCHASE</div>\n      </div>\n\n      <div class=\"tsukie-price-row\" id=\"tsukie-price-wrapper\">\n        <div class=\"tsukie-price\" id=\"tsukie-price\">{{ product.selected_or_first_available_variant.price | money }}</div>\n        <div class=\"tsukie-price-compare\" id=\"tsukie-compare-price\" style=\"{% unless product.selected_or_first_available_variant.compare_at_price > product.selected_or_first_available_variant.price %}display:none;{% endunless %}\">\n          {{ product.selected_or_first_available_variant.compare_at_price | money }}\n        </div>\n        <div class=\"tsukie-price-save\" id=\"tsukie-save-badge\" style=\"{% unless product.selected_or_first_available_variant.compare_at_price > product.selected_or_first_available_variant.price %}display:none;{% endunless %}\">\n          {% if product.selected_or_first_available_variant.compare_at_price > product.selected_or_first_available_variant.price %}\n            SAVE {{ product.selected_or_first_available_variant.compare_at_price | minus: product.selected_or_first_available_variant.price | times: 100 | divided_by: product.selected_or_first_available_variant.compare_at_price }}%\n          {% endif %}\n        </div>\n      </div>\n      \n      <!-- 1. PNG Trust Badges Section -->\n      <div class=\"tsukie-premium-badges\">\n        <div class=\"tsukie-premium-badge-item\">\n          <svg fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M20.25 7.5l-.625 10.632a2.25 2.25 0 01-2.247 2.118H6.622a2.25 2.25 0 01-2.247-2.118L3.75 7.5M10 11.25h4M3.375 7.5h17.25c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125H3.375c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125z\" /></svg>\n          <span class=\"tsukie-premium-badge-text\">COD Available</span>\n        </div>\n        <div class=\"tsukie-premium-badge-item\">\n          <svg fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z\" /></svg>\n          <span class=\"tsukie-premium-badge-text\">Secure Checkout</span>\n        </div>\n        <div class=\"tsukie-premium-badge-item\">\n          <svg fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M8.625 12a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H8.25m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H12m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0h-.375M21 12c0 4.556-4.03 8.25-9 8.25a9.764 9.764 0 01-2.555-.337A5.972 5.972 0 015.41 20.97a.75.75 0 01-1.074-.765 5.99 5.99 0 011.524-2.238C4.034 16.556 3 14.379 3 12c0-4.556 4.03-8.25 9-8.25s9 3.694 9 8.25z\" /></svg>\n          <span class=\"tsukie-premium-badge-text\">24/7 Support</span>\n        </div>\n      </div>\n\n      <!-- Tracker Section -->\n      <div class=\"tsukie-order-status-v2\">\n        <h3 class=\"tsukie-status-title-v2\">ORDER STATUS</h3>\n        <p class=\"tsukie-status-subtitle-v2\">Track your delivery and expected arrival time!</p>\n        \n        <div class=\"tsukie-timeline-v2\">\n          <div class=\"tsukie-node-v2\">\n            <div class=\"tsukie-circle-v2 active\">\n              <svg fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"3\" d=\"M5 13l4 4L19 7\"></path></svg>\n            </div>\n          </div>\n          <div class=\"tsukie-node-v2\">\n            <div class=\"tsukie-circle-v2 active\">\n              <svg fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"3\" d=\"M5 13l4 4L19 7\"></path></svg>\n            </div>\n          </div>\n          <div class=\"tsukie-node-v2\">\n            <div class=\"tsukie-circle-v2\">\n              <svg fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z\"></path></svg>\n            </div>\n          </div>\n        </div>\n        \n        <div class=\"tsukie-labels-grid-v2\">\n          <div class=\"tsukie-label-item-v2\">\n            <div class=\"tsukie-lbl-title-v2\">Order Confirmed</div>\n            <div class=\"tsukie-lbl-date-v2\">{{ \"now\" | date: \"%b %d %A\" }}</div>\n          </div>\n          <div class=\"tsukie-label-item-v2\">\n            <div class=\"tsukie-lbl-title-v2\">On Its Way</div>\n            <div class=\"tsukie-lbl-date-v2\">{{ \"now\" | date: \"%s\" | plus: 86400 | date: \"%b %d %A\" }}</div>\n          </div>\n          <div class=\"tsukie-label-item-v2\">\n            <div class=\"tsukie-lbl-title-v2\">Arriving Soon</div>\n            <div class=\"tsukie-lbl-date-v2\">Expected {{ \"now\" | date: \"%s\" | plus: 259200 | date: \"%b %d %A\" }}</div>\n          </div>\n        </div>\n      </div>\n      <!-- END OF TRACKER CODES -->\n      <div class=\"tsukie-features\">\n        <div class=\"tsukie-feature\">\n          <svg fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"1.5\" d=\"M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z\"></path></svg>\n          <div class=\"tsukie-feature-title\">PREMIUM FABRIC</div>\n          <div class=\"tsukie-feature-text\">100% Viscose</div>\n        </div>\n        <div class=\"tsukie-feature\">\n          <svg fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"1.5\" d=\"M4 4v5h.582m15.356 2A8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 0 01-15.357-2m15.357 2H15\"></path></svg>\n          <div class=\"tsukie-feature-title\">EASY EXCHANGE</div>\n          <div class=\"tsukie-feature-text\">14 days</div>\n        </div>\n        <div class=\"tsukie-feature\">\n          <svg fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"1.5\" d=\"M9 12l2 2 4-4m5.618-4.016A11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z\"></path></svg>\n          <div class=\"tsukie-feature-title\">SECURE PAYMENT</div>\n          <div class=\"tsukie-feature-text\">UPI · Cards · COD</div>\n        </div>\n      </div>\n\n      <!-- Accordion Blocks -->\n      <div class=\"tsukie-accordion\">\n        {% if product.description != blank %}\n          <div class=\"tsukie-accordion-item\">\n            <div class=\"tsukie-accordion-header\" onclick=\"tsukieToggleAccordion(this)\">\n              PRODUCT DESCRIPTION <span class=\"tsukie-accordion-icon\">+</span>\n            </div>\n            <div class=\"tsukie-accordion-content\">\n              <div style=\"padding-top:12px;\">{{ product.description }}</div>\n            </div>\n          </div>\n        {% endif %}\n        {% assign spec = product.metafields.custom.specification | default: product.metafields.custom.specifications %}\n        {% if spec != blank %}\n          <div class=\"tsukie-accordion-item\">\n            <div class=\"tsukie-accordion-header\" onclick=\"tsukieToggleAccordion(this)\">\n              SPECIFICATIONS <span class=\"tsukie-accordion-icon\">+</span>\n            </div>\n            <div class=\"tsukie-accordion-content\">\n              <div style=\"padding-top:12px;\">{{ spec }}</div>\n            </div>\n          </div>\n        {% endif %}\n        {% assign care = product.metafields.custom.fabric_care | default: product.metafields.custom.care %}\n        {% if care != blank %}\n          <div class=\"tsukie-accordion-item\">\n            <div class=\"tsukie-accordion-header\" onclick=\"tsukieToggleAccordion(this)\">\n              FABRIC & CARE <span class=\"tsukie-accordion-icon\">+</span>\n            </div>\n            <div class=\"tsukie-accordion-content\">\n              <div style=\"padding-top:12px;\">{{ care }}</div>\n            </div>\n          </div>\n        {% endif %}\n        <div class=\"tsukie-accordion-item\">\n          <div class=\"tsukie-accordion-header\" onclick=\"tsukieToggleAccordion(this)\">\n            SHIPPING & RETURNS <span class=\"tsukie-accordion-icon\">+</span>\n          </div>\n          <div class=\"tsukie-accordion-content\">\n            <div style=\"padding-top:12px;\">Free shipping on orders above ₹1,999. Easy 14-day returns and exchanges. Delivery within 5-7 business days across India.</div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </div>\n\n<!-- Size Guide Modal Markup -->\n<div class=\"tsukie-size-guide-modal\" id=\"tsukie-size-guide-modal\" style=\"display:none;\">\n  <div class=\"tsukie-size-guide-modal-overlay\" onclick=\"tsukieCloseSizeGuide()\"></div>\n  <div class=\"tsukie-size-guide-modal-content\">\n    <button class=\"tsukie-size-guide-modal-close\" onclick=\"tsukieCloseSizeGuide()\">&times;</button>\n    <h3 class=\"tsukie-size-guide-modal-title\">Size Guide</h3>\n    <div class=\"tsukie-size-guide-table-wrap\">\n      <table>\n        <thead>\n          <tr>\n            <th>Size</th>\n            <th>Bust (in)</th>\n            <th>Waist (in)</th>\n            <th>Hips (in)</th>\n          </tr>\n        </thead>\n        <tbody>\n          <tr>\n            <td>XS</td>\n            <td>32</td>\n            <td>26</td>\n            <td>36</td>\n          </tr>\n          <tr>\n            <td>S</td>\n            <td>34</td>\n            <td>28</td>\n            <td>38</td>\n          </tr>\n          <tr>\n            <td>M</td>\n            <td>36</td>\n            <td>30</td>\n            <td>40</td>\n          </tr>\n          <tr>\n            <td>L</td>\n            <td>38</td>\n            <td>32</td>\n            <td>42</td>\n          </tr>\n          <tr>\n            <td>XL</td>\n            <td>40</td>\n            <td>34</td>\n            <td>44</td>\n          </tr>\n          <tr>\n            <td>XXL</td>\n            <td>42</td>\n            <td>36</td>\n            <td>46</td>\n          </tr>\n          <tr>\n            <td>3XL</td>\n            <td>44</td>\n            <td>38</td>\n            <td>48</td>\n          </tr>\n          <tr>\n            <td>4XL</td>\n            <td>46</td>\n            <td>40</td>\n            <td>50</td>\n          </tr>\n        </tbody>\n      </table>\n    </div>\n  </div>\n</div>\n</section>\n\n<!-- Judge.me Reviews Widget -->\n<div style=\"max-width: 1200px; margin: 40px auto; padding: 0 20px; clear: both;\">\n  <div id=\"judgeme_product_reviews\" class=\"jdgm-widget jdgm-review-widget\" data-id=\"{{ product.id }}\" data-product-title=\"{{ product.title | escape }}\" data-product-id=\"{{ product.id }}\">\n    {{ product.metafields.judgeme.widget }}\n  </div>\n</div>\n\n<script>\nlet tsukieCurrentImage = 0;\n// Size Guide Modal JS\nfunction tsukieOpenSizeGuide(e) {\n  e.preventDefault();\n  const modal = document.getElementById('tsukie-size-guide-modal');\n  if (modal) modal.style.display = 'flex';\n}\nfunction tsukieCloseSizeGuide() {\n  const modal = document.getElementById('tsukie-size-guide-modal');\n  if (modal) modal.style.display = 'none';\n}\n\n// Color Filtered Gallery JS\nfunction tsukieFilterImagesByColor(colorName) {\n  if (!colorName) return;\n  const thumbs = document.querySelectorAll('.tsukie-thumb');\n  let firstMatch = null;\n  let firstMatchIndex = -1;\n  \n  thumbs.forEach((thumb, idx) => {\n    const alt = (thumb.getAttribute('data-alt') || '').toLowerCase();\n    const color = colorName.toLowerCase();\n    \n    if (alt.includes(color) || color.includes(alt)) {\n      thumb.style.display = 'block';\n      if (firstMatch === null) {\n        firstMatch = thumb;\n        firstMatchIndex = idx;\n      }\n    } else {\n      thumb.style.display = 'none';\n    }\n  });\n  \n  if (firstMatch) {\n    const src = firstMatch.querySelector('img').src.replace('200x', '1000x').replace('_200x', '_1000x');\n    tsukieChangeImage(src, firstMatchIndex);\n  } else {\n    thumbs.forEach(thumb => {\n      thumb.style.display = 'block';\n    });\n  }\n}\n\n// Push to Recently Viewed\n(function() {\n  const currentId = '{{ product.id }}';\n  if (currentId) {\n    let viewed = JSON.parse(localStorage.getItem('viewedProducts') || '[]');\n    viewed = viewed.filter(x => x !== currentId);\n    viewed.unshift(currentId);\n    viewed = viewed.slice(0, 10);\n    localStorage.setItem('viewedProducts', JSON.stringify(viewed));\n  }\n})();\n\nconst tsukieImages = [{% for image in product.images %}'{{ image | img_url: '1000x' }}'{% unless forloop.last %},{% endunless %}{% endfor %}];\nconst tsukieImageIds = [{% for image in product.images %}{{ image.id }}{% unless forloop.last %},{% endunless %}{% endfor %}];\nconst tsukieProduct = {{ product | json }};\n\nlet tsukieSelectedOptions = { 1: null, 2: null, 3: null };\nconst defaultVariantId = {{ product.selected_or_first_available_variant.id | default: 'null' }};\nif (defaultVariantId) {\n  const defaultVar = tsukieProduct.variants.find(v => v.id === defaultVariantId);\n  if (defaultVar) {\n    tsukieSelectedOptions[1] = defaultVar.option1;\n    tsukieSelectedOptions[2] = defaultVar.option2;\n    tsukieSelectedOptions[3] = defaultVar.option3;\n    \n    \n    // Also trigger initial filtering if there's a color option on load\n    const colorIndex = tsukieProduct.options.findIndex(opt => opt.toLowerCase() === 'color' || opt.toLowerCase() === 'colour');\n    if (colorIndex > -1) {\n      const initialColor = defaultVar['option' + (colorIndex + 1)];\n      if (initialColor) {\n        setTimeout(() => tsukieFilterImagesByColor(initialColor), 100);\n      }\n    }\n\n  }\n}\n\nfunction tsukieChangeImage(src, index) {\n  const mainImg = document.getElementById('tsukie-main-img');\n  if(mainImg) mainImg.src = src;\n  tsukieCurrentImage = index;\n  document.querySelectorAll('.tsukie-thumb').forEach((thumb, i) => {\n    thumb.classList.toggle('active', i === index);\n  });\n}\n\nfunction tsukiePrevImage() {\n  if(!tsukieImages.length) return;\n  tsukieCurrentImage = (tsukieCurrentImage - 1 + tsukieImages.length) % tsukieImages.length;\n  tsukieChangeImage(tsukieImages[tsukieCurrentImage], tsukieCurrentImage);\n}\n\nfunction tsukieNextImage() {\n  if(!tsukieImages.length) return;\n  tsukieCurrentImage = (tsukieCurrentImage + 1) % tsukieImages.length;\n  tsukieChangeImage(tsukieImages[tsukieCurrentImage], tsukieCurrentImage);\n}\n\nfunction tsukieScrollThumbs(direction) {\n  const container = document.getElementById('tsukie-thumbs-list');\n  if(!container) return;\n  container.scrollTop += (direction === 'up') ? -88 : 88;\n}\n\nfunction tsukieSelectOption(element, position, value) {\n  tsukieSelectedOptions[position] = value;\n  \n  const optionIndex = position - 1;\n  const optionName = tsukieProduct.options[optionIndex];\n  const isColor = optionName && (optionName.toLowerCase() === 'color' || optionName.toLowerCase() === 'colour');\n  if (isColor) {\n    tsukieFilterImagesByColor(value);\n  }\n  \n  document.querySelectorAll(`[data-option-position=\"${position}\"]`).forEach(el => {\n    el.classList.remove('active');\n  });\n  element.classList.add('active');\n  \n  const optionIndex = position - 1;\n  if(tsukieProduct.options[optionIndex]) {\n    const name = tsukieProduct.options[optionIndex].toLowerCase().replace(/\\s+/g, '-');\n    const selectedLabel = document.getElementById(`tsukie-selected-${name}`);\n    if(selectedLabel) selectedLabel.textContent = value;\n  }\n  \n  const matchedVariant = tsukieProduct.variants.find(variant => {\n    return (!variant.option1 || variant.option1 === tsukieSelectedOptions[1]) &&\n           (!variant.option2 || variant.option2 === tsukieSelectedOptions[2]) &&\n           (!variant.option3 || variant.option3 === tsukieSelectedOptions[3]);\n  });\n  \n  if (matchedVariant) {\n    document.getElementById('tsukie-variant-id').value = matchedVariant.id;\n    \n    const formatter = new Intl.NumberFormat('en-IN', { style: 'currency', currency: 'INR', maximumFractionDigits: 0 });\n    const priceEl = document.getElementById('tsukie-price');\n    \n    \n    if(priceEl) priceEl.textContent = formatter.format(matchedVariant.price / 100);\n    \n    \n    const compPriceEl = document.getElementById('tsukie-compare-price');\n    const saveBadgeEl = document.getElementById('tsukie-save-badge');\n    if(compPriceEl && saveBadgeEl) {\n      if(matchedVariant.compare_at_price && matchedVariant.compare_at_price > matchedVariant.price) {\n        compPriceEl.textContent = formatter.format(matchedVariant.compare_at_price / 100);\n        compPriceEl.style.display = 'block';\n        let pct = Math.round(((matchedVariant.compare_at_price - matchedVariant.price) * 100) / matchedVariant.compare_at_price);\n        saveBadgeEl.textContent = `SAVE ${pct}%`;\n        saveBadgeEl.style.display = 'block';\n      } else {\n        compPriceEl.style.display = 'none';\n        saveBadgeEl.style.display = 'none';\n      }\n    }\n    \n    if (matchedVariant.featured_image && matchedVariant.featured_image.id) {\n      const imgIndex = tsukieImageIds.indexOf(matchedVariant.featured_image.id);\n      if(imgIndex > -1) {\n        tsukieChangeImage(tsukieImages[imgIndex], imgIndex);\n      }\n    }\n    \n    const addBtn = document.getElementById('tsukie-add-to-cart-btn');\n    const buyBtn = document.getElementById('tsukie-buy-now-btn');\n    const addText = document.getElementById('tsukie-add-btn-text');\n    if(matchedVariant.available) {\n      if(addBtn) addBtn.removeAttribute('disabled');\n      if(buyBtn) buyBtn.removeAttribute('disabled');\n      if(addText) addText.textContent = \"ADD TO BAG\";\n    } else {\n      if(addBtn) addBtn.setAttribute('disabled', 'disabled');\n      if(buyBtn) buyBtn.setAttribute('disabled', 'disabled');\n      if(addText) addText.textContent = \"SOLD OUT\";\n    }\n  }\n}\n\n// Fixed Isolated Buy Now: Clears cart first so old items don't appear in Checkout!\nfunction tsukieBuyNowClean() {\n  const variantId = document.getElementById('tsukie-variant-id').value;\n  const buyBtn = document.getElementById('tsukie-buy-now-btn');\n  const buyTxt = document.getElementById('tsukie-buy-text');\n  \n  if(buyBtn) buyBtn.setAttribute('disabled', 'disabled');\n  if(buyTxt) buyTxt.textContent = \"PROCESSING...\";\n\n  // Phase 1: Wipe any legacy active cart items\n  fetch(window.Shopify.routes.root + 'cart/clear.js', {\n    method: 'POST',\n    headers: { 'Content-Type': 'application/json' }\n  })\n  // Phase 2: Add only the currently selected size/color variant\n  .then(() => {\n    return fetch(window.Shopify.routes.root + 'cart/add.js', {\n      method: 'POST',\n      headers: { 'Content-Type': 'application/json' },\n      body: JSON.stringify({\n        'items': [{ 'id': parseInt(variantId), 'quantity': 1 }]\n      })\n    });\n  })\n  // Phase 3: Securely push the user straight to Checkout panel\n  .then(res => res.json())\n  .then(() => {\n    window.location.href = '/checkout';\n  })\n  .catch(err => {\n    console.error('Checkout error:', err);\n    window.location.href = '/checkout?updates[' + variantId + ']=1';\n  });\n}\n\nfunction tsukieToggleAccordion(header) {\n  const currentItem = header.parentElement;\n  document.querySelectorAll('.tsukie-accordion-item').forEach(item => {\n    if (item !== currentItem) item.classList.remove('active');\n  });\n  currentItem.classList.toggle('active');\n}\n\nfunction tsukieCopyCode(el, code) {\n  navigator.clipboard.writeText(code).then(() => {\n    const copyLbl = el.querySelector('.copy-lbl');\n    if (copyLbl) {\n      const origText = copyLbl.textContent;\n      copyLbl.textContent = 'COPIED!';\n      copyLbl.style.color = '#1e2a38';\n      setTimeout(() => {\n        copyLbl.textContent = origText;\n        copyLbl.style.color = '#a08766';\n      }, 1500);\n    }\n  });\n}\n\n// Custom Reviews Hijack logic\n(function() {\n  function hideDuplicateWidgets() {\n    const allWidgets = document.querySelectorAll('.jdgm-review-widget');\n    if (allWidgets.length > 1) {\n      for (let i = 1; i < allWidgets.length; i++) {\n        allWidgets[i].style.setProperty('display', 'none', 'important');\n      }\n    }\n  }\n\n  function initCustomReviews() {\n    hideDuplicateWidgets();\n    const widget = document.querySelector('#judgeme_product_reviews');\n    if (!widget) return;\n    \n    const origList = widget.querySelector('.jdgm-rev-list');\n    if (!origList) return;\n    \n    if (widget.querySelector('.tsukie-custom-reviews-wrapper')) return;\n    \n    const customWrap = document.createElement('div');\n    customWrap.className = 'tsukie-custom-reviews-wrapper';\n    customWrap.innerHTML = `\n      <style>\n        .jdgm-widget-header,\n        .jdgm-histogram,\n        .jdgm-summary,\n        .jdgm-rev-widg__summary,\n        .jdgm-rev-widg__header,\n        .jdgm-rev-list,\n        .jdgm-paginate,\n        .jdgm-widget-actions-wrapper {\n          display: none !important;\n        }\n        .tsukie-custom-rev-list {\n          display: flex;\n          flex-direction: column;\n          gap: 20px;\n          margin-top: 20px;\n        }\n        .tsukie-custom-rev-list .jdgm-rev {\n          display: block !important;\n          border-bottom: 1px solid rgba(30,42,56,0.08);\n          padding-bottom: 20px;\n        }\n        .tsukie-custom-rev-list .jdgm-rev:last-child {\n          border-bottom: none;\n        }\n        .tsukie-custom-reviews-actions button {\n          font-family: 'Montserrat', sans-serif;\n          font-size: 11px;\n          letter-spacing: 2px;\n          text-transform: uppercase;\n          font-weight: 600;\n          cursor: pointer;\n          border: none;\n          transition: all 0.2s;\n          display: flex;\n          align-items: center;\n          justify-content: center;\n        }\n      </style>\n      <div class=\"tsukie-custom-rev-list\"></div>\n      <div class=\"tsukie-custom-reviews-actions\" style=\"display: none; justify-content: center; gap: 16px; margin-top: 24px; margin-bottom: 24px;\">\n        <button type=\"button\" class=\"tsukie-reviews-see-more tsukie-btn tsukie-btn-buy\" style=\"max-width: 200px; padding: 12px 24px; border-radius: 0;\">Load More</button>\n        <button type=\"button\" class=\"tsukie-reviews-see-less tsukie-btn\" style=\"max-width: 200px; padding: 12px 24px; display: none; background: transparent; border: 1px solid #1e2a38; color: #1e2a38; border-radius: 0;\">See Less</button>\n      </div>\n    `;\n    \n    widget.appendChild(customWrap);\n    \n    const customList = customWrap.querySelector('.tsukie-custom-rev-list');\n    const actionsDiv = customWrap.querySelector('.tsukie-custom-reviews-actions');\n    const seeMoreBtn = customWrap.querySelector('.tsukie-reviews-see-more');\n    const seeLessBtn = customWrap.querySelector('.tsukie-reviews-see-less');\n    \n    let allReviews = [];\n    let visibleCount = 1;\n    \n    function updateCustomView() {\n      customList.innerHTML = '';\n      const itemsToRender = allReviews.slice(0, visibleCount);\n      itemsToRender.forEach(rev => {\n        const clone = rev.cloneNode(true);\n        customList.appendChild(clone);\n      });\n      \n      const nativeNextBtn = widget.querySelector('.jdgm-paginate__next-page, .jdgm-next-page, [data-page=\"next\"], .jdgm-paginate__page[data-page=\"next\"]');\n      \n      if (allReviews.length > 1 || nativeNextBtn) {\n        actionsDiv.style.display = 'flex';\n      } else {\n        actionsDiv.style.display = 'none';\n      }\n      \n      if (visibleCount < allReviews.length || nativeNextBtn) {\n        seeMoreBtn.style.display = 'flex';\n        seeLessBtn.style.display = 'none';\n      } else {\n        seeMoreBtn.style.display = 'none';\n        seeLessBtn.style.display = 'flex';\n      }\n    }\n    \n    function scanOriginalReviews() {\n      const origRevs = origList.querySelectorAll('.jdgm-rev');\n      let newAdded = false;\n      origRevs.forEach(rev => {\n        const revId = rev.getAttribute('data-review-id') || rev.innerHTML.substring(0, 100);\n        const exists = allReviews.some(r => (r.getAttribute('data-review-id') || r.innerHTML.substring(0, 100)) === revId);\n        if (!exists) {\n          allReviews.push(rev);\n          newAdded = true;\n        }\n      });\n      if (newAdded) {\n        updateCustomView();\n      }\n    }\n    \n    scanOriginalReviews();\n    \n    const observer = new MutationObserver(() => {\n      scanOriginalReviews();\n    });\n    observer.observe(origList, { childList: true, subtree: true });\n    \n    seeMoreBtn.addEventListener('click', () => {\n      if (visibleCount < allReviews.length) {\n        visibleCount += 5;\n        updateCustomView();\n      } else {\n        const nativeNextBtn = widget.querySelector('.jdgm-paginate__next-page, .jdgm-next-page, [data-page=\"next\"], .jdgm-paginate__page[data-page=\"next\"]');\n        if (nativeNextBtn) {\n          seeMoreBtn.disabled = true;\n          seeMoreBtn.textContent = 'Loading...';\n          nativeNextBtn.click();\n          setTimeout(() => {\n            seeMoreBtn.disabled = false;\n            seeMoreBtn.textContent = 'Load More';\n            visibleCount += 5;\n            updateCustomView();\n          }, 1500);\n        }\n      }\n    });\n    \n    seeLessBtn.addEventListener('click', () => {\n      visibleCount = 1;\n      updateCustomView();\n      widget.scrollIntoView({ behavior: 'smooth' });\n    });\n  }\n  \n  const bodyObserver = new MutationObserver(() => {\n    hideDuplicateWidgets();\n    initCustomReviews();\n  });\n  bodyObserver.observe(document.body, { childList: true, subtree: true });\n  initCustomReviews();\n})();\n</script>",
