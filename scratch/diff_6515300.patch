g:6px 12px;\n  font-weight:600;\n  z-index: 2;\n}\n.tsukie-carousel-nav{\n  position:absolute;\n  top:50%;\n  transform:translateY(-50%);\n  background:rgba(255,255,255,0.9);\n  border:none;\n  width:40px;\n  height:40px;\n  cursor:pointer;\n  display:flex;\n  align-items:center;\n  justify-content:center;\n  z-index: 2;\n}\n.tsukie-carousel-nav.prev{left:12px}\n.tsukie-carousel-nav.next{right:12px}\n.tsukie-carousel-nav svg{width:18px;height:18px;color:#1e2a38}\n\n/* Right: Info */\n.tsukie-product-info{\n  padding-top:8px;\n}\n.tsukie-product-title{\n  font-family:'Playfair Display',serif;\n  font-size:36px;\n  font-weight:400;\n  color:#1e2a38;\n  margin:0 0 12px;\n  line-height:1.2;\n}\n.tsukie-product-subtitle{\n  font-family:'Montserrat',sans-serif;\n  font-size:13px;\n  color:#666;\n  margin:0 0 16px;\n  font-weight:300;\n}\n.tsukie-rating-row{\n  display:flex;\n  align-items:center;\n  gap:12px;\n  margin-bottom:20px;\n  padding-bottom:20px;\n  border-bottom:1px solid #e0d9cd;\n  flex-wrap:wrap;\n}\n.tsukie-stars{\n  display:flex;\n  gap:2px;\n}\n.tsukie-stars svg{\n  width:14px;\n  height:14px;\n  color:#1e2a38;\n  fill:#1e2a38;\n}\n.tsukie-rating-text{\n  font-family:'Montserrat',sans-serif;\n  font-size:13px;\n  color:#1e2a38;\n  font-weight:500;\n}\n.tsukie-rating-text span{\n  color:#666;\n  font-weight:400;\n}\n.tsukie-verified{\n  border:1px solid #e0d9cd;\n  padding:4px 10px;\n  font-family:'Montserrat',sans-serif;\n  font-size:10px;\n  letter-spacing:1px;\n  text-transform:uppercase;\n  color:#666;\n}\n\n/* Price */\n.tsukie-price-row{\n  margin-bottom:8px;\n  display:flex;\n  align-items:baseline;\n  gap:12px;\n  flex-wrap:wrap;\n}\n.tsukie-price{\n  font-family:'Montserrat',sans-serif;\n  font-size:28px;\n  font-weight:500;\n  color:#1e2a38;\n}\n.tsukie-price-compare{\n  font-family:'Montserrat',sans-serif;\n  font-size:16px;\n  color:#999;\n  text-decoration:line-through;\n  font-weight:400;\n}\n.tsukie-price-save{\n  background:#1e2a38;\n  color:#d4c5a9;\n  font-family:'Montserrat',sans-serif;\n  font-size:10px;\n  letter-spacing:1px;\n  padding:4px 8px;\n  font-weight:600;\n  text-transform:uppercase;\n}\n.tsukie-emi{\n  font-family:'Montserrat',sans-serif;\n  font-size:12px;\n  color:#666;\n  margin-bottom:24px;\n}\n.tsukie-emi strong{color:#1e2a38;font-weight:500}\n\n/* Variants */\n.tsukie-variant-section{\n  margin-bottom:20px;\n}\n.tsukie-variant-header{\n  display:flex;\n  justify-content:space-between;\n  align-items:center;\n  margin-bottom:12px;\n}\n.tsukie-variant-label{\n  font-family:'Montserrat',sans-serif;\n  font-size:11px;\n  letter-spacing:1.5px;\n  text-transform:uppercase;\n  color:#1e2a38;\n  font-weight:500;\n}\n.tsukie-variant-value{\n  font-family:'Montserrat',sans-serif;\n  font-size:11px;\n  color:#666;\n  font-weight:400;\n}\n.tsukie-color-swatches{\n  display:flex;\n  gap:10px;\n  flex-wrap:wrap;\n}\n.tsukie-color-swatch{\n  width:36px;\n  height:36px;\n  border-radius:50%;\n  border:2px solid transparent;\n  cursor:pointer;\n  transition:all 0.2s;\n}\n.tsukie-color-swatch.active{\n  border-color:#1e2a38;\n  box-shadow:0 0 0 2px #f5f1ea, 0 0 0 4px #1e2a38;\n}\n.tsukie-size-options{\n  display:flex;\n  gap:6px;\n  flex-wrap:wrap;\n}\n.tsukie-size-btn{\n  background:#fff;\n  border:1px solid #e0d9cd;\n  padding:8px 16px;\n  font-family:'Montserrat',sans-serif;\n  font-size:11px;\n  font-weight:500;\n  color:#1e2a38;\n  cursor:pointer;\n  transition:all 0.2s;\n  min-width:44px;\n}\n.tsukie-size-btn:hover{\n  border-color:#1e2a38;\n}\n.tsukie-size-btn.active{\n  background:#1e2a38;\n  color:#d4c5a9;\n  border-color:#1e2a38;\n}\n.tsukie-size-btn.disabled{\n  opacity:0.3;\n  cursor:not-allowed;\n  text-decoration:line-through;\n}\n.tsukie-size-guide{\n  margin-top:12px;\n  display:flex;\n  align-items:center;\n  gap:6px;\n  font-family:'Montserrat',sans-serif;\n  font-size:11px;\n  color:#666;\n}\n.tsukie-size-guide a{\n  color:#1e2a38;\n  text-decoration:underline;\n}\n.tsukie-inventory{\n  margin-top:12px;\n  font-family:'Montserrat',sans-serif;\n  font-size:11px;\n  color:#a08766;\n  display:flex;\n  align-items:center;\n  gap:6px;\n}\n.tsukie-inventory::before{\n  content:'';\n  width:6px;\n  height:6px;\n  background:#a08766;\n  border-radius:50%;\n}\n\n/* Buttons */\n.tsukie-product-form{\n  margin:32px 0;\n}\n.tsukie-btn-group{\n  display:grid;\n  grid-template-columns:1fr 1fr;\n  gap:12px;\n  margin-bottom:24px;\n}\n.tsukie-btn{\n  padding:16px;\n  font-family:'Montserrat',sans-serif;\n  font-size:11px;\n  letter-spacing:2px;\n  text-transform:uppercase;\n  font-weight:600;\n  cursor:pointer;\n  transition:all 0.2s;\n  display:flex;\n  align-items:center;\n  justify-content:center;\n  gap:8px;\n  box-sizing: border-box;\n  border: 2px solid transparent;\n  height: 52px;\n}\n.tsukie-btn:disabled{\n  opacity:0.5;\n  cursor:not-allowed;\n}\n.tsukie-btn-add{\n  background:#1e2a38;\n  color:#d4c5a9;\n  border-color:#1e2a38;\n}\n.tsukie-btn-add:hover:not(:disabled){\n  background:transparent;\n  color:#1e2a38;\n  border-color:#1e2a38;\n}\n.tsukie-btn-buy{\n  background:transparent;\n  color:#1e2a38;\n  border-color:#1e2a38;\n  position: relative;\n}\n.tsukie-btn-buy:hover:not(:disabled){\n  background:#1e2a38;\n  color:#d4c5a9;\n}\n.tsukie-btn svg{width:16px;height:16px}\n\n/* Features Horizontal Row */\n.tsukie-features{\n  display:grid;\n  grid-template-columns:repeat(3,1fr);\n  gap:0;\n  border:1px solid #e0d9cd;\n  margin-bottom:24px;\n  background: transparent;\n}\n.tsukie-feature{\n  padding:20px 12px;\n  text-align:center;\n  border-right:1px solid #e0d9cd;\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  justify-content: flex-start;\n}\n.tsukie-feature:last-child{border-right:none}\n.tsukie-feature svg{\n  width:20px;\n  height:20px;\n  color:#1e2a38;\n  margin-bottom:8px;\n  flex-shrink: 0;\n}\n.tsukie-feature-title{\n  font-family:'Montserrat',sans-serif;\n  font-size:10px;\n  letter-spacing:1px;\n  text-transform:uppercase;\n  color:#1e2a38;\n  font-weight:600;\n  margin-bottom:4px;\n}\n.tsukie-feature-text{\n  font-family:'Montserrat',sans-serif;\n  font-size:11px;\n  color:#666;\n}\n\n/* Accordions */\n.tsukie-accordion{\n  border-top:1px solid #e0d9cd;\n}\n.tsukie-accordion-item{\n  border-bottom:1px solid #e0d9cd;\n}\n.tsukie-accordion-header{\n  padding:20px 0;\n  display:flex;\n  justify-content:space-between;\n  align-items:center;\n  cursor:pointer;\n  font-family:'Montserrat',sans-serif;\n  font-size:11px;\n  letter-spacing:2px;\n  text-transform:uppercase;\n  color:#1e2a38;\n  font-weight:500;\n}\n.tsukie-accordion-icon{\n  font-size:18px;\n  transition:transform 0.3s;\n  display: inline-block;\n  line-height: 1;\n}\n.tsukie-accordion-item.active .tsukie-accordion-icon{\n  transform:rotate(45deg);\n}\n.tsukie-accordion-content{\n  max-height:0;\n  overflow:hidden;\n  transition:all 0.3s ease-out;\n  font-family:'Montserrat',sans-serif;\n  font-size:13px;\n  line-height:1.8;\n  color:#666;\n}\n.tsukie-accordion-item.active .tsukie-accordion-content{\n  max-height:600px;\n  padding-bottom:20px;\n}\n\n/* Mobile Adjustments */\n@media(max-width:989px){\n  .tsukie-product-container{\n    grid-template-columns:1fr;\n    gap:24px;\n    padding:0 20px;\n  }\n  .tsukie-product-media{\n    position:relative;\n    top:0;\n    flex-direction:column;\n  }\n  .tsukie-thumbnails-wrapper{\n    display:none;\n  }\n  .tsukie-product-title{\n    font-size:28px;\n  }\n  .tsukie-price{\n    font-size:24px;\n  }\n  .tsukie-btn-group{\n    grid-template-columns:1fr;\n  }\n  /* STRICT Horizontal Lock on Mobile */\n  .tsukie-features{\n    grid-template-columns:repeat(3,1fr) !important;\n  }\n  .tsukie-feature{\n    padding:16px 4px;\n    border-right:1px solid #e0d9cd;\n    border-bottom:none;\n  }\n  .tsukie-feature-title{\n    font-size:8px;\n    letter-spacing:0.5px;\n  }\n  .tsukie-feature-text{\n    font-size:9px;\n  }\n}\n\n  /* Size Guide Modal Styles */\n  .tsukie-size-guide-m