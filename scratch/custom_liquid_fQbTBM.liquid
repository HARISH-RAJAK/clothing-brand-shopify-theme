  background:linear-gradient(135deg, #1e2a38 0%, #a08766 30%, #c9a77c 50%, #a08766 70%, #1e2a38 100%);
  -webkit-background-clip:text;
  -webkit-text-fill-color:transparent;
  background-clip:text;
  line-height:1.1;
  position:relative;
}
.tsukie-header-divider{
  display:flex;
  align-items:center;
  justify-content:center;
  gap:12px;
  margin:0 auto;
}
.tsukie-header-line{
