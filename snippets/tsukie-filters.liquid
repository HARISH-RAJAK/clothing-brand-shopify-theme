                {%- when 'green' -%}{%- assign swatch_bg = '#27AE60' -%}
                {%- when 'navy' or 'navy blue' -%}{%- assign swatch_bg = '#001F3F' -%}
                {%- when 'pink' -%}{%- assign swatch_bg = '#E91E63' -%}
                {%- when 'beige' -%}{%- assign swatch_bg = '#F5F1EA' -%}
                {%- when 'cream' -%}{%- assign swatch_bg = '#FFFDD0' -%}
