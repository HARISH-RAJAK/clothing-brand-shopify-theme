{%- comment -%}
  Tsukie Premium Filter UI
  Renders filter bar + sidebar drawer for collection page
  Dynamic data from collection.filters & collection.all_tags
  Does NOT affect product grid layout
{%- endcomment -%}

{%- liquid
  assign sort_by = collection.sort_by | default: collection.default_sort_by
  assign total_active_values = 0
  for filter in collection.filters
    if filter.type == 'price_range'
      if filter.min_value.value != blank or filter.max_value.value != blank
        assign total_active_values = total_active_values | plus: 1
      endif
    else
      assign total_active_values = total_active_values | plus: filter.active_values.size
    endif
  endfor

  comment
    DYNAMIC COLOR FILTER FROM COLLECTION PRODUCTS
  endcomment
  assign color_option_name = "Color"
  assign raw_colors = ""
  for product in collection.products
    for option in product.options_with_values
      assign option_name_downcase = option.name | downcase
      if option_name_downcase == 'color' or option_name_downcase == 'colour'
        assign color_option_name = option.name
        for value in option.values
          assign val_clean = value | strip
          if val_clean != blank
            assign raw_colors = raw_colors | append: ";" | append: val_clean
          endif
        endfor
      endif
    endfor
  endfor
  assign unique_colors = raw_colors | split: ";" | uniq | compact
  assign color_param_name = "filter.v.option." | append: color_option_name | downcase

  assign has_native_color_filter = false
  for filter in collection.filters
    assign filter_down = filter.label | downcase
    if filter_down contains 'color' or filter_down contains 'colour'
      assign has_native_color_filter = true
    endif
  endfor
-%}

<!-- Google Fonts for Tsukie Filters -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400;1,500&family=Jost:wght@300;400;500&display=swap" rel="stylesheet">

{{ 'tsukie-filters.css' | asset_url | stylesheet_tag }}

<!-- ===== TSUKIE FILTER BAR ===== -->
<div class="tsukie-filter-bar">
  <div class="tsukie-filter-left">
    {%- assign current_handle = collection.handle -%}
    {%- if request.path == '/products' or request.path == '/collections' or request.path == '/collections/all' -%}
      {%- assign current_handle = 'all' -%}
    {%- endif -%}

    <a href="/collections/all" class="tsukie-filter-chip {% if current_handle == 'all' or current_handle == blank %}tsukie-active tsukie-gold{% endif %}">All</a>
    <a href="/collections/tops" class="tsukie-filter-chip {% if current_handle == 'tops' %}tsukie-active tsukie-gold{% endif %}">Tops</a>
    <a href="/collections/co-ord-set" class="tsukie-filter-chip {% if current_handle == 'co-ord-set' %}tsukie-active tsukie-gold{% endif %}">Co-ord Set</a>
    <a href="/collections/dresses" class="tsukie-filter-chip {% if current_handle == 'dresses' %}tsukie-active tsukie-gold{% endif %}">Dresses</a>
    <a href="/collections/skirts" class="tsukie-filter-chip {% if current_handle == 'skirts' %}tsukie-active tsukie-gold{% endif %}">Skirts</a>
    <a href="/collections/shirts" class="tsukie-filter-chip {% if current_handle == 'shirts' %}tsukie-active tsukie-gold{% endif %}">Shirts</a>
    <a href="/collections/bottoms" class="tsukie-filter-chip {% if current_handle == 'bottoms' %}tsukie-active tsukie-gold{% endif %}">Bottoms</a>
  </div>

  <div class="tsukie-filter-right">
    <select class="tsukie-sort-select" id="tsukieSortSelect">
      {%- for option in collection.sort_options -%}
        <option value="{{ option.value }}"{% if option.value == sort_by %} selected{% endif %}>
          {{ option.name }}
        </option>
      {%- endfor -%}
    </select>

    <button class="tsukie-filter-toggle-btn" id="tsukieFilterToggle" type="button">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><line x1="4" y1="6" x2="20" y2="6"/><line x1="4" y1="12" x2="14" y2="12"/><line x1="4" y1="18" x2="10" y2="18"/></svg>
      Filters
      {%- if total_active_values > 0 -%}
        <span class="tsukie-filter-count">{{ total_active_values }}</span>
      {%- endif -%}
    </button>
  </div>
</div>

<!-- ===== TSUKIE SIDEBAR OVERLAY ===== -->
<div class="tsukie-sidebar-overlay" id="tsukieSidebarOverlay"></div>

<!-- ===== TSUKIE SIDEBAR FILTERS ===== -->
<div class="tsukie-sidebar-filters" id="tsukieSidebarFilters">
  <div class="tsukie-sidebar-inner">
    <!-- Header -->
    <div class="tsukie-sidebar-header">
      <span class="tsukie-sidebar-heading">Refine</span>
      <button class="tsukie-sidebar-close" id="tsukieSidebarClose" type="button">✕ Close</button>
    </div>

    <!-- Dynamic Filters from collection.filters -->
    {%- for filter in collection.filters -%}
      <div class="tsukie-sidebar-section" data-filter-index="{{ forloop.index }}">
        <div class="tsukie-sidebar-title" onclick="this.parentElement.classList.toggle('tsukie-collapsed')">
          {{ filter.label }}
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><polyline points="6 9 12 15 18 9"/></svg>
        </div>
        <div class="tsukie-sidebar-content">

          {%- case filter.type -%}

            {%- when 'price_range' -%}
              <!-- PRICE RANGE -->
              <p class="tsukie-price-range-display">
                {{ filter.range_min | money_without_trailing_zeros }} — {{ filter.range_max | money_without_trailing_zeros }}
              </p>
              <div class="tsukie-price-inputs">
                <input
                  type="number"
                  class="tsukie-price-input"
                  id="tsukiePriceMin"
                  placeholder="{{ filter.range_min | money_without_trailing_zeros }}"
                  {%- if filter.min_value.value != blank %} value="{{ filter.min_value.value }}"{% endif %}
                  data-param-name="{{ filter.min_value.param_name }}"
                >
                <span class="tsukie-price-separator">—</span>
                <input
                  type="number"
                  class="tsukie-price-input"
                  id="tsukiePriceMax"
                  placeholder="{{ filter.range_max | money_without_trailing_zeros }}"
                  {%- if filter.max_value.value != blank %} value="{{ filter.max_value.value }}"{% endif %}
                  data-param-name="{{ filter.max_value.param_name }}"
                >
              </div>
              <button type="button" class="tsukie-price-apply" onclick="tsukieApplyPrice()">Apply</button>

            {%- when 'boolean' -%}
              <!-- BOOLEAN (e.g., Availability) -->
              <div class="tsukie-sidebar-options">
                {%- for value in filter.values -%}
                  <a href="javascript:void(0)"
                     class="tsukie-sidebar-option"
                     onclick="tsukieToggleFilter('{{ value.param_name }}','{{ value.value }}',{{ value.active }})"
                  >
                    <div class="tsukie-sidebar-check{% if value.active %} tsukie-checked{% endif %}"></div>
                    <span class="tsukie-sidebar-option-label">{{ value.label }}</span>
                    <span class="tsukie-sidebar-option-count">({{ value.count }})</span>
                  </a>
                {%- endfor -%}
              </div>

            {%- else -%}
              {%- assign filter_down = filter.label | downcase -%}

              {%- if filter_down contains 'size' -%}
                <!-- SIZE PILLS -->
                <div class="tsukie-size-pills">
                  {%- for value in filter.values -%}
                    {%- if value.count > 0 or value.active -%}
                      <a href="javascript:void(0)"
                         class="tsukie-size-pill{% if value.active %} tsukie-active{% endif %}"
                         onclick="tsukieToggleFilter('{{ value.param_name }}','{{ value.value }}',{{ value.active }})"
                         title="{{ value.label }} ({{ value.count }})"
                      >{{ value.label }}</a>
                    {%- endif -%}
                  {%- endfor -%}
                </div>

              {%- elsif filter_down contains 'color' or filter_down contains 'colour' -%}
