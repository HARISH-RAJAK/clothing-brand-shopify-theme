                  {%- for value in filter.values -%}
                    {%- if value.count > 0 or value.active -%}
                      {%- assign swatch_bg = '' -%}

                      {%- if value.swatch.color != blank -%}
                        {%- assign swatch_bg = value.swatch.color -%}
                      {%- else -%}
