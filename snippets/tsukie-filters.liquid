<!-- ===== TSUKIE FILTER JAVASCRIPT ===== -->
<script>
(function(){
  /* Sort handler */
  var sortEl = document.getElementById('tsukieSortSelect');
  if(sortEl){
    sortEl.addEventListener('change', function(){
      var url = new URL(window.location);
      if(this.value) url.searchParams.set('sort_by', this.value);
      else url.searchParams.delete('sort_by');
      window.location = url.toString();
    });
  }

  /* Sidebar open */
  var toggleBtn = document.getElementById('tsukieFilterToggle');
  if(toggleBtn){
    toggleBtn.addEventListener('click', function(){
      document.getElementById('tsukieSidebarFilters').classList.add('tsukie-open');
      document.getElementById('tsukieSidebarOverlay').classList.add('tsukie-open');
      document.body.style.overflow = 'hidden';
    });
  }

  /* Sidebar close */
  function closeSidebar(){
    document.getElementById('tsukieSidebarFilters').classList.remove('tsukie-open');
    document.getElementById('tsukieSidebarOverlay').classList.remove('tsukie-open');
    document.body.style.overflow = '';
  }

  var closeBtn = document.getElementById('tsukieSidebarClose');
  if(closeBtn) closeBtn.addEventListener('click', closeSidebar);

  var overlay = document.getElementById('tsukieSidebarOverlay');
  if(overlay) overlay.addEventListener('click', closeSidebar);

  /* Close on Escape key */
  document.addEventListener('keydown', function(e){
    if(e.key === 'Escape'){
      var sidebar = document.getElementById('tsukieSidebarFilters');
      if(sidebar && sidebar.classList.contains('tsukie-open')) closeSidebar();
    }
  });

  /* Parse active dynamic color parameters on load */
  var params = new URLSearchParams(window.location.search);
  var activeColorsCount = 0;
  var swatches = document.querySelectorAll('.tsukie-dynamic-color-swatch');
  swatches.forEach(function(swatch) {
    var paramName = swatch.getAttribute('data-param-name');
    var colorName = swatch.getAttribute('data-color-name');
    var activeValues = params.getAll(paramName);
    if (activeValues.includes(colorName)) {
      swatch.classList.add('tsukie-active');
      activeColorsCount++;
    }
  });

  if (activeColorsCount > 0) {
    // Update total active filter count badge
    var countBadge = document.querySelector('.tsukie-filter-count');
    if (countBadge) {
      var currentCount = parseInt(countBadge.textContent) || 0;
      countBadge.textContent = currentCount + activeColorsCount;
    } else {
      var toggleBtn = document.getElementById('tsukieFilterToggle');
      if (toggleBtn) {
        var badge = document.createElement('span');
        badge.className = 'tsukie-filter-count';
        badge.textContent = activeColorsCount;
        toggleBtn.appendChild(badge);
      }
    }

    // Ensure Clear All Filters button is visible
    var clearBtn = document.querySelector('.tsukie-clear-filters');
    if (!clearBtn) {
      var sidebarInner = document.querySelector('.tsukie-sidebar-inner');
      if (sidebarInner) {
        var clearA = document.createElement('a');
        clearA.href = window.location.pathname; // clears query params
        clearA.className = 'tsukie-clear-filters';
        clearA.textContent = 'Clear All Filters';
        sidebarInner.appendChild(clearA);
      }
    }
  }
})();

/* Toggle filter value via URL params */
function tsukieToggleFilter(paramName, value, isActive){
  var url = new URL(window.location);
  if(isActive){
    var allValues = url.searchParams.getAll(paramName);
    url.searchParams.delete(paramName);
    allValues.forEach(function(v){
      if(v !== value) url.searchParams.append(paramName, v);
    });
  } else {
    url.searchParams.append(paramName, value);
  }
  url.searchParams.delete('page');
  window.location = url.toString();
}

/* Apply price filter */
function tsukieApplyPrice(){
  var url = new URL(window.location);
  var minInput = document.getElementById('tsukiePriceMin');
  var maxInput = document.getElementById('tsukiePriceMax');

  if(minInput){
    if(minInput.value) url.searchParams.set(minInput.dataset.paramName, minInput.value);
    else url.searchParams.delete(minInput.dataset.paramName);
  }
  if(maxInput){
    if(maxInput.value) url.searchParams.set(maxInput.dataset.paramName, maxInput.value);
    else url.searchParams.delete(maxInput.dataset.paramName);
  }

  url.searchParams.delete('page');
  window.location = url.toString();
}
</script>
