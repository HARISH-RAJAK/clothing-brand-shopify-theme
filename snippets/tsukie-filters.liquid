                        {%- case cn -%}
                          {%- when 'black' -%}{%- assign swatch_bg = '#000000' -%}
                          {%- when 'white' -%}{%- assign swatch_bg = '#FFFFFF' -%}
                          {%- when 'red' -%}{%- assign swatch_bg = '#C0392B' -%}
                          {%- when 'blue' -%}{%- assign swatch_bg = '#2980B9' -%}
                          {%- when 'green' -%}{%- assign swatch_bg = '#27AE60' -%}
                          {%- when 'navy' or 'navy blue' -%}{%- assign swatch_bg = '#001F3F' -%}
                          {%- when 'pink' -%}{%- assign swatch_bg = '#E91E63' -%}
                          {%- when 'beige' -%}{%- assign swatch_bg = '#F5F1EA' -%}
                          {%- when 'cream' -%}{%- assign swatch_bg = '#FFFDD0' -%}
                          {%- when 'brown' -%}{%- assign swatch_bg = '#795548' -%}
                          {%- when 'grey' or 'gray' -%}{%- assign swatch_bg = '#95A5A6' -%}
                          {%- when 'yellow' -%}{%- assign swatch_bg = '#F1C40F' -%}
                          {%- when 'orange' -%}{%- assign swatch_bg = '#E67E22' -%}
                          {%- when 'purple' -%}{%- assign swatch_bg = '#9B59B6' -%}
                          {%- when 'maroon' -%}{%- assign swatch_bg = '#800000' -%}
                          {%- when 'olive' -%}{%- assign swatch_bg = '#808000' -%}
                          {%- when 'teal' -%}{%- assign swatch_bg = '#008080' -%}
                          {%- when 'nude' -%}{%- assign swatch_bg = '#E8D5C4' -%}
                          {%- when 'blush' -%}{%- assign swatch_bg = '#F5E6D8' -%}
                          {%- when 'charcoal' -%}{%- assign swatch_bg = '#2A2520' -%}
                          {%- when 'caramel' -%}{%- assign swatch_bg = '#8B7355' -%}
                          {%- when 'sage' -%}{%- assign swatch_bg = '#6B8E8A' -%}
                          {%- when 'dusty rose' -%}{%- assign swatch_bg = '#C4949A' -%}
                          {%- when 'off white' -%}{%- assign swatch_bg = '#FAF9F6' -%}
                          {%- when 'ivory' -%}{%- assign swatch_bg = '#FFFFF0' -%}
                          {%- when 'rust' -%}{%- assign swatch_bg = '#B7410E' -%}
                          {%- when 'burgundy' -%}{%- assign swatch_bg = '#800020' -%}
                          {%- when 'coral' -%}{%- assign swatch_bg = '#FF7F50' -%}
                          {%- when 'khaki' -%}{%- assign swatch_bg = '#C3B091' -%}
                          {%- when 'lavender' -%}{%- assign swatch_bg = '#E6E6FA' -%}
                          {%- when 'mint' -%}{%- assign swatch_bg = '#98FF98' -%}
                          {%- when 'peach' -%}{%- assign swatch_bg = '#FFDAB9' -%}
                          {%- when 'tan' -%}{%- assign swatch_bg = '#D2B48C' -%}
                          {%- when 'wine' -%}{%- assign swatch_bg = '#722F37' -%}
                          {%- when 'gold' -%}{%- assign swatch_bg = '#FFD700' -%}
                          {%- when 'silver' -%}{%- assign swatch_bg = '#C0C0C0' -%}
                          {%- when 'champagne' -%}{%- assign swatch_bg = '#F7E7CE' -%}
                          {%- when 'mustard' -%}{%- assign swatch_bg = '#FFDB58' -%}
                          {%- when 'rose' -%}{%- assign swatch_bg = '#FF007F' -%}
                          {%- when 'sand' -%}{%- assign swatch_bg = '#C2B280' -%}
                          {%- when 'taupe' -%}{%- assign swatch_bg = '#483C32' -%}
                          {%- when 'lilac' -%}{%- assign swatch_bg = '#C8A2C8' -%}
                          {%- when 'moss' -%}{%- assign swatch_bg = '#8A9A5B' -%}
                          {%- when 'copper' -%}{%- assign swatch_bg = '#B87333' -%}
                          {%- when 'indigo' -%}{%- assign swatch_bg = '#4B0082' -%}
                          {%- when 'turquoise' -%}{%- assign swatch_bg = '#40E0D0' -%}
                          {%- when 'magenta' -%}{%- assign swatch_bg = '#FF00FF' -%}
                          {%- when 'aqua' -%}{%- assign swatch_bg = '#00FFFF' -%}
                          {%- when 'plum' -%}{%- assign swatch_bg = '#DDA0DD' -%}
                          {%- when 'mauve' -%}{%- assign swatch_bg = '#E0B0FF' -%}
                          {%- when 'lime' -%}{%- assign swatch_bg = '#CDDC39' -%}
                          {%- when 'cyan' -%}{%- assign swatch_bg = '#00BCD4' -%}
                          {%- else -%}{%- assign swatch_bg = '#CCCCCC' -%}
                        {%- endcase -%}
                      {%- endif -%}

                      {%- assign is_light = false -%}
                      {%- assign cn_check = value.label | downcase | strip -%}
                      {%- if cn_check == 'white' or cn_check == 'off white' or cn_check == 'cream' or cn_check == 'ivory' or cn_check == 'beige' -%}
                        {%- assign is_light = true -%}
                      {%- endif -%}

                      <a href="javascript:void(0)"
                         class="tsukie-color-swatch{% if value.active %} tsukie-active{% endif %}"
                         style="background-color:{{ swatch_bg }};{% if is_light %}border:1px solid #E8DFD2;{% endif %}"
                         title="{{ value.label }} ({{ value.count }})"
                         onclick="tsukieToggleFilter('{{ value.param_name }}','{{ value.value }}',{{ value.active }})"
                      ></a>
                    {%- endif -%}
                  {%- endfor -%}
                </div>

              {%- else -%}
                <!-- GENERIC CHECKBOXES (Vendor, Product Type, etc.) -->
                <div class="tsukie-sidebar-options">
                  {%- for value in filter.values -%}
                    {%- if value.count > 0 or value.active -%}
                      <a href="javascript:void(0)"
                         class="tsukie-sidebar-option"
                         onclick="tsukieToggleFilter('{{ value.param_name }}','{{ value.value }}',{{ value.active }})"
                      >
                        <div class="tsukie-sidebar-check{% if value.active %} tsukie-checked{% endif %}"></div>
                        <span class="tsukie-sidebar-option-label">{{ value.label }}</span>
                        <span class="tsukie-sidebar-option-count">({{ value.count }})</span>
                      </a>
                    {%- endif -%}
                  {%- endfor -%}
                </div>
              {%- endif -%}

          {%- endcase -%}
        </div>
      </div>
    {%- endfor -%}

    {%- if has_native_color_filter == false and unique_colors.size > 0 -%}
      <div class="tsukie-sidebar-section custom-color-section" data-filter-index="color">
        <div class="tsukie-sidebar-title" onclick="this.parentElement.classList.toggle('tsukie-collapsed')">
