{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .tsukie-product-details-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  }

  .tsukie-trust-badges-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    border: 1px solid {{ block.settings.border_color }};
    margin: {{ block.settings.section_spacing }}px 0;
  }

  .tsukie-trust-item-{{ ai_gen_id }} {
    padding: {{ block.settings.badge_padding }}px;
    text-align: center;
    border-right: 1px solid {{ block.settings.border_color }};
  }

  .tsukie-trust-item-{{ ai_gen_id }}:last-child {
    border-right: none;
  }

  .tsukie-trust-icon-{{ ai_gen_id }} {
    font-size: {{ block.settings.icon_size }}px;
    color: {{ block.settings.icon_color }};
    margin-bottom: 8px;
    display: block;
  }

  .tsukie-trust-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.badge_title_size }}px;
    letter-spacing: {{ block.settings.title_letter_spacing }}px;
    text-transform: uppercase;
    color: {{ block.settings.title_color }};
    font-weight: 500;
    margin: 0 0 4px;
  }

  .tsukie-trust-subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.badge_subtitle_size }}px;
    color: {{ block.settings.subtitle_color }};
    margin: 0;
  }

  .tsukie-accordion-{{ ai_gen_id }} {
    border-top: 1px solid {{ block.settings.border_color }};
  }

  .tsukie-accordion-item-{{ ai_gen_id }} {
    border-bottom: 1px solid {{ block.settings.border_color }};
  }

  .tsukie-accordion-btn-{{ ai_gen_id }} {
    width: 100%;
    background: none;
    border: none;
    padding: {{ block.settings.accordion_padding }}px 0;
    display: flex;
    justify-content: space-between;
    align-items: center;
    cursor: pointer;
    font-size: {{ block.settings.accordion_title_size }}px;
    letter-spacing: {{ block.settings.title_letter_spacing }}px;
    text-transform: uppercase;
    color: {{ block.settings.title_color }};
    font-weight: 500;
  }

  .tsukie-accordion-icon-{{ ai_gen_id }} {
    font-size: {{ block.settings.accordion_icon_size }}px;
    transition: transform 0.3s ease;
  }

  .tsukie-accordion-item-{{ ai_gen_id }}.active .tsukie-accordion-icon-{{ ai_gen_id }} {
    transform: rotate(45deg);
  }

  .tsukie-accordion-content-{{ ai_gen_id }} {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease;
    font-size: {{ block.settings.accordion_content_size }}px;
    line-height: 1.7;
    color: {{ block.settings.subtitle_color }};
  }

  .tsukie-accordion-item-{{ ai_gen_id }}.active .tsukie-accordion-content-{{ ai_gen_id }} {
    max-height: 500px;
    padding-bottom: {{ block.settings.accordion_padding }}px;
  }

  .tsukie-accordion-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px 40px;
  }

  .tsukie-accordion-label-{{ ai_gen_id }} {
    font-size: {{ block.settings.grid_label_size }}px;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: {{ block.settings.icon_color }};
    margin: 0 0 4px;
  }

  .tsukie-accordion-value-{{ ai_gen_id }} {
    font-size: {{ block.settings.grid_value_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0;
  }

  @media (max-width: 749px) {
    .tsukie-trust-badges-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }
    .tsukie-trust-item-{{ ai_gen_id }} {
      border-right: none;
      border-bottom: 1px solid {{ block.settings.border_color }};
    }
    .tsukie-trust-item-{{ ai_gen_id }}:last-child {
      border-bottom: none;
    }
    .tsukie-accordion-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 16px;
    }
  }
{% endstyle %}

