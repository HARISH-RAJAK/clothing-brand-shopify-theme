</product-details-{{ ai_gen_id }}>

<script>
  (function() {
    class ProductDetails{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.accordionButtons = this.querySelectorAll('[data-accordion-toggle]');
        this.setupEventListeners();
      }

      setupEventListeners() {
        this.accordionButtons.forEach((button) => {
          button.addEventListener('click', () => {
            const accordionItem = button.parentElement;
            accordionItem.classList.toggle('active');
          });
        });
      }
    }

    customElements.define('product-details-{{ ai_gen_id }}', ProductDetails{{ ai_gen_id }});
  })();
</script>

