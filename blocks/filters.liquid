{%- liquid
  assign sort_by = results.sort_by | default: results.default_sort_by
  if results.url
    assign results_url = results.url
  else
    assign terms = results.terms | escape
    assign results_url = '?q=' | append: terms | append: '&options%5Bprefix%5D=last&sort_by=' | append: sort_by
  endif

  # Find relevant Shopify filters
  assign category_filter = nil
  assign size_filter = nil
  assign color_filter = nil
  assign price_filter = nil
  assign availability_filter = nil

  for filter in results.filters
    assign label_downcase = filter.label | downcase
    if label_downcase contains 'type' or label_downcase contains 'category'
      assign category_filter = filter
    elsif label_downcase == 'size' or label_downcase == 'sizes'
      assign size_filter = filter
    elsif label_downcase == 'color' or label_downcase == 'colour' or label_downcase == 'colours' or label_downcase == 'colors'
      assign color_filter = filter
    elsif filter.type == 'price_range'
      assign price_filter = filter
    elsif label_downcase contains 'availability' or label_downcase contains 'stock'
      assign availability_filter = filter
    endif
  endfor
-%}

<script src="{{ 'facets.js' | asset_url }}" type="module" fetchpriority="low"></script>

<!-- FILTER BAR -->
<div class="filter-bar">
  <div class="filter-left">
    {%- liquid
      # Determine if "All" is active (meaning no categories, prices, or sorts are active)
      assign is_all_active = true
      
      assign active_cat_label = nil
      if category_filter
        for val in category_filter.values
          if val.active
            assign active_cat_label = val.label
            assign is_all_active = false
          endif
        endfor
      endif
      
      assign active_max_price = nil
      if price_filter and price_filter.max_value.value != null
        assign active_max_price = price_filter.max_value.value | money_without_currency | replace: ',', '' | replace: '.', '' | plus: 0
        # In Shopify pricing model, a filtered max price changes "All" active state
        assign is_all_active = false
      endif
      
      assign current_sort = results.sort_by | default: results.default_sort_by
      if current_sort == 'best-selling' or current_sort == 'created-descending'
        assign is_all_active = false
      endif
    -%}
    <button class="filter-chip {% if is_all_active %}active gold{% endif %}" onclick="selectFilterBarChip('all', this)">All</button>
    <button class="filter-chip {% if current_sort == 'best-selling' %}active{% endif %}" onclick="selectFilterBarChip('bestselling', this)">Best Seller</button>
    <button class="filter-chip {% if current_sort == 'created-descending' %}active{% endif %}" onclick="selectFilterBarChip('newest', this)">New Arrival</button>
    
    {%- if category_filter -%}
      <div class="filter-divider"></div>
      {%- for value in category_filter.values -%}
        <button class="filter-chip {% if value.active %}active{% endif %}" onclick="selectFilterBarChip('cat-{{ value.value | escape }}', this)">{{ value.label }}</button>
      {%- endfor -%}
    {%- else -%}
      <!-- Fallback category chips -->
      <div class="filter-divider"></div>
      <button class="filter-chip" onclick="selectFilterBarChip('cat-dresses', this)">Dresses</button>
      <button class="filter-chip" onclick="selectFilterBarChip('cat-coordsets', this)">Co-ord Sets</button>
      <button class="filter-chip" onclick="selectFilterBarChip('cat-tops', this)">Tops</button>
      <button class="filter-chip" onclick="selectFilterBarChip('cat-bottoms', this)">Bottoms</button>
    {%- endif -%}
    
    {%- if price_filter -%}
      <div class="filter-divider"></div>
      <button class="filter-chip {% if active_max_price == 2499 %}active{% endif %}" onclick="selectFilterBarChip('price-2499', this)">Under ₹2,499</button>
      <button class="filter-chip {% if active_max_price == 2999 %}active{% endif %}" onclick="selectFilterBarChip('price-2999', this)">Under ₹2,999</button>
    {%- endif -%}
  </div>
  
  <div class="filter-right">
    <div class="grid-toggle">
      <button class="col-btn active" id="btn3col" onclick="setGrid(3, this)" title="3 columns">
        <span style="width:2px;height:12px;"></span><span style="width:2px;height:12px;"></span><span style="width:2px;height:12px;"></span>
      </button>
      <button class="col-btn" id="btn4col" onclick="setGrid(4, this)" title="4 columns">
        <span style="width:2px;height:12px;"></span><span style="width:2px;height:12px;"></span><span style="width:2px;height:12px;"></span><span style="width:2px;height:12px;"></span>
      </button>
    </div>
    
    <select class="sort-select" onchange="selectSortOption(this.value)">
      <option value="manual" {% if current_sort == 'manual' %}selected{% endif %}>Sort: Featured</option>
      <option value="created-descending" {% if current_sort == 'created-descending' %}selected{% endif %}>Newest First</option>
      <option value="price-ascending" {% if current_sort == 'price-ascending' %}selected{% endif %}>Price: Low to High</option>
      <option value="price-descending" {% if current_sort == 'price-descending' %}selected{% endif %}>Price: High to Low</option>
      <option value="best-selling" {% if current_sort == 'best-selling' %}selected{% endif %}>Best Selling</option>
      <option value="title-ascending" {% if current_sort == 'title-ascending' %}selected{% endif %}>Alphabetical</option>
    </select>
    
    <button class="filter-toggle-btn" onclick="toggleSidebar()">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><line x1="4" y1="6" x2="20" y2="6"/><line x1="4" y1="12" x2="14" y2="12"/><line x1="4" y1="18" x2="10" y2="18"/></svg>
      Filters
    </button>
  </div>
</div>

<!-- SIDEBAR FILTER WRAPPER -->
<facets-form-component class="facets__form-wrapper" section-id="{{ section.id }}" form-style="vertical">
  <form action="{{ results_url }}" id="FacetFiltersForm--{{ section.id }}" class="facets__form" ref="facetsForm">
    
    <div class="sidebar-filters" id="sidebarFilters">
      <div class="sidebar-inner">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:28px;">
          <span style="font-size:11px;letter-spacing:3px;text-transform:uppercase;color:#2A2520;font-weight:500;">Refine</span>
          <button type="button" class="clear-filters" style="margin:0;" onclick="toggleSidebar()">✕ Close</button>
        </div>

        <!-- CATEGORIES SECTION -->
        {%- if category_filter -%}
          {%- liquid
            assign any_cat_active = false
            for val in category_filter.values
              if val.active
                assign any_cat_active = true
              endif
            endfor
          -%}
          <div class="sidebar-section">
            <div class="sidebar-title">Category <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><polyline points="6 9 12 15 18 9"/></svg></div>
            <div class="sidebar-options">
              <div class="sidebar-option" data-cat-value="all" onclick="selectSidebarCategory('all', this)">
                <div class="sidebar-check {% unless any_cat_active %}checked{% endunless %}"></div>
                <span class="sidebar-option-label">All</span>
              </div>
              {%- for value in category_filter.values -%}
                <div class="sidebar-option" data-cat-value="{{ value.value | escape }}" data-param-name="{{ value.param_name }}" onclick="selectSidebarCategory('{{ value.value | escape }}', this)">
                  <div class="sidebar-check {% if value.active %}checked{% endif %}"></div>
                  <span class="sidebar-option-label">{{ value.label }}</span>
                </div>
              {%- endfor -%}
            </div>
          </div>
        {%- else -%}
          <!-- Fallback static Category -->
          <div class="sidebar-section">
            <div class="sidebar-title">Category <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><polyline points="6 9 12 15 18 9"/></svg></div>
            <div class="sidebar-options">
              <div class="sidebar-option" onclick="toggleStaticCheck(this)"><div class="sidebar-check checked"></div><span class="sidebar-option-label">All</span></div>
              <div class="sidebar-option" onclick="toggleStaticCheck(this)"><div class="sidebar-check"></div><span class="sidebar-option-label">Dresses</span></div>
              <div class="sidebar-option" onclick="toggleStaticCheck(this)"><div class="sidebar-check"></div><span class="sidebar-option-label">Co-ord Sets</span></div>
              <div class="sidebar-option" onclick="toggleStaticCheck(this)"><div class="sidebar-check"></div><span class="sidebar-option-label">Tops & Blouses</span></div>
              <div class="sidebar-option" onclick="toggleStaticCheck(this)"><div class="sidebar-check"></div><span class="sidebar-option-label">Bottoms</span></div>
              <div class="sidebar-option" onclick="toggleStaticCheck(this)"><div class="sidebar-check"></div><span class="sidebar-option-label">Jumpsuits</span></div>
            </div>
          </div>
        {%- endif -%}

        <!-- SIZE SECTION -->
        {%- if size_filter -%}
          <div class="sidebar-section">
            <div class="sidebar-title">Size <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><polyline points="6 9 12 15 18 9"/></svg></div>
            <div class="size-pills">
              {%- for value in size_filter.values -%}
                <span class="size-pill {% if value.active %}active{% endif %}" data-param-name="{{ value.param_name }}" data-value="{{ value.value | escape }}" onclick="toggleCustomSize(this)">{{ value.label }}</span>
              {%- endfor -%}
            </div>
          </div>
        {%- else -%}
          <!-- Fallback static Sizes -->
          <div class="sidebar-section">
            <div class="sidebar-title">Size <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><polyline points="6 9 12 15 18 9"/></svg></div>
            <div class="size-pills">
              <span class="size-pill" onclick="this.classList.toggle('active')">XS</span>
              <span class="size-pill active" onclick="this.classList.toggle('active')">S</span>
              <span class="size-pill active" onclick="this.classList.toggle('active')">M</span>
              <span class="size-pill" onclick="this.classList.toggle('active')">L</span>
              <span class="size-pill" onclick="this.classList.toggle('active')">XL</span>
              <span class="size-pill" onclick="this.classList.toggle('active')">XXL</span>
              <span class="size-pill" onclick="this.classList.toggle('active')">3XL</span>
              <span class="size-pill" onclick="this.classList.toggle('active')">4XL</span>
            </div>
          </div>
        {%- endif -%}

        <!-- PRICE RANGE SECTION -->
        {%- if price_filter -%}
          {%- liquid
            assign min_value = 0
            assign max_value = price_filter.range_max | money_without_currency | replace: ',', '' | replace: '.', '' | plus: 0
            
            assign current_min = price_filter.min_value.value | money_without_currency | replace: ',', '' | replace: '.', '' | plus: 0
            assign current_max = price_filter.max_value.value | money_without_currency | replace: ',', '' | replace: '.', '' | plus: 0
            
            if current_max == 0 or price_filter.max_value.value == nil
              assign current_max = max_value
            endif
          -%}
          <div class="sidebar-section">
            <div class="sidebar-title">Price Range <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><polyline points="6 9 12 15 18 9"/></svg></div>
            <p class="price-range-display">₹{{ current_min | number_with_delimiter }} — ₹{{ current_max | number_with_delimiter }}</p>
            <input type="range" class="price-slider" min="{{ min_value }}" max="{{ max_value }}" value="{{ current_max }}" id="priceSlider" oninput="updateCustomPrice(this.value)" onchange="submitCustomPrice(this.value)">
          </div>
        {%- else -%}
          <!-- Fallback static Price Slider -->
          <div class="sidebar-section">
            <div class="sidebar-title">Price Range <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><polyline points="6 9 12 15 18 9"/></svg></div>
            <p class="price-range-display">₹1,499 — ₹3,499</p>
            <input type="range" class="price-slider" min="1499" max="3499" value="3499" id="priceSlider" oninput="updateCustomPrice(this.value)">
          </div>
        {%- endif -%}

        <!-- COLOUR SECTION -->
        {%- if color_filter -%}
          <div class="sidebar-section">
            <div class="sidebar-title">Colour <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><polyline points="6 9 12 15 18 9"/></svg></div>
            <div class="color-swatches">
              {%- for value in color_filter.values -%}
                {%- liquid
                  assign color_name = value.label
                  assign bg_style = ''
                  case color_name | downcase
                    when 'blush'
                      assign bg_style = '#F5E6D8'
                    when 'nude'
                      assign bg_style = '#E8D5C4'
                    when 'charcoal'
                      assign bg_style = '#2A2520'
                    when 'white'
                      assign bg_style = '#FFFFFF; border: 1px solid var(--sand)'
                    when 'caramel'
                      assign bg_style = '#8B7355'
                    when 'dusty rose'
                      assign bg_style = '#C4949A'
                    when 'sage' or 'sage green'
                      assign bg_style = '#6B8E8A'
                    when 'navy' or 'navy blue'
                      assign bg_style = '#3D4A5C'
                    when 'black'
                      assign bg_style = '#000000'
                    when 'cream'
                      assign bg_style = '#F5F1EA'
                    when 'off white'
                      assign bg_style = '#FAF9F6'
                    when 'grey' or 'gray'
                      assign bg_style = '#808080'
                    else
                      # default fallback color based on name
                      assign bg_style = color_name | replace: ' ', ''
                  endcase
                -%}
                <div class="color-swatch {% if value.active %}active{% endif %}" 
                     style="background: {{ bg_style }};" 
                     title="{{ value.label }}" 
                     data-param-name="{{ value.param_name }}" 
                     data-value="{{ value.value | escape }}" 
                     onclick="toggleCustomColor(this)"></div>
              {%- endfor -%}
            </div>
          </div>
        {%- else -%}
          <!-- Fallback static Colours -->
          <div class="sidebar-section">
            <div class="sidebar-title">Colour <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><polyline points="6 9 12 15 18 9"/></svg></div>
            <div class="color-swatches">
              <div class="color-swatch active" style="background:#F5E6D8;" title="Blush" onclick="this.classList.toggle('active')"></div>
              <div class="color-swatch" style="background:#E8D5C4;" title="Nude" onclick="this.classList.toggle('active')"></div>
              <div class="color-swatch" style="background:#2A2520;" title="Charcoal" onclick="this.classList.toggle('active')"></div>
              <div class="color-swatch" style="background:#FFFFFF;border:1px solid var(--sand);" title="White" onclick="this.classList.toggle('active')"></div>
              <div class="color-swatch" style="background:#8B7355;" title="Caramel" onclick="this.classList.toggle('active')"></div>
              <div class="color-swatch" style="background:#C4949A;" title="Dusty Rose" onclick="this.classList.toggle('active')"></div>
              <div class="color-swatch" style="background:#6B8E8A;" title="Sage" onclick="this.classList.toggle('active')"></div>
              <div class="color-swatch" style="background:#3D4A5C;" title="Navy" onclick="this.classList.toggle('active')"></div>
            </div>
          </div>
        {%- endif -%}

        <!-- AVAILABILITY SECTION -->
        {%- if availability_filter -%}
          {%- liquid
            assign in_stock_val = nil
            for value in availability_filter.values
              if value.value == '1' or value.value == 'true' or value.label contains 'In stock'
                assign in_stock_val = value
              endif
            endfor
          -%}
          {%- if in_stock_val -%}
            <div class="sidebar-section">
              <div class="sidebar-title">Availability <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><polyline points="6 9 12 15 18 9"/></svg></div>
              <div class="sidebar-options">
                <div class="sidebar-option" data-param-name="{{ in_stock_val.param_name }}" data-value="{{ in_stock_val.value | escape }}" onclick="toggleAvailability(this)">
                  <div class="sidebar-check {% if in_stock_val.active %}checked{% endif %}"></div>
                  <span class="sidebar-option-label">In Stock Only</span>
                </div>
              </div>
            </div>
          {%- endif -%}
        {%- else -%}
          <!-- Fallback static Availability -->
          <div class="sidebar-section">
            <div class="sidebar-title">Availability <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><polyline points="6 9 12 15 18 9"/></svg></div>
            <div class="sidebar-options">
              <div class="sidebar-option" onclick="toggleStaticCheck(this)"><div class="sidebar-check checked"></div><span class="sidebar-option-label">In Stock Only</span></div>
            </div>
          </div>
        {%- endif -%}

        <button type="button" class="clear-filters" onclick="selectFilterBarChip('all', this)">Clear All Filters</button>
      </div>
    </div>

    <!-- Hidden standard inputs for mapping to forms -->
    <div class="hidden-filter-inputs" style="display: none !important;">
      {%- for filter in filters -%}
        {%- if filter.type == 'price_range' -%}
          <input type="number" name="{{ filter.min_value.param_name }}" id="hidden-price-min" value="{{ filter.min_value.value | money_without_currency | replace: ',', '' | replace: '.', '' }}">
          <input type="number" name="{{ filter.max_value.param_name }}" id="hidden-price-max" value="{{ filter.max_value.value | money_without_currency | replace: ',', '' | replace: '.', '' }}">
        {%- else -%}
          {%- for value in filter.values -%}
            <input type="checkbox" name="{{ value.param_name }}" value="{{ value.value | escape }}" id="hidden-check-{{ value.param_name | handle }}-{{ value.value | handle }}" {% if value.active %}checked{% endif %}>
          {%- endfor -%}
        {%- endif -%}
      {%- endfor -%}
      <input type="hidden" name="sort_by" id="hidden-sort-by" value="{{ results.sort_by | default: results.default_sort_by }}">
    </div>

  </form>
</facets-form-component>

<style>
/* Font variables */
:root {
  --cream: #F8F4EE;
  --ivory: #F2EDE5;
  --warm-white: #FDFBF7; /* beige override */
  --sand: #E8DFD2;
  --tan: #C9B99A;
  --nude: #B89E83;
  --charcoal: #2A2520;
  --dark-brown: #3D3228;
  --muted-brown: #6B5D52;
  --accent-gold: #C4A882;
  --accent-rust: #9B6E4E;
  --font-serif: 'Cormorant Garamond', Georgia, serif;
  --font-sans: 'Jost', sans-serif;
}

/* Force Cormorant Garamond on all filter elements */
.filter-bar,
.sidebar-filters,
.filter-chip,
.sort-select,
.filter-toggle-btn,
.sidebar-title,
.sidebar-option-label,
.price-range-display,
.size-pill,
.clear-filters {
  font-family: 'Cormorant Garamond', Georgia, serif !important;
}

/* Override Dawn's layout wrapper to support sidebar rendering on desktop */
.collection-wrapper {
  display: grid !important;
  grid-template-columns: 0px 1fr !important;
  grid-template-rows: auto 1fr !important;
  grid-template-areas:
    "filterbar filterbar"
    "sidebar products" !important;
  transition: grid-template-columns 0.35s ease !important;
  background-color: #FDFBF7 !important;
  gap: 0 !important;
  max-width: 100% !important;
  padding: 0 !important;
}
.collection-wrapper:has(#sidebarFilters.open),
.collection-wrapper:has(facets-form-component.open) {
  grid-template-columns: 280px 1fr !important;
}

.filter-bar {
  grid-area: filterbar;
}
facets-form-component {
  grid-area: sidebar;
  display: block;
  width: 0;
  overflow: hidden;
  transition: width 0.35s ease;
  background-color: #FDFBF7;
}
facets-form-component.open {
  width: 280px;
  border-right: 1px solid var(--sand);
}
.products-area {
  grid-area: products;
  flex: 1;
  padding: 32px 40px;
  background-color: #FDFBF7;
}

/* CSS Override for Products Grid to match Layout Density */
@media screen and (min-width: 750px) {
  .product-grid.products-grid {
    display: grid !important;
    grid-template-columns: repeat(3, 1fr) !important;
    gap: 28px !important;
  }
  .product-grid.products-grid.four-col {
    grid-template-columns: repeat(4, 1fr) !important;
    gap: 20px !important;
  }
}

/* ===== FILTER BAR ===== */
.filter-bar {
  background: #FDFBF7;
  border-bottom: 1px solid var(--sand);
  padding: 0 40px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20px;
  position: sticky;
  top: 72px;
  z-index: 90;
  height: 58px;
}
.filter-left { display: flex; align-items: center; gap: 10px; padding: 10px 0; overflow-x: auto; scrollbar-width: none; flex: 1; }
.filter-left::-webkit-scrollbar { display: none; }
.filter-chip {
  white-space: nowrap;
  padding: 8px 18px;
  border: 1px solid var(--sand);
  font-size: 11px;
  letter-spacing: 2px;
  text-transform: uppercase;
  font-weight: 400;
  color: var(--muted-brown);
  background: transparent;
  cursor: pointer;
  transition: all .2s;
  flex-shrink: 0;
  outline: none;
}
.filter-chip:hover, .filter-chip.active {
  background: var(--charcoal);
  color: var(--cream);
  border-color: var(--charcoal);
}
.filter-chip.active.gold {
  background: var(--accent-gold);
  border-color: var(--accent-gold);
  color: var(--charcoal);
}
.filter-divider { width: 1px; height: 20px; background: var(--sand); flex-shrink: 0; }
.filter-right { display: flex; align-items: center; gap: 16px; flex-shrink: 0; }
.sort-select {
  border: 1px solid var(--sand);
  background: transparent;
  font-size: 11px;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: var(--muted-brown);
  padding: 8px 14px;
  cursor: pointer;
  outline: none;
}
.sort-select:focus { border-color: var(--tan); }
.filter-toggle-btn {
  padding: 8px 18px;
  border: 1px solid var(--sand);
  font-size: 11px;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: var(--muted-brown);
  background: transparent;
  cursor: pointer;
  display: flex; align-items: center; gap: 8px;
  transition: all .2s;
}
.filter-toggle-btn:hover { border-color: var(--charcoal); color: var(--charcoal); }
.filter-toggle-btn svg { width: 14px; height: 14px; stroke-width: 1.5; }

/* ===== SIDEBAR FILTER ===== */
.sidebar-filters {
  width: 280px;
  overflow: hidden;
  background: #FDFBF7;
}
.sidebar-inner { width: 280px; padding: 32px 28px; }
.sidebar-section { margin-bottom: 40px; }
.sidebar-title { font-size: 11px; letter-spacing: 3px; text-transform: uppercase; color: var(--accent-gold); font-weight: 400; margin-bottom: 20px; display: flex; align-items: center; justify-content: space-between; cursor: pointer; }
.sidebar-title svg { width: 12px; height: 12px; stroke-width: 2; transition: transform .2s; }
.sidebar-options { display: flex; flex-direction: column; gap: 10px; }
.sidebar-option { display: flex; align-items: center; gap: 10px; cursor: pointer; }
.sidebar-check { width: 14px; height: 14px; border: 1px solid var(--tan); flex-shrink: 0; display: flex; align-items: center; justify-content: center; }
.sidebar-check.checked { background: var(--charcoal); border-color: var(--charcoal); }
.sidebar-check.checked::after { content: '✓'; color: white; font-size: 9px; line-height: 1; }
.sidebar-option-label { font-size: 13px; color: var(--muted-brown); letter-spacing: 0.5px; }
.price-range-display { font-size: 18px; font-weight: 400; color: var(--charcoal); margin-bottom: 16px; }
.price-slider { width: 100%; accent-color: var(--charcoal); }
.size-pills { display: flex; flex-wrap: wrap; gap: 8px; }
.size-pill { padding: 6px 12px; border: 1px solid var(--sand); font-size: 11px; letter-spacing: 1px; color: var(--muted-brown); cursor: pointer; transition: all .2s; }
.size-pill:hover, .size-pill.active { border-color: var(--charcoal); color: var(--charcoal); }
.color-swatches { display: flex; flex-wrap: wrap; gap: 10px; }
.color-swatch { width: 26px; height: 26px; border-radius: 50%; cursor: pointer; transition: transform .2s; position: relative; }
.color-swatch:hover { transform: scale(1.15); }
.color-swatch.active::after { content: ''; position: absolute; inset: -3px; border-radius: 50%; border: 1px solid var(--charcoal); }
.clear-filters { font-size: 11px; letter-spacing: 2px; text-transform: uppercase; color: var(--tan); cursor: pointer; background: none; border: none; margin-top: 32px; transition: color .2s; display: block; padding: 0; }
.clear-filters:hover { color: var(--accent-rust); }

/* ===== GRID COLUMNS TOGGLE ===== */
.grid-toggle { display: flex; gap: 8px; align-items: center; }
.col-btn { width: 30px; height: 30px; background: transparent; border: 1px solid var(--sand); display: flex; align-items: center; justify-content: center; cursor: pointer; gap: 2px; padding: 7px; transition: all .2s; }
.col-btn.active, .col-btn:hover { border-color: var(--charcoal); }
.col-btn span { display: block; background: var(--muted-brown); border-radius: 0; }
.col-btn.active span { background: var(--charcoal); }

/* ===== MOBILE OVERRIDES ===== */
@media (max-width: 900px) {
  .collection-wrapper {
    grid-template-columns: 1fr !important;
    grid-template-areas:
      "filterbar"
      "products" !important;
  }
  .filter-bar { padding: 0 20px; }
  .filter-right { display: flex !important; }
  .grid-toggle, .sort-select { display: none !important; }
  .products-area { padding: 24px 20px; }
  
  facets-form-component {
    position: fixed !important;
    top: 0 !important;
    left: -280px !important;
    width: 280px !important;
    height: 100vh !important;
    z-index: 10000 !important;
    box-shadow: 0 0 20px rgba(0,0,0,0.15) !important;
    transition: left 0.35s ease !important;
    background-color: #FDFBF7 !important;
    display: block !important;
  }
  facets-form-component.open {
    left: 0 !important;
    width: 280px !important;
  }
}
</style>

<script>
// Toggle sidebar drawer on desktop / mobile
function toggleSidebar() {
  const sb = document.getElementById('sidebarFilters');
  const fc = document.querySelector('facets-form-component');
  if (sb) sb.classList.toggle('open');
  if (fc) fc.classList.toggle('open');
}

// Toggle grid layout (3 vs 4 columns)
function setGrid(cols, btn) {
  const grid = document.getElementById('productsGrid');
  if (grid) {
    grid.classList.toggle('four-col', cols === 4);
  }
  document.querySelectorAll('.col-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
}

// Map helper to generate handles
function handleize(str) {
  if (!str) return '';
  return str.toString().toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/-+/g, '-').replace(/^-|-$/g, '');
}

// Toggle custom size pills in the sidebar
function toggleCustomSize(el) {
  const val = el.dataset.value;
  const param = el.dataset.paramName;
  const hiddenId = `hidden-check-${handleize(param)}-${handleize(val)}`;
  const hiddenInput = document.getElementById(hiddenId);
  if (hiddenInput) {
    hiddenInput.checked = !hiddenInput.checked;
    hiddenInput.dispatchEvent(new Event('change', { bubbles: true }));
  } else {
    el.classList.toggle('active');
  }
}

// Toggle custom color swatches in the sidebar
function toggleCustomColor(el) {
  const val = el.dataset.value;
  const param = el.dataset.paramName;
  const hiddenId = `hidden-check-${handleize(param)}-${handleize(val)}`;
  const hiddenInput = document.getElementById(hiddenId);
  if (hiddenInput) {
    hiddenInput.checked = !hiddenInput.checked;
    hiddenInput.dispatchEvent(new Event('change', { bubbles: true }));
  } else {
    el.classList.toggle('active');
  }
}

// Toggle Availability checkbox in the sidebar
function toggleAvailability(el) {
  const val = el.dataset.value;
  const param = el.dataset.paramName;
  const hiddenId = `hidden-check-${handleize(param)}-${handleize(val)}`;
  const hiddenInput = document.getElementById(hiddenId);
  if (hiddenInput) {
    hiddenInput.checked = !hiddenInput.checked;
    hiddenInput.dispatchEvent(new Event('change', { bubbles: true }));
  }
}

// Select Sidebar Category (mutually exclusive)
function selectSidebarCategory(val, el) {
  if (val === 'all') {
    const catSection = el.closest('.sidebar-section');
    catSection.querySelectorAll('.sidebar-option').forEach(opt => {
      const param = opt.dataset.paramName;
      const optVal = opt.dataset.catValue;
      if (optVal && optVal !== 'all') {
        const hiddenId = `hidden-check-${handleize(param)}-${handleize(optVal)}`;
        const hiddenInput = document.getElementById(hiddenId);
        if (hiddenInput) hiddenInput.checked = false;
      }
    });
    const form = document.querySelector('facets-form-component form');
    if (form) form.dispatchEvent(new Event('change', { bubbles: true }));
  } else {
    const param = el.dataset.paramName;
    const hiddenId = `hidden-check-${handleize(param)}-${handleize(val)}`;
    const hiddenInput = document.getElementById(hiddenId);
    if (hiddenInput) {
      hiddenInput.checked = !hiddenInput.checked;
      hiddenInput.dispatchEvent(new Event('change', { bubbles: true }));
    }
  }
}

// Update Price Slider text
function updateCustomPrice(val) {
  const minPrice = {% if price_filter and price_filter.min_value.value != nil %}{{ price_filter.min_value.value | money_without_currency | replace: ',', '' | replace: '.', '' | plus: 0 }}{% else %}0{% endif %};
  document.querySelector('.price-range-display').textContent = '₹' + minPrice.toLocaleString('en-IN') + ' — ₹' + parseInt(val).toLocaleString('en-IN');
}

// Submit price filter to form
function submitCustomPrice(val) {
  const hiddenMax = document.getElementById('hidden-price-max');
  if (hiddenMax) {
    hiddenMax.value = val;
    hiddenMax.dispatchEvent(new Event('change', { bubbles: true }));
  }
}

// Select Sort Option
function selectSortOption(val) {
  const hiddenSort = document.getElementById('hidden-sort-by');
  if (hiddenSort) {
    hiddenSort.value = val;
    hiddenSort.dispatchEvent(new Event('change', { bubbles: true }));
  }
}

// Select Filter Bar Chip
function selectFilterBarChip(type, el) {
  if (type === 'all') {
    const form = document.querySelector('facets-form-component form');
    if (form) {
      form.querySelectorAll('input[type="checkbox"]').forEach(chk => chk.checked = false);
      const hiddenMax = document.getElementById('hidden-price-max');
      if (hiddenMax) hiddenMax.value = '';
      const hiddenMin = document.getElementById('hidden-price-min');
      if (hiddenMin) hiddenMin.value = '';
      const hiddenSort = document.getElementById('hidden-sort-by');
      if (hiddenSort) hiddenSort.value = '';
      form.dispatchEvent(new Event('change', { bubbles: true }));
    }
  } else if (type === 'bestselling') {
    const hiddenSort = document.getElementById('hidden-sort-by');
    if (hiddenSort) {
      hiddenSort.value = 'best-selling';
      hiddenSort.dispatchEvent(new Event('change', { bubbles: true }));
    }
  } else if (type === 'newest') {
    const hiddenSort = document.getElementById('hidden-sort-by');
    if (hiddenSort) {
      hiddenSort.value = 'created-descending';
      hiddenSort.dispatchEvent(new Event('change', { bubbles: true }));
    }
  } else if (type.startsWith('cat-')) {
    const catVal = type.replace('cat-', '');
    const catFilter = {% if category_filter %}"{{ category_filter.values[0].param_name }}"{% else %}null{% endif %};
    if (catFilter) {
      const form = document.querySelector('facets-form-component form');
      form.querySelectorAll(`input[name="${catFilter}"]`).forEach(chk => {
        chk.checked = (chk.value === catVal);
      });
      form.dispatchEvent(new Event('change', { bubbles: true }));
    }
  } else if (type.startsWith('price-')) {
    const maxVal = type.replace('price-', '');
    const hiddenMax = document.getElementById('hidden-price-max');
    if (hiddenMax) {
      hiddenMax.value = maxVal;
      hiddenMax.dispatchEvent(new Event('change', { bubbles: true }));
    }
  }
}

// Fallback logic for static toggles
function toggleStaticCheck(el) {
  el.querySelector('.sidebar-check').classList.toggle('checked');
}
function toggleStaticOption(name, el) {
  el.classList.toggle('active');
}
</script>
