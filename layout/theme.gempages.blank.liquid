<!doctype html>
<html
  {% if request.design_mode %}
    class="shopify-design-mode"
  {% endif %}
  lang="{{ request.locale.iso_code }}"
>
  <head>
    {%- if settings.favicon != blank -%}
      <link
        rel="icon"
        type="image/png"
        href="{{ settings.favicon | image_url: width: 32, height: 32 }}"
      >
    {%- endif -%}

    {% # theme-check-disable RemoteAsset %}
    {% comment %} This a way to wait for main content to load when navigating to a new page so that the view transitions can work consistently {% endcomment %}
    {% if settings.transition_to_main_product or settings.page_transition_enabled %}
      <link
        rel="expect"
        href="#MainContent"
        blocking="render"
        id="view-transition-render-blocker"
      >
    {% endif %}

    {%- render 'meta-tags' -%}
    {%- render 'stylesheets' -%}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;1,400;1,600&family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400;1,500&family=Montserrat:wght@300;400;500;600&display=swap" rel="stylesheet">
    {%- render 'fonts' -%}
    {%- render 'scripts' -%}
    {%- render 'theme-styles-variables' -%}
    {%- render 'color-schemes' -%}

    {% if request.design_mode %}
      {%- render 'theme-editor' -%}
    {% endif %}

    {{ content_for_header }}
    {% # theme-check-enable RemoteAsset %}
    {%- render 'sr-checkout' -%}
  </head>

  <body class="page-width-{{ settings.page_width }} card-hover-effect-{{ settings.card_hover_effect }}"><main
      id="MainContent"
      class="content-for-layout"
      role="main"
      data-page-transition-enabled="{{ settings.page_transition_enabled }}"
      data-product-transition="{{ settings.transition_to_main_product }}"
      data-template="{{ template }}"
    >
      {{ content_for_layout }}
    </main></tbody>
          </table>
        </div>
      </div>
    </div>

    <script>
      function tsukieOpenSizeGuide(e) {
        if (e) e.preventDefault();
        const modal = document.getElementById('tsukie-size-guide-modal');
        if (modal) modal.classList.add('open');
      }
      function tsukieCloseSizeGuide() {
        const modal = document.getElementById('tsukie-size-guide-modal');
        if (modal) modal.classList.remove('open');
      }
    </script>

    <!-- Global price decimal removal (Antigravity global patch) -->
    <script>
      (function() {
        function removeDecimals(node) {
          if (node.nodeType === Node.TEXT_NODE) {
            const parent = node.parentElement;
            if (!parent) return;
            
            const ignoreTags = ['SCRIPT', 'STYLE', 'TEXTAREA', 'INPUT', 'SELECT'];
            if (ignoreTags.includes(parent.tagName)) return;
            
            const text = node.nodeValue;
            const isPriceContainer = parent.closest('[class*="price"], [class*="money"], [class*="amount"], [class*="cart"], [class*="total"], [class*="badge"], [class*="qty"], [class*="quantity"]');
            
            if (isPriceContainer || /Rs\b|₹|INR/i.test(text)) {
              const regex = /(\d+)(?:\.\d{2})\b/g;
              const newVal = text.replace(regex, '$1');
              if (text !== newVal) {
                node.nodeValue = newVal;
              }
            }
          } else {
            const ignoreTags = ['SCRIPT', 'STYLE', 'TEXTAREA', 'INPUT', 'SELECT'];
            if (!ignoreTags.includes(node.nodeName)) {
              for (let i = 0; i < node.childNodes.length; i++) {
                removeDecimals(node.childNodes[i]);
              }
            }
          }
        }

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', () => removeDecimals(document.body));
        } else {
          removeDecimals(document.body);
        }

        const observer = new MutationObserver(function(mutations) {
          mutations.forEach(function(mutation) {
            mutation.addedNodes.forEach(function(node) {
              removeDecimals(node);
            });
            if (mutation.type === 'characterData') {
              removeDecimals(mutation.target);
            }
          });
        });

        observer.observe(document.body, {
          childList: true,
          subtree: true,
          characterData: true
        });
      })();
    </script>
  </body>
</html>
